	if(dialogid == 377)
	{
		if(response)
		{
			new worldid = listitem+1;
			
			foreach(Player, i)
			{
				if(GetPlayerVirtualWorld(i) == worldid)
				{
					SetPlayerVirtualWorld(i, 0);
					WorldModerator[i] = false;
					SetPVarInt(i, "world", 0);
					SetPVarInt(i, "ShowKDtxd", -1);
					SetPVarInt(i, "ShowScoretxd", -1);
					SetPVarInt(i, "ShowTimetxd", -1);
					ResetKDStats(i);
					PlayerTextDrawHide(i, TDkdstats[i]);
					TextDrawShowForPlayer(i, TD[i]);
					if(pData[i][pDtbar] > 0) PlayerTextDrawShow(i, TDdatetime[i]);
					GameTextForPlayer(i, "~w~Back to ~g~CW/TG", 3000, 4);
					if(CWmode) 
					{
						SetPlayerTeamEx(i, 2);
						ResetPlayerWeapons(i);
					}
					ReSpawnPlayer(i);
				}
			}
				
			ResetWorld(worldid);
			
			new tmpstr[128];
			format(tmpstr, sizeof(tmpstr), "%s(%d) wipe world number %i", 
			PlayerName(playerid), playerid, listitem+1);
			SendSystemMessage(tmpstr);
		}
	}
