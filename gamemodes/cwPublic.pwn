	if(dialogid == 224) // ChangeNickname (Admin)
	{
		if(response)
		{
			if (GetPVarInt(playerid, "Admin") < 2) 
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"У вас низкий уровень админки для этого действия",
				"You have a low admin level for this action");
				return false;
			}
			if(GetPVarInt(playerid, "Admin") < GetPVarInt(ChosenPlayer[playerid], "Admin"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"У данного игрока выше уровень админки", "This player has a higher admin level");
				return true;
			}
			if(strlen(inputtext) > MAX_PLAYER_NAME || strlen(inputtext) < 3) {
				return SendClientMessageEx(playerid, COLOR_GREY, 
				"Неверное имя! (3-20 символов)", "Incorrect nickname! (3-20 symbols)");
			}
			
			new NickName[MAX_PLAYER_NAME]; 
			new stringru[64], stringen[64];
			new header[48];
			GetPlayerName(ChosenPlayer[playerid],NickName,sizeof(NickName));
			
			// new newaccount[64], oldaccount[64];
			//format(oldaccount,sizeof(oldaccount),"players/%s.ini",NickName);
			//format(newaccount,sizeof(newaccount),"players/%s.ini",inputtext);
			
			#if defined _YSF_included
			if(!IsValidNickName(inputtext))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное имя! Придумайте другое имя.",
				"Incorrect nickname. Choose another nickname!");
				if (pData[playerid][pLang] == 0)
				{
					format(header, sizeof(header), "Сменить никнейм %s(%d)",
					PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
					"{FFFFFF}Использовать ники администраторов, других игроков \
					и теги чужих кланов{FF0000} запрещено!{FFFFFF}\n\
					Введите новый ник (максимум 20 символов):", "Сменить", "Выйти");
				} else {
					format(header, sizeof(header), "Change nickname %s(%d)",
					PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
					"{FFFFFF}Impersonating administrators, other players and clantags {FF0000} \
					is forbidden!{FFFFFF}\nEnter a new nickname (max 20 symbols):", "Save", "Cancel");
				}
			}
			#endif
				
			//frename(oldaccount, newaccount);
			//if(fexist(newaccount)) fremove(oldaccount);
			
			new szQuery[128], DBResult: query;
			format(szQuery, sizeof(szQuery),
			"SELECT Nickname FROM Accounts WHERE (Nickname = '%q')",
			db_escape(inputtext));
			query = db_query(dbaccounts, szQuery);
			if(db_num_rows(query))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Это имя уже занято. Придумайте другое имя.",
				"This nickname already exists. Choose another nickname!");
				if (pData[playerid][pLang] == 0)
				{
					format(header, sizeof(header), "Сменить никнейм %s(%d)",
					PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
					"{FFFFFF}Использовать ники администраторов, других игроков \
					и теги чужих кланов{FF0000} запрещено!{FFFFFF}\n\
					Введите новый ник (максимум 20 символов):", "Сменить", "Выйти");
				} else {
					format(header, sizeof(header), "Change nickname %s(%d)",
					PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
					"{FFFFFF}Impersonating administrators, other players and clantags {FF0000} \
					is forbidden!{FFFFFF}\nEnter a new nickname (max 20 symbols):", "Save", "Cancel");
				}
			} else {
				format(szQuery, sizeof(szQuery),
				"UPDATE Accounts SET Nickname = '%q' WHERE (Nickname = '%q')",
				db_escape(inputtext), NickName);
				query = db_query(dbaccounts, szQuery);
				db_free_result(query);
				
				format(stringru, sizeof(stringru), "Администратор %s сменил ник %s на %s",
				PlayerName(playerid), NickName, inputtext);
				format(stringen, sizeof(stringen), "Admin %s changed nickname %s to %s",
				PlayerName(playerid), NickName, inputtext);
				AdminActionsLog(stringen);
				
				SetPlayerName(ChosenPlayer[playerid], inputtext);// change in client
			}
			
			new year, month, day, hour, minute, datetime[20];
			getdate(year, month, day); gettime(hour, minute, _);
			format(datetime, sizeof(datetime), "%d.%d.%d %d:%02d", year, month, day, hour, minute);

			format(szQuery, sizeof(szQuery),
			"INSERT INTO Nicknameslog (Datetime, Nickname, NewNickname) VALUES ('%s', '%q', '%q')",
			datetime, NickName, inputtext);
			db_query(dblogs, szQuery);
			
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			SendClientMessageEx(ChosenPlayer[playerid], COLOR_GREY,
			"{FF0000}ВАЖНО:{FFFFFF} Не забудьте сменить никнейм в SA:MP клиенте!",
			"{FF0000}IMPORTANT:{FFFFFF} Do not forget to change your nickname in the SA:MP client!");
		}		
	}
