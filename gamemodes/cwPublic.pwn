			{
				case 0:	WORLD_MODE(playerid);
				case 1:
				{
					if(World[worldid][wLocked]) OnPlayerCommandText(playerid, "/unlockworld");
					else OnPlayerCommandText(playerid, "/lockworld");
				}
				case 2:
				{
					if(World[worldid][wVehicles]) World[worldid][wVehicles] = 0;
					else World[worldid][wVehicles] = 1;
					WORLD_MANAGE(playerid);
				}
				case 3:
				{
					if(World[worldid][wWeapons]) World[worldid][wWeapons] = 0;
					else World[worldid][wWeapons] = 1;
					WORLD_MANAGE(playerid);
				}
				case 4:
				{
					if(World[worldid][wTeleports]) World[worldid][wTeleports] = 0;
					else World[worldid][wTeleports] = 1;
					WORLD_MANAGE(playerid);
				}
				case 5:
				{
					#if !defined _streamer_included
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Недоступно. Streamer не подключен", "Error. Streamer not connected");
					WORLD_MANAGE(playerid);
					#endif
					if(World[worldid][wGreenZone])
					{
						DestroyDynamicArea(World[worldid][wGreenZone]);
						World[worldid][wGreenZone] = 0;
						WORLD_MANAGE(playerid);
					} else {
						if(pData[playerid][pLang])
						{
							ShowPlayerDialog(playerid, 319, DIALOG_STYLE_INPUT,
							"GreenZone", "{FFFFFF}Set the current position as a green zone without weapons for all players in this virtual world\nEnter the radius for the green zone:",
							"Select", "Cancel");
						} else {
							ShowPlayerDialog(playerid, 319, DIALOG_STYLE_INPUT,
							"GreenZone",
							"{FFFFFF}Установит текущую позицию, как зеленую зону без оружия для всех игроков в этом виртуальном мире\nВведите радиус для зеленой зоны:",
							"Выбрать", "Отмена");
						}
					}
				}
				case 6: 
				{
					if(World[worldid][wMarkers]) ToggleMarkersInWorld(worldid, false);
					else ToggleMarkersInWorld(worldid, true);
					format(stringru, sizeof(stringru),
					"%s(%d) переключил отображение маркеров оппонентов на радаре.",
					PlayerName(playerid), playerid);
					format(stringen, sizeof(stringen),
					"%s(%d) switched opponent markers on map.", PlayerName(playerid), playerid);
					SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
					WORLD_MANAGE(playerid);
				}
				case 7: 
				{
					if(World[worldid][wMapRadar]) 
					{
						World[worldid][wMapRadar] = 0;
						foreach(Player, i)
						{
							if(GetPlayerVirtualWorld(i) == worldid)	{
								GangZoneShowForPlayer(i, OffRadar, 0x000000FF);
							}
						}
					} else {
						foreach(Player, i)
						{
							if(GetPlayerVirtualWorld(i) == worldid)	{
								GangZoneHideForPlayer(i, OffRadar);
							}
						}
						World[worldid][wMapRadar] = 1;
					}						
					format(stringru, sizeof(stringru),
					"%s(%d) переключил отображение карты на радаре.",
					PlayerName(playerid), playerid);
					format(stringen, sizeof(stringen),
					"%s(%d) switched the map display on the radar.", PlayerName(playerid), playerid);
					SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
					WORLD_MANAGE(playerid);
				}
				case 8:
				{
					if(World[worldid][wKillheal]) World[worldid][wKillheal] = 0;
					else World[worldid][wKillheal] = 1;
					WORLD_MANAGE(playerid);
				}
				case 9:
				{
					if(World[worldid][wVehicleFix]) World[worldid][wVehicleFix] = 0;
					else World[worldid][wVehicleFix] = 1;
					WORLD_MANAGE(playerid);
				}
				case 10:
				{
					if(!World[worldid][wSpawnPoint])
					{
						if(pData[playerid][pLang])
						{
							ShowPlayerDialog(playerid, 317, DIALOG_STYLE_MSGBOX,
							"Change world spawn point", "{FFFFFF}Do you want to keep your current position as a spawn point for all players in this virtual world?",
							"Select", "Cancel");
						} else {
							ShowPlayerDialog(playerid, 317, DIALOG_STYLE_MSGBOX,
							"Сменить точку спавна в мире",
							"{FFFFFF}Вы хотите сохранить текущую позицию, как точку спавна для всех игроков этом виртуальном мире?",
							"Выбрать", "Отмена");
						}
					} else {
						if(pData[playerid][pLang])
						{
							ShowPlayerDialog(playerid, 317, DIALOG_STYLE_MSGBOX,
							"Change world spawn point",
							"{FFFFFF}Do you want to reset the spawn point in the world for all players to default?",
							"Select", "Cancel");
						} else {
							ShowPlayerDialog(playerid, 317, DIALOG_STYLE_MSGBOX,
							"Сменить точку спавна в мире",
							"{FFFFFF}Вы хотите сбросить точку спавна в мире для всех игроков на стандартную?",
							"Выбрать", "Отмена");
						}
					}
				}
				case 11:
				{
					if(World[worldid][wCbug]) World[worldid][wCbug] = 0;
					else World[worldid][wCbug] = 1;
					WORLD_MANAGE(playerid);
				}
				case 12:
				{
					if(World[worldid][wCJrun]) World[worldid][wCJrun] = 0;
					else World[worldid][wCJrun] = 1;
					WORLD_MANAGE(playerid);
				}
				case 13: WORLD_SKINS(playerid);
				case 14: WORLD_HEALTH(playerid);
				case 15: OnPlayerCommandText(playerid, "/map");
				case 16:
				{
					if(pData[playerid][pLang] == 0)
					{
						ShowPlayerDialog(playerid, 293, DIALOG_STYLE_INPUT,
						"Установка времени в мире",
						"{FFFFFF}Посмотреть сочетания погоды времени можно на: \n\
						{4682B4}https://dev.prineside.com/en/gtasa_weather_id/ \n\
						{FFFFFF}Введите время [0-23]. Стандартное [12].", "Ok", "Выход");
					} else {
						ShowPlayerDialog(playerid, 293, DIALOG_STYLE_INPUT,
						"Set virtual world time",
						"{FFFFFF}You can view time weather combinations on: \n\
						{4682B4}https://dev.prineside.com/en/gtasa_weather_id/ \n\
						{FFFFFF}Enter time [0-23]. Default [12].", "Ok", "Cancel");
					}
				}
				case 17:
				{
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 294, DIALOG_STYLE_INPUT,
						"Change world weather",
						"{FFFFFF}You can view time weather combinations on: \n\
						{4682B4}https://dev.prineside.com/en/gtasa_weather_id/ \n\
						{FFFFFF}Enter world weather id [0-255]:",
						"Select", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 294, DIALOG_STYLE_INPUT,
						"Сменить погоду в мире",
						"{FFFFFF}You can view time weather combinations on: \n\
						{4682B4}https://dev.prineside.com/en/gtasa_weather_id/ \n\
						{FFFFFF}Введите ID погоды [0-255]:",
						"Выбрать", "Отмена");
					}
				}
				case 18: 
				{
					if(pData[playerid][pLang])
					{		
						ShowPlayerDialog(playerid, 334, DIALOG_STYLE_INPUT,
						"World name",
						"{FF0000}The name of the world should not contain insults and provocations!\n\
						\n{FFFFFF}Enter the name for the virtual world", "Submit", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 334, DIALOG_STYLE_INPUT,
						"Название мира",
						"{FF0000}Название мира не должно содержать оскорблений и провокаций!\n\
						\n{FFFFFF}Введите новое название для мира", "Сменить", "Отмена");
					}
				}
				case 19: 
				{
					if(World[worldid][wAnticheat]) World[worldid][wAnticheat] = 0;
					else World[worldid][wAnticheat] = 1;
					WORLD_MANAGE(playerid);
				}
				case 20:
				{
					new tbtext[512], tmpstr[128];
					foreach(Player, i)
					{
						if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid)
						&& i != playerid)
						{
							format(tmpstr, 32, "%s\t(%d)\n", PlayerName(i), i);
							strcat(tbtext, tmpstr);
						}
					}
					if(!strlen(tbtext))
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Некому выдать права в мире", "There is no one to give rights in the world");
						WORLD_MANAGE(playerid);
						return 1;
					}
					ShowPlayerDialog(playerid, 298, DIALOG_STYLE_TABLIST,
					"Players in world", tbtext, "Select", "Cancel");
				}
			}
