stock AutoLogin(playerid)
{
	new LastIP[16],	PlayerNickName[MAX_PLAYER_NAME],
		ip[16], serial[41], lastserial[41]
	;
	
	GetPlayerIp(playerid, ip, sizeof ip);
	gpci(playerid,serial,40);
	GetPlayerName(playerid, PlayerNickName, sizeof(PlayerNickName));
	new year,month,day,hour,minute,second, lastlogin[24];
	getdate(year, month, day); gettime(hour,minute,second);
	format(lastlogin, sizeof(lastlogin), "%d.%d.%d %d:%d", day,month,year,hour,minute);
	
	new AutologinQuery[256], DBResult: aquery;
	format(AutologinQuery, sizeof(AutologinQuery),
	"SELECT Serial, Lastip FROM Accounts WHERE Nickname = '%q'",
	db_escape(PlayerNickName));
	aquery = db_query(dbaccounts, AutologinQuery);
	if(db_num_rows(aquery) > 0)
	{
		db_get_field(aquery, 0, lastserial, sizeof(lastserial));
		format(lastserial, sizeof(lastserial), "%s", lastserial);
		
		db_get_field(aquery, 1, LastIP, sizeof(LastIP));
		format(LastIP, sizeof(LastIP), "%s", LastIP);
		
		db_free_result(aquery);
		new subnet[16], subnet2[16];
		format(subnet, sizeof(subnet), "%s", LastIP);
		format(subnet2, sizeof(subnet2), "%s", ip);
		strdel(subnet, strlen(subnet)-3, strlen(subnet));
		strdel(subnet2, strlen(subnet2)-3, strlen(subnet2));
		//printf("%s %s | %s %s", LastIP, subnet, ip, subnet2);
		//  && !strcmp(subnet, subnet2, true)
		if(!strcmp(serial, lastserial, true) && !strcmp(subnet, subnet2, true))
		{
			new szQuery[512], DBResult: query;
			format(szQuery, sizeof(szQuery),
			"SELECT Admin, Lang, Skin, \
			Weather, Hour, Hud, Fpsbar, Dtbar, Bottombar, Hpbar, Bell, Killchat, \
			Dmginformer, Togpm,	AttachSlot0, AttachSlot1, AttachSlot2, AttachSlot3, \
			Muted, Banned, Verified, Cookies, Sfx FROM Accounts WHERE Nickname = '%q'", db_escape(PlayerNickName));
			query = db_query(dbaccounts, szQuery);
			
			pData[playerid][pAdmin] = db_get_field_int(query, 0);
			pData[playerid][pLang] = db_get_field_int(query, 1);
			pData[playerid][pSkin] = db_get_field_int(query, 2);
			pData[playerid][pWeather] = db_get_field_int(query, 3);
			pData[playerid][pHour] = db_get_field_int(query, 4);
			pData[playerid][pHud] = db_get_field_int(query, 5);
			pData[playerid][pFpsbar] = db_get_field_int(query, 6);
			pData[playerid][pDtbar] = db_get_field_int(query, 7);
			pData[playerid][pBottombar] = db_get_field_int(query, 8);
			pData[playerid][pHpbar] = db_get_field_int(query, 9);
			pData[playerid][pBell] = db_get_field_int(query, 10);
			pData[playerid][pKillchat] = db_get_field_int(query, 11);
			pData[playerid][pDmgInformer] = db_get_field_int(query, 12);
			pData[playerid][pTogpm] = db_get_field_int(query, 13);
			pData[playerid][pAttachSlot0] = db_get_field_int(query, 14);
			pData[playerid][pAttachSlot1] = db_get_field_int(query, 15);
			pData[playerid][pAttachSlot2] = db_get_field_int(query, 16);
			pData[playerid][pAttachSlot3] = db_get_field_int(query, 17);
			pData[playerid][pMuted] = db_get_field_int(query, 18);
			pData[playerid][pBanned] = db_get_field_int(query, 19);
			pData[playerid][pVerified] = db_get_field_int(query, 20);
			pData[playerid][pCookies] = db_get_field_int(query, 21);
			pData[playerid][pSfx] = db_get_field_int(query, 22);
			
			db_free_result(query);
			
			if(strlen(PlayerGeoIPInfo[playerid][pCountry]) > 1)
			{
				format(szQuery, sizeof(szQuery),
				"UPDATE Accounts SET Lastip = '%s', Lastlogin = '%s', \
				Lastcountry = '%s', Lastcity = '%s' WHERE (Nickname = '%q')",
				ip, lastlogin,
				PlayerGeoIPInfo[playerid][pCountry],
				PlayerGeoIPInfo[playerid][pCity],
				db_escape(PlayerNickName));
			} else {
				format(szQuery, sizeof(szQuery),
				"UPDATE Accounts SET Lastip = '%s', Lastlogin = '%s' \
				WHERE (Nickname = '%q')", ip, lastlogin, db_escape(PlayerNickName));
			}
			query = db_query(dbaccounts, szQuery);
			db_free_result(query);
			
			if(pData[playerid][pBanned] > 0)
			{
				if(fexist("core.db"))
				{
					new banquery[128];
					format(banquery, sizeof(banquery),
					"SELECT Date, Reason FROM Banlist WHERE Nickname = '%q' LIMIT 1",
					db_escape(PlayerNickName));
					query = db_query(dbcore, banquery);
					if(db_num_rows(query))
					{
						new date[22], reason[48], tmpstr[128];
						db_get_field(query, 0, date, sizeof(date));
						db_get_field(query, 1, reason, sizeof(reason));
						db_free_result(query);
						
						format(tmpstr, sizeof(tmpstr),
						"Account banned %s (reason: %s)", date, reason);
						KickPlayerEx(playerid, tmpstr);
					} else {
						KickPlayerEx(playerid, "Account banned");
					}
				}
			}
			
			SetPVarInt(playerid, "Logged", 1);
			SetPVarInt(playerid, "Admin", pData[playerid][pAdmin]);
			SetPlayerWeather(playerid, pData[playerid][pWeather]); 
			SetPlayerTime(playerid,pData[playerid][pHour],0);
			
			#if defined _INC_WEAPON_CONFIG
			if(pData[playerid][pDmgInformer] > 0) {
				SetDamageFeedForPlayer(playerid, 1);
			} 
			else SetDamageFeedForPlayer(playerid, -1);
			#endif
			
			KillTimer(NoLogin_Timer[playerid]);

			#if defined _nex_ac_included
				if(GetPVarInt(playerid, "Admin") >= 3)
				{
					// Disable dialog spoofing check
					EnableAntiCheatForPlayer(playerid, 39, false);
				}
			#endif
			
			if(GetPVarInt(playerid, "Admin") > 0 && strcmp(PlayerNickName, "1NS", true))
			{
				new message[128],messageru[128];
				format(message, sizeof(message), "%s(%d) has logged in as Admin! (Level:%i)", PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
				format(messageru, sizeof(messageru), "%s(%d) вошел на сервер как Администратор! (Уровень:%i)", PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
				SendClientMessageToAllEx(COLOR_GREY, messageru, message);
			}

			//ShowWelcomeMessage(playerid);
			//SetTimerEx("SetSkin", 1000, false, "i", playerid);
		}
		else LoginDialog(playerid);
	}
	else LoginDialog(playerid);
}


stock GivePlayerCookies(playerid, amount, silent = false)
{
	if(playerid == INVALID_PLAYER_ID || !IsPlayerConnected(playerid))
	{
		return false;
	}
	
	new string[32];
	pData[playerid][pCookies] = pData[playerid][pCookies] + amount;
	if(!silent)
	{
		if(amount > 1) format(string, 32, "~b~received ~g~%d cookies", amount);
		else format(string, 32, "~b~received ~g~cookie");
		SendNotify(playerid, string, 5);
	}	
	new szQuery[128];
	format(szQuery, sizeof(szQuery),
	"UPDATE Accounts SET Cookies = %i WHERE (Nickname = '%q')",
	pData[playerid][pCookies], db_escape(PlayerName(playerid)));
	db_query(dbaccounts, szQuery);
	
	return 1;
}

stock ShowDbBanlist(playerid)
{
	if (GetPVarInt(playerid, "Admin") < 3) 
	{
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Для использования этих функций Вы должны быть администратором 3 уровня!",
		"To use these functions you need to have 3 level admin rights!");
	}
	
	new szQuery[256], DBResult: query;
	new tmpstr[128], nick[24+1], ip[16+1];
	new hwban, hwmute, forceac, ipban;
	new s_hwban[32], s_hwmute[32], s_forceac[32], s_ipban[32];
	
	format(szQuery, sizeof(szQuery),
	"SELECT Nickname, HwBan, HwMute, Forceac, IpBan, IP FROM Banlist LIMIT 100");
	query = db_query(dbcore, szQuery);
	new rows = db_num_rows(query);
	for(new i; i < rows; i++)
	{
		db_get_field(query, 0, nick, sizeof(nick));
		format(nick, sizeof(nick), "%s", nick);
		
		hwban = db_get_field_int(query, 1);
		hwmute = db_get_field_int(query, 2);
		forceac = db_get_field_int(query, 3);
		ipban = db_get_field_int(query, 4);
		
		db_get_field(query, 5, ip, sizeof(ip));
		format(ip, sizeof(ip), "%s", ip);
		
		if(hwban) format(s_hwban, 32, "{FF0000}hwban %d{FFFFFF}", hwban);
		else format(s_hwban, 32, "hwban %d", hwban);
		if(hwmute) format(s_hwmute, 32, "{FF0000}hwmute %d{FFFFFF}", hwmute);
		else format(s_hwmute, 32, "hwmute %d", hwmute);
		if(forceac) format(s_forceac, 32, "{FF0000}forceac %d{FFFFFF}", forceac);
		else format(s_forceac, 32, "forceac %d", forceac);
		if(ipban) format(s_ipban, 32, "{FF0000}ipban %d{FFFFFF}", ipban);
		else format(s_ipban, 32, "ipban %d", ipban);
		
		format(tmpstr, 128, "%s - | %s | %s | %s | %s | ip %s",
		nick, s_hwban, s_hwmute, s_forceac, s_ipban, ip);
		SendClientMessage(playerid, -1, tmpstr);
		db_next_row(query);
	}
	db_free_result(query);
	if(rows < 1)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Нет результатов для отображения", "No results to display");
	} else {
		format(tmpstr, 128, "Found results: %i", rows);
		SendClientMessage(playerid, -1, tmpstr);
	}
	return 1;
}

stock FindSimilarAccs(playerid, const nickname[MAX_PLAYER_NAME])
{
	if (GetPVarInt(playerid, "Admin") < 3) 
	{
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Для использования этих функций Вы должны быть администратором 3 уровня!",
		"To use these functions you need to have 3 level admin rights!");
	}
	
	if(strlen(nickname) < 3 && isnull(nickname) && strlen(nickname) > 24)
	{
		return SendClientMessage(playerid, COLOR_GREY, "Error: Incorrect value");
	}
	
	new serial[64];
	//gpci(playerid, serial, sizeof(serial));
	new nick[24+8], country[32+2], lastcountry[32+2],lastip[16+2], verified;
	new tbtext[2024], tmpstr[128];
	new szQuery[256], DBResult: query;
	
	format(szQuery, sizeof(szQuery),
	"SELECT Serial, Lastcountry FROM Accounts WHERE (Nickname = '%q')",
	db_escape(nickname));
	query = db_query(dbaccounts, szQuery);
	if(db_num_rows(query))
	{
		db_get_field(query, 0, serial, sizeof(serial));
		format(serial, sizeof(serial), "%s", serial);
		
		db_get_field(query, 1, country, sizeof(country));
		format(country, sizeof(country), "%s", country);
	} else {
		SendClientMessage(playerid, COLOR_GREY, "Error: Account not found");
	}
	
	format(szQuery, sizeof(szQuery),
	"SELECT Verified, Nickname, Lastcountry, Lastip FROM Accounts WHERE (Serial = '%s' AND Lastcountry = '%s') LIMIT 100",
	serial, country);
	query = db_query(dbaccounts, szQuery);
	
	new rows = db_num_rows(query);
	if(rows > 10)
	{
		for(new i; i < rows; i++)
		{
			verified = db_get_field_int(query, 0);
			
			db_get_field(query, 1, nick, sizeof(nick));
			if(verified) format(nick, sizeof(nick), "{00FF00}%s", nick);
			else format(nick, sizeof(nick), "%s", nick);
			
			db_get_field(query, 2, lastcountry, sizeof(lastcountry));
			format(lastcountry, sizeof(lastcountry), "%s", lastcountry);
			
			db_get_field(query, 3, lastip, sizeof(lastip));
			format(lastip, sizeof(lastip), "%s", lastip);
			
			format(tmpstr, 128, "%s - %s - %s", nick, lastcountry, lastip);
			SendClientMessage(playerid, -1, tmpstr);
			
			db_next_row(query);
		}
		db_free_result(query);
		if(rows < 1)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Нет результатов для отображения", "No results to display");
		} else {
			format(tmpstr, 128, "Found results: %i", rows);
			SendClientMessage(playerid, -1, tmpstr);
		}
	} else {
		for(new i; i < rows; i++)
		{
			verified = db_get_field_int(query, 0);
			
			db_get_field(query, 1, nick, sizeof(nick));
			if(verified) format(nick, sizeof(nick), "{00FF00}%s\t", nick);
			else format(nick, sizeof(nick), "%s\t", nick);
				
			db_get_field(query, 2, lastcountry, sizeof(lastcountry));
			format(lastcountry, sizeof(lastcountry), "%s\t", lastcountry);
			
			db_get_field(query, 3, lastip, sizeof(lastip));
			format(lastip, sizeof(lastip), "%s\n", lastip);
			
			strcat(tbtext, nick);
			strcat(tbtext, lastcountry);
			strcat(tbtext, lastip);
			
			db_next_row(query);
		}
		db_free_result(query);
		
		if(strlen(tbtext) < 1)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Нет результатов для отображения", "No results to display");
		}
		else ShowPlayerDialog(playerid, 246, DIALOG_STYLE_LIST,
		"Player accs", tbtext, "Select", "Cancel");
	}
	return true;
}

stock VerifyAccounts(playerid)
{
	if(GetPVarType(playerid, "Youtuber"))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Недоступно в режиме стримера", "Not available in streamer mode");
		return true;
	}
	
	if(pData[playerid][pLang])
	{
		ShowPlayerDialog(playerid, 276, DIALOG_STYLE_INPUT,
		"Verify account", "Enter part of nickname to search", "Search", "Cancel");
	} else {
		ShowPlayerDialog(playerid, 276, DIALOG_STYLE_INPUT,
		"Верификация аккаунтов", "Введите часть никнейма для поиска", "Найти", "Отмена");
	}
	return 1;
}

public CreateCoreDb()
{
	// Create table with default values
	dbcore = db_open("core.db");
	// Fill settings table 
	db_query(dbcore, "CREATE TABLE IF NOT EXISTS Settings (Option text, Value int)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_sprinthook_delay',10)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_sprinthook_speed',60)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_sprinthook_kickafter',5)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('map',2)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('max_fps',105)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('max_ping',400)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('min_fps',25)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('kick_lagers',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_distancebug',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_cbug',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_slide',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('fpsunlock',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('host',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('nologin_delay',90)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('teamsautobalance',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('syncmode',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('togglenametags',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_pedifp',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_cleo',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('max_packetloss',50)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_rapid',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('showenemybar',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('useproxychecker',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('autoteamspec',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('spawnlock',1)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_autoscroll',0)");
    db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('ac_only',0)");
	db_query(dbcore, "INSERT INTO Settings (Option, Value) VALUES('serverlock',0)");
	// Fill ban list table 
	db_query(dbcore, "CREATE TABLE IF NOT EXISTS Banlist (Nickname text, Serial text, \
	HwBan int, HwMute int, Forceac int, IP text, Reason text, Date text)");
	db_query(dbcore, "CREATE TABLE IF NOT EXISTS Settings (Option text, Value int)");
	
	if(Selftest) 
	{
		if(fexist("core.db")) print("Created core.db\t[OK]");
		else print("Created core.db\t[fail]");
	}
}

