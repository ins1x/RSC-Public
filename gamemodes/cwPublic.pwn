stock ChangeGameMode(playerid, gamemode)
{
	if(SYNCMODE == gamemode)
	{
		// return SendClientMessageToAllEx(COLOR_GREY,
		// "Выбранный режим синхронизации уже активна!",
		// "Selected synchronization mode is active now!");
		return 0;
	}
	SetTimerEx("GameModeRestart", 10000, false, "ii", playerid, gamemode);
	SYNCMODE = gamemode;
	//SaveServerConfigfile();
	SaveServerConfig();
	if(gamemode == 0)
	{
		SendClientMessageToAllEx(COLOR_GREY,
		"Администратор установил стандартную синхронизацию",
		"Administrator has set basic synchronization");
	}
	else if(gamemode == 1)
	{
		SendClientMessageToAllEx(COLOR_GREY,
		"Администратор установил улучшенную синхронизацию",
		"Administrator has set improved synchronization");
	}
	else if(gamemode == 2)
	{
		SendClientMessageToAllEx(COLOR_GREY,
		"Администратор переключил синхронизацию на lagshot",
		"The administrator switched sync to lagshot");
	}
	SendClientMessageToAllEx(COLOR_RED,
	"Сервер будет перезагружен через 10 секунд",
	"The server will restart in 10 seconds");
	return 1;
}

public GameModeRestart(playerid, changemode)
{
	// Techincal restart server
	// changemode = 0 restart and load default sync mode
	// changemode = 1 restart and load previous version
	// changemode = 2 restart and load weaponconfig sync mode
	// changemode = -1 default restart

	SendRconCommand("hostname Russian Sawn-off Community | Restart...");
	
	SendClientMessageToAllEx(0xb4c1d2FF,
	"Сервер перезагружается. Вы сможете продолжить игру через минуту",
	"The server is restarting. You will be able to continue the game in a couple of minutes.");
	
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);

	GameTextForAll("~w~RELOAD ~y~GAMEMODE", 1000, 3);

	// Fix flycam reconnect bug
	foreach(Player, i)
	{
		if (IsPlayerConnected(i))
		{
			SetPlayerSpecialAction(i, SPECIAL_ACTION_NONE);
			PlayerPlaySound(i, 1069, 0.0, 0.0, 0.0);
			if(noclipdata[i][cameramode] == CAMERA_MODE_FLY) SpecOff(i);
		}
	}
	// Fix Re-connection bug with enabled autoclantags
	#if defined _YSF_included
	if(AutosetClanTags)
	{						
		foreach(Player, i) VisualToggleClanTag(i, false);
		AutosetClanTags = false;
	}
	#endif
	
	// change gamemode sync
	if(changemode == 0)	SendRconCommand("changemode cwPublic");
	else if(changemode == 1) SendRconCommand("changemode cwPublicStable");
	else if(changemode == 2) SendRconCommand("changemode cwPublicWC");
	else SendRconCommand("gmx");

	return true;
}

public DestroyAllVehicles(worldid)
{
	if(worldid != -1)
	{
		for(new i = GetVehiclePoolSize() +1; --i != 0;)
		{
			if(GetVehicleVirtualWorld(i) == worldid) DestroyVehicle(i);
		}
	} else {
		for(new i = GetVehiclePoolSize() +1; --i != 0;) DestroyVehicle(i);
	}
	
	return true;
}

public AttachToVehicle(vehicleid, objectid, playerid, slot,
Float: ox, Float:oy, Float:oz, Float:orx, Float:ory, Float:orz)
{
	// Add attach to player vehicle
	VehicleAttaches[playerid][slot] = CreateDynamicObject(objectid,
	0.0, 0.0, -1000.0, 0.0, 0.0, 0.0, // default object place 
	GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid));
	AttachDynamicObjectToVehicle(VehicleAttaches[playerid][slot], vehicleid,
	ox, oy, oz, orx, ory, orz);
	//return VehicleAttaches[playerid][slot];
}

public SpawnPlayerVehicle(playerid, modelid)
{
	// Main vehicle spawn function
	new vehicle;
	new worldid = GetPlayerVirtualWorld(playerid);
	
	if(GetPlayerVirtualWorld(playerid) == 0 && CWmode) 
	{
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Недоступно во время проведения матча", "Not available during CW match");
	}
	
	if(modelid < 400 && modelid > 611) return 0;

	// Forbidden vehs for all
	switch(modelid)
	{
		case 590, 570, 569, 538, 537, 449: return false; // Trains
		case 441, 464, 594, 501, 465, 564: return false; // RC Toys
		case 606, 607, 608, 610, 611, 584, 591, 450, 435: return false; // Trailers
	}
	// Forbidden vehs for players
	if(GetPVarInt(playerid, "Admin") < 3 && worldid == 0)
	{
		switch(modelid)
		{
			case 520, 425, 447, 430, 476, 432, 601: return false; // War vehs
			case 406, 407, 486: return false; // Special Vehs
		}
	}
	// Forbidden vehs for not hosters
	if(!WorldModerator[playerid] && worldid != 0)
	{
		switch(modelid)
		{
			case 520, 425, 447, 430, 476, 432, 601: return false; // War vehs
			case 406, 407, 486: return false; // Special Vehs
		}
	}
	
	for(new attachid = 0; attachid < MAX_VEHICLE_ATTACHES; attachid++)
	{
		if(IsValidDynamicObject(VehicleAttaches[playerid][attachid]))
		{
			DestroyDynamicObject(VehicleAttaches[playerid][attachid]);
		}
	}
			
	new Float:x, Float:y, Float:z, Float:ang;
	GetPlayerPos(playerid, x, y, z);
	GetPlayerFacingAngle(playerid, ang);
	new Float:adj = 2.0;
	new LookAt = GetDirectionInWhichPlayerLooks(playerid, ang);
	switch(LookAt) 
	{
		case 0: y=y+adj;
		case 1: x=x-adj,y=y+adj;
		case 2: x=x-adj;
		case 3: x=x-adj,y=y-adj;
		case 4: y=y-adj;
		case 5: x=x+adj,y=y-adj;
		case 6: x=x+adj;
		case 7: x=x+adj,y=y+adj;
	}
	
	if(GetPVarInt(playerid, "Vehicle") != 0) {
		DestroyVehicle(GetPVarInt(playerid, "Vehicle"));
	}
	
	if (IsPlayerInAnyVehicle(playerid))	{
		DestroyVehicle(GetPlayerVehicleID(playerid));
	}
	
	if(worldid != 0)
	{
		vehicle = CreateVehicle(modelid, x, y, z, ang-90,
		World[worldid][wColor1], World[worldid][wColor2], -1);
	} else {
		new color = random(256);
		if(GetPVarInt(playerid, "Team") == 0) color = 160;
		if(GetPVarInt(playerid, "Team") == 1) color = 223;
		vehicle = CreateVehicle(modelid, x, y, z, ang-90, color, color, -1);
	}
	SetPVarInt(playerid, "Vehicle", vehicle);
	new vehicleid = GetPlayerVehicleID(playerid);
	if(worldid != 0) ChangeVehiclePaintjob(vehicleid, World[worldid][wPaintjob]);
	SetVehicleVirtualWorld(GetPVarInt(playerid, "Vehicle"), GetPlayerVirtualWorld(playerid));
	LinkVehicleToInterior(GetPVarInt(playerid, "Vehicle"), GetPlayerInterior(playerid));
	//if(GetPlayerInterior(playerid) != 0) SetVehicleToRespawn(vehicleid);
	//PutPlayerInVehicle(playerid, GetPVarInt(playerid, "Vehicle"), 0);
	SetVehicleNumberPlate(vehicleid,"{FFFFFF}R{4682b4}S{FF0000}C");
	
	new string[48];
	format(string, sizeof(string), "~w~%s", VehicleNames[modelid-400]);
	PlayerTextDrawSetString(playerid, TDnames[playerid], string);
	PlayerTextDrawShow(playerid, TDnames[playerid]);
			
	return vehicleid;
}

stock LoadDefaultAccountConfiguration(playerid)
{
	// Load defaul account config if registation off
	ShowPlayerDialog(playerid, 6, DIALOG_STYLE_LIST, "Language", "English\nRussian", "OK", "Cancel");
	// Load Account config
	new PlayerNickName[MAX_PLAYER_NAME];
    GetPlayerName(playerid,PlayerNickName,sizeof(PlayerNickName));
	pData[playerid][pWeather] = 1;
	pData[playerid][pHour] = 12;
	pData[playerid][pHud] = 1;
	pData[playerid][pFpsbar] = 1;
	pData[playerid][pHpbar] = 1;
	pData[playerid][pBell] = 17802;
	pData[playerid][pKillchat] = 0;
	pData[playerid][pSfx] = 0;
	pData[playerid][pAttachSlot0] = -1;
	pData[playerid][pAttachSlot1] = -1;
	pData[playerid][pAttachSlot2] = -1;
	pData[playerid][pAttachSlot3] = -1;
	SetPVarInt(playerid, "Logged", 1);
	//SetPVarInt(playerid, "Team", 2);// fix reg miss bug
	//SetPlayerSkin(playerid,pData[playerid][pSkin]);
	//if(pData[playerid][pHud] > 0) PlayerTextDrawShow(playerid, Commands[playerid]);
	//if(pData[playerid][pHud] > 0) PlayerTextDrawShow(playerid, TDlagmode[playerid]);
	SetPlayerWeather(playerid, pData[playerid][pWeather]); 
	SetPlayerTime(playerid,pData[playerid][pHour],0); 
	
	KillTimer(GetPVarInt(playerid, "Team") -3);
	
	
	if(!fexist("accounts.db"))
	{	
		if(fexist("Admins.txt"))
		{
			new File:sfile = fopen("Admins.txt", io_read);
			if(sfile)
			{
				new admlist[512];
				while(fread(sfile, admlist))
				{
					if(strfind(admlist, PlayerNickName)!= -1)
					{
						SetPVarInt(playerid, "Admin", 3);
						new message[128],messageru[128];
						format(message, sizeof(message), "%s(%d) has logged in as Admin! (Level:%i)", PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
						format(messageru, sizeof(messageru),
						"%s(%d) вошел на сервер как Администратор! (Уровень:%i)",
						PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
						SendClientMessageToAllEx(COLOR_GREY, messageru, message);
					} else {
						SetPVarInt(playerid, "Admin", 0);
						pData[playerid][pAdmin] = 0;
					}
				}
				fclose(sfile);
			}
		}
	} else { // if all Ok load data from accounts.db
		new szQuery[128], DBResult: query;
		format(szQuery, sizeof(szQuery),
		"SELECT Admin FROM Accounts WHERE Nickname = '%q' LIMIT 1",
		db_escape(PlayerNickName));
		query = db_query(dbaccounts, szQuery);
		if(db_num_rows(query))
		{
			SetPVarInt(playerid, "Admin", db_get_field_int(query, 0));
			new message[128],messageru[128];
			format(message, sizeof(message), "%s(%d) has logged in as Admin! (Level:%i)",
			PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
			format(messageru, sizeof(messageru), "%s(%d) вошел на сервер как Администратор! (Уровень:%i)", PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
			SendClientMessageToAllEx(COLOR_GREY, messageru, message);
			db_free_result(query);
		} else {
			SetPVarInt(playerid, "Admin", 0);
			pData[playerid][pAdmin] = 0;
		}
	}
	//ShowWelcomeMessage(playerid);
}

stock LoadExitCwPlayer(playerid) // /load
{
	// Restore data of the disconnected player from the match
	Update3DTextLabelText(Spawnkill3d[playerid], 0x00000001, " ");
	SetPlayerInterior(playerid, MapInterior[Map]);
	onspawnprotect[playerid] = false;
	KillTimer(SpawnKill_Timer[playerid]);
	new oldslot = -1;
	new pname[MAX_PLAYER_NAME];
	for(new p = 0; p < _MAX_PLAYERS; p++)
	{
		GetPlayerName(playerid, pname, sizeof(pname));
		if(!strcmp(pname, CwData[p][cwNickname], false)){
			if(strlen(pname) == strlen(CwData[p][cwNickname])){
				//printf("find at slot %i nick %s", p, pname);
				if(CwData[playerid][cwPosX] != 0.0) oldslot = p;
			}
		}
	}
	if(oldslot != -1)
	{
		SetPlayerPos(playerid,
		CwData[oldslot][cwPosX], CwData[oldslot][cwPosY], CwData[oldslot][cwPosZ]);
		SetPlayerTeam(playerid, CwData[oldslot][cwTeam]);
		SetPVarInt(playerid, "Team",CwData[oldslot][cwTeam]);
		new team = CwData[oldslot][cwTeam];
		SetPlayerColor(playerid, TCC[team]);
		//SetSpawnInfo(playerid, 0, GetPlayerSkin(playerid),
		//CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2], 0, 0, 0, 0, 0, 0, 0);
		SetPlayerFacingAngle(playerid, CwData[oldslot][cwPosA]);
		// check if health and armour more then 100 drop to default
		SetPlayerHealth(playerid, CwData[oldslot][cwHealth]);
		SetPlayerArmour(playerid, CwData[oldslot][cwArmour]);
		//stats load
		//SetPlayerSkin(playerid, CwData[oldslot][cwPlayerSkin]);
		SetPVarInt(playerid,"cwkills", CwData[oldslot][cwKills]);
		SetPVarInt(playerid,"cwdeath", CwData[oldslot][cwDeaths]);
		SetPVarInt(playerid,"cwteamkills", CwData[oldslot][cwTeamkills]);
		SetPVarFloat(playerid,"cwdamage", CwData[oldslot][cwDamage]);
		SetPVarFloat(playerid,"cwinjuries", CwData[oldslot][cwInjuries]);	
		SetPVarFloat(playerid,"cwteamdamage", CwData[oldslot][cwTeammateDamage]);
		SetPVarInt(playerid,"round_kills", CwData[oldslot][cwRoundKills]);
		SetPVarInt(playerid,"round_death", CwData[oldslot][cwRoundDeaths]);
		SetPVarInt(playerid,"round_teamkills", CwData[oldslot][cwRoundTeamkills]);
		SetPVarFloat(playerid,"round_damage", CwData[oldslot][cwRoundDamage]);
		SetPVarFloat(playerid,"round_injuries", CwData[oldslot][cwRoundInjuries]);
		SetPVarFloat(playerid,"round_teamdamage", CwData[oldslot][cwRoundTeammateDamage]);
	} else {
		if (pData[playerid][pSyncX] == 0.0)
		{
			//SendClientMessageEx(playerid, COLOR_GREY,
			//"Позиция игрока после вылета не была сохранена.",
			//"Position after crash isn't saved.");
			return false;
		}
		SetPlayerPos(playerid, pData[playerid][pSyncX],
		pData[playerid][pSyncY], pData[playerid][pSyncZ]);
		SetPlayerFacingAngle(playerid, pData[playerid][pSyncA]);
		if (pData[playerid][pSaveHP] > 100) {
			SetPlayerHealth(playerid, 100.0);
			SetPlayerArmour(playerid, pData[playerid][pSaveHP] -100.0);
		} else {
			SetPlayerHealth(playerid, pData[playerid][pSaveHP]);
		}
	}
	SetCameraBehindPlayer(playerid);
	SetPVarFloat(playerid, "LastHP", pData[playerid][pSaveHP] +0.000001);
	//ClearAnimations(playerid);
	//ApplyAnimation(playerid, "BSKTBALL", "BBALL_Dnk_Gli_O", 4.1, 0, 0, 0, 1, 0, 1);
	TogglePlayerControllable(playerid, false);
	SetPVarInt(playerid, "frz", true);
	SetVirtualWorldSpawnInfo(playerid, GetPlayerSkin(playerid));
	GiveDefaultWeapons(playerid);
	PlayerRefreshScore(playerid);
	return true;
}

stock ShowWelcomeMessage(playerid)
{
	if(!GetPVarInt(playerid, "firstspawn"))
	{
		SendClientMessage(playerid, -1, "=========================================================");
		SendClientMessage(playerid, -1,
		"{008000}CW/TG {AFAFAF}Russian Sawn-off Community {008000}(dsc.gg/sawncommunity)");
		SendClientMessageEx(playerid, -1,
		"Чтобы увидеть список серверных команд, нажмите {008000}/help{FFFFFF}",
		"For the list of all server commands type {008000}/help{FFFFFF}");
		SendClientMessageEx(playerid, -1,
		"Для настройки Вашего аккаунта используйте команду {008000}/settings{FFFFFF}",
		"To customize your account settings use command {008000}/settings{FFFFFF}");
		SendClientMessageEx(playerid, -1,
		"Ознакомьтесь с правилами сервера с помощью команды {008000}/rules{FFFFFF}",
		"Make yourself familiar with the server rules by typing {008000}/rules{FFFFFF}");
		SendClientMessageEx(playerid, -1,
		"Для изменения языка на сервере воспользуйтесь командой {008000}/lang{FFFFFF}",
		"To switch between English/Russian use command {008000}/lang{FFFFFF}");
		SendClientMessageEx(playerid, -1,
		"Вы можете тренироваться в виртуальном мире {008000}/world{FFFFFF}",
		"You can training in the virtual world {008000}/world{FFFFFF}");
		SendClientMessage(playerid, -1, "=========================================================");
	}
    #if defined DISCORD_VERIFICATION
	if(!pData[playerid][pVerified])
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Ваш аккаунт не верифицирован, пройдите верификацию в Discord: dsc.gg/sawncommunity",
		"Your account is not verified, please verify in Discord: dsc.gg/sawncommunity");
	}
    #endif
	if(Online <= 1)
	{
		SendClientMessageEx(playerid, -1,
		"Если Вам не с кем поиграть, Вы можете позвать игроков в discord канале {AFAFAF}#discussion {008000}(dsc.gg/sawncommunity)",
		"If you have no one to play with you can call players in the discord channel {AFAFAF}#discussion {008000}(dsc.gg/sawncommunity)");
	}
}

