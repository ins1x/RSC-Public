			CLANADD_MENU(playerid);
		}
		else CLANADD_MENU(playerid);
	}
	if(dialogid == 384)
	{
		if(response)
		{
			if(strlen(inputtext) && strlen(inputtext) <= 12)
			{
				SetPVarString(playerid, "editclantag", db_escape(inputtext));
			} 
			CLANADD_MENU(playerid);
		}
		else CLANADD_MENU(playerid);
	}
	if(dialogid == 385)
	{
		if(response)
		{
			if(strlen(inputtext) && strlen(inputtext) <= 32)
			{
				SetPVarString(playerid, "editclancountry", db_escape(inputtext));
			} 
			CLANADD_MENU(playerid);
		}
		else CLANADD_MENU(playerid);
	}
	if(dialogid == 386)
	{
		if(response)
		{
			if(strlen(inputtext) && strlen(inputtext) <= 32)
			{
				SetPVarString(playerid, "editclanleader", db_escape(inputtext));
			} 
			CLANADD_MENU(playerid);
		}
		else CLANADD_MENU(playerid);
	}
	if(dialogid == 387)
	{
		if(response)
		{
			if(strlen(inputtext) && strlen(inputtext) <= 12)
			{
				SetPVarString(playerid, "editclanyear", db_escape(inputtext));
			} 
			CLANADD_MENU(playerid);
		}
		else CLANADD_MENU(playerid);
	}
	if(dialogid == 388)
	{
		if(response)
		{
			if(strlen(inputtext) && strlen(inputtext) <= 32)
			{
				SetPVarString(playerid, "editclanwebpage", db_escape(inputtext));
			} 
			CLANADD_MENU(playerid);
		}
		else CLANADD_MENU(playerid);
	}
	if(dialogid == 389)
	{
		if(response)
		{
			new szQuery[128], DBResult: query;
			format(szQuery, sizeof(szQuery),
			"DELETE FROM Clanlist WHERE (Clanname = '%q')",
			db_escape(inputtext));
			query = db_query(dbcore, szQuery);
			db_free_result(query);
			
			new string[128];
			format(string, sizeof(string), "%s(%d) has removed clan %s from clanlist",
			PlayerName(playerid), playerid, db_escape(inputtext));
			SendSystemMessage(string);
			AdminActionsLog(string);
			
			SendClientMessageEx(playerid, COLOR_GREY,
			"Клан был удален из списка", "Сlan has been removed from the list");
		}
	}
	
	//lastdialog last dialog
	return true;
}

stock CHANGEWORLD_MENU(playerid)
{
	new tbtext[1024], buffer[100];
	
	if(pData[playerid][pLang]) {
		strcat(tbtext, "{AFAFAF}#  {FFFFFF}Name\t{AFAFAF}Gamemode\t{FFFFFF}Status\n");
	}
	else strcat(tbtext, "{AFAFAF}#  {FFFFFF}Название\t{AFAFAF}Режим\t{FFFFFF}Статус\n");
	
	for(new slot=1; slot < MAX_WORLD_SLOTS; slot++)
	{
		new worldmode[24];
		format(worldmode, sizeof(worldmode), "{AFAFAF}%s", WorldModes[World[slot][wGamemode]]);
		
		new worldname[24];
		if(strlen(World[slot][wName])) {
		format(worldname, sizeof(worldname), "%s",World[slot][wName]);
		}
		else format(worldname, sizeof(worldname), "%s", MapNames[World[slot][wMap]]);
		
		if(pData[playerid][pLang]) 
		{
			if(World[slot][wHosted] != -1)
			{
				format(buffer, sizeof(buffer),
				"{AFAFAF}%d  {FFFFFF}%s\t%s\t%s\n",
				slot, worldname, worldmode,
				(World[slot][wLocked]) ? ("{FF0000}[Locked]") : ("{00FF00}[Open]"));
			} else {
				format(buffer, sizeof(buffer),
				"{AFAFAF}%d  {00FF00}[Free slot]\t\t\n", slot);
			}
		} else {
			if(World[slot][wHosted] != -1)
			{
				format(buffer, sizeof(buffer),
				"{AFAFAF}%d  {FFFFFF}%s\t%s\t%s\n",
				slot, worldname, worldmode,
				(World[slot][wLocked]) ? ("{FF0000}[Закрыт]") : ("{00FF00}[Открыт]"));
			} else {
				format(buffer, sizeof(buffer),
				"{AFAFAF}%d  {00FF00}[Свободный слот]\t\t\n", slot);
			}
		}
		strcat(tbtext, buffer);
	}
	
	if(pData[playerid][pLang]) strcat(tbtext, "{FFFFFF}>> Default world <<\t\t\n");
	else strcat(tbtext, "{FFFFFF}>> Основной мир <<\t\t\n");
	
	if(pData[playerid][pLang])
	{
		ShowPlayerDialog(playerid, 272, DIALOG_STYLE_TABLIST_HEADERS,
		"Change world", tbtext, "Select", "Cancel");
	} else {
		ShowPlayerDialog(playerid, 272, DIALOG_STYLE_TABLIST_HEADERS,
		"Сменить мир", tbtext, "Выбрать", "Отмена");
	}
	
	SetPlayerChatBubble(playerid, "..opens world menu..", COLOR_GREY, 50.0, 5000);
	return true;
}

stock GetPlayersInWorld(worldid)
{
	// Count player in virtual world
	new totalplayers;
	foreach(Player, i)
	{
		if(GetPlayerVirtualWorld(i) == worldid)
		{
			totalplayers++;
		}
	}
	return totalplayers;
}

stock CAM_MENU(playerid)
{
	new tbtext[200];
