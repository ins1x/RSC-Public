	GetPVarString(playerid, "editclancountry", country, sizeof(country));
	GetPVarString(playerid, "editclanyear", year, sizeof(year));
	GetPVarString(playerid, "editclantag", clantag, sizeof(clantag));
	GetPVarString(playerid, "editclanleader", clanleader, sizeof(clanleader));
	GetPVarString(playerid, "editclanwebpage", webpage, sizeof(webpage));
				
	format(tbtext, sizeof(tbtext),
	"Clanname\t{AFAFAF}%s\n"\
	"Tag\t{AFAFAF}%s\n"\
