stock Help(playerid)
{
	new tbtext[340];

	if (pData[playerid][pLang] == 0)
	{
		format(tbtext, sizeof(tbtext),
		"{FFD700}Общие команды\n\
		{FFD700}CW/TG команды\n\
		{FFD700}Чат команды\n\
		{FFD700}Команды в мире\n\
		{FFD700}Правила\n\
		{FFD700}Разрешенные модификации\n\
		{FFD700}Горячие клавиши\n");

		if (GetPVarInt(playerid, "Admin") >= 1)
		{
			strcat(tbtext, "{FF0000}Команды администратора LVL1\n");
			if (GetPVarInt(playerid, "Admin") >= 2)
			{
				strcat(tbtext, "{FF0000}Команды администратора LVL2\n");
			}
			if (GetPVarInt(playerid, "Admin") >= 3)
			{
				strcat(tbtext, "{FF0000}Команды администратора LVL3\n");
				strcat(tbtext, "{FF0000}Памятка для админов LVL3\n");
				strcat(tbtext, "{FF0000}Команды для отладки\n");
			}
		}
	} else {
		format(tbtext, sizeof(tbtext),
		"{FFD700}General commands\n\
		{FFD700}CW/TG commands\n\
		{FFD700}Chat commands\n\
		{FFD700}Virtual world commands\n\
		{FFD700}Rules\n\
		{FFD700}Allowed mods\n\
		{FFD700}Hotkeys\n");

		if (GetPVarInt(playerid, "Admin") >= 1)
		{
			strcat(tbtext, "{FF0000}Admin commands LVL1\n");
			if (GetPVarInt(playerid, "Admin") >= 2)
			{
				strcat(tbtext, "{FF0000}Admin commands LVL2\n");
			}
			if (GetPVarInt(playerid, "Admin") >= 3)
			{
				strcat(tbtext, "{FF0000}Admin commands LVL3\n");
				strcat(tbtext, "{FF0000}Guide for admins LVL3\n");
				strcat(tbtext, "{FF0000}Debug commands\n");
			}
		}
	}
	ShowPlayerDialog(playerid, 10, DIALOG_STYLE_LIST,
	"{FFD700}[HELP]", tbtext, "OK", "");
}

stock CwHelpToggle(playerid, toggle = false)
{
	new tmp[1024]; // Max String Length
	// Show CW Help
	if(toggle)
	{
		// Hide specbar (fix)
		if(GetPVarInt(playerid, "specbar") != -1)
		{
			PlayerTextDrawHide(playerid, TDspecbar[playerid]);
			PlayerTextDrawHide(playerid, TDspecbarDynBox[playerid]);
			SetPVarInt(playerid, "specbar",-1);
		}
		
		format(tmp, sizeof(tmp),
		"How to start a ~g~CW/TG~w ~~n~\
		> If needed, change team names:~n~\
		Press 'Team name', or use command /clantag [oldname][newname]~n~\
		> Switch OFF Killheal:~n~\
		Press 'Heal after kill', or use command /killheal~n~\
		> Clear the total score:~n~\
		Press 'Reset everything', or use command /resetall~n~\
		> Set up the amount of kills in a round:~n~\
		Press 'Round kills', or use command /roundkills [points]~n~\
		> Move all players to spectators:~n~\
		Press 'Reset teams', or use command /resetteams~n~\
		> Move selected players to their teams:~n~\
		Press 'Move player', or use command /t id [teamname]~n~\
		> If needed, switch ON spectate only mode:~n~\
		Press 'Speconly', or use command /speconly~n~\
		> Spawn all players:~n~\
		Press 'Spawn all', or use command /spawn~n~\
		> Start the match by using command /start [1-20]~n~");
			
		PlayerTextDrawSetString(playerid, TDhelpbar[playerid], tmp);
		PlayerTextDrawShow(playerid, TDhelpbar[playerid]);
	} else {
		PlayerTextDrawHide(playerid, TDhelpbar[playerid]);
	}
}

stock CwHelp(playerid)
{
	if (pData[playerid][pLang] == 1)
	{
		ShowPlayerDialog(playerid, 87, DIALOG_STYLE_MSGBOX, "{FFD700}[CW Help]",
		"{ffffff}How to start a CW/TG:\n\n"\
		"- If needed, change team names:\n"\
		"Press 'Team name', or use command /clantag [oldname][newname]\n"\
		"\n"\
		"- Choose the map:\n"\
		"Press 'Map' to set up a map, or use command /map [id 2-big airport]\n"\
		"\n"\
		"- Switch ON Clan War mode:\n"\
		"Press 'CW mode', or use command /cwmode\n"\
		"\n"\
		"- Switch OFF Killheal:\n"\
		"Press 'Heal after kill', or use command /killheal\n"\
		"\n"\
		"- Clear the total score:\n"\
		"Press 'Reset everything', or use command /resetall\n"\
		"\n"\
		"- Set up the amount of kills in a round:\n"\
		"Press 'Round kills', or use command /roundkills [points]\n"\
		"\n"\
		"- Move all players to spectators:\n"\
		"Press 'Reset teams', or use command /resetteams\n"\
		"\n"\
		"- Move selected players to their teams:\n"\
		"Press 'Move player', or use command /t id [teamname]\n"\
		"\n"\
		"- If needed, switch ON spectate only mode:\n"\
		"Press 'Speconly', or use command /speconly\n"\
		"\n"\
		"- Spawn all players:\n"\
		"Press 'Spawn all', or use command /spawn\n"\
		"\n"\
		"- Start the match by using command /start [1-20]\n"\
		"\n"\
		"- If a pause is needed:\n"\
		"Press 'Pause', or use command /frz\n"\
		"\n"\
		"{FF0000}IMPORTANT! {FFFFFF}After the match is over set all settings back to default by using command /default\n",
		"OK", "");
	} else {
		ShowPlayerDialog(playerid, 87, DIALOG_STYLE_MSGBOX, "{FFD700}[CW Help]",
		"{ffffff}Как запустить КВ/ТКВ:\n\n"\
		"- Если необходимо, смените названия команд:\n"\
		"Нажмите 'Название команды', или используйте команду /clantag [старое название][новое название]\n"\
		"\n"\
		"- Выберите карту:\n"\
		"Нажмите 'Карта', или используйте команду /map [id 2-большое аэро]\n"\
		"\n"\
		"- Включите Clan War режим:\n"\
		"Нажмите 'CW режим', или используйте команду /cwmode\n"\
		"\n"\
		"- Отключите лечение после убийства:\n"\
		"Нажмите 'Лечение после убийства', или используйте команду /killheal\n"\
		"\n"\
		"- Обнулите общий счет:\n"\
		"Нажмите 'Сбросить все', или используйте команду /resetall\n"\
		"\n"\
		"- Установите необходимое кол-во убийств в раунде:\n"\
		"Нажмите 'Кол-во убийств в раунде', или используйте команду /roundkills [кол-во очков]\n"\
		"\n"\
		"- Очистите команды:\n"\
		"Нажмите 'Очистить команды', или используйте команду /resetteams\n"\
		"\n"\
		"- Переместите нужных игроков в команды:\n"\
		"Нажмите 'Переместить игрока', или используйте команду /t id [название команды]\n"\
		"\n"\
		"- Если необходимо, включите принудительный режим наблюдения:\n"\
		"Нажмите 'Принудительное наблюдение', или используйте команду /speconly\n"\
		"\n"\
		"- Заспавнить всех игроков:\n"\
		"Нажмите 'Заспавнить всех', или используйте команду /spawn\n"\
		"\n"\
		"- Начните матч, используя команду /start [1-20]\n"\
		"\n"\
		"- Если нужна пауза:\n"\
		"Нажмите 'Пауза', или используйте команду /frz\n"\
		"\n"\
		"{FF0000}ВАЖНО! {FFFFFF}После окончания матча установите дефолтные настройки раунда, используя команду /default",
		"OK", "");
	}
}

stock WorldsHelp(playerid) // /wcmds
{
	new worldid = GetPlayerVirtualWorld(playerid);
	if(worldid == 0 || WorldModerator[playerid])
	{
		if (pData[playerid][pLang] == 1)
		{
			ShowPlayerDialog(playerid, 289, DIALOG_STYLE_MSGBOX,
			"{FFD700}Worlds help",
			"{FFFFFF}In the virtual world you are isolated from the main world, where {FF0000}CW/TG{FFFFFF} matches are being played.\n\
			In the virtual worlds you can customize the rules and environment to suit your needs.\n\
			The virtual world stats don't count into the main world stats and the rules of the main world don't apply here.\n\
			You can exit the world with the command {FFD700}/leave{FFFFFF} or through the menu {FFD700}/w{FFFFFF}.\n\
			After exiting the world, it's settings will be reset. You can transfer hoster rights via the menu.\n\
			If the hoster is out and there are still players in the world, the hoster's rights will be transferred to the first active moderator.\n\
			{FFD700}Moderator{FFFFFF} has almost all the hoster rights, with the exception of some functions\n\
			Moderators can be granted only by the hoster, the number of moderators is not limited\n\
			\n\
			{FF0000}Forbidden to spoil the game for other players\n\
			Forbidden to use server functions to the detriment of the gameplay\n\
			\n\
			{FFFFFF}Available features for moderators:\n\
			- World settings menu by pressing {FFD700}Y{FFFFFF}\n\
			- Use different modes {FFD700}(Training, DM, PvP, Racing, WoT, Derby, Skill){FFFFFF}\n\
			- Messages for all players of the world via {FFD700}*Text{FFFFFF}\n\
			- Lock the world {FFD700}/lockworld [password] | (/unlockworld){FFFFFF}\n\
			- Change the map {FFD700}/map [mapid]{FFFFFF}\n\
			- Use administrator 1 lvl commands {FFD700}/spawn, /heal, /disarm, etc.{FFFFFF}\n\
			- Spawn vehicles {FFD700}/v [Vehicle ID or Vehicle Name]{FFFFFF}\n\
			- Kick a player {FFD700}/wkick [ID]{FFFFFF} or all {FFD700}/kickall{FFFFFF}\n\
			- Selection of any weapon and control options {FFD700}/weapons{FFFFFF}\n\
			- Teleport menu {FFD700}/tp{FFFFFF} and teleport by marker in {FFD700}ESC{FFFFFF}\n\
			- Create bots for shooting practice {FFD700}Y - bots{FFFFFF}\n\
			- Special features {FFD700}/flymode, /jp, /surfly, /jump{FFFFFF}\n\
			- Flexible camera settings {FFD700}/camset{FFFFFF}\n\
			- Invite a player to the world {FFD700}/invite [ID]{FFFFFF}\n\
			\n",
			" X ", "");
		} else {
			ShowPlayerDialog(playerid, 289, DIALOG_STYLE_MSGBOX,
			"{FFD700}Worlds help",
			"{FFFFFF}В виртуальном мире Вы изолированы от основного мира, где проводятся {FF0000}CW/TG{FFFFFF} матчи.\n\
			Вы можете настраивать правила виртуального мира под ваши потребности.\n\
			В мирах не засчитывается статистика в общие показатели и не действуют правила основного мира.\n\
			Выйти из мира можно командой {FFD700}/leave{FFFFFF} либо через меню {FFD700}/w{FFFFFF}.\n\
			Поcле выхода из мира его настройки будут обнулены. Вы можете передать права хостера через меню.\n\
			Если хостер вышел, а в мире еще есть игроки, то права хостера будут переданы первому активному модератору.\n\
			{FFD700}Модератор{FFFFFF} имеет практически все права хостера, за исключением некоторых функций\n\
			Модераторов может назначать только хостер, количество модераторов в мире не ограничено\n\
			\n\
			{FF0000}Запрещено портить игру другим игрокам\n\
			Запрещено использовать функции сервера во вред игрового процесса\n\
			\n\
			{FFFFFF}Доступные для модераторов возможности:\n\
			- Меню настроек мира на клавишу {FFD700}Y{FFFFFF}\n\
			- Использовать различные режимы {FFD700}(Training, DM, PvP, Racing, WoT, Derby){FFFFFF}\n\
			- Сообщения для всех игроков мира через {FFD700}*Текст{FFFFFF}\n\
			- Закрыть мир на пароль {FFD700}/lockworld [пароль] | (/unlockworld){FFFFFF}\n\
			- Сменить карту {FFD700}/map [mapid]{FFFFFF}\n\
			- Использовать команды администратора 1-го уровня {FFD700}/spawn, /heal, /disarm и.т.д.{FFFFFF}\n\
			- Спавн и управление транспортом {FFD700}/v [Vehicle ID or Vehicle Name]{FFFFFF}\n\
			- Кикнуть игрока {FFD700}/wkick [ID]{FFFFFF} или всех {FFD700}/kickall{FFFFFF}\n\
			- Выбор любого оружия и опции управления {FFD700}/weapons{FFFFFF}\n\
			- Меню телепортов {FFD700}/tp{FFFFFF} и телепорт по метке в {FFD700}ESC{FFFFFF}\n\
			- Создавать ботов и актеров для тренировки стрельбы {FFD700}/bots, /actors{FFFFFF}\n\
			- Специальные возможности {FFD700}/flymode, /jp, /surfly, /jump{FFFFFF}\n\
			- Гибкие настройки камеры {FFD700}/camset{FFFFFF}\n\
			- Пригласить игрока в мир {FFD700}/invite [ID]{FFFFFF}\n\
			\n",
			" X ", "");
		}
	} else {
		new tbtext[512];
		new players = GetPlayersInWorld(worldid);
		new vehicles = 0;
		
		for(new i = GetVehiclePoolSize() +1; --i != 0;)
		{
			if(GetVehicleVirtualWorld(i) == worldid) vehicles++;
		}
		
		new moderators[256], tmpstr[32];
		foreach(Player, i)
		{
			if(WorldModerator[i])
			{
				format(tmpstr, sizeof(tmpstr), " %s ", PlayerName(i));
				strcat(moderators, tmpstr);
			}
		}
		
		if(pData[playerid][pLang])
		{
			format(tbtext, sizeof(tbtext),
			"{FFD700}%s{FFFFFF}\n\
			- View current world settings {FFD700}/winfo{FFFFFF}.\n\
			- View help on virtual worlds {FFD700}/whelp{FFFFFF}.\n\
			- You can exit the world with the command {FFD700}/leave{FFFFFF}.\n\
			\n\
			{FF0000}- Forbidden to spoil the game for other players\n\
			- Forbidden to use server functions to the detriment of the gameplay\n\
			\n\
			{FFFFFF}World moderators:{FFD700}%s{FFFFFF}\n\
			Players in world: %d\n",
			WorldModes[World[worldid][wGamemode]], moderators, players);
		} else {
			format(tbtext, sizeof(tbtext),
			"{FFD700}%s{FFFFFF}\n\
			- Посмотреть текущие настройки мира {FFD700}/winfo{FFFFFF}.\n\
			- Посмотреть помощь по виртуальным мирам {FFD700}/whelp{FFFFFF}.\n\
			- Выйти из мира можно командой {FFD700}/leave{FFFFFF}.\n\
			\n\
			{FF0000}- Запрещено портить игру другим игрокам\n\
			- Запрещено использовать функции сервера во вред игрового процесса\n\
			\n\
			{FFFFFF}Модераторы:{FFD700}%s{FFFFFF}\n\
			Игроков в мире: %d\n",
			WorldModes[World[worldid][wGamemode]], moderators, players);
		}
		ShowPlayerDialog(playerid, 289, DIALOG_STYLE_MSGBOX,
		"{FFD700}Worlds help", tbtext, " X ", "");
	}
}

stock AdminHelp(playerid) // /banhelp
{
	if (pData[playerid][pLang] == 1)
	{
		if(GetPVarInt(playerid, "Admin") < 3)
		{
			ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX,
			"{FFD700}Admin help [LVL 2]",
			"{FFFFFF}The full list of admin commands can be found in {FF3333}/help{FFFFFF}\n\
			\n\
			{FF3333}[Punishments]{FFFFFF}\n\
			- Slap or kick player's ass {FF3333}/slap [ID] and /punch [ID]{FFFFFF}\n\
			- Freeze a player {FF3333}/frz [ID]{FFFFFF}\n\
			- Take away weapons from a player{FF3333}/disarm [ID]{FFFFFF}\n\
			- Kick a player {FF3333}/kick [ID] <reason> {FFFFFF}\n\
			- Mute a player by IP {FF3333}/mute [ID] <time>{FFFFFF} where the time is specified in seconds\n\
			- Forbid the use of commands {FF3333}/lockcmds [ID]{FFFFFF}\n\
			\n{FF3333}[BAN]{FFFFFF}\n\
			Level 2 administrators can't ban players, but they can kick a player by using {FF3333}/kick [ID] <reason> {FFFFFF}\n\
			\n\
			In case of abusing the admin commands or incorrect issuance of punishments\n\
			{FF0000}admin rights will be removed.{FFFFFF}\n\
			",
			"OK", "");
		} else {
			ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX,
			"{FFD700}Admin help [LVL 3+]",
			"{FFFFFF}The full list of admin commands can be found in {FF3333}/help{FFFFFF}\n\
			\n\
			{FF3333}[BAN]{FFFFFF}\n\
			- The easiest way to ban a player by IP {FF3333}/ban [ID] <reason>{FFFFFF}\n\
			- The recommended and most effective way to ban a player by hardware {FF3333}/hwban [ID] <reason>{FFFFFF}\n\
			- If the player is offline, then use {FF3333}/offban [Nickname] <reason>{FFFFFF}\n\
			- You can unban a player by using {00FF00}/unban{FFFFFF} even if this player is offline\n\
			- Unban the IP or subnet of the player {00FF00}/unbanip{FFFFFF}\n\
			- View the list of banned players {00FF00}/banlist{FFFFFF}\n\
			\n{FF3333}[Punishments]{FFFFFF}\n\
			- Slap or kick player's ass {FF3333}/slap [ID] and /punch [ID]{FFFFFF}\n\
			- Freeze a player {FF3333}/frz [ID]{FFFFFF}\n\
			- Take away weapons from a player{FF3333}/disarm [ID]{FFFFFF}\n\
			- Kick a player {FF3333}/kick [ID] <reason> {FFFFFF}\n\
			- Forbid the use of commands {FF3333}/lockcmds [ID]{FFFFFF}\n\
			- Mute a player by IP {FF3333}/mute [ID] <time>{FFFFFF} where the time is specified in seconds\n\
			- Mute a player by hardware {FF3333}/hwmute [ID] <time>{FFFFFF} where the time is specified in seconds\n\
			- Force a player to play with anti-cheat (by hardware) {FF3333}/forceac{FFFFFF}\n\
			- Kick all players without anti-cheat {FF3333}/kickac{FFFFFF}\n\
			\n\
			More information for decision making can be obtained through {FF3333}/logs{FFFFFF}\n\
