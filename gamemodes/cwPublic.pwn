stock ADMINS_ONLINE(playerid)
{
	new tbtext[750], string[64], counter = 0;
	
	for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
		if (IsPlayerConnected(i))
		{
			new name[MAX_PLAYER_NAME];
			GetPlayerName(playerid,name,sizeof(name));
			if (GetPVarInt(i, "Admin") > 0 && GetPVarInt(i, "Invis") == 0 
			&& strcmp(name, "1NS", true))
			{
				if(GetPVarInt(i, "tmpAdmin") < 1)
				{
					format(string, sizeof string, "{FFFFFF}%s[%d] - {FF0000}(%i)lvl{FFFFFF}\n",
					PlayerName(i), i, GetPVarInt(i, "Admin"));
					strcat(tbtext, string);
					counter++;
				}
			}
			if (GetPVarInt(i, "Fakeadmin") > 0)
			{
				format(string, sizeof string, "{FFFFFF}%s[%d] - {FF0000}(%i)lvl{FFFFFF}\n",
				PlayerName(i), i, GetPVarInt(i, "Fakeadmin"));
				strcat(tbtext, string);
				counter++;
			}
		}
	}
	
	if(counter == 0) {
		SendClientMessageEx(playerid, COLOR_GREY,
		"В данный момент на сервере нет администраторов", "No admins online");
	}
	else ShowPlayerDialog(playerid, 18, DIALOG_STYLE_MSGBOX, "Admins online", tbtext, "Ok", "");
	return true;
}

stock GeoIpTable(playerid, targerplayerid)
{
	/*
	Get geolocation and internet provider (ISP) info 
	used in /stalk <ID> command
	returns a table with data
	*/
	
	new ip[16], header[64], tbtext[512];
	new stringru[128], stringen[128];

	if(IsPlayerConnected(targerplayerid))
	{
		GetPlayerIp(targerplayerid, ip, sizeof(ip));
		if(strcmp(ip, "127.0.0.1", true) == 0)
		{
			//SendClientMessageEx(playerid, COLOR_GREY,
			//"На локалхосте данные не отображаются полностью",
			//"On localhost, the data is not displayed completely");
			
			SendClientMessageEx(playerid, COLOR_GREY,
			"На локалхосте вы видите результат вывода для DNS Google",
			"On localhost you see result for Google DNS request");
		}
		
		if(PlayerGeoIPInfo[targerplayerid][pSource] == 1)
		{
			format(header, sizeof(header), "Stalk");
		}
		else if (PlayerGeoIPInfo[targerplayerid][pSource] == 2)
		{
			format(header, sizeof(header), "Stalk [Localbase]");
		} else {
			format(header, sizeof(header), "Stalk");
		}
		if(strcmp(ip, "127.0.0.1", true) == 0)
		{
			format(header, sizeof(header), "Stalk [DNS test]");
		}
		
		if (pData[playerid][pLang] == 0)
		{
			format(tbtext, sizeof(tbtext), 
			"{FFFFFF}Игрок: {FFD700}%s(%d)\n"\
			"{FFFFFF}Континент: {FFD700}%s\n"\
			"{FFFFFF}Страна: {FFD700}%s\n"\
			"{FFFFFF}Регион: {FFD700}%s\n"\
			"{FFFFFF}Город: {FFD700}%s\n"\
			"{FFFFFF}Провайдер: {FFD700}%s\n"\
			"{FFFFFF}Прокси: {FFD700}%s",
			PlayerName(targerplayerid), targerplayerid,
			PlayerGeoIPInfo[targerplayerid][pContinent],
			PlayerGeoIPInfo[targerplayerid][pCountry],
			PlayerGeoIPInfo[targerplayerid][pRegion],
			PlayerGeoIPInfo[targerplayerid][pCity],
			PlayerGeoIPInfo[targerplayerid][pIsp],
			PlayerGeoIPInfo[targerplayerid][pProxy]);
		} else {
			format(tbtext, sizeof(tbtext), 
			"{FFFFFF}Player: {FFD700}%s(%d)\n"\
			"{FFFFFF}Continent: {FFD700}%s\n"\
			"{FFFFFF}Country: {FFD700}%s\n"\
			"{FFFFFF}Region: {FFD700}%s\n"\
			"{FFFFFF}City: {FFD700}%s\n"\
			"{FFFFFF}Provider: {FFD700}%s\n"\
			"{FFFFFF}Proxy: {FFD700}%s",
			PlayerName(targerplayerid), targerplayerid,
			PlayerGeoIPInfo[targerplayerid][pContinent],
			PlayerGeoIPInfo[targerplayerid][pCountry],
			PlayerGeoIPInfo[targerplayerid][pRegion],
			PlayerGeoIPInfo[targerplayerid][pCity],
			PlayerGeoIPInfo[targerplayerid][pIsp],
			PlayerGeoIPInfo[targerplayerid][pProxy]);
		}
		
		format(stringru, sizeof(stringru), "%s(%d) пробил по IP игрока %s(%d).",
		PlayerName(playerid), playerid, PlayerName(targerplayerid), targerplayerid);
		format(stringen, sizeof(stringen), "%s(%d) is stalking player %s(%d).",
		PlayerName(playerid), playerid, PlayerName(targerplayerid), targerplayerid);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
	} else { 
		SendClientMessageEx(playerid, COLOR_GREY,
		"Игрок не подключен либо вышел.", "This player isn't connected.");
	}
	
	ShowPlayerDialog(playerid, 78, DIALOG_STYLE_MSGBOX, header, tbtext, "Ok", "");
}

stock DopInfo(playerid, targerplayerid)
{
	/* 	extended player spawn information	*/
	if (GetPVarInt(playerid, "Admin") >= 2)
	{
		if(IsPlayerConnected(targerplayerid))
		{
			new tbtext[1024], header[64], string[128];
			new Float:px, Float:py, Float:pz;
			
			#if defined _YSF_included
			new teamid, modelid, Float:fX, Float:fY, Float:fZ,
			Float:fAngle, weapon[3], weapon_ammo[3], Float:fBounds[4];
			
			GetSpawnInfo(targerplayerid, teamid, modelid, fX, fY, fZ, fAngle,
			weapon[0], weapon_ammo[0],weapon[1], weapon_ammo[1],
			weapon[2], weapon_ammo[2]);
			GetPlayerWorldBounds(targerplayerid, fBounds[0], fBounds[1], fBounds[2], fBounds[3]);
			
			if(!IsPlayerNPC(targerplayerid))
			{
				format(header, sizeof(header),
				"Check player %s(%d)", PlayerName(targerplayerid), targerplayerid);
			} else {
				format(header, sizeof(header),
				"Check NPC %s(%d)", PlayerName(targerplayerid), targerplayerid);
			}
		
			new newstate[36];
			switch(GetPlayerState(targerplayerid))
			{
				case 0: format(newstate, sizeof(newstate), "NONE");
				case 1:	format(newstate, sizeof(newstate), "ONFOOT");
				case 2:	format(newstate, sizeof(newstate), "DRIVER");
				case 3:	format(newstate, sizeof(newstate), "PASSENGER");
				case 4:	format(newstate, sizeof(newstate), "EXIT_VEHICLE");
				case 5:	format(newstate, sizeof(newstate), "ENTER_VEHICLE_DRIVER");
				case 6:	format(newstate, sizeof(newstate), "ENTER_VEHICLE_PASSENGER");	
				case 7:	format(newstate, sizeof(newstate), "WASTED");
				case 8:	format(newstate, sizeof(newstate), "SPAWNED");
				case 9:	format(newstate, sizeof(newstate), "SPECTATING");
				default: format(newstate, sizeof(newstate), "NONE");
			}
			
			#if defined _YSF_included
				format(string, sizeof(string),
				"State: %s (%s)\n", 
				newstate, CONNECT_MODE[NetStats_ConnectionStatus(targerplayerid)]);
				strcat(tbtext, string);
			#else
				format(string, sizeof(string), "State: %s \n", newstate);
				strcat(tbtext, string);
			#endif
			
			format(string, sizeof(string),
			"W:%d I:%d %s %s %s %s %s\n",
			GetPlayerVirtualWorld(targerplayerid), GetPlayerInterior(targerplayerid),
			//(!WC_IsPlayerSpawned(targerplayerid)) ? "~r~NotSpawned" : " ",
			//(!IsPlayerSpawned(targerplayerid)) ? "~r~NotSpawned" : "",
			(IsPlayerAFK(targerplayerid)) ? "AFK" : "",
			(GetPVarInt(targerplayerid, "FlyMode")) ? "Flymode" : "",
			(GetPVarInt(targerplayerid, "Specing") != -1) ? "Specing" : "",
			(GetPVarInt(targerplayerid, "frz")) ? "Freezed" : "",
			(GetPVarInt(targerplayerid, "Removed")) ? "Hidden" : "");
			strcat(tbtext, string);
				
			format(string, sizeof(string),
			"Teamid: %d(%d), Skinid: %d\n",
			teamid, GetPVarInt(targerplayerid, "Team"), modelid);
			strcat(tbtext, string);
			
			format(string, sizeof(string),
			"Spawn position: %.3f, %.3f, %.3f, %.3f\n",
			fX, fY, fZ, fAngle);
			strcat(tbtext, string);
			
			new Float:x, Float:y, Float:z;
			if(GetPlayerState(targerplayerid) != PLAYER_STATE_SPECTATING)
			{
				#if defined _nex_ac_included					
					AntiCheatGetPos(targerplayerid, x,y,z);
					format(string, sizeof(string),
					"Player pos x: %.3f y: %.3f z: %.3f\n", x,y,z);
					strcat(tbtext, string);
				#else
					GetPlayerPos(targerplayerid, x,y,z);
					format(string, sizeof(string),
					"Player pos x: %.3f y: %.3f z: %.3f\n", x,y,z);
					strcat(tbtext, string);
				#endif
			} else {
				GetPlayerCameraPos(targerplayerid, x, y, z);
				format(string, sizeof(string),
				"Cam position x: %.3f y: %.3f z: %.3f\n", x,y,z);
				strcat(tbtext, string);
			}
			#if defined _YSF_included
				new Float:qw, Float:qx, Float:qy, Float:qz;
				GetPlayerRotationQuat(targerplayerid, qw, qx, qy, qz);
				format(string, sizeof(string),
				"Quaternion qw: %.3f, qx: %.3f, qy: %.3f, qz: %.3f\n", qw, qx, qy, qz);
				strcat(tbtext, string);
				
				new Float:fOffsetX, Float:fOffsetY, Float:fOffsetZ;
				GetPlayerSurfingOffsets(targerplayerid, fOffsetX, fOffsetY, fOffsetZ);
				format(string, sizeof(string),
				"SurfingOffsets x: %.3f y: %.3f z: %.3f\n",
				fOffsetX, fOffsetY, fOffsetZ);
				strcat(tbtext, string);
			#endif
			
			format(string, sizeof(string),
			"Worldbounds: %.2f, %.2f, %.2f, %.2f\n",
			fBounds[0], fBounds[1], fBounds[2], fBounds[3]);
			
			new weaponid = GetPlayerWeapon(targerplayerid);
			new weapstate[20];
			switch(GetPlayerWeaponState(targerplayerid))
			{
				case -1: weapstate = "not in hands";
				case 0: weapstate = "no bullets";
				case 1: weapstate = "last bullet";
				case 2: weapstate = "have bullets";
				case 3: weapstate = "reload";
			}
				
			format(string, sizeof(string), "Weapon: %s (%d) slot: %d ammo: %d %s\n",
			WeaponNamesEN[weaponid], weaponid, GetWeaponSlot(weaponid),
			GetPlayerAmmo(targerplayerid), weapstate);
			strcat(tbtext, string);
			
			new shootrate_str[24];
			if(LastShotTime[targerplayerid] < 1000) {
				format(shootrate_str, sizeof(shootrate_str), "rate %d ms",
				LastShotTime[targerplayerid]);
			} else {
				format(shootrate_str, sizeof(shootrate_str), " ");
			}
				
			if(Stats[targerplayerid][pShots] && Stats[targerplayerid][pShots] != 0)
			{
				new Float:shotsper = floatdiv(Stats[targerplayerid][pShots],Stats[targerplayerid][pHits]);
				format(string, sizeof(string),
				"Shots %i hits %i shot/hits ratio %.2f %s\n", 
				Stats[targerplayerid][pShots], Stats[targerplayerid][pHits], shotsper, shootrate_str);
				strcat(tbtext, string);
			} else {
				format(string, sizeof(string),
				"Shots %i hits %i shot/hits ratio %.2f %s\n",
				Stats[targerplayerid][pShots], Stats[targerplayerid][pHits], 0.0, shootrate_str);
				strcat(tbtext, string);
			}
				
			/*format(string, sizeof(string),
			"Weapon1: %d:%d, Weapon2: %d:%d, Weapon3: %d:%d\n",
			weapon[0], weapon_ammo[0], weapon[1], weapon_ammo[1],
			weapon[2], weapon_ammo[2]);
			strcat(tbtext, string);*/
			
			format(string, sizeof(string),
			"Widescreen: %d, Aspect ratio: %.1f\n",
			IsPlayerWidescreenToggled(targerplayerid), GetPlayerCameraAspectRatio(targerplayerid));
			strcat(tbtext, string);
			
			format(string, sizeof(string),
			"Removed buildings: %d\n", GetPlayerBuildingsRemoved(targerplayerid));
			strcat(tbtext, string);
			#endif
			
			/*#if defined _sampcac_included
			if(CAC_GetStatus(targerplayerid) > 0)
			{
				format(string, sizeof(string),
				"Default GTA FPS Unlocker: %d\n", GetPVarInt(targerplayerid, "DefaultFPSLimiterON"));
				strcat(tbtext, string);
			}
			#endif*/
			
			#if defined _nex_ac_included
			new Float:health, Float:armour;
			AntiCheatGetHealth(targerplayerid, health);
			AntiCheatGetArmour(targerplayerid, armour);
			format(string, sizeof(string), "AC health: %.1f, AC armour: %.1f\n", health, armour);
			strcat(tbtext, string);
			
			AntiCheatGetSpawnPos(targerplayerid, px, py, pz);
			format(string, sizeof(string), "Spawn Pos: %.3f, %.3f, %.3f\n", px, py, pz);
			strcat(tbtext, string);
			
			AntiCheatGetPos(targerplayerid, px, py, pz);
			format(string, sizeof(string), "Player Pos: %.3f, %.3f, %.3f\n", px, py, pz);
			strcat(tbtext, string);
			#else
			GetPlayerPos(targerplayerid, px, py, pz);
			format(string, sizeof(string), "Player Pos: %.3f, %.3f, %.3f\n", px, py, pz);
			strcat(tbtext, string);
			#endif
			
			format(string, sizeof(string), "Played: %d min, Cookies: %d\n",
			NetStats_GetConnectedTime(targerplayerid)/60000, pData[targerplayerid][pCookies]);
			strcat(tbtext, string);
			
			format(string, sizeof(string),
			"Anim index %d, Player Speed %d, Traffic Mps %d\n", 
			GetPlayerAnimationIndex(targerplayerid), GetPlayerSpeed(targerplayerid),
			NetStats_MessagesRecvPerSecond(targerplayerid));
			strcat(tbtext, string);
			
			// https://sampwiki.blast.hk/wiki/CameraModes
			new cammode[48];
			switch(GetPlayerCameraMode(targerplayerid))
			{
				case 3: cammode = "Train/tram camera";
				case 4: cammode = "Cam follow ped";
				case 7: cammode = "Sniper aiming";
				case 8: cammode = "Rocket Launcher aiming";
				case 15: cammode = "Fixed camera";
				case 16: cammode = "Vehicle front or side cam";
				case 18: cammode = "Normal vehicle cam";
				case 22: cammode = "Normal boat camera";
				case 46: cammode = "Camera weapon aiming";
				case 51: cammode = "Heat-seeking R.Launcher aiming";
				case 53: cammode = "Aiming any other weapon";
				case 55: cammode = "Vehicle passenger drive-by";
				case 56: cammode = "Helicopter/bird view";
				case 57: cammode = "Ground cam, zooms in very quickly";
				case 58: cammode = "Horizontal flyby past vehicle";
				case 59: cammode = "Airveh looking up ground camera";
				case 62: cammode = "Airveh vertical flyby past airveh";
				case 63: cammode = "Airveh horizontal flyby past airveh";
				case 64: cammode = "Airveh camera focused on pilot";
			}

			format(string, sizeof(string),"Cameramode: %s\n",cammode);
			strcat(tbtext, string);
			
			#if defined _nex_ac_included
				format(string, sizeof(string), "LastSpecialActionID: %d\n",
				AntiCheatGetLastSpecialAction(targerplayerid));
				strcat(tbtext, string);
				
				#if defined _YSF_included
					format(string, sizeof(string), "LastDialogID: %d\n",
					GetPlayerDialogID(targerplayerid));
					strcat(tbtext, string);
				#endif
				
				new pwarn;
				for(new code = 0; code != 52; code++)
				{
					if(NEXAC_DETECT_COUNTERS[targerplayerid][code] != 0)
					{
						pwarn = pwarn + NEXAC_DETECT_COUNTERS[targerplayerid][code];
					}
				}
				format(string, sizeof(string), "NEXAC warnings: %i\n", pwarn);
				strcat(tbtext, string);
			#endif
			
			if(strlen(tbtext) > 1)
			{
				ShowPlayerDialog(playerid, 222, DIALOG_STYLE_MSGBOX,
				header, tbtext, "Refresh", "");
			}
		} else { 
			SendClientMessageEx(playerid, COLOR_GREY,
			"Игрок не подключен либо вышел.", "This player isn't connected.");
		}
	}
}

stock UpdateteamtabTable()
{
	/* Update team textdraw. Display AC state, FPS, Ping and PL. */
	new Team0data[256], Team1data[256];// Team2data[256];
	new Team0dataStats[512], Team1dataStats[512];
	new string[64];
	foreach(Player, i)
	{
		if(GetPlayerVirtualWorld(i) == 0)
		{
			new SampcacState[18];
			#if defined _sampcac_included
				new major, minor, patch;
				CAC_GetClientVersion(i, major, minor, patch);
				if(CAC_GetStatus(i) > 0 && minor == 10) SampcacState = "~h~~b~ON";
				else SampcacState= "~r~OFF";
			#else
				SampcacState = "";
			#endif
				
			switch(GetPVarInt(i, "Team"))
			{
				case 0:	
				{
					format(string, sizeof string,
					"%s(%d) %s~n~",
					TDC[0], i, PlayerName(i));
					strcat(Team0data, string);

					format(string, sizeof string,
					"~w~AC:%s ~w~FPS:%.0f Ping:%i PL:%.2f%%~n~",
					SampcacState, floatabs(GetPVarInt(i, "fps")), 
					GetPlayerPing(i), NetStats_PacketLossPercent(i));
					strcat(Team0dataStats, string);
				}
				case 1: 
				{
					format(string, sizeof string,
					"%s(%d) %s~n~",
					TDC[1], i, PlayerName(i));
					strcat(Team1data, string);

					format(string, sizeof string,
					"~w~AC:%s ~w~FPS:%.0f Ping:%i PL:%.2f%%~n~",
					SampcacState, floatabs(GetPVarInt(i, "fps")),
					GetPlayerPing(i), NetStats_PacketLossPercent(i));
					strcat(Team1dataStats, string);
				}
				/*case 2: 
				{
					format(string, sizeof string,
					"%s(%d) ",
					PlayerName(i),i);
					strcat(Team2data, string);
				}*/
			}
		}
	}
	/*format(teamtdtext, sizeof(teamtdtext), "%sSpectators~n~%s~n~",
	TDC[2],Team2data);*/
	format(teamtdtext1, sizeof(teamtdtext1), "%s%s~n~%s~n~%s%s~n~%s~n~",
	TDC[0],ClanName[0],Team0data, TDC[1], ClanName[1], Team1data);
	format(teamtdtext2, sizeof(teamtdtext2), "~n~%s~n~~n~%s~n~",
	Team0dataStats, Team1dataStats);
	//foreach(Player, i) PlayerTextDrawSetString(i, TDteamtab1[i],teamtdtext);
}	

// KickWithDelay only used only for timer. 
// Note: Use KickPlayerEx("reason") instead of the standard function
forward KickWithDelay(playerid);
public KickWithDelay(playerid) {
	#if defined _nex_ac_included
		if(Kicked[playerid]) AntiCheatKickWithDesync(playerid, 52);
	#else
		if(Kicked[playerid]) Kick(playerid);
	#endif
}

stock GetPlayerShootData(playerid, silentmode = true)
{
	// this function is called before the player's kick
	// to record the latest data on the player's shooting
	new 
		tmpstr[128],
		Float:fHitPosX, Float: fHitPosY, Float: fHitPosZ,
		Float:poX, Float:poY, Float:poZ,
		Float:rangedistance, Float:fOriginX, Float:fOriginY, Float:fOriginZ,
		Float:dist
	;
	
	GetPlayerPos(playerid,poX,poY,poZ);
	dist = GetPlayerDistanceFromPoint(GetPVarInt(playerid, "hitid"), poX, poY, poZ);
	GetPlayerLastShotVectors(playerid, fOriginX, fOriginY, fOriginZ, fHitPosX, fHitPosY, fHitPosZ);
	rangedistance = VectorSize(fOriginX-fHitPosX, fOriginY-fHitPosY, fOriginZ-fHitPosZ);
	
	format(tmpstr, sizeof(tmpstr), "Player %s(%d) Last shot information:",
	PlayerName(playerid), playerid);
	if(silentmode) print(tmpstr);
	
	format(tmpstr, sizeof(tmpstr), "Initial: %f, %f, %f. Shot position: %f, %f, %f",
	fOriginX, fOriginY, fOriginZ, fHitPosX, fHitPosY, fHitPosZ);
	if(!silentmode) SendSystemMessage(tmpstr);
	print(tmpstr);
	
	format(tmpstr, sizeof(tmpstr), "Distance to hitid: %f Shot distance: %f",
	dist, rangedistance);
	if(!silentmode) SendSystemMessage(tmpstr);
	print(tmpstr);
	
	format(tmpstr, sizeof(tmpstr), "bodypart: %i amount: %f",
	Stats[playerid][pBodypart],Stats[playerid][pAmount]);
	if(!silentmode) SendSystemMessage(tmpstr);
	print(tmpstr);
	
	if(Stats[playerid][pShots] && Stats[playerid][pShots] != 0)
	{
		new Float:shotsper = floatdiv(Stats[playerid][pShots], Stats[playerid][pHits]);
		format(tmpstr, sizeof(tmpstr), "Ratio (shots/hits) %.2f", shotsper);
		if(!silentmode) SendSystemMessage(tmpstr);
		print(tmpstr);
	}
}

stock BanPlayerEx(playerid, const reason[], banmode = 0)
{
	/*
		reason - ban reason write to chat and admlog
		banmode - ban mode (ipban, hwban, etc)
		nolog - no adm log messages (silent ban)
	*/
	new message[128],messageru[128], banmodestr[10];
	new ip[16], serial[41];
	new year, month, day, date[20]; 
	getdate(year, month, day); 
	format(date, sizeof(date), "%d.%d.%d", year, month, day);
	gpci(playerid,serial,40);
	GetPlayerIp(playerid, ip, sizeof ip);
	/*
	country[64];
	#if defined _geolocation_included
		GetPlayerCountry(playerid, country, sizeof(country));
	#else
		format(country, sizeof country, "none");
	#endif
	*/
	new name[MAX_PLAYER_NAME];
	GetPlayerName(playerid,name,sizeof(name));
	
	//#if defined _sampcac_included
		//new hwid[CAC__MAX_HARDWARE_ID];
	//#endif
	
	switch(banmode)
	{
		case 0:	format(banmodestr, sizeof(banmodestr), "%s", "ban");
		case 1:	format(banmodestr, sizeof(banmodestr), "%s", "sban");
		case 2:	format(banmodestr, sizeof(banmodestr), "%s", "ipban");
		case 3:	format(banmodestr, sizeof(banmodestr), "%s", "rban");
		case 4:	format(banmodestr, sizeof(banmodestr), "%s", "hwban");
	}
	
	if (pData[playerid][pLang] == 1) {
		format(message, sizeof(message), "You were banned. Reason: %s", reason);
		if(!Kicked[playerid]) SendClientMessage(playerid, COLOR_RED, message);
	} else {
		format(messageru, sizeof(messageru), "Вы были забанены. Причина: %s", reason);
		if(!Kicked[playerid]) SendClientMessage(playerid, COLOR_RED, messageru);
	}
	
	if(banmode != 1) // if no silent ban
	{
		format(messageru, sizeof(messageru), "%s(%d) был забанен (%s). Причина: %s",
		PlayerName(playerid), playerid, banmodestr, reason);
		format(message, sizeof(message), "%s(%d) was banned (%s). Reason: %s",
		PlayerName(playerid), playerid, banmodestr, reason);
		printf("%s(%d) was banned (%s). Reason: %s", 
		PlayerName(playerid), playerid, banmodestr, reason);
		foreach(Player, i) 
		{
			if(i != playerid) SendClientMessageEx(i, COLOR_RED, messageru, message);
		}
	}
	
	new szQuery[256];
	format(szQuery, sizeof(szQuery),
	"UPDATE Accounts SET Banned = 1 WHERE (Nickname = '%q')",
	db_escape(PlayerName(playerid)));
	db_query(dbaccounts, szQuery);
	
	if(!Kicked[playerid])
	{
		format(szQuery, sizeof(szQuery),
		"INSERT INTO Banlist (Nickname, Serial, IpBan, IP, Date, Reason) \
		VALUES('%s','%s',%i,'%s','%s','%s')",
		PlayerName(playerid), serial, 1, ip, date, db_escape(reason));
		db_query(dbcore, szQuery);
		
		format(szQuery, sizeof(szQuery),
		"INSERT INTO Kicklog (Nickname, Date, IP, Reason) \
		VALUES ('%q', '%s', '%q', '%q')",
		name, date, ip, reason);
		db_query(dblogs, szQuery);
	}
	
	// Kick after delay
	ForceDesynced[playerid] = 1;
	BanEx(playerid, reason);
	if(!Kicked[playerid])
	{
		SetTimerEx("KickWithDelay", 1000, false, "d", playerid);
		Kicked[playerid] = true;
	}
	return true;
}

stock KickPlayerEx(playerid, const reason[], bool:silentmode = false)
{
	/*
		options:
		reason - kick reason write to chat and admlog
		silentmode - no messages in chat only log
	*/
	new message[128],messageru[128];
	new ip[16], serial[41];
	gpci(playerid,serial,40);
	GetPlayerIp(playerid, ip, sizeof ip);
	/*
	country[64];
	#if defined _geolocation_included
		GetPlayerCountry(playerid, country, sizeof(country));
	#else
		format(country, sizeof country, "none");
	#endif
	*/
	new name[MAX_PLAYER_NAME];
	GetPlayerName(playerid,name,sizeof(name));

	//#if defined _sampcac_included
		//new hwid[CAC__MAX_HARDWARE_ID];
	//#endif
	if(!silentmode)
	{
		if (pData[playerid][pLang] == 1) {
			format(message, sizeof(message), "You were kicked. Reason: %s", reason);
			if(!Kicked[playerid]) SendClientMessage(playerid, COLOR_RED, message);
		} else {
			format(messageru, sizeof(messageru), "Вы были кикнуты. Причина: %s", reason);
			if(!Kicked[playerid]) SendClientMessage(playerid, COLOR_RED, messageru);
		}
		format(messageru, sizeof(messageru), "%s(%d) был кикнут. Причина: %s",
		PlayerName(playerid), playerid, reason);
		format(message, sizeof(message), "%s(%d) was kicked. Reason: %s",
		PlayerName(playerid), playerid, reason);
		printf("%s(%d) was kicked. Reason: %s", PlayerName(playerid), playerid, reason);
		foreach(Player, i) 
		{
			if(i != playerid) SendClientMessageEx(i, COLOR_RED, messageru, message);
		}
	}
	
	// need for tests ac system
	if(GetPVarInt(playerid, "Acoff")) return true;
	
	// write log
	if(!Kicked[playerid])
	{
		new year, month, day, hour, minute, datetime[20];
		getdate(year, month, day); gettime(hour, minute, _);
		format(datetime, sizeof(datetime), "%d.%d.%d %d:%02d", year, month, day, hour, minute);

		new szQuery[256];
		format(szQuery, sizeof(szQuery),
		"INSERT INTO Kicklog (Nickname, Date, IP, Reason) \
		VALUES ('%q', '%s', '%q', '%q')",
		name, datetime, ip, reason);
		db_query(dblogs, szQuery);
	}
	
	// Kick after delay
	ForceDesynced[playerid] = 1;
	if(!Kicked[playerid])
	{
		SetTimerEx("KickWithDelay", 1000, false, "d", playerid);
		Kicked[playerid] = true;
	}
	return true;
}

stock ShowKickedPlayers(playerid)
{
	/* Returns the dialog with a list of last kicked players */
	
	if(!fexist("logs.db"))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Нет логов для отображения", "No logs to display");
		return 0;
	}
	
	new nickname[24], ip[16], reason[64], datetime[16], tmpstr[128];
	
	new szQuery[256], DBResult: query;
	format(szQuery, sizeof(szQuery),
	"SELECT Nickname, Date, IP, Reason FROM Kicklog \
	ORDER BY rowid DESC LIMIT 50");
	query =  db_query(dblogs, szQuery);
	new rows = db_num_rows(query);
	for(new i; i < rows; i++)
	{
		db_get_field(query, 0, nickname, sizeof(nickname));
		format(nickname, sizeof(nickname), "%s", nickname);
		
		db_get_field(query, 1, datetime, sizeof(datetime));
		format(datetime, sizeof(datetime), "%s", datetime);
		
		db_get_field(query, 2, ip, sizeof(ip));
		format(ip, sizeof(ip), "%s", ip);
		
		db_get_field(query, 3, reason, sizeof(reason));
		format(reason, sizeof(reason), "%s", reason);
		
		format(tmpstr, 128, "%s %s {AFAFAF}(%s){FFFFFF} reason {FF0000}%s",
		datetime, nickname, ip, reason);
		SendClientMessage(playerid, -1, tmpstr);
		
		db_next_row(query);
	}
	db_free_result(query);
	
	if(rows < 1)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Нет результатов для отображения", "No results to display");
	} else {
		format(tmpstr, 128, "Show %i results", rows);
		SendClientMessage(playerid, -1, tmpstr);
	}
	
	return 1;
}

