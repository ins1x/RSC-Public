	if(dialogid == 60) //WEAPONDAT_OPTIONS
	{
		if(response)
		{
			switch(listitem)
			{
				case 0:
				{
					if(AC_DAMAGEHACKS) AC_DAMAGEHACKS = false;
					else AC_DAMAGEHACKS = true;
					WEAPONDAT_OPTIONS(playerid);
				}
				case 1: 
				{
					if(pData[playerid][pLang] == 1) {
						ShowPlayerDialog(playerid, 61, DIALOG_STYLE_INPUT,"AC DAMAGEHACK SETTINGS",
						"{FFFFFF}Enter the number of triggers after which the player will be kicked when triggering anti-cheat [1-10]", "Ok", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 61, DIALOG_STYLE_INPUT, "AC DAMAGEHACK SETTINGS",
						"{FFFFFF}Введите количество сработок, после которых игрок будет кикнут при срабатывании античита [1-10]", "Ok", "Cancel");
					}
				}
				case 2: 
				{
					if(pData[playerid][pLang] == 1) {
						ShowPlayerDialog(playerid, 64, DIALOG_STYLE_INPUT, "AC DAMAGEHACK SETTINGS default: 3.0",
						"Helps to reduce false signals Antica ignoring lagers.\nEnter the percentage of packet loss of the player, after which anticheat will ignore the lag of the player [0-20].", "Ok", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 64, DIALOG_STYLE_INPUT, "AC DAMAGEHACK SETTINGS default: 3.0",
						"{FFFFFF}Позволяет уменьшить ложные сработки античита игнорируя лагеров. \nВведите процент потери пакетов игрока, после которых античит будет игнорировать лаги игрока [0-20].", "Ok", "Cancel");
					}
				}
			}
		}
		else GAMEACSET(playerid);
	}
	if(dialogid == 61) // AC_DAMAGEWARN_KICKAFTER
	{
		if(response)
		{
			if (strval(inputtext) > 10 || strval(inputtext) < 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Доступные значения [1-10]","Incorrect! available values [1-10]");
			} else {
				AC_DAMAGEWARN_KICKAFTER = strval(inputtext);
			}
		} else {
			WEAPONDAT_OPTIONS(playerid);
		}
	}
	if(dialogid == 62) // MODSET_MENU
	{
		if(response)
		{
			switch(listitem)
			{
				case 0:
				{
					new hostname[64], tbtext[256];
					GetServerVarAsString("hostname", hostname, sizeof(hostname));
					
					if(pData[playerid][pLang])
					{
						format(tbtext, sizeof(tbtext),
						"\n{FFFFFF}Hostname: %s\n\
						Enter new hostname (3-32 symbols)", hostname);
					} else {
						format(tbtext, sizeof(tbtext),
						"\n{FFFFFF}Hostname: %s\n\
						Введите новое мия (3-32 символа)", hostname);
					}
					ShowPlayerDialog(playerid, 187, DIALOG_STYLE_INPUT,
					"Change hostname", tbtext, "Change", "Cancel");
				}
				case 1: HITBOX_SETTINGS(playerid);
				case 2:
				{
					if (GetPVarInt(playerid, "Admin") < 2) {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 2+ уровня!",
						"To use these functions you need to have 2+ level admin rights!");
					}	
					new KICK_LAGERS_State[24];
					if(KICK_LAGERS == 0) KICK_LAGERS_State = "{00FF00}[NO CHECK]";
					else if (KICK_LAGERS == 1) KICK_LAGERS_State = "{00FF00}[WARNING]";
					else if (KICK_LAGERS == 2) KICK_LAGERS_State = "{00FF00}[KICK]";
					else if (KICK_LAGERS == 3) KICK_LAGERS_State = "{00FF00}[MOVESPEC]";
					
					new tbtext[300];
					if(pData[playerid][pLang])
					{
						format(tbtext, sizeof(tbtext),
						"Check Lagers\t%s\n"\
						"Max Ping \t%d\n"\
						"Max Packetloss\t%.1f\n"\
						"Min FPS drop\t%d\n",
						KICK_LAGERS_State, MAX_PING, MAX_PACKETLOSS, MIN_FPS);
					} else {
						format(tbtext, sizeof(tbtext),
						"Проверять лагеров\t%s\n"\
						"Максимальный пинг\t%d\n"\
						"Максимальная потеря\t%.1f\n"\
						"Минимальный фпс\t%d\n",
						KICK_LAGERS_State, MAX_PING, MAX_PACKETLOSS, MIN_FPS);
					}
					
					ShowPlayerDialog(playerid, 70, DIALOG_STYLE_TABLIST,
					"Check Lagers", tbtext, "Ok", "Cancel");
				}
				case 3: LOGINCONFIG_MENU(playerid);
				case 4:
				{
					#if defined _YSF_included
					new tbtext[320];
					format(tbtext, sizeof(tbtext),
					"{FFFFFF}Current server tickrate: %i (YSF: %i)\n\
					\nEnter new tickrate value (ticks): \n",
					GetServerTickRate(), YSF_GetTickRate());
					
					ShowPlayerDialog(playerid, 168, DIALOG_STYLE_INPUT,
					"Tickrate", tbtext, "Ok", "Cancel");
					#else
					MODSET_MENU(playerid);
					#endif
				}
				case 5:
				{
					if (GetPVarInt(playerid, "Admin") >= 3) {
						if(ServerAntiSpam) {
							ServerAntiSpam = false;
							SendClientMessageEx(playerid,COLOR_GREY,
							"Вы отключили антиспам","You disable Anti-Spam");
						} else {
							ServerAntiSpam = true;
							SendClientMessageEx(playerid,COLOR_GREY,
							"Вы включили антиспам","You enable Anti-Spam");
						}
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have 3+ level admin rights!");
					}
					MODSET_MENU(playerid);
				}
				case 6:
				{
					if (GetPVarInt(playerid, "Admin") >= 3) 
					{
						if (Debug) {
							Debug = false;
							SendClientMessageEx(playerid, COLOR_GREY,
							"Режим отладки деактивирован","Debug mode deactivated");
						} else {
							Debug = true;
							SendClientMessageEx(playerid, COLOR_GREY,
							"Режим отладки активирован","Debug mode activated");
						}
					} else {
						SendClientMessageEx(playerid, COLOR_GREY,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have 3+ level admin rights!");
