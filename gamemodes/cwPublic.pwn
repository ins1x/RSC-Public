						"SELECT Nickname FROM Accounts WHERE \
						(LastIP = '%q' AND Verified = 1) LIMIT 1",ip);
						query = db_query(dbaccounts, szQuery);
						if(db_num_rows(query))
						{
							new tempnick[24];
							db_get_field(query, 0, tempnick, sizeof(tempnick));
							format(tempnick, sizeof(tempnick), "%s", tempnick);
							format(stringru, sizeof(stringru),
