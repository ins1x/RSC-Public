	if(dialogid == 232)
	{
		if(response)
		{
			switch(listitem)
			{
				case 0:
				{
					ShowPlayerDialog(playerid, 181, DIALOG_STYLE_MSGBOX,
					"Unmute", "{FFFFFF}Unmute the account?", "Unmute", "Cancel");
				}
				case 1:
				{
					if(GetPVarInt(playerid, "Admin") >= 3)
					{
						new tbtext[520], szQuery[150], DBResult: query;
						new buffer[128], nick[24], ip[16], country[64];
						new banned, muted, hwban, hwmute, forceac;
						new nickname[MAX_PLAYER_NAME];
						GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
						format(szQuery, sizeof(szQuery),
						"SELECT Nickname, Lastip, Lastcountry, Banned, Muted \
						FROM Accounts WHERE Nickname = '%q'", nickname);
						query = db_query(dbaccounts, szQuery);
					
						db_get_field(query, 0, nick, sizeof(nick));
						format(buffer, sizeof(buffer), "{FFFFFF}Nickname\t{FF0000}%s{FFFFFF}\n", nick);
						strcat(tbtext, buffer);
						
						db_get_field(query, 1, ip, sizeof(ip));
						format(buffer, sizeof(buffer), "Last IP\t{FF0000}%s{FFFFFF}\n", ip);
						strcat(tbtext, buffer);
						
						db_get_field(query, 2, country, sizeof(country));
						format(buffer, sizeof(buffer), "Last Country\t{FF0000}%s{FFFFFF}\n", country);
						strcat(tbtext, buffer);
						
						banned = db_get_field_int(query, 3);
						format(buffer, sizeof(buffer), "IP Banned\t{FF0000}%i{FFFFFF}\n", banned);
						strcat(tbtext, buffer);
						
						muted = db_get_field_int(query, 4);
						format(buffer, sizeof(buffer), "Muted\t{FF0000}%i{FFFFFF}\n", muted);
						strcat(tbtext, buffer);
						
						db_free_result(query);
						
						format(szQuery, sizeof(szQuery),
						"SELECT HwBan, HwMute, Forceac FROM Banlist WHERE Nickname = '%q'",
						db_escape(nickname));
						query = db_query(dbcore, szQuery);
						
						hwban = db_get_field_int(query, 0);
						format(buffer, sizeof(buffer), "HwBanned\t{FFD700}%i\n", hwban);
						strcat(tbtext, buffer);
						
						hwmute = db_get_field_int(query, 1);
						format(buffer, sizeof(buffer), "HwMuted\t{FFD700}%i\n", hwmute);
						strcat(tbtext, buffer);
						
						forceac = db_get_field_int(query, 2);
						format(buffer, sizeof(buffer), "ForceAC\t{FFD700}%i\n", forceac);
						strcat(tbtext, buffer);
						
						db_free_result(query);
						
						strcat(tbtext, "\nAre you sure you want to unban this player?");
						
