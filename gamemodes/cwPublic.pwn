stock FakeClientCheck(playerid)
{
	new name[MAX_PLAYER_NAME], serial[41], ip[16], hostip[16];
	GetPlayerName(playerid,name,sizeof(name));
	gpci(playerid,serial,40);
	GetServerVarAsString("bind", hostip, 16);
	GetPlayerIp(playerid, ip, sizeof ip);
	
	if(!strcmp(name, "[SS]Cannibal", true)) return 0;
	if(!strcmp(name, "1NS", true)) return 0;
	
	if(!IsPlayerNPC(playerid))
	{
		new symb;   
		for(new s = 0; s < strlen(serial); s++)  
		{  
			if(serial[s] >= '0' && serial[s] <= '9') symb++;  
		}  
		if (symb >= 30 || strlen(serial) <= 30) KickPlayerEx(playerid, "FakeClient");
	}
	
	if(IsPlayerNPC(playerid))
	{
		if(strlen(hostip) && strcmp(ip, hostip) != 0)
		{
			if(strcmp(ip, "127.0.0.1", false))
			{
				return KickPlayerEx(playerid, "BotSpam");
			}
		}		
	}
	return 1;
}

stock ShowBanReasonDialog(playerid)
{
	if(fexist("core.db"))
	{
		new serial[41], tmpstr[256];
		gpci(playerid,serial,40);
		new reason[48], date[24];
		new szQuery[256], DBResult: query;
		format(szQuery, sizeof(szQuery),
		"SELECT Reason, Date FROM Banlist WHERE Serial = '%q'", serial);
		query = db_query(dbcore, szQuery);
		new rows = db_num_rows(query);
		for(new i; i < rows; i++)
		{		
			db_get_field(query, 0, reason, sizeof(reason));
			db_get_field(query, 1, date, sizeof(date));
		}
		db_free_result(query);
		if(strlen(reason))
		{
			format(tmpstr, sizeof(tmpstr),
			"{FFFFFF}You are banned {FF0000}%s{FFFFFF} for a reason {FF0000}%s{FFFFFF}\n\
			You can appeal the decision on {4682b4}dsc.gg/sawncommunity{FFFFFF}", date, reason);
			ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX,
			"\t", tmpstr, "Cancel", "");
		}
	}
}

public HardwareBanCheck(playerid)
{
	new ip[16], serial[41];
	new name[MAX_PLAYER_NAME];
	new szStringen[144];
	GetPlayerName(playerid,name,sizeof(name));
	gpci(playerid,serial,40);
	GetPlayerIp(playerid, ip, sizeof ip);
	#if defined _sampcac_included
	new hwid[64];
	new major, minor, patch;
	CAC_GetClientVersion(playerid, major, minor, patch);
	CAC_GetHardwareID(playerid, hwid, sizeof(hwid));
	#endif
	
	if(fexist("core.db"))
	{
		new hwban, hwmute, forceac, hwidban[64];
		new szQuery[256], DBResult: query;
		format(szQuery, sizeof(szQuery),
		"SELECT HwBan, HwMute, Forceac, HwID FROM Banlist WHERE Serial = '%q'", serial);
		query = db_query(dbcore, szQuery);
		new rows = db_num_rows(query);
		for(new i; i < rows; i++)
		{		
			hwban = db_get_field_int(query, 0);
			hwmute = db_get_field_int(query, 1);
			forceac = db_get_field_int(query, 2);	
			db_get_field(query, 3, hwidban, sizeof(hwidban));
			
			if(hwban)
			{
				#if defined _sampcac_included
				if(CAC_GetStatus(playerid) == 0)
				{
					KickPlayerEx(playerid, "SAMPCAC required");
					printf("Attempt of entering without AC a banned player by serial: %s nickname: %s from ip:%s",
					serial, name, ip);
				} else {
					// hwid != unknown &&  hwid != banned
					if(strlen(hwid) > 8 && !strcmp(hwid, hwidban, true))
					{
						format(szStringen, sizeof(szStringen),
						"%s(%d) has left the server. (Banned)",
						name, playerid);
						if(!Kicked[playerid]) SendClientMessageToAll(COLOR_GREY, szStringen);
						ShowBanReasonDialog(playerid);
						KickPlayerEx(playerid, "Banned on this server (code 1)");
						printf("Attempt of entering a banned player by hwid: %s nickname: %s from ip:%s",
						hwid, name, ip);
					}
				}
				#else
				format(szStringen, sizeof(szStringen), "%s(%d) has left the server. (Banned)",
				name, playerid);
				if(!Kicked[playerid]) SendClientMessageToAll(COLOR_GREY, szStringen);
				KickPlayerEx(playerid, "Banned on this server (code 1)");
				printf("Attempt of entering a banned player by serial: %s nickname: %s from ip:%s",
				serial, name, ip);
				#endif
			}
			if(hwmute)
			{
				SetPVarInt(playerid,"Hwmuted",1);
				printf("Entering a muted player by serial: %s nickname: %s from ip:%s",
				serial, name, ip);
			}
			if(forceac)
			{
				#if defined _sampcac_included
				if(CAC_GetStatus(playerid) == 0)
				{
					//format(szStringen, sizeof(szStringen),
					//"%s(%d) has left the server. (SAMPCAC is not installed)", name, playerid);
					//SendClientMessageToAll(COLOR_GREY, szStringen);
					KickPlayerEx(playerid, "SAMPCAC is not installed");
					printf("Attempt of entering without AC a banned player by serial: %s nickname: %s from ip:%s",
					serial, name, ip);
				}
				#endif
			}
			db_next_row(query);
		}
		db_free_result(query);
		
		#if defined _sampcac_included
		if(CAC_GetStatus(playerid))
		{
			format(szQuery, sizeof(szQuery),
			"SELECT HwBan, HwMute FROM Banlist WHERE HwID = '%q'", hwid);
			query = db_query(dbcore, szQuery);
			new dbrows = db_num_rows(query);
			for(new i; i < dbrows; i++)
			{		
				hwban = db_get_field_int(query, 0);
				hwmute = db_get_field_int(query, 1);
				
				if(hwban)
				{
					format(szStringen, sizeof(szStringen), "%s(%d) has left the server. (Banned)",
					name, playerid);
					if(!Kicked[playerid])  SendClientMessageToAll(COLOR_GREY, szStringen);
					ShowBanReasonDialog(playerid);
					KickPlayerEx(playerid, "Banned on this server (code 2)");
					printf("Attempt of entering a banned player by hwid: %s nickname: %s from ip:%s",
					hwid, name, ip);
				}
				if(hwmute)
				{
					SetPVarInt(playerid,"Hwmuted",1);
					printf("Entering a muted player by hwid: %s nickname: %s from ip:%s",
					hwid, name, ip);
				}
				db_next_row(query);
			}
			db_free_result(query);
		}
		#endif
	}
	return 1;
}

public StartVoteMap(playerid, mapid)
{
	if(GetPVarInt(playerid, "Admin") < 1)
	{
		if(NetStats_GetConnectedTime(playerid)/60000 < 5)
		{
			return SendClientMessageEx(playerid, COLOR_GREY, 
			"Вы должны быть онлайн не менее 5 минут",
			"You must be online for at least 5 minutes");
		}
	}
	if(CWmode)
	{	
		SendClientMessageEx(playerid, COLOR_GREY,
		"Сейчас Вы не можете использовать данную функцию.",
		"You can't use this function right now.");
		return true;
	}
	if(Votemap != -1)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Голосование уже было запущено", "Voting has already started");
		return true;	
	}
	if(mapid < 0 || mapid > MAX_MAPID)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Некорректное значение", "Incorrect value");
		return true;
	}
	if(VotemapRepeatTime > gettime())
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Запускать голосование можно раз в 5 минут",
		"You can start voting every 5 minutes");
		return true;
	}
	if(Online < 3)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Должно быть не менее 3-х игроков онлайн",
		"Must have at least 3 players online");
		return true;
	}
	
	new stringru[128], stringen[128];
	format(stringru, sizeof(stringru), "%s(%d) запустил голосование по смене карты на %d. %s",
	PlayerName(playerid), playerid, mapid, MapNames[mapid]);
	format(stringen, sizeof(stringen), "%s(%d) has launched a vote to change the map to %d. %s",
	PlayerName(playerid), playerid, mapid, MapNames[mapid]);
	SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
	
	foreach(Player, i) {
		SendClientMessageEx(i, COLOR_GREY,
		"Нажмите <Y> или введите /vote чтобы проголосовать за смену карты",
		"Press <Y> or use /vote to vote for the map change");
		SendNotify(playerid, "Press ~g~<Y>~w~ to vote for the map change", 5);
	}
	Votemap = mapid;
	VotemapRepeatTime = gettime() + 60 * 7;
	SetPVarInt(playerid, "VoteMap", mapid);
	SetTimerEx("EndVoteMap", 1000*60, false, "i", mapid);
	return true;
}

public EndVoteMap(mapid)
{
	if(CWmode)
	{
		SendClientMessageToAllEx(COLOR_GREY,
		"Запущен CW режим. Голосование отменено.",
		"Started CW mode. Voting has been cancelled.");
		Votemap = -1;
		foreach(Player,i) SetPVarInt(i, "VoteMap", -1);
	}
	Votemap = -1;
	new stringru[128], stringen[128];
	new playerstotal, voted;
	foreach(Player,i)
	{
		playerstotal++;
		if(GetPVarInt(i, "VoteMap") != -1)
		{
			SetPVarInt(i, "VoteMap", -1);
			voted++;
		}
	}
	
	if(voted > floatround(playerstotal/2))
	{
		format(stringru, sizeof(stringru), "Проголосовали за %i игроков из %i",
		voted, playerstotal);
		format(stringen, sizeof(stringen), "Voted %i players out of %i",
		voted, playerstotal);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		
		format(stringru, sizeof(stringru), "Карта была сменена по голосованию на %d. %s",
		mapid, MapNames[mapid]);
		format(stringen, sizeof(stringen), "The map has been changed by vote to %d. %s",
		mapid, MapNames[mapid]);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		
		Map = mapid;
		for(new i = 0; i < MAX_PLAYER_ID; i++)
		{
			if (IsPlayerConnected(i))
			{
				new team = GetPVarInt(i, "Team");
				SetSpawnInfo(i, 0, GetPlayerSkin(i),
				CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
				0, 0, 0, 0, 0, 0, 0); // 0.3d R2 bugfix, ReSpawnPlayer()
				if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
				{
					if (!GetPVarInt(i, "UnBug"))
					{
						ReSpawnPlayer(i);
					}
				}
				else if (GetPlayerState(i) == PLAYER_STATE_SPECTATING)
				{
					if (MapInterior[Map] != MapInterior[mapid])
					{
						SetPlayerInterior(i, MapInterior[mapid]);
					}
				}
			}
		}
	} else {
		format(stringru, sizeof(stringru),
		"Карта не была сменена. Проголосовали за %i игроков из %i", voted, playerstotal);
		format(stringen, sizeof(stringen),
		"Map has not been changed. Voted %i players out of %i", voted, playerstotal);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
	}
	return voted;
}

stock MoveMapCam(playerid, map)
{
	// Used to move the camera while selecting map
	new tmpstr[64];
	if(GetPVarInt(playerid, "MapSelect"))
	{
		SetPlayerInterior(playerid, MapInterior[map]);
		InterpolateCameraPos(playerid, CwMaps[map][1][0], CwMaps[map][1][1], CwMaps[map][1][2]+2.5,
		CwMaps[map][0][0], CwMaps[map][0][1], CwMaps[map][0][2]+2.5, 10000, CAMERA_MOVE);
		format(tmpstr, sizeof(tmpstr), "   %i ~n~~<~ select map ~>~~n~      %s",
		map, MapNames[map]);
	}
	GameTextForPlayer(playerid, tmpstr, 3000, 5);
}

stock SetVirtualWorldSpawnInfo(playerid, skinid = -1)
{
	// SetSpawnInfoEx
	new worldid = GetPlayerVirtualWorld(playerid);
	new team = GetPVarInt(playerid, "Team");
				
	if(skinid == -1)
	{
		if(World[worldid][wSkin] != 0) {
			skinid = World[worldid][wSkin];
		} else {
			if(pData[playerid][pSkin] != -1) skinid = pData[playerid][pSkin];
			else skinid = GetPVarInt(playerid, "skinid");
		}
	}
	
	if(GetPlayerVirtualWorld(playerid) != 0)
	{	
		if(World[worldid][wSpawnPoint])
		{
			SetSpawnInfo(playerid, team, skinid,
			World[worldid][wSpawnX], World[worldid][wSpawnY], World[worldid][wSpawnZ],
			0, 0, 0, 0, 0, 0, 0);
		} else {
			new map = World[worldid][wMap];
			SetSpawnInfo(playerid, team, skinid,
			CwMaps[map][team][0], CwMaps[map][team][1], CwMaps[map][team][2], 
			0, 0, 0, 0, 0, 0, 0);
		}
	} else {
		SetSpawnInfo(playerid, team, skinid,
		CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
		0, 0, 0, 0, 0, 0, 0);
	}
	return 1;
}

public SendNotify(playerid, const text[], time)
{
	/* Show info textdraw to player */
	if (text[0] == '\0' || (text[0] == '\1' && text[1] == '\0')) return 0;
	PlayerTextDrawHide(playerid, TDinfobox[playerid]);
	PlayerTextDrawSetString(playerid, TDinfobox[playerid], db_escape(text));
	PlayerTextDrawShow(playerid, TDinfobox[playerid]);
	SetTimerEx("HideInfobox", time*1000, false, "i", playerid);
	return time;
}

public HideInfobox(playerid)
{
	/* Hide info textdraw to player */
	PlayerTextDrawHide(playerid, TDinfobox[playerid]);
	return 1;
}

GetPlayerFPS(playerid)
{
	new drunk2 = GetPlayerDrunkLevel(playerid);
	if(drunk2 < 100){
	    SetPlayerDrunkLevel(playerid,2000);
	}else{
	    if(GetPVarInt(playerid, "drunk") != drunk2){
	        new fps = GetPVarInt(playerid, "drunk") - drunk2;
	        if((fps > 0) )// && (fps < 200))
   			SetPVarInt(playerid, "fps", fps);
			SetPVarInt(playerid, "drunk", drunk2);
		}
	}
	return GetPVarInt(playerid, "fps");
}

isnumeric(const string[])
{
	for(new i, j = strlen(string); i < j; i++)
	{
		if(!('0' <= string[i] <= '9')) return 0;
	}
	return 1;
}

forward KillPlayer(playerid);
public KillPlayer(playerid)
{
	SetPlayerHealth(playerid, 0.0);
	SetPlayerArmour(playerid, 0.0);
	return 1;
}

stock ReSpawnPlayer(playerid)
{
	// Valid "playerid" check inside "GetPlayerVehicleID".
	
	if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) return 1;
	
	new
		vid = GetPlayerVehicleID(playerid);
	if (vid)
	{
		new
			Float:x,
			Float:y,
			Float:z;
		// Remove them without the animation.
		GetVehiclePos(vid, x, y, z),
		SetPlayerPos(playerid, x, y, z);
	}
	
	return SpawnPlayer(playerid);
}

stock Sync(playerid)
{
	// Force resync player
	SetPVarInt(playerid, "UnBug", true);
	SetPlayerInterior(playerid, MapInterior[Map]);
	SetPlayerVirtualWorld(playerid, GetPVarInt(playerid, "world"));
	GetPlayerPos(playerid, pData[playerid][pSyncX], 
	pData[playerid][pSyncY], pData[playerid][pSyncZ]);
	GetPlayerFacingAngle(playerid, pData[playerid][pSyncA]);
	//GetPlayerVelocity(playerid, syncveloX, syncveloY, syncveloZ);
	SetPlayerSpecialAction(playerid,SPECIAL_ACTION_NONE);

	#if defined _INC_SKY
		SpawnPlayerForWorld(playerid);
	#endif
	
	if(GetPlayerVirtualWorld(playerid) != 0) SetVirtualWorldSpawnInfo(playerid);
	else SetVirtualWorldSpawnInfo(playerid, GetPlayerSkin(playerid));
	
	#if defined _INC_WEAPON_CONFIG
		ResyncPlayer(playerid);
		WC_SpawnPlayer(playerid);
		//UpdateSyncData(playerid);
	#else
		ReSpawnPlayer(playerid);
	#endif
	return true;
}

stock RemoveClanTagFromName(playerid) 
{
    new start, end, string[MAX_PLAYER_NAME];
	GetPlayerName(playerid, string, MAX_PLAYER_NAME);
    start = strfind(string, "[", true);
    end = strfind(string, "]", true);
    if (start >= end) {
		return string;
    } else {
        strdel(string, start, end + 1);
        return string;
    }
}

