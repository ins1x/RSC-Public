	if (!strcmp(cmdtext, "/spec ", true, 6))
	{
		if (!cmdtext[6])
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Использование: /spec [ID]", "Use: /spec [ID]");
			return true;
		}
		if(Finalscreen) 
