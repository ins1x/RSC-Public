stock WORLD_BOTS(playerid)
{
	#if defined _FCNPC_included
	new tbtext[640], header[64];
	header = ".:: Manage bots ::.";
	
	new worldid = GetPlayerVirtualWorld(playerid);
	new botskin[16];
	if(World[worldid][wBotSkin]) {
		format(botskin, sizeof(botskin), "%d", World[worldid][wBotSkin]);
	} else {
		if(pData[playerid][pLang]) format(botskin, sizeof(botskin), "[Random]");
		else format(botskin, sizeof(botskin), "[Случайный]");
	}
	
	new damageset[24];
	if(World[worldid][wBotAccuracy] == 50.0 
	&& World[worldid][wBotShootrate] == 1055
	&& World[worldid][wBotShootdelay] == 1500
	&& World[worldid][wBotReloadtime] == 1500)
	{
		if(pData[playerid][pLang]) damageset = "[Default]";
		else damageset = "[Стандартный]";
	} else {
		if(pData[playerid][pLang]) damageset = "[Custom]";
		else damageset = "[Измененный]";
	}
	
	new movetype[24];
	if(pData[playerid][pLang])
	{
		if(World[worldid][wBotMovetype] == -1) movetype = "[Auto]";
		else if(World[worldid][wBotMovetype] == 0) movetype = "[Walk]";
		else if(World[worldid][wBotMovetype] == 1) movetype = "[Run]";
		else if(World[worldid][wBotMovetype] == 2) movetype = "[Sprint]";
	} else {
		if(World[worldid][wBotMovetype] == -1) movetype = "[Авто]";
		else if(World[worldid][wBotMovetype] == 0) movetype = "[Ходьба]";
		else if(World[worldid][wBotMovetype] == 1) movetype = "[Бег]";
		else if(World[worldid][wBotMovetype] == 2) movetype = "[Спринт]";
	}
		
	new action[64];
	if(World[worldid][wBotAction] == 1) {
		if(pData[playerid][pLang]) format(action, sizeof(action), "[Chases and shoots at the player]");
		else format(action, sizeof(action), "[Преследует и стреляет в игрока]");
	} else if(World[worldid][wBotAction] == 2) {
		if(pData[playerid][pLang]) format(action, sizeof(action),"[Stands still and responds with one shot]"); else format(action, sizeof(action), "[Стоит на месте и отвечает одим выстрелом]");
	} else if(World[worldid][wBotAction] == 3) {
		if(pData[playerid][pLang]) format(action, sizeof(action), "[Stalking the player]");
		else format(action, sizeof(action), "[Преследует игрока]");
	} else if(World[worldid][wBotAction] == 4) {
		if(pData[playerid][pLang]) format(action, sizeof(action), "[Fall back]");
		else format(action, sizeof(action), "[Падает на спину]");
	} else if(World[worldid][wBotAction] == 5) {
		if(pData[playerid][pLang]) format(action, sizeof(action), "[Spawn in a random place]");
		else format(action, sizeof(action), "[Спавнится в случайном месте]");
	}
	
	if(pData[playerid][pLang])
	{	
		format(tbtext, sizeof(tbtext),
		"Skin\t{AFAFAF}%s\n"\
		"Health\t{AFAFAF}%d\n"\
		"Weapon set\t{AFAFAF}[%s]\n"\
		"Action on damage\t{AFAFAF}%s\n"\
		"Damage set\t{AFAFAF}%s\n"\
		"Type of movement\t{AFAFAF}%s\n"\
		"Type\t{AFAFAF}%s\n"\
		"Stop bot attack\t\n"\
		"Attack nearest player\t\n"\
		"Create bot group\t\n"\
		"Actors\t\n"\
		"\t\n"\
		"{00FF00}Add new bot\n"\
		"{00FF00}List of bots\n"\
		"{FF0000}Remove bots\n"\
		"Information\n",
		botskin, 
		World[worldid][wBotHealth],
		WeaponNamesEN[World[worldid][wBotWeaponid]],
		action, damageset, movetype,
		(World[worldid][wBotType]) ? ("[Dynamic]") : ("[Static]"));
		
		ShowPlayerDialog(playerid, 333, DIALOG_STYLE_TABLIST,
		header, tbtext, "Ok", "Cancel");
