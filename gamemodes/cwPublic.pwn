	if (dialogid == 215) // maxrounds
	{
		if(response)
		{
			if(strval(inputtext) < 1  && strval(inputtext) > 30)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное значение. Допустимые значения 1-30",
				"Invalid value. Acceptable values are 1-30");
				return true;
			}
			
			if(CWmode && strval(inputtext) < Round && strval(inputtext) > 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Нельзя выставить значение меньше текущего раунда",
				"You cannot set a value less than the current round");
				return true;
			}
			
			
			MaxRounds = strval(inputtext);
			new stringru[100], stringen[100];
			format(stringru, sizeof(stringru), "%s(%d) установил количество раундов %d",
			PlayerName(playerid), playerid, MaxRounds);
			format(stringen, sizeof(stringen), "%s(%d) has set max rounds %d",
			PlayerName(playerid), playerid, MaxRounds);
			SendClientMessageToVirtualWorld(0, COLOR_GREY, stringru, stringen);
			ROUNDSET_MENU(playerid);
		} else {
			//if(LAST_DIALOG[playerid] == 35) ROUND_TEAMSET_MENU(playerid);
			ROUNDSET_MENU(playerid);
		}
	}
	if (dialogid == 216) // kickall
	{
		if(response)
		{
			new stringru[128], stringen[128];
			new worldid = GetPlayerVirtualWorld(playerid); 
			
			if(worldid != 0 && World[worldid][wHosted] == playerid)
			{
				format(stringru, sizeof(stringru),
				"%s(%d) кикнул всех игроков с виртуального мира.", PlayerName(playerid), playerid);
				format(stringen, sizeof(stringen),
				"%s(%d) kicked all players from the virtual world.", PlayerName(playerid), playerid);
				SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
				foreach(Player, i)
				{
					if(GetPlayerVirtualWorld(playerid) == GetPlayerVirtualWorld(i)
					&& playerid != i && !WorldModerator[i])
					{
						SetPlayerVirtualWorld(i, 0);
						SetPVarInt(i, "world", 0);
						SetPVarInt(i, "ShowKDtxd", -1);
						SetPVarInt(i, "ShowScoretxd", -1);
						SetPVarInt(i, "ShowTimetxd", -1);
						ResetKDStats(i);
						PlayerTextDrawHide(i, TDkdstats[i]);
						TextDrawShowForPlayer(i, TD[i]);
						if(pData[i][pDtbar] > 0) PlayerTextDrawShow(i, TDdatetime[i]);
						GameTextForPlayer(i, "~w~Back to ~g~CW/TG", 3000, 4);
						if(CWmode) 
						{
							SetPlayerTeamEx(i, 2);
							ResetPlayerWeapons(i);
						}
						ReSpawnPlayer(i);
						
						SendClientMessageEx(i, COLOR_GREY,
						"Вас выкинул хостер мира", "You were kicked by world hoster");
					}
				}
				return true;
			}
			
			if(worldid == 0 && GetPVarInt(playerid, "Admin") >= 3)
			{
				if(!CWmode)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Сперва включите Clan War режим!", "Turn ON Clan War mode first!");
					return true;
				}
							
				format(stringru, sizeof(stringru),
				"%s(%d) кикнул всех игроков, кроме %s, %s и %s с сервера.",
				PlayerName(playerid), playerid, ClanName[0], ClanName[1], CLAN_TAG);
				format(stringen, sizeof(stringen),
				"%s(%d) has kicked every player except %s, %s and %s from server.",
				PlayerName(playerid), playerid, ClanName[0], ClanName[1], CLAN_TAG);
				
				AdminActionsLog(stringen);
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
				foreach(Player, i)
				{
					if (playerid != i)
					{
						GetPlayerName(i, stringru, MAX_PLAYER_NAME);
						if (strfind(stringru, ClanName[0], true) == -1 
						&& strfind(stringru, ClanName[1], true) == -1 
						&& strfind(stringru, CLAN_TAG, true) == -1)
						{
							KickPlayerEx(i, "Server closed by admin");
						}
					}
				}
				return true;
			}
		}
	}
