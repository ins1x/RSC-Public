				GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
				
				format(szQuery, sizeof(szQuery),
				"SELECT Lastip FROM Accounts WHERE Nickname = '%q'", nickname);
				query = db_query(dbaccounts, szQuery);
				if(db_num_rows(query))
				{
					db_get_field(query, 0, ip, sizeof(ip));
					db_free_result(query);
				}
				strdel(ip, strlen(ip)-2, strlen(ip));
				format(szQuery, sizeof(szQuery),
				"DELETE FROM Accounts WHERE Lastip LIKE '%%%s%%'", ip);
				query = db_query(dbaccounts, szQuery);
				
				db_free_result(query);
			}
			else return SendClientMessageEx(playerid, COLOR_RED, "Для использования этих функций Вы должны быть администратором 3+ уровня!", "To use these functions you need to have 3+ level admin rights!");
