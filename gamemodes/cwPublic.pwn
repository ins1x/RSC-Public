						format(tbtext, sizeof(tbtext),
						"Show FPS and Ping on the player\t%s\n"\
						"Show information about the enemy over the radar\t%s\n"\
						"3d text draw distance\t%d\n"\
						"Show a bar of health and armor above the player\t%s\n",
						(ShowBodyLabel) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
						(ShowEnemyBar) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
						TXT_DRAW_DISTANCE,
						(ToggleNameTags) ? "{00FF00}[ON]" : "{FF0000}[ОFF]");
