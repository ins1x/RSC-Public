	if(dialogid == 106) // change skin for chosen player
	{
		if(response)
		{
			new stringen[128], stringru[128];
			new skinid = strval(inputtext);
			new worldid = GetPlayerVirtualWorld(playerid);
			if(strlen(inputtext) < 1) return SendClientMessage(playerid, COLOR_GREY, "Incorrect ID");
			if(skinid < 0 || skinid >= 300 || skinid == 74) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Ошибка: неверный № скина", "ERROR: Invalid skin id!");
			}
			if(GetPlayerState(ChosenPlayer[playerid]) != PLAYER_STATE_ONFOOT)
			{
				return SendClientMessageEx(playerid,COLOR_GREY,
				"Несихрнонизирован: Попробуйте позже", "Desynced: Try later");
			}
			if(GetPlayerAnimationIndex(ChosenPlayer[playerid]) == 1274 || 
			GetPlayerAnimationIndex(ChosenPlayer[playerid]) == 1159)
			{
				ApplyAnimation(ChosenPlayer[playerid],"PLAYIDLES","stretch",4.0,0,0,0,0,0);
			}
			if(GetPVarInt(playerid, "Admin") < 3)
			{
				if(!World[worldid][wBagoskins] || worldid == 0)
				{
					switch(skinid)
					{
						case 0,1,2,74,86,92,99,149,265,266,267,268,269,270,271,272:
						{
							return SendClientMessageEx(playerid, COLOR_GREY, "Этот скин запрещен!", "This skin is forbidden!");
						}
					}
				}
			}
			if (GetPVarInt(playerid, "Admin") >= 1)
			{
				TogglePlayerControllable(ChosenPlayer[playerid], false);
				SetPlayerSkin(ChosenPlayer[playerid], skinid);
				TogglePlayerControllable(ChosenPlayer[playerid], true);
				new team = GetPVarInt(playerid, "Team");
				SetSpawnInfo(ChosenPlayer[playerid], 0, GetPlayerSkin(ChosenPlayer[playerid]), CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2], 0, 0, 0, 0, 0, 0, 0);
				format(stringen, sizeof(stringen), "%s(%d) change skin to player %s(%d) (skinid:%d).",
				PlayerName(playerid), playerid,
				PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid], skinid);
				format(stringru, sizeof(stringru), "%s(%d) сменил скин игроку %s(%d) (skinid:%d).",
				PlayerName(playerid), playerid,
				PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid], skinid);
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
				
				if(pData[ChosenPlayer[playerid]][pAttachSlot0] == 600)
				{
					pData[ChosenPlayer[playerid]][pAttachSlot0] = -1;
					pData[ChosenPlayer[playerid]][pSkin] = skinid;
					
					new szQuery[128];
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET Skin = %i WHERE (Nickname = '%q')",
					pData[ChosenPlayer[playerid]][pSkin],
					db_escape(PlayerName(ChosenPlayer[playerid])));
					db_query(dbaccounts, szQuery);
					
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET AttachSlot0 = %i WHERE (Nickname = '%q')",
					pData[ChosenPlayer[playerid]][pAttachSlot0],
					db_escape(PlayerName(ChosenPlayer[playerid])));
					db_query(dbaccounts, szQuery);
				}
				return true;
			}
		}
		else DOP_MENU(playerid);
	}
