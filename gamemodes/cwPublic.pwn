	if(dialogid == 52)//gamehealth
	{
		if(response)
		{
			new Float: health, Float: armour;
			new bool: flag = false;
			
			switch(listitem)
			{
				case 0: GameHealth = 100;
				case 1: //100 + 100
				{
					flag = true;
					GameHealth = 200;
				}
				case 2: //custom
				{
					flag = true;
					if (pData[playerid][pLang] == 0) {
						return ShowPlayerDialog(playerid, 37, DIALOG_STYLE_INPUT, "GameHealth (/gamehealth)","{FFFFFF}Введите кол-во жизни и брони", "Ok", "Выход");
					} else {
						return ShowPlayerDialog(playerid, 37, DIALOG_STYLE_INPUT, "GameHealth (/gamehealth)","{FFFFFF}Set up game health.", "Save", "Cancel");
					}
				}
			}
			
			if(flag == false)
			{
				foreach(Player, i)
				{
					if (IsPlayerConnected(i))
					{
						if (GetPlayerState(i) == PLAYER_STATE_ONFOOT && GetPVarInt(i, "Team") != 2)
						{
							GetPlayerHealth(i, health);
							GetPlayerArmour(i, armour);
							if (health +armour > GameHealth)
							{
								if (GameHealth > 100)
								{
									SetPlayerHealth(i, 100.0);
									SetPlayerArmour(i, GameHealth -100);
								}else{
									SetPlayerHealth(i, GameHealth);
									SetPlayerArmour(i, 0.0);
								}
								SetPVarFloat(i, "LastHP", GameHealth +0.000001);
							}
							ReSpawnPlayer(i);
						}
					}
				}
				new stringru[73], stringen[74];
				if (GameHealth > 100)
				{
					format(stringru, sizeof(stringru), "%s(%d) выставил 100 хп и %d брони.", PlayerName(playerid), playerid, GameHealth -100);
					format(stringen, sizeof(stringen), "%s(%d) has set up game with 100 HP and %d armour.", PlayerName(playerid), playerid, GameHealth -100);
				}else{
					format(stringru, sizeof(stringru), "%s(%d) выставил %d хп.", PlayerName(playerid), playerid, GameHealth);
					format(stringen, sizeof(stringen), "%s(%d) has set up game with %d HP.", PlayerName(playerid), playerid, GameHealth);
				}
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			}
		}
		else ROUNDSET_MENU(playerid);
	}
