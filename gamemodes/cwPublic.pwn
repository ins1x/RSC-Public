public OnPlayerDisconnect(playerid, reason)
{	
	new stringru[128], stringen[128];
	
	if (playerid +1 >= MAX_PLAYER_ID)
	{
	    for(new i = MAX_PLAYER_ID -2; i > -1; i--)
		{
			if (IsPlayerConnected(i))
			{
				MAX_PLAYER_ID = i +1;
				break;
			}
		}
		if (playerid +1 == MAX_PLAYER_ID)
		{
		    MAX_PLAYER_ID = 0;
		}
	}
	
	if(IsPlayerNPC(playerid)) return true;
	
	KillTimer(NoLogin_Timer[playerid]);
	Online --;
	
	new name[MAX_PLAYER_NAME];
	GetPlayerName(playerid, name, sizeof(name));
	
	if (reason == 0)
	{
		// network diagnostic
		#if defined _YSF_included
		if(NetStats_ConnectionStatus(playerid) == 8) // CONNECTED
		{
			format(stringru, sizeof(stringru), "%s(%d) покинул сервер. (Вылет)", name, playerid);
			format(stringen, sizeof(stringen), "%s(%d) has left the server. (Timeout)", name, playerid);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		} else {
			if(PlayerPloss[playerid] > 0.3)
			{
				format(stringru, sizeof(stringru),
				"%s(%d) покинул сервер [ploss:%.2f]. (%s)",
				name, playerid, PlayerPloss[playerid], CONNECT_MODE[NetStats_ConnectionStatus(playerid)]);
				format(stringen, sizeof(stringen),
				"%s(%d) has left the server [ploss:%.2f]. (%s)",
				name, playerid, PlayerPloss[playerid], CONNECT_MODE[NetStats_ConnectionStatus(playerid)]);
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
				if(Debug) print(stringen);
			} else {
				format(stringru, sizeof(stringru), "%s(%d) покинул сервер. (%s)",
				name, playerid, CONNECT_MODE[NetStats_ConnectionStatus(playerid)]);
				format(stringen, sizeof(stringen), "%s(%d) has left the server. (%s)",
				name, playerid, CONNECT_MODE[NetStats_ConnectionStatus(playerid)]);
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			}
		}
		#else
		format(stringru, sizeof(stringru), "%s(%d) покинул сервер. (Вылет)", name, playerid);
		format(stringen, sizeof(stringen), "%s(%d) has left the server. (Timeout)", name, playerid);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		#endif
	}
	else if (reason == 1)
	{
		format(stringru, sizeof(stringru), "%s(%d) покинул сервер. (Выход)", name, playerid);
		format(stringen, sizeof(stringen), "%s(%d) has left the server. (Leaving)", name, playerid);

	    SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		if(Debug) print(stringen); // logging
	}
	else if (reason == 2)
	{
		format(stringru, sizeof(stringru), "%s(%d) покинул сервер. (Кик/Бан)", name, playerid);
		format(stringen, sizeof(stringen), "%s(%d) has left the server. (Kick/Ban)", name, playerid);
	    SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
	}
	
	if (!freeze_score)
	{
		if(CWmode && GetPVarInt(playerid, "Logged") > 0 && GetPVarInt(playerid, "Team") < 2)
		{
			//Dirty way to fix issue the round freeze bug when random players are kicked
			if(CwData[playerid][cwTeam] < 2 && GetPlayerVirtualWorld(playerid) == 0) 
			{
				frz = true;
				SendClientMessageToVirtualWorld(0, COLOR_GREY,
				"Матч был заморожен по причине выхода одного из участников.",
				"The match was frozen due to the withdrawal of one of the participants.");

				new replacementplayers[144];
				foreach(Player, i)
				{
					if (GetPVarInt(i, "Admin") >= 1 && GetPlayerVirtualWorld(i) == 0)
					{
						SendClientMessageEx(i, COLOR_GREY,
						"Для восстановления последней позиции и параметров игрока используйте /load [ID] после того как игрок подключится",
						"To load the position and player stats use /load [ID] after the player connects");
					}
					if (GetPVarInt(i, "Team") < 2 && GetPlayerVirtualWorld(i) == 0)
					{
						if(GetPlayerState(i) == PLAYER_STATE_ONFOOT)
						{
							ResetPlayerWeapons(i);
							TogglePlayerControllable(i, false);
							SetPVarInt(i, "frz", true);
							SendClientMessageEx(i, COLOR_GREY,
							"Вы получите оружие через 3 секунды после старта.",
							"You will receive weapons 3 seconds after start.");
							GameTextForPlayer(i, "~w~Game~n~ ~r~paused", 3000, 5);
						}
					}
					if (GetPVarInt(i, "Team") == 2 && !IsPlayerAFK(i))
					{
						new nick[MAX_PLAYER_NAME];
						format(nick, sizeof(nick), " %s(%d)", PlayerName(i), i);
						
						if(AConly)
						{
							#if defined _sampcac_included
							new major, minor, patch;
							CAC_GetClientVersion(i, major, minor, patch);
							if(CAC_GetStatus(i) == 0 || minor != 10) {
								strcat(replacementplayers, nick);
							}
							#endif
						} else {
							strcat(replacementplayers, nick);
						}
					}
				}
				if(strlen(replacementplayers))
				{
					foreach(Player, i)
					{
						if(GetPVarInt(i, "Admin") >= 1 && GetPlayerVirtualWorld(i) == 0)
						{
							SendClientMessageEx(i, COLOR_GREY,
							"Возможные игроки на замену:",
							"Possible replacement players:");
							SendClientMessage(i, COLOR_GREY, replacementplayers);
						}
					}
				}
				GetPlayerPos(playerid, pData[playerid][pSyncX],
				pData[playerid][pSyncY], pData[playerid][pSyncZ]);
				GetPlayerFacingAngle(playerid, pData[playerid][pSyncA]);
				new Float: health, Float: armour;
				GetPlayerHealth(playerid, health);
				GetPlayerArmour(playerid, armour);
				pData[playerid][pSaveHP] = floatround(health +armour, floatround_round);
			}
		}
	}
	if (GetPVarInt(playerid, "Spected"))
    {
	    for(new i = 0; i < MAX_PLAYER_ID; i++)
		{
		    if (IsPlayerConnected(i))
		    {
		        if (GetPVarInt(i, "Team") == 2)
		        {
		        	if (GetPVarInt(i, "Specing") == playerid)
		        	{
		        	    GameTextForPlayer(i, " ", 1, 3);
		        	    TogglePlayerSpectating(i, false);
	    				SetPVarInt(i, "Specing", -1);
		        	}
				}
		    }
		}
	}
	
	if(pData[playerid][pMuted] > 0)
	{				
		new szQuery[128];
		format(szQuery, sizeof(szQuery),
		"UPDATE Accounts SET Muted = %i WHERE (Nickname = '%q')",
		pData[playerid][pMuted], db_escape(PlayerName(playerid)));
		db_query(dbaccounts, szQuery);
	}

	pData[playerid][pAdmin] = 0;

	// drop hud data
	pData[playerid][pHpbar] = 0;
	pData[playerid][pFpsbar] = 0;
	pData[playerid][pHud] = 0;

	// drop ac data
	LastShotTime[playerid] = 0;
	LastShotTick[playerid] = 0;
	LastCrouchTick[playerid] = 0;
	DamageHacksWarns[playerid] = 0;
	LastRejectHitReason[playerid] = -1;
	Antispam[playerid][0] = EOS;
	
	// Kill assist system
	for(new assist; assist < 3; assist++) {
		KillAssist[playerid][assist] = INVALID_PLAYER_ID;
	}

	// Remove Player Objects
	pData[playerid][pAttachSlot0] = -1;
	pData[playerid][pAttachSlot1] = -1;
	pData[playerid][pAttachSlot2] = -1;
	pData[playerid][pAttachSlot3] = -1;
	for(new s=0; s<MAX_PLAYER_ATTACHED_OBJECTS; s++)
	{
		if(IsPlayerAttachedObjectSlotUsed(playerid, s)) {
			RemovePlayerAttachedObject(playerid, s);
		}
	}	

	// Rempve Player Testdraws and 3d text
	PlayerTextDrawDestroy(playerid, TDlagmode[playerid]);
	PlayerTextDrawDestroy(playerid,	Logo[playerid]);
	PlayerTextDrawDestroy(playerid, Commands[playerid]);
	PlayerTextDrawDestroy(playerid, FPSBAR[playerid]);
	PlayerTextDrawDestroy(playerid, TDspecbar[playerid]);
	PlayerTextDrawDestroy(playerid, TDspecbarDynBox[playerid]);
	PlayerTextDrawDestroy(playerid, TDinfobox[playerid]);
	//PlayerTextDrawDestroy(playerid, TDteamtab[playerid]);
	PlayerTextDrawDestroy(playerid, TDteamtab1[playerid]);
	PlayerTextDrawDestroy(playerid, TDteamtab2[playerid]);
	PlayerTextDrawDestroy(playerid, TDdatetime[playerid]);
	PlayerTextDrawDestroy(playerid, TDnames[playerid]);
	PlayerTextDrawDestroy(playerid, TDbigscore[playerid]);
	PlayerTextDrawDestroy(playerid, TDenemybar[playerid]);
	PlayerTextDrawDestroy(playerid, TDkdstats[playerid]);
	PlayerTextDrawDestroy(playerid, TDhelpbar[playerid]);
	
	// Remove 3d texts
	Delete3DTextLabel(BodyLabel[playerid]);
	Delete3DTextLabel(Spawnkill3d[playerid]);
	
	// FlyMode init
	CAM_MOVE_SPEED[playerid] = 50.0;
	CAM_MOVE_DEFAULT[playerid] = 40.0;
	CAM_MOVE_MAXIMUM[playerid] = 65.0;
	CAM_ACCEL_RATE[playerid] = 0.05;
	
	OnFly[playerid] = false;
	
	if(AC_AimWarnings)
	{
		ProAimWarns[playerid] = 0;
		PerfectAimWarns[playerid] = 0;
	}
	// drop players data table
	pData[playerid] = NULL_pData;	
	Stats[playerid] = NULL_Stats;

	// drop players data table
	PlayerGeoIPInfo[playerid] = NULL_PlayerGeoIPInfo;
	
	// remove player vehicle
	if(GetPVarInt(playerid, "Vehicle") != 0) {
		DestroyVehicle(GetPVarInt(playerid, "Vehicle"));
	}
			
	// Worlds system wipe world settings
	WorldModerator[playerid] = false;
	for(new worldid; worldid < MAX_WORLD_SLOTS; worldid++)
	{
		if(World[worldid][wHosted] == playerid)
		{
			World[worldid][wHosted] = -1;
			World[worldid][wPass] = EOS;
			World[worldid][wLocked] = 0;
			World[worldid][wMap] = 0;
		}
	}
	
	#if defined _nex_ac_included
	for(new code = 0; code != 52; code++)
	{
		NEXAC_DETECT_COUNTERS[playerid][code] = 0;
	}
	#endif
	return true;
}

public NoLoginKick(playerid, bool: srv)
{
	// Kick player if didn't enter the password 
	// NOLOGIN_KICK_DELAY - seconds after kick
	if (!srv)
	{
		new string[32];
		format(string, sizeof(string), "NoLogin (%d sec)", NOLOGIN_KICK_DELAY);
		KickPlayerEx(playerid, string);
	}
	return true;
}

public HidePlayerMarker(playerid, remark)
{
	for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
		if (IsPlayerConnected(i))
		{
		    if (GetPVarInt(i, "Team") < 2)
		    {
			    if (GetPVarInt(i, "Team") != GetPVarInt(playerid, "Team"))
			    {
			        if (GetPVarInt(playerid, "Team") == 0)
			        {
			            SetPlayerMarkerForPlayer(i, playerid, COLOR_INVGREEN);
			            SetPlayerMarkerForPlayer(playerid, i, COLOR_INVBLUE);
					} else {
					    SetPlayerMarkerForPlayer(i, playerid, COLOR_INVBLUE);
					    SetPlayerMarkerForPlayer(playerid, i, COLOR_INVGREEN);
					}
				}
			}
		}
	}
	if (remark == 0)
 	{
 	    SetTimerEx("Hide", 1000, false, "ii", playerid, 1);
 	    return true;
 	}
 	if (remark == 1)
 	{
 	    SetTimerEx("Hide", 5000, false, "ii", playerid, 2);
 	    return true;
 	}
	return true;
}

stock SetMarkersForPlayer(playerid)
{
	if (!Marker)
	{
		if (GetPVarInt(playerid, "Team") < 2)
		{
			foreach(Player, i)
			{
				if (GetPVarInt(i, "Team") < 2)
				{
					if (GetPVarInt(i, "Team") != GetPVarInt(playerid, "Team"))
					{
						if (GetPVarInt(i, "Team") == 0)
						{
							SetPlayerMarkerForPlayer(playerid, i, TCC[0]);
						} else {
							SetPlayerMarkerForPlayer(playerid, i, TCC[1]);
						}
						SetPlayerMarkerForPlayer(i, playerid, TCC[2]);
					}
				}
			}
		}
	}
}

stock GetActivePlayerid(worldid)
{
	// Find first active player and return them id
	new first_active_playerid = -1;
	foreach(Player, playerid)
	{
		if(first_active_playerid == -1)
		{
			if(IsPlayerConnected(playerid) && GetPVarInt(playerid, "Team") != 2
			&& GetPlayerVirtualWorld(playerid) == worldid)
			{
				if(GetPlayerState(playerid) != PLAYER_STATE_SPECTATING)
				{
					first_active_playerid = playerid;
				}
			}
		}
	}
	return first_active_playerid;
}

public OnPlayerStreamIn(playerid, forplayerid)
{
	if (AntiTK)
	{
		SetPlayerTeam(playerid, GetPVarInt(playerid, "Team"));
		SetPlayerTeam(forplayerid, GetPVarInt(forplayerid, "Team"));
	} else {
	    if (GetPVarInt(playerid, "Team") == 2) SetPlayerTeam(playerid, 2);
		if (GetPVarInt(forplayerid, "Team") == 2) SetPlayerTeam(forplayerid, 2);
	}
	return true;
}

public OnPlayerStreamOut(playerid, forplayerid)
{
	return 1;
}

#if defined _YSF_included

public OnPlayerClientGameInit(playerid, &usecjwalk, &limitglobalchat,
		&Float:globalchatradius, &Float:nametagdistance, &disableenterexits, &nametaglos,
		&manualvehengineandlights, &spawnsavailable, &shownametags, &showplayermarkers,
		&onfoot_rate, &incar_rate, &weapon_rate, &lagcompmode, &vehiclefriendlyfire)
{
	#if defined YSF_GameInitDebug
	printf("OnPlayerClientGameInit(playerid = %d, &usecjwalk = %d, &limitglobalchat = %d, &globalchatradius = %f, &nametagdistance = %f, &disableenterexits = %d, &nametaglos = %d, &manualvehengineandlights = %d, \
	&spawnsavailable = %d, &shownametags = %d, &showplayermarkers = %d, &onfoot_rate = %d, &incar_rate = %d, &weapon_rate = %d, &lagcompmode = %d, &vehiclefriendlyfire = %d",
	playerid, usecjwalk, limitglobalchat, globalchatradius, nametagdistance, disableenterexits, nametaglos, manualvehengineandlights,
	spawnsavailable, shownametags, showplayermarkers, onfoot_rate, incar_rate, weapon_rate, lagcompmode, vehiclefriendlyfire);
	#endif
	
	new string[128];
	if(nametagdistance != TXT_DRAW_DISTANCE && nametagdistance != 70.0)
	{
		format(string, sizeof(string), "[AC] %s(%d) possible wallhack detected [nametagdistance: %.3f]",
		PlayerName(playerid), playerid, nametagdistance);
		SendSystemMessage(string);
	}
	if(lagcomp) // server lagcomp mode
	{
		if(!lagcompmode)
		{
			format(string, sizeof(string), "[AC] %s(%d) client connected with incorrect lagcomp mode",
			PlayerName(playerid), playerid, nametagdistance);
			SendSystemMessage(string);
		}
	} else {
		if(lagcompmode)
		{
			format(string, sizeof(string), "[AC] %s(%d) client connected with incorrect lagcomp mode",
			PlayerName(playerid), playerid, nametagdistance);
			SendSystemMessage(string);
		}
	}
	
	new server_onfoot_rate = GetServerVarAsInt("onfoot_rate");
	new server_incar_rate = GetServerVarAsInt("incar_rate");
	new server_weapon_rate = GetServerVarAsInt("weapon_rate");
	
	if(onfoot_rate != server_onfoot_rate || incar_rate != server_incar_rate ||
	weapon_rate != server_weapon_rate){
		format(string, sizeof(string), "[AC] %s(%d) client connected with incorrect rate data",
		PlayerName(playerid), playerid);
		SendSystemMessage(string);
		KickPlayerEx(playerid, "incorrect rate");
	}
}
#endif

public OnPlayerStateChange(playerid, newstate, oldstate)
{
    if(oldstate == PLAYER_STATE_ONFOOT && newstate == PLAYER_STATE_DRIVER) 
    {
		if(CWmode && GetPlayerVirtualWorld(playerid) == 0)
		{
			new vehicleid = GetPlayerVehicleID(playerid);
			DestroyVehicle(vehicleid);
		}
    }
	// Set Player Attachments
	if(oldstate == PLAYER_STATE_SPAWNED && newstate == PLAYER_STATE_ONFOOT)
	{
		if(GetPVarInt(playerid, "Mobile") && GetPVarInt(playerid, "Admin") < 3)
		{
			KickPlayerEx(playerid, "Mobile client");
			return 0;
		}
		if(GetPlayerVirtualWorld(playerid) == 0)
		{
			SetPlayerWeather(playerid, pData[playerid][pWeather]); 
			SetPlayerTime(playerid,pData[playerid][pHour],0);
		}
		if(!HideAttachesOnCW)
		{
			if(pData[playerid][pAttachSlot0] != -1) {
				PlayerAttachments(playerid, 0, pData[playerid][pAttachSlot0], false);
			}
			if(pData[playerid][pAttachSlot1] != -1) {
				PlayerAttachments(playerid, 1, pData[playerid][pAttachSlot1], false);
			}
			if(pData[playerid][pAttachSlot2] != -1) {
				PlayerAttachments(playerid, 2, pData[playerid][pAttachSlot2], false);
			}
			if(pData[playerid][pAttachSlot3] != -1) {
				PlayerAttachments(playerid, 3, pData[playerid][pAttachSlot3], false);
			}
		}
	}
	// Toggle player bars in spectate mode (flymode, specmode, mapselect)
	if(newstate == PLAYER_STATE_SPECTATING)
	{
		PlayerTextDrawHide(playerid, FPSBAR[playerid]);
		PlayerTextDrawHide(playerid, Commands[playerid]);
		PlayerTextDrawHide(playerid, TDlagmode[playerid]);
		PlayerTextDrawHide(playerid, PlayerHp[playerid]);
		PlayerTextDrawHide(playerid, PlayerArmour[playerid]);
		SetPVarInt(playerid, "ShowTimetxd", -1);
		SetPVarInt(playerid, "ShowScoretxd", -1);
	}
	if(oldstate == PLAYER_STATE_SPECTATING)
	{
		RefreshHud(playerid);
		SetPVarInt(playerid, "specbar", -1);
		PlayerTextDrawHide(playerid, TDspecbar[playerid]);
		PlayerTextDrawHide(playerid, TDspecbarDynBox[playerid]);
	}
	
	if(newstate == PLAYER_STATE_DRIVER) 
	{
		new worldid = GetPlayerVirtualWorld(playerid);
		if(World[worldid][wVehicleFix])
		{
			SendNotify(playerid,
			"Press ~g~<2>~w~ to autotune vehicle~n~Press ~g~<H>~w~ to flip", 4);
		}
	}
	
	if(oldstate == PLAYER_STATE_DRIVER)
	{
		if(DestroyVehAfterEx) DestroyVehicle(GetPVarInt(playerid, "Vehicle"));
		if(noclipdata[playerid][cameramode] == CAMERA_MODE_VEH)
		{
			SetCameraBehindPlayer(playerid);
			noclipdata[playerid][cameramode] = CAMERA_MODE_VEH;
			DestroyObject(noclipdata[playerid][flyobject]);
			noclipdata[playerid][flyobject] = CAMERA_MODE_NONE;
		}
		
		new worldid = GetPlayerVirtualWorld(playerid);
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			if(World[worldid][wGamemode] == GAMEMODE_WOT
			|| World[worldid][wGamemode] == GAMEMODE_DERBY)
			{
				PutPlayerInVehicle(playerid, GetPVarInt(playerid, "Vehicle"), 0);
			}
		}
	}
	
	// GBUG fix
	if(newstate == PLAYER_STATE_PASSENGER)
	{
		new vehicleid = GetPlayerVehicleID(playerid);
		new vehlastdriver = -1;
		foreach(Player, i)
		{
			if(IsPlayerInVehicle(i, vehicleid) && GetPlayerState(i) == PLAYER_STATE_DRIVER) 
			{
				vehlastdriver = i;
			}
		}
		if(vehlastdriver == -1) RemovePlayerFromVehicle(playerid);
	}
    return 1;
}

public OnPlayerInteriorChange(playerid, newinteriorid, oldinteriorid)
{
	foreach(Player, i)
	{
		if(GetPVarInt(i, "Spected"))
		{
			if(GetPVarInt(i, "Specing") == playerid) SetPlayerInterior(i, newinteriorid);
		}
	}
	return 1;
}

public OnPlayerSpawn(playerid)
{	
	if(!GetPVarInt(playerid, "firstspawn"))
	{
		SetPVarInt(playerid, "firstspawn",1);
	}
	
	if(GetPlayerVirtualWorld(playerid) != 0)
	{
		if(!World[GetPlayerVirtualWorld(playerid)][wMapRadar]) {
			GangZoneShowForPlayer(playerid, OffRadar, 0x000000FF);
		}
		else GangZoneHideForPlayer(playerid, OffRadar);
	}
	else GangZoneHideForPlayer(playerid, OffRadar);
	
	// BottomBar
	switch(pData[playerid][pBottombar])
	{
		case 0: //default 
		{
			TextDrawUseBox(TD[playerid], 1);
			TextDrawShowForPlayer(playerid, TD[playerid]);
		}
		case 1: //hide 
		{
			TextDrawHideForPlayer(playerid, TD[playerid]);
		}
		case 2: //no background
		{
			TextDrawUseBox(TD[playerid], 0);
			TextDrawShowForPlayer(playerid, TD[playerid]);
		}
		case 3:  //alternative style
		{
			TextDrawShowForPlayer(playerid, TD[playerid]);
		}
	}
	if(GetPlayerVirtualWorld(playerid) != 0) TextDrawHideForPlayer(playerid, TD[playerid]);
	
	// Show texdraws (HP, FPS, cmdhelp ,mode)
	if(pData[playerid][pFpsbar] > 0) PlayerTextDrawShow(playerid, FPSBAR[playerid]);
	if(pData[playerid][pHud] > 0) PlayerTextDrawShow(playerid, Commands[playerid]);
	if(pData[playerid][pHud] > 0) PlayerTextDrawShow(playerid, TDlagmode[playerid]);
	if(pData[playerid][pDtbar] > 0) PlayerTextDrawShow(playerid, TDdatetime[playerid]);
	#if defined _INC_WEAPON_CONFIG
		// Show or hide health bar for player.
		EnableHealthBarForPlayer(playerid, true);
	#endif
	
	// Preload anims
	if(!gPlayerAnimLibsPreloaded[playerid]) {
   		ApplyAnimation(playerid,"BOMBER","null",0.0,0,0,0,0,0);
    	ApplyAnimation(playerid,"BEACH","null",0.0,0,0,0,0,0);
    	ApplyAnimation(playerid,"GANGS","null",0.0,0,0,0,0,0);
   		ApplyAnimation(playerid,"SMOKING","null",0.0,0,0,0,0,0);
    	ApplyAnimation(playerid,"FOOD","null",0.0,0,0,0,0,0);
    	ApplyAnimation(playerid,"ON_LOOKERS","null",0.0,0,0,0,0,0);
    	ApplyAnimation(playerid,"DEALER","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"CRACK","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"GRAVEYARD","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"CHAINSAW","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"SWEET","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"KNIFE","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"MISC","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"CARRY","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"CASINO","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"PED","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"PLAYIDLES","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"SHOP","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"STRIP","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"RIOT","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"PARK","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"INT_HOUSE","null",0.0,0,0,0,0,0);
		ApplyAnimation(playerid,"RAPPING","null",0.0,0,0,0,0,0);
		gPlayerAnimLibsPreloaded[playerid] = 1;
	}
	
	SetPVarFloat(playerid, "LastHP", GameHealth + 0.000001);
    SetPlayerVirtualWorld(playerid, GetPVarInt(playerid, "world"));
	SetPlayerDrunkLevel(playerid, Drunk);
	
	if (score[0] == Roundkills || score[1] == Roundkills)
	{
	    PlayerPlaySound(playerid, 1185, 0.0, 0.0, 0.0);
	    SetPlayerInterior(playerid, 0);
	    TogglePlayerControllable(playerid, false);
		SetPlayerPos(playerid, 1373.6, 2175.2, 11.1);
		SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DANCE1);
		SetPlayerCameraPos(playerid, 1379.0, 2180.6, 12.0);
		SetPlayerCameraLookAt(playerid, 1383.6, 2185.2, 10.0);
	    return true;
	}
	
	if (GetPVarInt(playerid, "RestoreFlymode") == 1)
	{
		SetTimerEx("FlyMode", 300, false, "i", playerid);
		SetPlayerCameraPos(playerid, CwMaps[Map][2][0], CwMaps[Map][2][1], CwMaps[Map][2][2]); 
		DeletePVar(playerid, "RestoreFlymode");
		return true;
	}
	
	new team = GetPVarInt(playerid, "Team");
	if(GetPlayerVirtualWorld(playerid) != 0)
	{
		ResetPlayerWeapons(playerid);
		if(World[GetPlayerVirtualWorld(playerid)][wWeapons])
		{
			GiveVirtualWorldWeapons(playerid);
		}
		SetPlayerTeam(playerid, NO_TEAM);
	} else {
		if (team < 2)
		{
			if (!frz)
			{
				for(new w = 0; w < sizeof(Skill); w++) SetPlayerSkillLevel(playerid, w, Skill[w]);
				// dirty dmgfix
				if (AntiTK) {
					SetPlayerTeam(playerid, GetPVarInt(playerid, "Team"));
				} else {
					SetPlayerTeam(playerid, NO_TEAM);
				}
				ResetPlayerWeapons(playerid);
				//RestorePlayerWeapons(playerid);
				GiveDefaultWeapons(playerid);
			}
		} else {
			CheckSpec(playerid);
		}
	}
	
	if (!Marker && team < 2) HidePlayerMarker(playerid, 0);
	
    if (GetPVarInt(playerid, "Spected"))
    {
        SetTimerEx("Spec", 300, false, "i", playerid);
	}
	
	// related to the Sync() function, do not move or delete.
    if (GetPVarInt(playerid, "UnBug"))
	{
	    SetPlayerPos(playerid, pData[playerid][pSyncX],
		pData[playerid][pSyncY], pData[playerid][pSyncZ]);
		SetPlayerFacingAngle(playerid, pData[playerid][pSyncA]);
		//SetPlayerVelocity(playerid, syncveloX, syncveloY, syncveloZ);
		SetCameraBehindPlayer(playerid);
		SetPVarInt(playerid, "UnBug", false);
		pData[playerid][pSyncX]  = 0.0;
		return true;
	}

	if (GameHealth > 100)
	{
	    SetPlayerHealth(playerid, 100.0);
	    SetPlayerArmour(playerid, GameHealth -100);
	}else{
	    SetPlayerHealth(playerid, GameHealth);
	    SetPlayerArmour(playerid, 0.0);
	}
	
	//new world = GetPVarInt(playerid, "world");
	new worldid = GetPlayerVirtualWorld(playerid);
	if(GetPlayerVirtualWorld(playerid) != 0)
	{
		if(World[worldid][wSpawnPoint])
		{
			SetPlayerPos(playerid, World[worldid][wSpawnX]+random(5),
			World[worldid][wSpawnY]+random(5), World[worldid][wSpawnZ]);
			SetPlayerFacingAngle(playerid, World[worldid][wSpawnA]);
			SetPlayerInterior(playerid, World[worldid][wSpawnInterior]);
		} else {
			new map = World[worldid][wMap];
			SetPlayerPos(playerid, CwMaps[map][team][0]+random(2),
			CwMaps[map][team][1]+random(2), CwMaps[map][team][2]);
			SetPlayerFacingAngle(playerid, CwMaps[map][team][3]);
			SetPlayerInterior(playerid, MapInterior[map]);
			//SetPlayerVirtualWorld(playerid, world);
		}
	} else {
		SetPlayerPos(playerid, CwMaps[Map][team][0]+random(2),
		CwMaps[Map][team][1]+random(2), CwMaps[Map][team][2]);
		SetPlayerFacingAngle(playerid, CwMaps[Map][team][3]);
		SetPlayerInterior(playerid, MapInterior[Map]);
	}
    SetCameraBehindPlayer(playerid);
	
	if(World[worldid][wGamemode] == GAMEMODE_DM)
	{
		if(World[worldid][wRandSpawn] == 1)
		{
			new Float:RandomSpawn[][5] = { // LV baseball
