			return true;
		}
		
		if (GetPlayerVirtualWorld(playerid) == 0 && GetPVarInt(playerid, "Admin") < 2)
		{
			return false;
		}
		
		if (GetPVarInt(playerid, "Admin") >= 2 && worldid == 0)
		{
			for(new i = GetVehiclePoolSize() +1; --i != 0;) SetVehicleToRespawn(i);
		}
		
		if(GetPlayerVirtualWorld(playerid) != 0 && WorldModerator[playerid])
		{
			for(new i = GetVehiclePoolSize() +1; --i != 0;) 
			{
				if(GetVehicleVirtualWorld(i) == worldid) SetVehicleToRespawn(i);
			}
		}
		
		if(worldid != 0)
		{
