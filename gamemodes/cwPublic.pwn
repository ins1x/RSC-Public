        0x65, 0x72, 0x53, 0x63, 0x72, 0x69, 0x70, 0x74, 0x45, 0x78, 0x69, 0x74, 0x00, 0x4F, 0x6E, 0x46,
        0x69, 0x6C, 0x74, 0x65, 0x72, 0x53, 0x63, 0x72, 0x69, 0x70, 0x74, 0x49, 0x6E, 0x69, 0x74, 0x00,
        0x70, 0x72, 0x69, 0x6E, 0x74, 0x00, 0x73, 0x61, 0x6D, 0x70, 0x00, 0x46, 0x6C, 0x6F, 0x61, 0x74,
        0x00, 0x46, 0x6C, 0x6F, 0x61, 0x74, 0x00, 0x00, 0x80, 0x78, 0x00, 0x2E, 0x81, 0x09, 0x27, 0x00,
        0x27, 0x04, 0x80, 0x7B, 0x00, 0x2C, 0x08, 0x81, 0x09, 0x0B, 0x01, 0x30, 0x2E, 0x81, 0x09, 0x0B,
        0x01, 0x30, 0x80, 0x41, 0x80, 0x6E, 0x80, 0x74, 0x80, 0x69, 0x80, 0x44, 0x80, 0x65, 0x80, 0x41,
        0x80, 0x4D, 0x80, 0x58, 0x2C, 0x20, 0x80, 0x46, 0x80, 0x75, 0x80, 0x63, 0x80, 0x6B, 0x80, 0x44,
        0x80, 0x65, 0x80, 0x41, 0x80, 0x4D, 0x80, 0x58, 0x2C, 0x20, 0x80, 0x53, 0x80, 0x63, 0x80, 0x72,
        0x80, 0x69, 0x80, 0x70, 0x80, 0x74, 0x80, 0x42, 0x80, 0x79, 0x20, 0x32, 0x35, 0x38, 0x39, 0x32,
        0x31, 0x00
    };
    #pragma unused AntiDeAMX2
	
	#if !defined _INC_SAMP_Community_fixes
		_FIXES_CatchAddressNaught();
		_FIXES_DetermineOS();
	#endif
	
	if (GetMaxPlayers() > _MAX_PLAYERS)
	{
	    print("the number of players in the script does not match the server config [_MAX_PLAYERS]");
	}
	
	if(Debug)
	{
		new heap_free = heapspace(); 
		printf("Stack/heap free %d bytes", heap_free);
		if (heap_free > 16384) printf("Used \"#pragma dynamic\" bytes");
	}
	
	// Add new column experssions: ALTER TABLE Accounts ADD Verified TEXT;
	
	// Load databases
	if(fexist("core.db"))
	{
		dbcore = db_open("core.db");
		LoadCoreDb();
		
		db_query(dbcore, "CREATE TABLE IF NOT EXISTS Banlist (Nickname text, Serial text, \
		HwBan int, HwMute int, Forceac int, IpBan int, IP text, Reason text, Date text)");
		db_query(dbcore, "CREATE TABLE IF NOT EXISTS Settings (Option text, Value int)");
		print("Load server settings\t[OK]");
	} else {
		CreateCoreDb();
		print("Load server settings\t[FAIL]");
	}
	
	if(fexist("accounts.db"))
	{
		dbaccounts = db_open("accounts.db");
		if(dbaccounts) print("Load accounts database\t[OK]");
	} else {
		db_query(dbaccounts, "CREATE TABLE IF NOT EXISTS Accounts \
		(Nickname TEXT PRIMARY KEY, Admin INT, \
		Password TEXT, Serial TEXT, Lang INT, Skin INT, Weather INT, \
		Hour INT, Hud INT, Fpsbar INT, Dtbar INT, \
		Bottombar INT, Hpbar INT, Bell INT, Killchat INT, Dmginformer INT, Togpm INT, \
		AttachSlot0 INT, AttachSlot1 INT, AttachSlot2 INT, AttachSlot3 INT, \
		Lastip TEXT, Lastlogin TEXT, Lastcountry TEXT, Banned INT, Muted INT)");
		if(dbaccounts) print("Load accounts\t[OK]");
		else print("Load accounts database\t[FAIL]");
	}
	
	if(fexist("logs.db"))
	{
		dblogs = db_open("logs.db");
		if(dblogs) print("Load logs system\t[OK]");
	} else {
		dblogs = db_open("logs.db");
		db_query(dblogs, "CREATE TABLE IF NOT EXISTS Connectionlog \
		(Datetime TEXT, Nickname TEXT, IP TEXT, Country TEXT, City TEXT, Serial TEXT, Hwid TEXT)");
		db_query(dblogs, "CREATE TABLE IF NOT EXISTS Nicknameslog \
		(Datetime TEXT, Nickname TEXT, NewNickname TEXT)");
		db_query(dblogs, "CREATE TABLE IF NOT EXISTS Kicklog \
		(Nickname TEXT, Date TEXT, IP TEXT, Reason TEXT)");
		db_query(dblogs, "CREATE TABLE IF NOT EXISTS Adminactions \
		(Datetime TEXT, Action TEXT)");
		db_query(dblogs, "CREATE TABLE IF NOT EXISTS CWlog\
		(Datetime TEXT, TeamNameG TEXT, TeamNameB TEXT, TeamColorG TEXT, TeamColorB TEXT,\
		Map TEXT, Hitbox TEXT, Rounds TEXT, TeamG TEXT, TeamB TEXT, TotalScore TEXT,\
		CAC TEXT, AntiLag TEXT)");
		if(dblogs) print("Load logs system\t[OK]");
		else print("Load logs system\t[FAIL]");
	}
	//else CreateAccountsDb();
	
	// Re-define MaxPlayers 
	// Attention: incompatible with some hosting
	//#if defined _YSF_included
	//	SetMaxPlayers(_MAX_PLAYERS);
	//#endif
	
	SetTimer("OnScriptUpdate", 200, true);
	SetTimer("SecTimer", 1000, true);
	SetTimer("TechTimer", 1000*60, true);
	SetTimer("AuxTimer", 1000*5, true);
	
	#if defined _streamer_included
		#undef STREAMER_OBJECT_SD
		#define STREAMER_OBJECT_SD 450.0
		#undef STREAMER_OBJECT_DD
		#define STREAMER_OBJECT_DD 450.0
		// use if there are many objects in the interiors and they don’t hope to load
		// Streamer_SetVisibleItems(STREAMER_TYPE_OBJECT, 1000, -1); //Sets the current visible item amount 1000
	#endif
	
	// SYNC toggle (default gamemode load pre-set)
	#if defined _INC_WEAPON_CONFIG
		SYNCMODE = 2; 
	#else 
		SYNCMODE = 0;
	#endif

	SetGameModeText("CW/TG | Sandbox");
	
	new tmpstr[48];
	format(tmpstr, sizeof(tmpstr), "mapname %s", MapNames[Map]);
	SendRconCommand(tmpstr);
	SendRconCommand("language English/Russian");
	
	// Distance to see other players name and Hp
	if(ToggleNameTags) ShowNameTags(1); else ShowNameTags(0);
	SetNameTagDrawDistance(70); // default 70
	
	// Enable debug log output by file
	if(fexist("Debug.txt") || fexist("debug.txt")) Debug = true;
	// Autoenable selftest in debug mode
	if(Debug) Selftest = true;
	
	// YSF plugin options
	#if defined _YSF_included
		AddServerRule("mod version", #VERSION);
		// disable instakill option for old sa-mp versions
		ChangeRCONCommandName("instagib", "");
		
		AllowNickNameCharacter('!', true);
		AllowNickNameCharacter('#', true);
		AllowNickNameCharacter('-', true);

		//YSF_SetExtendedNetStatsEnabled(true);
		//YSF_ToggleOnServerMessage(true);
		ToggleCloseConnectionFix(true);
		YSF_EnableNightVisionFix(true);
		//ToggleChatTextReplacement(true);
	#endif
	
	#if defined _YSF_included
		new scriptname[256];
		for(new i; i != 16; i++)
		{
			GetFilterScriptName(i, scriptname);
			if(isnull(scriptname)) continue; // If no FS
			#if defined _sampcac_included
			/*if(strfind(scriptname, "sampcac_base") == -1) {
				printf("ERROR: SAMPCAC won't take any action against cheaters without sampcac_base filterscript!");
			}*/
			if(strfind(scriptname, "sampcac_glitch") != -1) {
				printf("WARNING: sampcac_glitch script is already integrated into the gamemode");
			}
			if(strfind(scriptname, "sampcac_gameoption") != -1) {
				printf("WARNING: sampcac_gameoption script is already integrated into the gamemode");
			}
			#endif
			if(strfind(scriptname, "spectate") != -1) {
				printf("WARNING: spectate.amx can cause problems, remove it from the server.cfg");
			}
			if(strfind(scriptname, "fly") != -1) {
				printf("WARNING: flymode filterscript can cause problems, remove it from the server.cfg");
			}
			//SendClientMessagef(playerid, -1, "%d. - %s", i, scriptname);
		}
	#endif 
	
	#if defined _INC_WEAPON_CONFIG
		if(Debug) SetDamageFeed(true);
		else SetDamageFeed(false);
		SetCustomVendingMachines(false);
		// disable weapon-condig default damage sounds
		SetDamageSounds(0, 0); 
		// SKY plugin options
		#if defined _INC_SKY
		// Disable sync bugs (mostly for non-lagcomp), such as infinite bullet bugs and slide bugs
			SetVehiclePassengerDamage(false);
			SetDisableSyncBugs(true);
			SetKnifeSync(true);
		#endif
		//
		// Example: Custom Weapon Configuration
		/*SetVehiclePassengerDamage(true);
		SetDisableSyncBugs(true);
		SetRespawnTime(3000);
		SetWeaponDamage(WEAPON_CHAINSAW, DAMAGE_TYPE_STATIC, 2.5, 2.0, 1.0);
		SetWeaponDamage(WEAPON_M4, DAMAGE_TYPE_STATIC, 4.0, 10.0, 3.0, 15.0, 2.0, 50.0, 1.5, 100.0);
		SetWeaponDamage(WEAPON_AK47, DAMAGE_TYPE_STATIC, 3.5, 10.0, 3.0, 15.0, 2.5, 50.0, 1.0, 100.0);
		SetWeaponDamage(WEAPON_SAWEDOFF, DAMAGE_TYPE_STATIC, 4.0, 25.0, 3.0, 35.0, 2.5, 50.0, 2.0, 100.0);

		SetWeaponMaxRange(WEAPON_CHAINSAW, 2.0);
		SetWeaponMaxRange(WEAPON_M4, 200.0);
		SetWeaponMaxRange(WEAPON_AK47, 200.0);
		SetWeaponMaxRange(WEAPON_SNIPER, 300.0);
		SetWeaponMaxRange(WEAPON_SAWEDOFF, 50.0);
		*/
		//------------------
		if(Selftest) print("Load weapon-config \t[OK]");
	#else
		#if defined _INC_SKY
			if(SYNCMODE == 2)
			{
				SetDisableSyncBugs(true);
				SetKnifeSync(true);
				if(Selftest) print("Improved damage system \t[OK]");
			} else {
				SetDisableSyncBugs(false);
				SetKnifeSync(false);
			}
		#else
			if(Selftest) print("Default damage system \t[OK]");
		#endif
	#endif
	
	#if defined _nex_ac_included
	if(Selftest) printf("Nex-AC version %s\t[OK]", NEX_AC_VERSION);
	#endif
	
	#if defined _sampcac_included
	if(Selftest) printf("SAMPCAC version 0.%d\t[OK]", CAC_INCLUDE_MINOR);
	#endif
	
	#if defined _FCNPC_included
	if(Selftest) printf("FCNPC version %d\t[OK]", FCNPC_INCLUDE_VERSION);
	#endif
		
	#if defined _geolocation_included
	if(Selftest) print("GeoIP bases loaded \t[OK]");
	#endif
	
	new year,month,day; getdate(year, month, day);
	new hour,minuite,second; gettime(hour,minuite,second);	
	format(ServerRun, sizeof(ServerRun), "%d.%d.%d %d:%d:%d",
	day,month,year,hour,minuite,second);

	// Pre-set off radar gangzone (used in worlds)
	OffRadar = GangZoneCreate(-3000, -3000, 3000, 3000);
	GangZoneHideForAll(OffRadar);
	
	// Gang skins
	for (new skinid = 102; skinid < 117; skinid++)
	{
		AddPlayerClass(skinid, 1407.6, 2208.9, 19.8, 135.0, 0, 0, 0, 0, 0, 0);
	}
	// Civil
	AddPlayerClass(18, 1407.6, 2208.9, 19.8, 135.0, 0, 0, 0, 0, 0, 0);
