			return true;
		}
		if (!strcmp(cmdtext[6], "off", true))
		{
			if (speconly)
			{
				SendClientMessageEx(playerid, COLOR_GREY, "В данный момент наблюдатели обязаны оставаться в режиме наблюдения.", "Spectators are required to use spectate mode right now.");
				SendClientMessageEx(playerid, COLOR_GREY,
