						"{FFFFFF}Enter the animation in the format {FFD700}[animlib] [animname]\n\
						{FFFFFF}For example: {FFD700}PED ATM\n\
						{FFFFFF}List of animations: {FFD700}https://www.open.mp/docs/scripting/resources/animations",
						"Set", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 373, DIALOG_STYLE_INPUT,
						"Set actor animation",
						"{FFFFFF}Введите анимацию в формате {FFD700}[animlib] [animname]\n\
						{FFFFFF}Например: {FFD700}PED ATM\n\
						{FFFFFF}Список анимаций: {FFD700}https://www.open.mp/docs/scripting/resources/animations",
						"Применить", "Отмена");
					}
				}
				case 3:
				{
					#if defined _streamer_included
						if(!IsValidDynamicActor(ChosenActor[playerid]))
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Вы не выбрали актера","You didn't choose an actor");
							return false;
						}
						ClearDynamicActorAnimations(ChosenActor[playerid]);
					#endif
					WORLD_EDITACTORS(playerid);
				}
				case 4:
				{
					#if defined _streamer_included
						if(!IsValidDynamicActor(ChosenActor[playerid]))
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Вы не выбрали актера","You didn't choose an actor");
							return false;
						}
						new Float:ang;
						GetPlayerFacingAngle(playerid, ang);
						ang = ang - 180;
						SetDynamicActorFacingAngle(ChosenActor[playerid], ang);
					#endif
					WORLD_EDITACTORS(playerid);
				}
				case 5:
				{
					#if defined _streamer_included
						if(!IsValidDynamicActor(ChosenActor[playerid]))
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Вы не выбрали актера","You didn't choose an actor");
							return false;
						}
						
						new Float:x, Float:y, Float:z;
						GetPlayerPos(playerid, x,y,z);
						//GetPlayerFacingAngle(playerid, angle);
						GetXYInFrontOfPlayer(playerid, x, y, 1.5);
						SetDynamicActorPos(ChosenActor[playerid], x, y, z);
					#endif
					WORLD_EDITACTORS(playerid);
				}
				case 6:
				{
					#if defined _streamer_included
						if(!IsValidDynamicActor(ChosenActor[playerid]))
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Вы не выбрали актера","You didn't choose an actor");
							return false;
						}
						
						if(GetDynamicActorVirtualWorld(ChosenActor[playerid]) == worldid 
						&& IsValidDynamicActor(ChosenActor[playerid]))
						{
							DestroyDynamicActor(ChosenActor[playerid]);
						}
					#endif
					WORLD_EDITACTORS(playerid);
				}
			}
		}
		else WORLD_ACTORS(playerid);
	}
	if(dialogid == 372) 
	{
		if(response)
		{
			if(!strlen(inputtext) || !isnumeric(inputtext))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное значение", "Incorrect value");
				return WORLD_EDITACTORS(playerid);
			}
			
			new string[64];
			new actorid = strval(inputtext);
			new worldid = GetPlayerVirtualWorld(playerid);
			
			#if defined _streamer_included
			if(IsValidDynamicActor(actorid) 
			&& GetDynamicActorVirtualWorld(actorid) == worldid)
			{
				ChosenActor[playerid] = actorid;
				format(string, sizeof(string), "You choose actor %i to edit", actorid);
				SendClientMessage(playerid, COLOR_GREY, string);
			}
			#endif
			WORLD_EDITACTORS(playerid);
		}
		else WORLD_EDITACTORS(playerid);
	}
	if(dialogid == 373) 
	{
		if(response)
		{
			#if defined _streamer_included
				if(!IsValidDynamicActor(ChosenActor[playerid]))
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Вы не выбрали актера","You didn't choose an actor");
					return false;
				}
				new tmp[128], idx;
				tmp = strtok(inputtext, idx);
				new animname[32], aniimlib[32];
				if (!strlen(tmp)) {
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Использование: [animlib] [animname]", "Use: [animlib] [animname]");
				}
				format(aniimlib, 32, "%s", tmp);
				tmp = strtok(inputtext, idx);
				if (!strlen(tmp)) {
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Использование: [animlib] [animname]", "Use: [animlib] [animname]");
				}
				format(animname, 32, "%s", tmp);
				ApplyDynamicActorAnimation(ChosenActor[playerid],aniimlib,animname,4.1,1,1,1,0,0);
			#endif
			WORLD_EDITACTORS(playerid);
		}
		else WORLD_EDITACTORS(playerid);
	}
