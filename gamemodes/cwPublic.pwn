		}
	}
	
	return 1;
}

public OnPlayerPickUpDynamicPickup(playerid, pickupid)
{
	new worldid = GetPlayerVirtualWorld(playerid);
	
	if(pickupid == CostumePickup)
	{
		CostumesMenu(playerid);
	}
	if(WorldFlagsRedTeam[worldid])
	{
		if(GetPVarInt(playerid, "Team") == WORLD_TEAM_BLUE)
		{
			SendClientMessageToVirtualWorld(worldid, COLOR_RED,
			"Захвачен флаг красной команды", "The flag of the red team has been captured");
			SetPlayerAttachedObject(playerid, 0, 19607, 1, 0.940999, 0.038999, 0.012000, 0.000000,
			88.499984, 0.000000,  0.538999, 0.319999, 0.356000); // 19605
			DestroyDynamicCP(WorldFlagsRedTeam[worldid]);
		} else {
			SendClientMessageToVirtualWorld(worldid, COLOR_RED,
			"Защищайте флаг своей команды", "Protect your team's flag");
		}
		return 1;
	}
	if(WorldFlagsBlueTeam[worldid])
	{
		if(GetPVarInt(playerid, "Team") == WORLD_TEAM_RED)
		{
			SendClientMessageToVirtualWorld(worldid, COLOR_BLUE,
			"Захвачен флаг синей команды", "The flag of the blue team has been captured");
			SetPlayerAttachedObject(playerid, 0, 19605, 1, 0.940999, 0.038999, 0.012000, 0.000000,
			88.499984, 0.000000,  0.538999, 0.319999, 0.356000); // 19605
			DestroyDynamicCP(WorldFlagsBlueTeam[worldid]);
		} else {
			SendClientMessageToVirtualWorld(worldid, COLOR_BLUE,
			"Защищайте флаг своей команды", "Protect your team's flag");
		}
		return 1;
	}
	return 1;
}


#endif

public OnPlayerClickMap(playerid, Float:fX, Float:fY, Float:fZ)
{
	new tmpstr[64];
	
	if(CWmode || GetPlayerVirtualWorld(playerid) == 0) return 0;

	new worldid = GetPlayerVirtualWorld(playerid);
	if(GetPlayerVirtualWorld(playerid) != 0)
	{
		if(!World[worldid][wTeleports] && playerid != WorldModerator[playerid]) return 0;
	}
	
	switch(GetPlayerState(playerid))
	{
		case PLAYER_STATE_SPECTATING:
		{
			SetPlayerObjectPos(playerid, noclipdata[playerid][flyobject], fX, fY, fZ+1.0);
		}
		case PLAYER_STATE_DRIVER: SetVehiclePos(GetPlayerVehicleID(playerid), fX, fY, fZ);
		case PLAYER_STATE_ONFOOT: SetPlayerPosFindZ(playerid, fX, fY, fZ); 
		default: return 0;
	}
	
	format(tmpstr, sizeof(tmpstr),
	"~w~x:~g~%.2f ~w~y:~g~%.2f ~w~z:~g~%.2f", fX, fY, fZ+1.0);
	SendNotify(playerid, tmpstr, 5);
	
    return 1;
}

public OnPlayerText(playerid, text[])
{
	// nologin == no text messages
	if(Kicked[playerid]) return false;
	if(GetPVarInt(playerid, "Logged") <= 0)
	{
		SendClientMessage(playerid, COLOR_GREY, "You are not logged in");
		return false;
	}
	
	if (pData[playerid][pMuted] > 0)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Вы заглушены и не можете говорить.", "You can't speak, you're muted.");
		return false;
	}
	
	if(GetPVarInt(playerid,"Hwmuted"))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Вы заглушены и не можете говорить.", "You can't speak, you're muted.");
		return false;
	}
	
	if(ServerAntiSpam)
	{
		if(strfind(Antispam[playerid], text, false) != -1)
		{
			SetPVarInt(playerid, "Chatrepeat", GetPVarInt(playerid, "Chatrepeat") + 1);
			if(GetPVarInt(playerid, "Chatrepeat") >= 3)
			{
				new string[128], stringru[128];
				// you repeated this message 3 times now. Do not repeat your message
				format(string, sizeof(string),
				"Server has muted player %s(%d) for 5 minutes (reason: Flood[3])",
				PlayerName(playerid), playerid);
				format(stringru, sizeof(stringru),
				"Сервер заглушил игрока %s(%d) на 5 минут (причина: Flood[3])",
				PlayerName(playerid), playerid);
				pData[playerid][pMuted] = 5*60; //unix time + min
				SendClientMessageToAllEx(COLOR_GREY, stringru, string);
				return 0;
			}
		}
		else SetPVarInt(playerid, "Chatrepeat", 0);

		strmid(Antispam[playerid], text, 0, strlen(text), 144);
	}
	
	// default spam checker (Flooder.cs)
	new tick = GetTickCount();
	if (tick -GetPVarInt(playerid, "PreviousMess1") < 500)
	{
		KickPlayerEx(playerid, "Spam");
		return false;
	}
	SetPVarInt(playerid, "PreviousMess1", GetPVarInt(playerid, "PreviousMess0"));
	SetPVarInt(playerid, "PreviousMess0", tick);
	
	// no empty text on common chat
	if(isempty(text)) return 0;
	
	// emotions
	else if(text[0]==')' && text[1]==')')
	{
		SetPlayerChatBubble(playerid, "(>_<)", COLOR_GREY, 50.0, 5000);
	}
	else if(text[0]==')')
	{
		SetPlayerChatBubble(playerid, ":D", COLOR_GREY, 50.0, 5000);
	}

	if(text[0]=='(' && text[1]=='(')
	{
		SetPlayerChatBubble(playerid, "(-_-)", COLOR_GREY, 50.0, 5000);
	}
	else if(text[0]=='(')
	{
		SetPlayerChatBubble(playerid, ":(", COLOR_GREY, 50.0, 5000);
	}
	
	if(text[0] == '.')//point to slash
	{
		text[0] = '/';
		OnPlayerCommandText(playerid,text);
		return 0; 
	}
	if(text[0] == '?')//question to slash
	{
		text[0] = '/';
		OnPlayerCommandText(playerid,text);
		return 0; 
	}
	if (text[0] == '!') // teamchat
	{
		new string[128], nickname[MAX_PLAYER_NAME];
		GetPlayerName(playerid, nickname, MAX_PLAYER_NAME);
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"В мире командный чат недоступен","Team chat is not available in the virtual world");
			return false;
		}
		foreach(Player, i)
		{
			if (GetPVarInt(playerid, "Team") == GetPVarInt(i, "Team")
			&& GetPlayerVirtualWorld(i) == 0)
			{	
				if(GetPVarInt(i, "Team") == TEAM_GREEN) {
					format(string, sizeof(string), "(%s chat) %s: %s", ClanName[0], nickname, text[1]);
				}
				if(GetPVarInt(i, "Team") == TEAM_BLUE) {
					format(string, sizeof(string), "(%s chat) %s: %s", ClanName[1], nickname, text[1]);
				}
				if(GetPVarInt(i, "Team") == TEAM_SPEC) {
					format(string, sizeof(string), "(Spec chat) %s: %s", nickname, text[1]);
				}
				
				if(!GetPVarType(i, "HideTeamChat"))
				{
					SendClientMessage(i, 0xB5FF4AAA, string);
					PlayerPlaySound(i, 45400, 0.0, 0.0, 0.0);// clan chat sound
				}
				continue;
			}
		}
		return false;
	}
	
	if (text[0] == '*') // worldsay
	{
		if (GetPlayerVirtualWorld(playerid) != 0 && WorldModerator[playerid])
		{
			if (isempty(text[1])) {
				return 0;
			}
			if(strlen(text[1]) > 128) {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Слишком длинное сообщение!","Too long message");
				return 0;
			}
			new string[128];
			format(string, 128, "Moderator: %s", text[1]);
			SendClientMessageToVirtualWorld(GetPlayerVirtualWorld(playerid), 0x00ff00FF , string, string);
			return false;
		}
		if ( GetPlayerVirtualWorld(playerid) == 0 && GetPVarInt(playerid, "Admin") >= 3 )
		{
			if (isempty(text[1])) {
				return 0;
			}
			if(strlen(text[1]) > 128) {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Слишком длинное сообщение!","Too long message");
				return 0;
			}
			new string[128];
			format(string, 128, "Admin: %s", text[1]);
			SendClientMessageToAll( 0xFFD700FF , string); // COLOR_GOLD
			foreach(Player, i) PlayerPlaySound(i, 31205, 0.0, 0.0, 0.0); // WINNER Sound
			return false;
		}
	}
	if (text[0] == '@') // adminchat
	{
		new string[128];
		GetPlayerName(playerid, string, MAX_PLAYER_NAME);
		format(string, sizeof(string), "{ff3333}(Admin-Chat) %s: %s", string, text[1]);
		if(GetPVarInt(playerid, "Admin") >= 1)
		{
			foreach(Player, i)
			{
				if (IsPlayerConnected(i) && GetPVarInt(i, "Admin") >= 1)
				{
					if(!GetPVarType(i, "HideAdminChat"))
					{
						SendClientMessage(i, COLOR_RED, string);
					}
					continue;
				}
			}
		}
		return false;
	}
	else
	{
		SetPVarInt(playerid, "spamcount", GetPVarInt(playerid, "spamcount") + 1);
		if(Mutespec && GetPVarInt(playerid, "Team") == 2)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете писать в общий чат, используйте командный чат !Text",
			"You can't use global chat right now, use team chat !Text");
			return false;
		}
		if(GetPlayerInterior(playerid) == 6 && GetPlayerVirtualWorld(playerid) == 66666) 
		{
			format(text, 128, "Gay %s(%d):{FFFFFF} %s", PlayerName(playerid), playerid, text);
			SendClientMessageToAll(0xFF0080FF, text);
			return false;
		}
		if(GetPVarInt(playerid, "clist") != -1 && CWmode == false)
		{
			format(text, 128, "%s(%d):{FFFFFF} %s", PlayerName(playerid), playerid, text);
			SendClientMessageToAll(playerClistColors[GetPVarInt(playerid, "clist")], text);
		} else {
			format(text, 128, "%s(%d):{FFFFFF} %s", PlayerName(playerid), playerid, text);
			if(GetPlayerVirtualWorld(playerid) != 0 || GetPVarType(playerid, "Lounge")) {
				SendClientMessageToAll(GetPlayerColor(playerid), text);
			} else {
				switch(GetPVarInt(playerid, "Team"))
				{
					case 0: SendClientMessageToAll(TCC[0], text);
					case 1: SendClientMessageToAll(TCC[1], text);
					case 2: SendClientMessageToAll(TCC[2], text);
					default: return false;
				}
			}
		}
	}
	return false;
}

public Countdown(num, world)
{
	// Run gametext counter 1,2,3 start
    new string[32];
    if (num > 0)
    {
		if (num > 2)
		{
			format(string, sizeof(string), "~y~ %d ~n~ %d ~n~~g~%d", num -2, num -1, num);
		} else if (num == 2) {
		    format(string, sizeof(string), "~y~START!~n~ %d ~n~~g~%d", num -1, num);
		} else {
		    format(string, sizeof(string), "~n~~y~START!~n~~g~%d", num);
		}
		
        for(new i = 0; i < MAX_PLAYER_ID; i++)
		{
			if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == world)
			{
				PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0);
				GameTextForPlayer(i, string, 1400, 4);
			}
		}
		
		SetTimerEx("Countdown", 1000, false, "ii", num -1, world);
	} else {
	    frz = false;
	    for(new i = 0; i < MAX_PLAYER_ID; i++)
		{
			if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == world)
			{
			    if (GetPVarInt(i, "Team") < 2)
			    {
			        if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
        			{
        			    if (GetPVarInt(i, "frz"))
        			    {
	        			    //ClearAnimations(i);
	        			    TogglePlayerControllable(i, true);
	        			    SetPVarInt(i, "frz", false);
			    		}
					}
				}
			
				
				if(CWmode && pData[i][pSfx])
				{
					if(Round == 1) {
						if(pData[i][pSfx]) PlayAudioStreamForPlayer(i,
						"https://www.myinstants.com/media/sounds/mortal-kombat-9-sound-drop-round-1-fight.mp3");
					} else if(Round == 2) {
						if(pData[i][pSfx]) PlayAudioStreamForPlayer(i,
						"https://www.myinstants.com/media/sounds/round-2-fight-mortal-kombat-sound-effect.mp3");
					} else {
						if(pData[i][pSfx]) PlayAudioStreamForPlayer(i,
						"https://www.myinstants.com/media/sounds/prepare-to-fight.mp3");
					}

				}
				
				PlayerPlaySound(i, 1057, 0.0, 0.0, 0.0);
				format(string, sizeof(string), "~n~~n~~n~~g~START!");
				GameTextForPlayer(i, string, 1000, 4);
				
			}
		}
	    
	    if (CWmode)
		{
		    freeze_score = false;
		}
		SetTimerEx("RestoreRoundGuns", 3000, false, "i", world);
	}
	return true;
}

public Spec(playerid)
{
	if (!IsPlayerConnected(playerid)) return false;
	
	for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
	    if (GetPVarInt(i, "Team") == 2)
		{
			if (GetPVarInt(i, "Specing") == playerid) PlayerSpectatePlayer(i, playerid);
		}
	}
	
	return true;
}

public OnPlayerClickPlayerTextDraw(playerid, PlayerText:playertextid)
{
	if(GetPVarInt(playerid, "skinc_active") == 0) return 0;

	new curpage = GetPVarInt(playerid, "skinc_page");
	
	// Handle: next button
	if(playertextid == gNextButtonTextDrawId[playerid]) {
	    if(curpage < (GetNumberOfPages() - 1)) {
	        SetPVarInt(playerid, "skinc_page", curpage + 1);
	        ShowPlayerModelPreviews(playerid);
         	UpdatePageTextDraw(playerid);
         	PlayerPlaySound(playerid, 1083, 0.0, 0.0, 0.0);
		} else {
		    PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
		}
		return 1;
	}
	
	// Handle: previous button
	if(playertextid == gPrevButtonTextDrawId[playerid]) {
	    if(curpage > 0) {
	    	SetPVarInt(playerid, "skinc_page", curpage - 1);
	    	ShowPlayerModelPreviews(playerid);
	    	UpdatePageTextDraw(playerid);
	    	PlayerPlaySound(playerid, 1084, 0.0, 0.0, 0.0);
		} else {
		    PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
		}
		return 1;
	}
	
	// Search in the array of textdraws used for the items
	new x=0;
	while(x != SELECTION_ITEMS) {
	    if(playertextid == gSelectionItems[playerid][x]) {
	        HandlePlayerItemSelection(playerid, x);
	        PlayerPlaySound(playerid, 1083, 0.0, 0.0, 0.0);
	        DestroySelectionMenu(playerid);
	        CancelSelectTextDraw(playerid);
        	SetPVarInt(playerid, "skinc_active", 0);
        	return 1;
		}
		x++;
	}
	
	return 0;
}

public OnPlayerClickTextDraw(playerid, Text:clickedid)
{
	// Even though only Player* textdraws are used in this script,
    // OnPlayerClickTextDraw is still required to handle ESC
   	if(GetPVarInt(playerid, "skinc_active") == 0) return 0;

	// Handle: They cancelled (with ESC)
	if(clickedid == Text:INVALID_TEXT_DRAW) {
        DestroySelectionMenu(playerid);
        SetPVarInt(playerid, "skinc_active", 0);
        PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
        return 1;
	}
	
	return 0;
}

public OnPlayerClickPlayer(playerid, clickedplayerid, source)
{
	if(playerid == INVALID_PLAYER_ID || playerid > _MAX_PLAYERS) return false;
	if(clickedplayerid == INVALID_PLAYER_ID || clickedplayerid > _MAX_PLAYERS) return false;
	ChosenPlayer[playerid] = clickedplayerid;
	new worldid = GetPlayerVirtualWorld(playerid);
	
	if (GetPVarInt(playerid, "Admin") >= 3) DOP_MENU(playerid);
	else if(WorldModerator[playerid] || World[worldid][wHosted] == playerid)
	{
		WORLD_TABMENU(playerid);
	}
	else PlayerStatistics(clickedplayerid, playerid);
	return true;
}

public OnPlayerCommandText(playerid, cmdtext[])
{
	new name[MAX_PLAYER_NAME];
    GetPlayerName(playerid, name, sizeof(name));
    new cmd[128], tmp[128], idx;
	cmd = strtok(cmdtext, idx);
	//SetPVarString(playerid, "LastCommand", cmdtext);
	new tick = GetTickCount();
    if (tick - GetPVarInt(playerid, "PreviousMess1") < 500)
	{
        KickPlayerEx(playerid, "Command spam");
		return false;
	}
	
	if(Kicked[playerid]) return true;
	if(GetPVarInt(playerid, "Logged") <= 0)
	{
		SendClientMessage(playerid, COLOR_GREY, "You are not logged in");
		return true;
	}
	
	if(GetPVarInt(playerid, "Lockcmds"))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Вам запрещено использовать команды", "Your commands have been blocked ");
		return true;
	}
	
	SetPVarInt(playerid, "PreviousMess1", GetPVarInt(playerid, "PreviousMess0"));
	SetPVarInt(playerid, "PreviousMess0", tick);
    
	printf("[cmd] [%s]: %s", name, cmdtext);
	
	// Main commands (Player commands)
	if (!strcmp(cmdtext, "/commands", true) || !strcmp(cmdtext, "/cmds", true) 
		|| !strcmp(cmdtext, "/cmd", true) || !strcmp(cmdtext, "/help", true))
	{
		Help(playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/whelp", true) || !strcmp(cmdtext, "/worldhelp", true)
		|| !strcmp(cmdtext, "/wcmds", true)) 
	{
		if(pData[playerid][pLang])
		{
			ShowPlayerDialog(playerid, 375, DIALOG_STYLE_LIST,
			".:: Worlds help ::.", "Description of the worlds system\nDescription of gamemodes",
			"Select", "Cancel");	
		} else {
			ShowPlayerDialog(playerid, 375, DIALOG_STYLE_LIST,
			".:: Описание вирт.миров ::.", "Описание системы миров\nОписание режимов",
			"Выбрать", "Отмена");	
		}
		return true;
	}
	if (!strcmp(cmdtext, "/ahelp", true) || !strcmp(cmdtext, "/adminhelp", true)
		|| !strcmp(cmdtext, "/banhelp", true)) 
	{
		if(GetPVarInt(playerid, "Admin") < 2)
		{
			return false;
		}
		AdminHelp(playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/rules", true) || !strcmp(cmdtext, "/rule", true))
	{
		Rules(playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/admins", true) || !strcmp(cmdtext, "/adm", true))
	{
		ADMINS_ONLINE(playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/settings", true) || !strcmp(cmdtext, "/set", true)
	|| !strcmp(cmdtext, "/setting", true))
	{
		SETTINGS_MENU(playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/credits", true) || !strcmp(cmdtext, "/about", true))
	{	
		new CreditsText[1240];
		format(CreditsText, sizeof(CreditsText),
		"{FFFFFF}Version: {FFD700}%s{FFFFFF} build %s\n", VERSION, BUILD_DATE);
		/*strcat(CreditsText,"Add our second server to your favorites:\n");
		if(Host == 0) // ru host
		{
			strcat(CreditsText,
			"{FFD700}Russian Sawn-off Community | Lagshot  | EU host - 82.208.17.10:27445\n");
			strcat(CreditsText,
			"{FFD700}Russian Sawn-off Community | Skinshot | EU host - 82.208.17.10:27981\n");
		}
		if(Host == 1 && lagcomp)//skin eu
		{
			strcat(CreditsText,
			"{FFD700}Russian Sawn-off Community | Lagshot | EU host -  82.208.17.10:27445\n");
		}
		if(Host == 1 && !lagcomp)//lagshot eu
		{
			strcat(CreditsText,
			"{FFD700}Russian Sawn-off Community | Skinshot | EU host -  82.208.17.10:27981\n");
		}*/
		strcat(CreditsText,"\n{888800}Team SturmStaffel{FFFFFF} was created in 2012 on the russian server simHost\n");
		strcat(CreditsText, "by 3 players: {888800}Cannibal, WhiteOne and EGoZoNE.{FFFFFF}\n");

		strcat(CreditsText, "The clan name may be translated from German as Storm Squad, the name\n");
		strcat(CreditsText, "and idea which we always try to do justice to, confronting our enemies\n"); strcat(CreditsText, "head-on no matter what. Our playstyle was always based mostly on\n");
		strcat(CreditsText, "sawn-off/run weapons play. \n");

		strcat(CreditsText, "Over the years playing on russian public servers we proved ourselves\n");
		strcat(CreditsText, "as eager competitors. These days we are looking for new challenges\n");
		strcat(CreditsText, "at the international level.\n");
		
		strcat(CreditsText,"\nWebsite: {888800}sturmstaffel.ru{FFFFFF}\n");
		strcat(CreditsText,"Discord {FFFFFF}R{4682b4}S{FF0000}C: {4682b4}dsc.gg/sawncommunity{FFFFFF}\n");
		//strcat(CreditsText,"\n{FFFFFF}Have you found a bug? Please report it!\n");
		strcat(CreditsText,"\n{FFFFFF}Do you like this mod? Help us to know how to improve this mod.\n");
		strcat(CreditsText,"Thank you for playing on this server and have fun!\n");
		strcat(CreditsText,"Developer: 1NS\n");
		ShowPlayerDialog(playerid, 88, DIALOG_STYLE_MSGBOX,
		"RSC {008000}CW/TG {FFFFFF}mode by {FFD700}Russian Sawn-off Community{FFFFFF}",
		CreditsText, "OK", "");
		return true;
	}
	if (!strcmp(cmdtext, "/lang", true))
	{
		ShowPlayerDialog(playerid, 6, DIALOG_STYLE_LIST, "Language", "English\nRussian", "OK", "Cancel");
		return true;
	}
	if (!strcmp(cmdtext, "/kill", true) || !strcmp(cmdtext, "/suicide", true))
	{
	    if (GetPVarInt(playerid, "UnBug"))
		{
		    SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете совершить самоубийство.", "You can't suicide right now.");
			return true;
		}
		if (GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
			SetVehicleHealth(GetPlayerVehicleID(playerid), 0.0);
			return true;
		}
	    if (GetPlayerState(playerid) != PLAYER_STATE_ONFOOT || score[0] == Roundkills || score[1] == Roundkills)
		{
	        SendClientMessageEx(playerid, COLOR_GREY, "Сейчас Вы не можете совершить самоубийство.", "You can't suicide right now.");
	        return true;
	    }
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED
		|| GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		switch(random(5))
		{
			case 0:	ApplyAnimation(playerid,"MISC","plyr_shkhead",4.0,0,0,0,0,0,1); // facepalm
			case 1:	ApplyAnimation(playerid, "SWEET", "Sweet_injuredloop", 4.1,0,1,1,1,1);
			case 2:	ApplyAnimation(playerid, "KNIFE", "KILL_Knife_Ped_Die", 4.1,0,1,1,1,1);
			case 3:	ApplyAnimation(playerid, "CHAINSAW", "CSAW_Hit_1", 4.1,0,1,1,1,1);
			case 4:	ApplyAnimation(playerid, "CHAINSAW", "CSAW_Hit_2", 4.1,0,1,1,1,1);
			case 5:	ApplyAnimation(playerid, "CHAINSAW", "CSAW_Hit_3", 4.1,0,1,1,1,1);
		}
		if(pData[playerid][pSfx])
		{
			switch(random(3))
			{
				case 0: PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/blood_caleb_everybodydies.mp3");
				case 1: PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/postal-dude-you-gotta-be-fucking-kidding.mp3");
				case 2: PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/hallelujah_nI2w7It.mp3");
				case 3: PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/10-mario-died.mp3");
				case 4: PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/overwatch-reapers-ultimate-die-die-dieeee.mp3");
				case 5: PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/you-must-die.mp3");
				case 6: PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/die-insect.mp3");
			}
		}	
		
		SetTimerEx("KillPlayer", 1500, false, "d", playerid);
		SendClientMessageEx(playerid, COLOR_GREY,
		"Используйте команду /respawn чтобы заспавниться без смерти.",
		"Use /respawn if you need to respawn without death.");
	    return true;
	}
	if (!strcmp(cmdtext, "/class", true))
	{
	    if (score[0] == Roundkills || score[1] == Roundkills 
		|| (speconly && GetPVarInt(playerid, "Team") == 2))
	 	{
		    SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете использовать данную функцию .",
			"You can't use this function right now.");
	 	    return true;
	 	}
		
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED
		|| GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.",
			"You can't respawn yourself right now.");
			return true;
		}
		
	    ForceClassSelection(playerid);
		SetPlayerHealth(playerid, 0.0);
		SetPlayerArmour(playerid, 0.0);
		if(pData[playerid][pFpsbar] > 0) PlayerTextDrawHide(playerid, FPSBAR[playerid]);
		if(pData[playerid][pHpbar] > 0) PlayerTextDrawHide(playerid, PlayerHp[playerid]);
		if(pData[playerid][pHpbar] > 0) PlayerTextDrawHide(playerid, PlayerArmour[playerid]);
		return true;
	}
	if (!strcmp(cmdtext, "/slapme", true)) 
	{
		new Float: x, Float: y, Float: z;
		GetPlayerPos(playerid, x, y, z);
		SetPlayerPos(playerid, x+1, y+1, z+1.5);
		PlayerPlaySound(playerid, 1130, x, y, z); // PUNCH_PED
		return true;
	}
	if (!strcmp(cmdtext, "/lounge", true) || !strcmp(cmdtext, "/lobby", true)) 
	{
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		new Float: x, Float: y, Float: z;
		GetPlayerPos(playerid, x, y, z);
		
		if(!GetPVarType(playerid, "Lounge"))
		{
			SetPVarInt(playerid, "Lounge", 1);
			ResetPlayerWeapons(playerid);
			SetPlayerPos(playerid, 1722.0690, -1645.8715, 20.2269);
			SetPlayerFacingAngle(playerid, 176.53);
			SetPlayerInterior(playerid, 18);
			//PlayerPlaySound(playerid, 1130, x, y, z); // PUNCH_PED
			SetPlayerColor(playerid, COLOR_WHITE);
			SetPlayerTeam(playerid, NO_TEAM);
		} else {
			DeletePVar(playerid, "Lounge");
			SetPlayerTeamEx(playerid, TEAM_SPEC);
			ReSpawnPlayer(playerid);
		}
		return true;
	}
	if (!strcmp(cmdtext, "/tab", true) || !strcmp(cmdtext, "/table", true))
	{
		if(GetPVarInt(playerid, "teamtab") == -1)
		{
			//PlayerTextDrawHide(playerid, TDteamtab[playerid]);
			PlayerTextDrawHide(playerid, TDteamtab1[playerid]);
			PlayerTextDrawHide(playerid, TDteamtab2[playerid]);
			//PlayerTextDrawShow(playerid, TDteamtab[playerid]);
			PlayerTextDrawShow(playerid, TDteamtab1[playerid]);
			PlayerTextDrawShow(playerid, TDteamtab2[playerid]);
			SetPVarInt(playerid, "teamtab", 1);
		} else {
			//PlayerTextDrawHide(playerid, TDteamtab[playerid]);
			PlayerTextDrawHide(playerid, TDteamtab1[playerid]);
			PlayerTextDrawHide(playerid, TDteamtab2[playerid]);
			SetPVarInt(playerid, "teamtab", -1);
		}
		return true;
	}
	/*if (!strcmp("/events", cmd, true) || !strcmp("/minigames", cmd, true))
	{
		SetPlayerChatBubble(playerid, "..opens events..", COLOR_GREY, 50.0, 5000);
		ShowPlayerDialog(playerid, 12, DIALOG_STYLE_TABLIST, "Events",
		"Halloween\t\n", "Join", "Cancel");
		return true;
	}*/
	if (!strcmp("/forceskin", cmd, true))
	{
		if(GetPVarInt(playerid, "Admin") < 2)
		{
			return SendClientMessageEx(playerid, COLOR_RED,
			"Для использования этих функций Вы должны быть администратором 2+ уровня!",
			"To use these functions you need to have level 2+ admin rights!");
		}
		
		tmp = strtok(cmdtext, idx);
		new id = strval(tmp);
		
		if(!strlen(tmp))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /forceskin <ID>", "Use: /forceskin <ID>");
			return true;
		}
		
		if(IsPlayerConnected(id))
		{
			ForceClassSelection(id);
			SetPlayerHealth(id, 0.0);
			SetPlayerArmour(id, 0.0);
			if(pData[id][pFpsbar] > 0) PlayerTextDrawHide(id, FPSBAR[id]);
			if(pData[id][pHpbar] > 0) PlayerTextDrawHide(id, PlayerHp[id]);
			if(pData[id][pHpbar] > 0) PlayerTextDrawHide(id, PlayerArmour[id]);
		}
		return 1;
	}
	if (!strcmp("/skin", cmd, true))
	{
		tmp = strtok(cmdtext, idx);
		new skinid = strval(tmp);
		new worldid = GetPlayerVirtualWorld(playerid);
		
		if(strlen(tmp) == 0) 
		{
			SetPVarInt(playerid, "oldskin", GetPlayerSkin(playerid));

			// If there was a previously created selection menu, destroy it
			DestroySelectionMenu(playerid);
			
			SetPVarInt(playerid, "skinc_active", 1);
			//SetPVarInt(playerid, "skinc_page", 0); // will reset the page back to the first
			
			CreateSelectionMenu(playerid);
			SelectTextDraw(playerid, 0xACCBF1FF);
			return true;
		}
		// Skins from 300 to 311 have been added
		// to SA-MP 0.3.7 RC3 and they don't work in older versions!
		if(skinid < 0 || skinid >= 300 || skinid == 74) 
		{
			SendClientMessageEx(playerid,COLOR_GREY,
			"Ошибка: неверный № скина", "ERROR: Invalid skin id!");
			if(pData[playerid][pLang] == 0)
			{
				ShowPlayerDialog(playerid, 9, DIALOG_STYLE_INPUT, "Сменить скин",
				"{FFFFFF}Для визуального предпросмотра, используйте: {33AA33}/skin \n\
				{FFFFFF}Введите номер скина:", "Сменить", "Выйти");
			} else {
				ShowPlayerDialog(playerid, 9, DIALOG_STYLE_INPUT, "Change Skin",
				"{FFFFFF}For visual preview, use: {33AA33}/skin \n\
				{FFFFFF}Enter the skin ID below:", "Confirm", "Cancel");
			}
			return true;
		}
		if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED
		|| GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if(pData[playerid][pAttachSlot0] == 600)
		{
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Это действие вам запрещено администрацией",
			"The action was forbidden to you by the administration");
		}
		if(GetPlayerAnimationIndex(playerid) == 1274 || GetPlayerAnimationIndex(playerid) == 1159)
		{
			ApplyAnimation(playerid,"PLAYIDLES","stretch",4.0,0,0,0,0,0);
		}
		else
		{
			if(IsPlayerInAnyVehicle(playerid))
			{
				return SendClientMessage(playerid, COLOR_GREY, "Exit from vehicle!");
			}
			if(!World[worldid][wBagoskins] || worldid == 0)
			{
				switch(skinid)
				{
					case 0,1,2,74,86,92,99,149,265,266,267,268,269,270,271,272:
					{
						return SendClientMessageEx(playerid, COLOR_GREY,
						"Этот скин запрещен!", "This skin is forbidden!");
					}
				}
			}
			
			SetPVarInt(playerid, "oldskin", GetPlayerSkin(playerid));
			new string[128];
			if (pData[playerid][pLang] == 1) {
				format(string, sizeof(string),
				"{afafaf}New skin id: {008000}%i{afafaf}, old skin id: {008000}%i{ffffff}",
				skinid, GetPVarInt(playerid, "oldskin"));
			} else {
				format(string, sizeof(string),
				"{afafaf}№ нового скина: {008000}%i{afafaf}, № предыдущего скина: {008000}%i{ffffff}", skinid, GetPVarInt(playerid, "oldskin"));
			}
			SendClientMessage(playerid, COLOR_GREY, string);
			SetPlayerSkin(playerid, skinid);
			SetVirtualWorldSpawnInfo(playerid, skinid);
			SetPlayerChatBubble(playerid, ".. change skin ..", COLOR_GREY, 50.0, 1000);
		}
		return 1;
	}
	if (!strcmp(cmdtext, "/radio", true))
	{
		if(pData[playerid][pSfx] > 0)
		{
			//SendClientMessageEx(playerid, COLOR_GREY,
			//"Звуковые эффекты были временно отключены",
			//"Sound effects have been temporarily disabled");
			pData[playerid][pSfx] = 0;
		}
		
		new tbtext[256];
		for(new i = 0; i < sizeof RadioCategory; i++)
		{
			if((i % 2) == 0) format(tbtext, sizeof tbtext, "%s{FFFFFF}%s\n", tbtext, RadioCategory[i]);
			else format(tbtext, sizeof tbtext, "%s{CDCDCD}%s\n", tbtext, RadioCategory[i]);
		}
		
		ShowPlayerDialog(playerid, 281, DIALOG_STYLE_LIST,
		"Radio", tbtext, "Select","Cancel");
		SetPlayerChatBubble(playerid, ".. open radio station list ..", COLOR_GREY, 50.0, 5000);
		return 1;
	}
	if (!strcmp(cmdtext, "/offradio", true) || !strcmp(cmdtext, "/stop", true))
	{
		new szQuery[128], DBResult: query;
		new sfx;
		format(szQuery, sizeof(szQuery),
		"SELECT Sfx FROM Accounts WHERE (Nickname = '%q')",
		db_escape(PlayerName(playerid)));
		db_query(dbaccounts, szQuery);
		if(db_num_rows(query))
		{
			sfx = db_get_field_int(query, 0);
			db_free_result(query);
		}
		
		if(sfx)	pData[playerid][pSfx] = 1;
		
		SetPVarInt(playerid, "Radio", 0);
		StopAudioStreamForPlayer(playerid);
		return 1;
	}
	if (!strcmp("/tp", cmd, true) || !strcmp("/tpcoord", cmd, true))
	{
		tmp = strtok(cmdtext, idx);
		
		if(GetPVarInt(playerid, "Admin") <= 2 && GetPlayerVirtualWorld(playerid) != 0)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				if(!World[worldid][wTeleports] && !WorldModerator[playerid])
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Использование телепорта в мире было запрещено.",
					"Using teleports in virtual world was forbidden.");
				}
				return true;
			}
			
			TELEPORT_MENU(playerid);
			return true;
		}
		
		if (strlen(tmp) == 0)
		{
			TELEPORT_MENU(playerid);
			return true;
		}
		
		new px = strval(tmp);
		
		tmp = strtok(cmdtext, idx);
		if (strlen(tmp) == 0){
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /tp x y z",	"Use: /tp x y z");
		}
		new py = strval(tmp);
	
		tmp = strtok(cmdtext, idx);
		if (strlen(tmp) == 0){
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /tp x y z",	"Use: /tp x y z");
		}
		new pz = strval(tmp);
		
		SetPlayerPos(playerid, px, py, pz);
		return true;
	}
	if (!strcmp(cmdtext, "/flip", true))
	{
		if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
			new Float:a;
			new worldid = GetPlayerVirtualWorld(playerid);
			if(worldid != 0 && !WorldModerator[playerid])
			{
				if(World[worldid][wVehicleFix])
				{
					GetVehicleZAngle(GetPlayerVehicleID(playerid), a);
					SetVehicleZAngle(GetPlayerVehicleID(playerid), a);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Транспорт поставлен на колеса. Вы можете использавать клавишу <H> для этого",
					"The transport is put on wheels. You can use the <H> key to do this");
				}
			}			
			GetVehicleZAngle(GetPlayerVehicleID(playerid), a);
			SetVehicleZAngle(GetPlayerVehicleID(playerid), a);
			SendClientMessageEx(playerid, COLOR_GREY,
			"Транспорт поставлен на колеса. Вы можете использавать клавишу <H> для этого",
			"The transport is put on wheels. You can use the <H> key to do this");
			
		}
		return true;
	}
	if (!strcmp(cmdtext, "/fix", true))
	{
		if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			if(worldid != 0 && !WorldModerator[playerid])
			{
				if(World[worldid][wVehicleFix])
				{
					RepairVehicle(GetPlayerVehicleID(playerid));
					SendClientMessageEx(playerid, COLOR_GREY,
					"Транспорт был восстановлен.","Transport has been repaired");
				}
			}			
			RepairVehicle(GetPlayerVehicleID(playerid));
			SendClientMessageEx(playerid, COLOR_GREY,
			"Транспорт был восстановлен.","Transport has been repaired");
			
		}
		return true;
	}
	if (!strcmp(cmdtext, "/v", true))
	{
		new worldid = GetPlayerVirtualWorld(playerid);
		if(worldid == 0 && GetPVarInt(playerid, "Admin") < 2)
		{
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Для использования этих функций Вы должны быть администратором 2+ уровня!",
			"To use these functions you need to have 2+ level admin rights!");
		}
		if(worldid == 0 && CWmode) 
		{
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Недоступно во время проведения матча", "Not available during CW match");
		}
		
		if(worldid != 0)
		{
			if(!World[worldid][wVehicles] && !WorldModerator[playerid])
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Использование транспорта в мире было запрещено.",
				"Using transport in virtual world was forbidden.");
			}
			if(!WorldModerator[playerid] && World[worldid][wGamemode] == GAMEMODE_DERBY)
			{
