stock TEAMS_MENU(playerid)
{
	new tbtext[1024], tmpstr[32];
		
	foreach(Player, i)
	{
		if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid))
		{
			switch(GetPVarInt(i, "Team"))
			{
				case 0:
				{
					format(tmpstr, sizeof(tmpstr), "%s%s\n", THC[0], PlayerName(i));
					strcat(tbtext, tmpstr);
				}
				case 1:
				{
					format(tmpstr, sizeof(tmpstr), "%s%s\n", THC[1], PlayerName(i));
					strcat(tbtext, tmpstr);
				}
				case 2:
				{
					format(tmpstr, sizeof(tmpstr), "%s%s\n", THC[2], PlayerName(i));
					strcat(tbtext, tmpstr);
				}
			}
		}
	}
	
	if (pData[playerid][pLang] == 1)
	{
		ShowPlayerDialog(playerid, 51, DIALOG_STYLE_LIST,
		"Move team",tbtext, "Select", "Cancel");
	} else {
		ShowPlayerDialog(playerid, 51, DIALOG_STYLE_LIST,
		"Переместить игрока",tbtext, "Выбрать", "Назад");
	}
}

