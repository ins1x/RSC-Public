		Быстрый вызов меню\n\
		Доступные возможности\n");
	}
	
	if(GetPVarInt(playerid, "Admin") >= 1)
	{ 	
		ShowPlayerDialog(playerid, 53, DIALOG_STYLE_LIST,
		header,	tbtext, "Select", "Cancel");
	} else {
		SendClientMessageEx(playerid, COLOR_GREY,
		"Для использования этих функций Вы должны быть администратором 1+ уровня!",
		"To use these functions you need to have level 1+ admin rights!");
	}
	
}

