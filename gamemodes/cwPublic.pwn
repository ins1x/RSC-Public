			return true;
		}
		
		tmp = strtok(cmdtext, idx);
		new PARAM = strval(tmp);
		if (!strlen(tmp))
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			if(worldid != 0)
			{
				if(!WorldModerator[playerid])
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Вы не модератор мира!", "You are not moderator!");
					return true;
				}
				foreach(Player, i)
				{
					if (GetPlayerState(i) == PLAYER_STATE_ONFOOT && !GetPVarInt(i, "UnBug"))
					{
						if(GetPlayerVirtualWorld(playerid) == GetPlayerVirtualWorld(i))
						{
							ReSpawnPlayer(i);
						}
					}
				}
				format(stringru, sizeof(stringru), "%s(%d) зареспавнил всех игроков на карте",
				PlayerName(playerid), playerid);
				format(stringen, sizeof(stringen), "%s(%d) respawn all players on map",
				PlayerName(playerid), playerid);
				SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
			} else {
				for(new i = 0; i < MAX_PLAYER_ID; i++)
				{
					if (IsPlayerConnected(i))
					{
						if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
						{
							if (!GetPVarInt(i, "UnBug"))
							{
								ReSpawnPlayer(i);
							}
						}
					}
				}
				
				//SetPVarInt(playerid,"LastActionDelay",gettime() + 5);
				format(stringru, sizeof(stringru), "%s(%d) заспавнил всех игроков.",
				PlayerName(playerid), playerid);
				format(stringen, sizeof(stringen), "%s(%d) has respawned all players.",
				PlayerName(playerid), playerid);
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
				return true;
			}
		} else {
			if (GetPlayerVirtualWorld(playerid) != 0 && GetPVarInt(playerid, "Admin") < 1)
			{
				OnPlayerCommandText(playerid, "/spawn");
				return true;
			}
			if (PARAM == INVALID_PLAYER_ID)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /spawn <ID>", "Use: /spawn <ID>");
				return true;
			}
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
			new playerstate = GetPlayerState(PARAM);
			if (playerstate == PLAYER_STATE_NONE)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не заспавнился.", "The player isn't spawned.");
				return true;
			}
			if (playerstate == PLAYER_STATE_WASTED || playerstate == PLAYER_STATE_SPAWNED)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок мертв либо находится в меню выбора класса.", "The player is dead.");
				return true;
			}
			if (GetPVarInt(PARAM, "UnBug"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок уже в процессе проверки", "The player already being tested.");
				return true;
			}
			if (score[0] == Roundkills || score[1] == Roundkills)
			{
				SendClientMessageEx(playerid, COLOR_GREY, "Сейчас Вы не можете использовать данную функцию.", "You can't use this function right now.");
				return true;
			}
			
			if(GetPVarInt(PARAM, "Removed") > 0) {
				#if defined _YSF_included
				foreach(Player, i) ShowPlayerForPlayer(i, PARAM);
				HidePlayerMarker(PARAM, 0);
				#else
				SetPlayerVirtualWorld(PARAM, 0);
				#endif
				SetPVarInt(PARAM, "Removed", 0);
			}
			
			RemovePlayerAttachedObject(PARAM, 0);
			ReSpawnPlayer(PARAM);
			
			format(stringru, sizeof(stringru), "%s(%d) заспавнил игрока %s(%d).", 
			PlayerName(playerid), playerid, PlayerName(PARAM), PARAM);
			format(stringen, sizeof(stringen), "%s(%d) has respawned player %s(%d).",
			PlayerName(playerid), playerid, PlayerName(PARAM), PARAM);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
		return true;
	}
