				if(IsPlayerConnected(i)) {
					format(stringen, sizeof(stringen), "[%d]%s",i, PlayerName(i));
					if(playerid != i && i < 6) SendClientMessage(playerid, COLOR_GREY, stringen);
				}
			}
			return true;
		}
		new Float:x, Float:y, Float:z;
		GetPlayerPos(PARAM, x, y, z);
		SetPlayerPos(playerid, x+2, y+2, z);
		new name1[MAX_PLAYER_NAME];
		GetPlayerName(PARAM, name1, sizeof(name1));
		format(stringen, sizeof(stringen), "%s(%d) has teleported to player %s(%d).",
		name, playerid, name1, PARAM);
		format(stringru, sizeof(stringru), "%s(%d) телепортировался к игроку %s(%d).",
		name, playerid, name1, PARAM);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		AdminActionsLog(stringen);
		return true;
	}
	if (!strcmp(cmdtext, "/get ", true, 5))
	{
		if (GetPlayerVirtualWorld(playerid) == 0 && GetPVarInt(playerid, "Admin") < 2)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Для использования этих функций Вы должны быть администратором 2+ уровня!",
			"To use these functions you need to have 2+ level admin rights!");
			return true;
		}
		if(GetPlayerVirtualWorld(playerid) != 0 
		&& !WorldModerator[playerid])
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы не модератор мира!", "You are not moderator!");
			return true;
		}
		if (!cmdtext[5])
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Использование: /get [ID] ", "Use: /get [ID]");
			return true;
		}
		new PARAM = strval(cmdtext[5]);
		if (!IsPlayerConnected(PARAM) || PARAM == playerid)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Игрок не подключен либо вышел.", "This player isn't connected.");
			return true;
		}
		if(GetPVarInt(playerid, "Admin") < GetPVarInt(PARAM, "Admin"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"У данного игрока выше уровень админки", "This player has a higher admin level");
			return true;
		}
		if(GetPlayerVirtualWorld(PARAM) != GetPlayerVirtualWorld(playerid))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Недоступно. Игрок в другом виртуальном мире!",
			"Not available. Player is in another virtual world!");
			return 1;
		}
		new stringru[90], stringen[90], Float:Pos[3]; // x,y,z
		GetPlayerPos(playerid, Pos[0], Pos[1], Pos[2]);
		SetPlayerPos(PARAM, Pos[0], Pos[1]+1, Pos[2]);
		format(stringru, sizeof(stringru), "%s(%d) телепортировал игрока %s(%d) к себе", 
		PlayerName(playerid), playerid, PlayerName(PARAM), PARAM);
		format(stringen, sizeof(stringen), "%s(%d) has teleported the player %s(%d) to himself", 
		PlayerName(playerid), playerid, PlayerName(PARAM), PARAM);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		AdminActionsLog(stringen);
		return true;
	}	
	if (!strcmp("/count", cmd, true) || !strcmp("/countdown", cmd, true))
	{
		if(GetPlayerVirtualWorld(playerid) == 0)
		{
			if(GetPVarInt(playerid, "Admin") >= 2)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Используйте в основном мире /start <0-20>",
				"In main world use: /start <0-20>");
			}
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы не можете использовать данную функцию здесь, перейдите в виртуальный мир",
			"You can't use this function here, go to the virtual world"); 
			return true;
		} else {			
			if(!WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
		}
		
		if(GetPVarInt(playerid, "LastActionDelay") > gettime())
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы слишком часто используете данную функцию.",
			"You are using this feature too often.");
			return true;
		}
		SetPVarInt(playerid, "LastActionDelay", gettime() + 25);
		
		tmp = strtok(cmdtext, idx);
		if(strval(tmp) > 20 || strval(tmp) < 1)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Используйте /count <0-20>","Use: /count <0-20>");
			return true;
		}
		
		if(!strlen(tmp))
		{
			Countdown(0, GetPlayerVirtualWorld(playerid));
		} else {
			Countdown(strval(tmp), GetPlayerVirtualWorld(playerid));
		}
		
		SetPlayerChatBubble(playerid, "..has started countdown..", COLOR_GREY, 50.0, 5000);
		return true;
	}
	// Admin commands lvl 2
	if(GetPVarInt(playerid, "Admin") >= 2)
	{
		if (!strcmp("/check", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			new PARAM = strval(tmp);
		    if (!strlen(tmp) || strval(tmp) == INVALID_PLAYER_ID)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /check [ID]", "Use: /check [ID]");
				return true;
			}
			
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
			
			ChosenPlayer[playerid] = PARAM;
			DopInfo(playerid, ChosenPlayer[playerid]);
			return true;
		}
		if (!strcmp(cmdtext, "/dop", true))
		{
			new tbtext[500], tmpstr[48];
			foreach(Player, i)
			{	
				format(tmpstr, sizeof(tmpstr), "%s%s[%d]\t",
				THC[GetPVarInt(i, "Team")], PlayerName(i),i);
				strcat(tbtext, tmpstr);
				if((i % 2) == 0) strcat(tbtext, "\n");
			}
			strcat(tbtext, "\n{FFFFFF}Enter the player id");
			ShowPlayerDialog(playerid, 89, DIALOG_STYLE_INPUT,
			"Dop menu", tbtext, "Ok", "Cancel");
			/*
			if (pData[playerid][pLang] == 1)
			{
				ShowPlayerDialog(playerid, 89, DIALOG_STYLE_INPUT, "Dop menu",
				"{FFFFFF}Enter the player id", "Ok", "Cancel");
			} else {
				ShowPlayerDialog(playerid, 89, DIALOG_STYLE_INPUT,
				"Доп. меню","{FFFFFF}Введите ID игрока", "Ok", "Выход");
			}*/
			return true;
		}
		if (!strcmp(cmdtext, "/dop ", true, 3))
		{		
			if(!cmdtext[3]) 
			{
				new tbtext[500], tmpstr[48];
				foreach(Player, i)
				{	
					format(tmpstr, sizeof(tmpstr), "%s%s[%d]\t",
					THC[GetPVarInt(i, "Team")], PlayerName(i),i);
					strcat(tbtext, tmpstr);
					if((i % 2) == 0) strcat(tbtext, "\n");
				}
				strcat(tbtext, "\n{FFFFFF}Enter the player id");
				ShowPlayerDialog(playerid, 89, DIALOG_STYLE_INPUT,
				"Dop menu", tbtext, "Ok", "Cancel");
				return true;
			}
			new id = strval(cmdtext[4]);
			if (IsPlayerConnected(id))
			{
				ChosenPlayer[playerid] = id;
				DOP_MENU(playerid);
			} else {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
			}
			return true;
		}
		if (!strcmp("/kick", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			new PARAM = strval(tmp);
		    if (!strlen(tmp) || strval(tmp) == INVALID_PLAYER_ID)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /kick [ID] <причина>", "Use: /kick [ID] <reason>");
				return true;
			}
			
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
			if (GetPVarInt(PARAM, "Admin") > GetPVarInt(playerid, "Admin")) 
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете кикнуть администратора выше уровня", "You cannot kick admin above level");
				return true;
			}
			new ip[16];
			new stringru[128], stringen[128];
			GetPlayerIp(PARAM, ip, sizeof ip);
			tmp = strtok(cmdtext, idx);
		    if(!strlen(tmp))
		    {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /kick [ID] <причина>", "Use: /kick [ID] <reason>");
				return true;
			}
			format(stringru, sizeof(stringru), "%s(%d) кикнул игрока %s(%d). Причина: %s (Kick)",
			PlayerName(playerid), playerid, PlayerName(PARAM), PARAM, tmp);
			format(stringen, sizeof(stringen), "%s(%d) has kicked player %s(%d). Reason: %s (Kick)",
			PlayerName(playerid), playerid, PlayerName(PARAM), PARAM, tmp);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			AdminActionsLog(stringen);
			KickPlayerEx(PARAM, tmp, true);
			BlockIpAddress(ip, 60 * 1000); 
		    return true;
		}
		if (!strcmp("/mute", cmd, true) || !strcmp("/zip", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			
			if (!strlen(tmp) || strval(tmp) == INVALID_PLAYER_ID){
				if (GetPVarInt(playerid, "Admin") >= 3) {
					SendClientMessageEx(playerid, COLOR_GREY,
					"Использование: /mute [ID] <время> <причина>",
					"Use: /mute [ID] <time> <reason>");
					return true;
				}
			}
			if(!IsPlayerConnected(strval(tmp)))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Неверный ID игрока", "Incorrect player id");
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /mute [ID] <время> <причина>",
				"Use: /mute [ID] <time> <reason>");
				return true;
			}
			
			new id = strval(tmp), string[144], stringru[144];
			if (GetPVarInt(id, "Admin") > GetPVarInt(playerid, "Admin")) 
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете забанить администратора выше уровня", "You cannot ban admin above level");
				printf("Attempt to mute %s was rejected. %s have above level.",
				PlayerName(id), PlayerName(playerid));
				return true;
			}
			
			tmp = strtok(cmdtext, idx);
			if (strlen(tmp) == 0 || strval(tmp) < 0 || strval(tmp) == 0 || strval(tmp) > 43800)
			{ // 43800 min = 1 month
				SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректно указано время (0-43800 минут)",
				"Incorrect time (0-43800 min)");
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /mute [ID] <время> <причина>",
				"Use: /mute [ID] <time> <reason>");
				return true;
			}
			new time = strval(tmp);
			
			tmp = strtok(cmdtext, idx);
			if(strlen(tmp) == 0)
			{
				format(string, sizeof(string), "%s(%d) has muted player %s(%d) for %d minutes",
				PlayerName(playerid), playerid, PlayerName(id), id, time);
				format(stringru, sizeof(stringru), "%s(%d) заглушил игрока %s(%d) на %d минут", 
				PlayerName(playerid), playerid, PlayerName(id), id, time);
				pData[id][pMuted] = time*60;
				AdminActionsLog(string);
			} else {
			    format(string, sizeof(string),
				"%s(%d) has muted player %s(%d) for %d minutes. reason: %s",
				PlayerName(playerid), playerid, PlayerName(id), id, time, tmp);
			    format(stringru, sizeof(stringru),
				"%s(%d) заглушил игрока %s(%d) на %d минут. причина: %s",
				PlayerName(playerid), playerid, PlayerName(id), id, time, tmp);
				pData[id][pMuted] = time*60;
				AdminActionsLog(string);
			}
			
			new szQuery[128];
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Muted = %i WHERE (Nickname = '%q')",
			pData[id][pMuted], db_escape(PlayerName(id)));
			db_query(dbaccounts, szQuery);
	
			AdminActionsLog(string);
			SendClientMessageToAllEx(COLOR_GREY, stringru, string);
			return true;
		}
		if (!strcmp(cmdtext, "/mutespec", true))
		{
			new string[100], stringru[100];
			if(Mutespec) 
			{
				Mutespec = false;
				format(string, sizeof(string), "%s(%d) has allowed spectators to use global chat.",
				PlayerName(playerid), playerid);
				format(stringru, sizeof(stringru), "%s(%d) разрешил наблюдателям использовать общий чат.",
				PlayerName(playerid), playerid);
			} else {
				Mutespec = true;
				format(string, sizeof(string), "%s(%d) has forbidden spectators to use global chat.",
				PlayerName(playerid), playerid);
				format(stringru, sizeof(stringru), "%s(%d) запретил наблюдателям использовать общий чат.",
				PlayerName(playerid), playerid);
			}
			AdminActionsLog(string);
			SendClientMessageToAllEx(COLOR_GREY, stringru, string);
			return true;
		}
		if (!strcmp(cmdtext, "/unmute", true))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /unmute [ID]", "Use: /unmute [ID]");
			return true;
		}
		if (!strcmp(cmdtext, "/unmute ", true, 8))
		{
		    if (!cmdtext[8])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /unmute [ID]","Use: /unmute [ID]");
				return true;
			}
		    new string[128], stringru[128];
		 	format(string, 7, "%s", cmdtext[8]);
		 	new PARAM = strval(string);
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
			new name1[MAX_PLAYER_NAME];
		    GetPlayerName(PARAM, name1, sizeof(name1));
		    format(string, sizeof(string), "%s(%d) has unmuted player %s(%d)",
			name, playerid, name1, PARAM);
		    format(stringru, sizeof(stringru), "%s(%d) разглушил игрока %s(%d)",
			name, playerid, name1, PARAM);
			AdminActionsLog(string);
			SendClientMessageToAllEx(COLOR_GREY, stringru, string);
			pData[PARAM][pMuted] = 0;
			DeletePVar(playerid,"Hwmuted");
			
			/*new szQuery[128];
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Muted = 0 WHERE (Nickname = '%q')",
			db_escape(PlayerName(PARAM)));
			db_query(dbaccounts, szQuery);*/
			new szQuery[128], DBResult: query;
			new ip[16], mutedip[16+1], nickname[24];
			GetPlayerIp(PARAM, ip, sizeof ip);
			format(szQuery, sizeof(szQuery),
			"SELECT Lastip, Nickname FROM Accounts WHERE Muted > 0");
			query = db_query(dbaccounts, szQuery);
			new rows = db_num_rows(query);
			for(new p; p < rows; p++)
			{			
				db_get_field(query, 0, mutedip, sizeof(mutedip));
				new len = strlen(mutedip);
				strdel(mutedip, len-2, len);
				
				db_get_field(query, 1, nickname, sizeof(nickname));
				if(strfind(ip, mutedip) != -1)
				{
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET Muted = 0 WHERE (Nickname = '%q')",
					db_escape(nickname));
					db_query(dbaccounts, szQuery);
				}
				db_next_row(query);
			}
			db_free_result(query);
			return true;
		}
		if (!strcmp(cmdtext, "/punch", true))
		{
			new Float:x,Float:y,Float:z;
			GetPlayerPos(playerid, x,y,z);
			foreach(Player, i)
			{
				if(i != playerid
				&& GetPlayerInterior(i) == GetPlayerInterior(playerid)
				&& GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid)
				&& GetPlayerState(i) == PLAYER_STATE_ONFOOT)
				{
					IsPlayerInRangeOfPoint(i, 3.0, x,y,z);
					SetPlayerVelocity(i, 0.2, 0.5, 0.3);
					GameTextForPlayer(i, "~g~ PUNCH!!", 3000, 5);
				}
			}
		}
		if (!strcmp(cmdtext, "/punch ", true, 6))
		{
			if (!cmdtext[7])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /punch [ID]", "Use: /punch [ID]");
				new Float:x,Float:y,Float:z;
				GetPlayerPos(playerid, x,y,z);
				foreach(Player, i)
				{
					if(i != playerid
					&& GetPlayerInterior(i) == GetPlayerInterior(playerid)
					&& GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid)
					&& GetPlayerState(i) == PLAYER_STATE_ONFOOT)
					{
						IsPlayerInRangeOfPoint(i, 3.0, x,y,z);
						SetPlayerVelocity(i, 0.2, 0.5, 0.3);
						GameTextForPlayer(i, "~g~ PUNCH!!", 3000, 5);
					}
				}
				return true;
			}
			new stringen[128], stringru[128];
			new PARAM = strval(cmdtext[7]);
			format(stringen, sizeof(stringen), "%s(%d) has kicked %s(%d)'s ass.",
			PlayerName(playerid), playerid, PlayerName(PARAM), PARAM);
			format(stringru, sizeof(stringru), "%s(%d) дал поджопник игроку %s(%d).",
			PlayerName(playerid), playerid, PlayerName(PARAM), PARAM);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			
			ApplyAnimation(PARAM,"PARACHUTE","FALL_skyDive_DIE",4.1,0,1,1,1,1);
			new Float: x, Float: y, Float: z;
			PlayerPlaySound(PARAM, 1130, x, y, z); // PUNCH_PED
			return 1;
		}
		if (!strcmp(cmdtext, "/lockspawn", true) || !strcmp(cmdtext, "/spawnlock", true))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			new string[100], stringru[100];
			if(Spawnlock) 
			{
				Spawnlock = false;
				format(string, sizeof(string), "%s(%d) has allowed spectators to leave spawn.",
				PlayerName(playerid), playerid);
				format(stringru, sizeof(stringru), "%s(%d) разрешил наблюдателям покидать спавн.",
				PlayerName(playerid), playerid);
			} else {
				Spawnlock = true;
				format(string, sizeof(string), "%s(%d) has forbidden spectators to leave spawn.",
				PlayerName(playerid), playerid);
				format(stringru, sizeof(stringru), "%s(%d) запретил наблюдателям покидать спавн.",
				PlayerName(playerid), playerid);
			}
			AdminActionsLog(string);
			SendClientMessageToAllEx(COLOR_GREY, stringru, string);
			return true;
		}
		if (!strcmp(cmdtext, "/lockteams", true) || !strcmp(cmdtext, "/teamslock", true))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			new stringru[100], stringen[100];
			if (LockedTeams)
			{
				LockedTeams = false;
				format(stringru, sizeof(stringru), "%s(%d) разрешил смену команд.", name, playerid);
				format(stringen, sizeof(stringen), "%s(%d) has allowed team join.", name, playerid);
			}else{
				LockedTeams = true;
				format(stringru, sizeof(stringru), "%s(%d) заблокировал смену команд.", name, playerid);
				format(stringen, sizeof(stringen), "%s(%d) has disallowed team join.", name, playerid);
			}
			AdminActionsLog(stringen);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			return true;
		}
		if (!strcmp("/lockcmds", cmd, true) || !strcmp("/cmdslock", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			new id = strval(tmp);
			if(!strlen(tmp))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /lockcmds <ID>", "Use: /lockcmds <ID>");
			}
			
			if(!IsPlayerConnected(id))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
			
			if(playerid == id)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Нельзя использовать на себя", "You can't block yourself");
				return true;
			}
		
			if(GetPVarInt(playerid, "Admin") < GetPVarInt(id, "Admin"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"У данного игрока выше уровень админки", "This player has a higher admin level");
				return true;
			}
			
			new stringru[100], stringen[100];
			if(GetPVarInt(id, "Lockcmds"))
			{
				SetPVarInt(id, "Lockcmds", 0);
				format(stringru, sizeof(stringru),
				"%s(%d) разблокировал использование команд %s(%d).",
				PlayerName(playerid), playerid, PlayerName(id), id);
				format(stringen, sizeof(stringen),
				"%s(%d) has unblocked cmds usage for %s(%d).",
				PlayerName(playerid), playerid, PlayerName(id), id);
			}else{
				SetPVarInt(id, "Lockcmds", 1);
				format(stringru, sizeof(stringru),
				"%s(%d) заблокировал использование команд %s(%d).",
				PlayerName(playerid), playerid, PlayerName(id), id);
				format(stringen, sizeof(stringen),
				"%s(%d) has blocked cmds usage for %s(%d).",
				PlayerName(playerid), playerid, PlayerName(id), id);
			}
			AdminActionsLog(stringen);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
