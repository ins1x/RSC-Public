						"Clear slot?", "{FF0000}Clear current slot?", "Clear", "Back");
					}
					else AttachMenu(playerid);
				}
				case 2: 
				{
					SetPVarInt(playerid, "ActiveAttachSlot", 3);
					if(pData[playerid][pAttachSlot3] > 0) {
						ShowPlayerDialog(playerid, 192, DIALOG_STYLE_MSGBOX,
						"Clear slot?", "{FF0000}Clear current slot?", "Clear", "Back");
					}
					else AttachMenu(playerid);
				}
				case 3:
				{
					if(pData[playerid][pAttachSlot0] == 600)
					{
						return SendClientMessageEx(playerid, COLOR_GREY,
						"Это действие вам запрещено администрацией",
						"The action was forbidden to you by the administration");
					}
					SetPVarInt(playerid, "ActiveAttachSlot", 0);
					if(pData[playerid][pSkin] == -1)
					{
						//SendClientMessageEx(playerid, COLOR_GREY,
						//"Включите сохранение скинов чтобы использовать костюмы",
						//"Turn on save skins to use costumes");
						pData[playerid][pSkin] = GetPlayerSkin(playerid);
					}
					if(pData[playerid][pAttachSlot0] > 0 || 
					IsPlayerAttachedObjectSlotUsed(playerid, 9)) 
					{
						if (pData[playerid][pLang] == 0)
						{
							ShowPlayerDialog(playerid, 198, DIALOG_STYLE_MSGBOX, "Costumes",
							"{FFFFFF}Костюм уже использован.\n\
							Желаете очистить слот?", "Продолжить", "Отмена");
						} else {
							ShowPlayerDialog(playerid, 198, DIALOG_STYLE_MSGBOX, "Costumes",
							"{FFFFFF}This costume has already been used. \n\
							Do you want to clear the slot?", "Continue", "Back");
						}
					}
					else CostumesMenu(playerid);
				}
				case 4:
				{
					if(pData[playerid][pAttachSlot0] == 600)
					{
						return SendClientMessageEx(playerid, COLOR_GREY,
						"Это действие вам запрещено администрацией",
						"The action was forbidden to you by the administration");
					}
					if(pData[playerid][pSkin] != -1)
					{
						pData[playerid][pSkin] = -1;
						SendClientMessage(playerid, -1, "Save costume skin - {FF0000}[OFF]");
					} else {
						SendClientMessage(playerid, -1, "Save costume skin - {00ff00}[ON]");
						pData[playerid][pSkin] = GetPlayerSkin(playerid);
					}
					
					new szQuery[128];
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET Skin = %i WHERE (Nickname = '%q')",
					pData[playerid][pSkin], db_escape(PlayerName(playerid)));
					db_query(dbaccounts, szQuery);
					
					AttachSlotMenu(playerid);
				}
				case 5:
				{
					if(pData[playerid][pAttachSlot0] == 600)
					{
						return SendClientMessageEx(playerid, COLOR_GREY,
						"Это действие вам запрещено администрацией",
						"The action was forbidden to you by the administration");
					}
					if(GetPVarInt(playerid, "ShareActionDelay") > gettime())
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Вы слишком часто используете данную функцию.",
						"You are using this feature too often.");
						return true;
					}
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 358, DIALOG_STYLE_INPUT,
						"Share attaches",
						"{FFFFFF}Enter the ID of the player you want to transfer your attaches set",
						"Change","Cancel");
					} else {
						ShowPlayerDialog(playerid, 358, DIALOG_STYLE_INPUT,
						"Передать набор аттачей",
						"{FFFFFF}Введите ид игрока которому хотите передать свой набор",
						"Передать","Отмена");
					}
				}
				case 6:
				{
					if(pData[playerid][pAttachSlot0] == 600)
					{
						return SendClientMessageEx(playerid, COLOR_GREY,
						"Это действие вам запрещено администрацией",
						"The action was forbidden to you by the administration");
					}
					pData[playerid][pAttachSlot0] = -1;
					pData[playerid][pAttachSlot1] = -1;
					pData[playerid][pAttachSlot2] = -1;
					pData[playerid][pAttachSlot3] = -1;
					
					for(new s=0; s<MAX_PLAYER_ATTACHED_OBJECTS; s++)
					{
						if(IsPlayerAttachedObjectSlotUsed(playerid, s)) {
							RemovePlayerAttachedObject(playerid, s);
						}
					}
					
					new szQuery[256];
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET AttachSlot0 = %i, AttachSlot1 = %i, \
					AttachSlot2 = %i, AttachSlot3 = %i WHERE (Nickname = '%q')",
					pData[playerid][pAttachSlot0], pData[playerid][pAttachSlot1],
					pData[playerid][pAttachSlot2], pData[playerid][pAttachSlot3],
					db_escape(PlayerName(playerid)));
					db_query(dbaccounts, szQuery);
					
					AttachSlotMenu(playerid);
				}
			}
		} else {
			if(LAST_DIALOG[playerid] == 19) SETTINGS_MENU(playerid);
		}
	}
