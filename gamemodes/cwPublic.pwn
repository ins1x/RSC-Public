			"%s(%d) переключил отображение маркеров на радаре.", name, playerid);
			format(stringen, sizeof(stringen),
			"%s(%d) switched opponent markers on map.", name, playerid);
			SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
		} else {
			if (GetPVarInt(playerid, "Admin") < 1)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 1+ уровня!",
				"To use these functions you need to have 1+ level admin rights!");
				return true;
			}
			if(Marker) TogglePlayerMarkers(false);
			else TogglePlayerMarkers(true);
			format(stringru, sizeof(stringru),
