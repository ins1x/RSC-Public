						"Список нарушений игрока", "Введите часть никнейма для поиска",
						"Найти", "Отмена");
					}
				}
				case 7: ShowNicknamesLog(playerid);
				case 8: ShowKickedPlayers(playerid);
				case 9: ShowConnectionsLog(playerid);
				case 10:
				{
					if(!fexist("logs.db"))
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Нет логов для отображения", "No logs to display");
						return 0;
					}
					
					new 
						nickname[24], ip[16], country[32],
						city[32], serial[41], hwid[64], tmpstr[128]
					;
					
					new year,month,day, datetime[20];
					getdate(year, month, day); 
					format(datetime, sizeof(datetime),
					"%d.%d.%d", year, month, day);
	
					new szQuery[256], DBResult: query;
					format(szQuery, sizeof(szQuery),
					"SELECT Datetime, Nickname, IP, Country, City, Serial, Hwid FROM Connectionlog \
					WHERE Datetime LIKE '%%%s%%' ORDER BY rowid DESC LIMIT 50", datetime);
					query =  db_query(dblogs, szQuery);
					new rows = db_num_rows(query);
					for(new i; i < rows; i++)
					{
						db_get_field(query, 0, datetime, sizeof(datetime));
						format(datetime, sizeof(datetime), "%s", datetime);
						
						db_get_field(query, 1, nickname, sizeof(nickname));
						format(nickname, sizeof(nickname), "%s", nickname);
						
						db_get_field(query, 2, ip, sizeof(ip));
						format(ip, sizeof(ip), "%s", ip);
						
						db_get_field(query, 3, country, sizeof(country));
						format(country, sizeof(country), "%s", country);
						
						db_get_field(query, 4, city, sizeof(city));
						format(city, sizeof(city), "%s", city);
						
						db_get_field(query, 5, serial, sizeof(serial));
						//strdel(serial, strlen(serial) - 32, strlen(serial));
						strdel(serial, 5, 35);
						strins(serial, "**", 5);
						format(serial, sizeof(serial), "%s", serial);
						
						db_get_field(query, 6, hwid, sizeof(hwid));
						if(strfind(hwid, "unk") != -1)
						{
							format(hwid, sizeof(hwid), "%s", hwid);
						} else {
							if(strlen(hwid) > 8) strdel(hwid, 5, 27); strins(hwid, "**", 5);
							format(hwid, sizeof(hwid), "%s", hwid);
						}
						
						format(tmpstr, 128, "%s %s - {AFAFAF}%s (%s){FFFFFF} - %s - {FF0000}%s %s",
						datetime, nickname, country, city, ip, serial, hwid);
						SendClientMessage(playerid, -1, tmpstr);
						
						db_next_row(query);
					}
					db_free_result(query);
					
					if(rows < 1)
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Нет результатов для отображения", "No results to display");
					} else {
						format(tmpstr, 128, "Show %i results", rows);
						SendClientMessage(playerid, -1, tmpstr);
					}
				}
				case 11:
				{
					#if defined _YSF_included
					ShowPlayerDialog(playerid, 92, DIALOG_STYLE_INPUT, "Check ip in server banlist (samp.ban)", "{FFFFFF}Check Ip adress in samp.ban file.\n Enter the IP:", "Check IP", "Cancel");
					#else 
					SendClientMessageEx(playerid, COLOR_RED,
					"Нужен плагин YSF", "Install YSF plugin for use it");
					#endif
				}
			}
		} 
		else ADMIN_MENU(playerid);
	}
	if (dialogid == 35) // empty ex EXTRA_ROund
	{
	}
	if(dialogid == 36) //roundkills
	{
		if(response)
		{
			if (strval(inputtext) > 1 || strval(inputtext) < 999999999)
			{
				if (score[0] == Roundkills || score[1] == Roundkills)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Сейчас Вы не можете использовать данную функцию.",
					"You can't use this function right now.");
					return true;
				}
				if (strval(inputtext) == Roundkills)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Такое значение уже выставлено.", "This points are already set up.");
					return true;
				}
				if(strval(inputtext) != 0) Roundkills = strval(inputtext); else Roundkills = 9999;
				new stringru[69];
				format(stringru, sizeof(stringru), "%s(%d) установил раунд до %d очков.",
				PlayerName(playerid), playerid, strval(inputtext));
				new stringen[73];
				format(stringen, sizeof(stringen), "%s(%d) has set up one round till %d points.", PlayerName(playerid), playerid, strval(inputtext));
				SendClientMessageToVirtualWorld(0, COLOR_GREY, stringru, stringen);
				if (strval(inputtext) <= score[0] || strval(inputtext) <= score[1])
				{
					RefreshScore();
				}
			}
			else SendClientMessageEx(playerid, COLOR_GREY,
			"Недопустимая операция!", "Don't do bullshits!");
		}
		else ROUNDSET_MENU(playerid);
	}
	if(dialogid == 37) //gamehealth (custom)
	{
		if(response)
		{
		    new PARAM = strval(inputtext);
		    if (GameHealth == PARAM)
		    {
		        SendClientMessageEx(playerid, COLOR_GREY,
				"Такое значение уже выставлено.", "This health is already set up.");
		        return true;
		    }
		    if (PARAM > 0 && PARAM <= 999999)
		    {
				GameHealth = PARAM;
				new Float: health, Float: armour;
				for(new i = 0; i < MAX_PLAYER_ID; i++)
				{
				    if (IsPlayerConnected(i))
				    {
				        if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
	                	{
					        GetPlayerHealth(i, health);
							GetPlayerArmour(i, armour);
							if (health +armour > GameHealth)
							{
								if (GameHealth > 100)
								{
								    SetPlayerHealth(i, 100.0);
								    SetPlayerArmour(i, GameHealth -100);
								}else{
								    SetPlayerHealth(i, GameHealth);
								    SetPlayerArmour(i, 0.0);
								}
								SetPVarFloat(i, "LastHP", GameHealth +0.000001);
							}
							ReSpawnPlayer(i);
						}
				    }
				}
				new stringru[73], stringen[74];
		        if (GameHealth > 100)
		        {
		        	format(stringru, sizeof(stringru), "%s(%d) выставил 100 хп и %d брони.",
					PlayerName(playerid), playerid, GameHealth -100);
		        	format(stringen, sizeof(stringen), "%s(%d) has set up game with 100 HP and %d armour.", PlayerName(playerid), playerid, GameHealth -100);
				}else{
				    format(stringru, sizeof(stringru), "%s(%d) выставил %d хп.",
					PlayerName(playerid), playerid, GameHealth);
				    format(stringen, sizeof(stringen), "%s(%d) has set up game with %d HP.",
					PlayerName(playerid), playerid, GameHealth);
				}
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		    }else{
		        SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /gamehealth [1-999999]", "Use: /gamehealth [1-999999]");
		    }
		}
		else ROUNDSET_MENU(playerid);
	}
	if(dialogid == 38) //map select
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			if(worldid == 0)
			{
				if (score[0] == Roundkills || score[1] == Roundkills)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Сейчас Вы не можете использовать данную функцию.",
					"You can't use this function right now.");
					return true;
				}
			}
			
			if(GetPVarInt(playerid, "Admin") < 1 && worldid == 0)
			{
				StartVoteMap(playerid, LAST_MAP_INDEX[playerid]);
				//return SendClientMessageEx(playerid, COLOR_GREY,
				//"Для использования этих функций Вы должны быть администратором 1+ уровня!",
				//"To use these functions you need to have 1+ level admin rights!");
				return true;
			}
			
			if(worldid != 0 && !WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
		
			new stringru[128], stringen[128];
						
			if(GetPVarInt(playerid, "MapSelect") == 1)
			{
				if(worldid == 0)
				{
					format(stringru, sizeof(stringru), "%s(%d) сменил карту на %d. %s",
					PlayerName(playerid), playerid,
					LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
					format(stringen, sizeof(stringen), "%s(%d) has changed the map to %d. %s",
					PlayerName(playerid), playerid,
					LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
				} else {
					format(stringru, sizeof(stringru), "%s(%d) сменил карту в мире на %d. %s",
					PlayerName(playerid), playerid,
					LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
					format(stringen, sizeof(stringen), "%s(%d) has changed the world map to %d. %s",
					PlayerName(playerid), playerid,
					LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
				}
				SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
				
				if(worldid == 0) Map = LAST_MAP_INDEX[playerid];
				else World[worldid][wMap] = LAST_MAP_INDEX[playerid];
				
				foreach(Player, i)
				{
					if(GetPlayerVirtualWorld(playerid) == GetPlayerVirtualWorld(i))
					{
						SetPlayerInterior(i, MapInterior[LAST_MAP_INDEX[playerid]]);
						new team = GetPVarInt(i, "Team");
						SetSpawnInfo(i, 0, GetPlayerSkin(i),
						CwMaps[LAST_MAP_INDEX[playerid]][team][0],
						CwMaps[LAST_MAP_INDEX[playerid]][team][1],
						CwMaps[LAST_MAP_INDEX[playerid]][team][2],
						0, 0, 0, 0, 0, 0, 0);
						ReSpawnPlayer(i);
						SetPlayerInterior(i, MapInterior[LAST_MAP_INDEX[playerid]]);
					}
				}
				//SetPVarInt(playerid, "MapSelect", 0); //disable mapselect mode
				SpecOff(playerid); // stop fly mode on F key
			}
		} 
	}
