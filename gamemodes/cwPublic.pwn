				return SendClientMessageEx(playerid, COLOR_GREY,
				"Неверное значение", "Incorrect value");
			}
			
			switch(GetPVarInt(playerid, "TeleportToMode"))
			{
				case 1:
				{
					if(strval(inputtext) != INVALID_PLAYER_ID
					&& IsPlayerConnected(strval(inputtext)))
					{
						new cmd[24];
						format(cmd, sizeof(cmd), "/goto %i", strval(inputtext));
						OnPlayerCommandText(playerid, cmd);
					}
				}
				case 2:
				{
					if(IsValidVehicle(strval(inputtext)))
					{
						if(GetVehicleVirtualWorld(strval(inputtext))
						!= GetPlayerVirtualWorld(playerid))
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Транспорт в другом виртуальном мире!",
							"Transport in another virtual world!");
							return false;
						}
						
						new Float:vehx, Float:vehy, Float:vehz;
						GetVehiclePos(strval(inputtext), vehx, vehy, vehz);
						SetPlayerPos(playerid, vehx+2, vehy+2, vehz);
					}
				}
				case 3:
				{
					#if defined _streamer_included
					if(IsValidDynamicActor(strval(inputtext)))
					{
						if(GetDynamicActorVirtualWorld(strval(inputtext))
						!= GetPlayerVirtualWorld(playerid))
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Актер несуществует либо в другом виртуальном мире!",
							"Actor does not exist or in another virtual world");
							return false;
						}
						
						new Float:ax, Float:ay, Float:az;
						GetDynamicActorPos(strval(inputtext), ax, ay, az);
						SetPlayerPos(playerid, ax+1, ay+1, az);
					}
					#else
					if(IsValidActor(strval(inputtext)))
					{
						if(GetActorVirtualWorld(strval(inputtext))
						!= GetPlayerVirtualWorld(playerid))
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Актер несуществует либо в другом виртуальном мире!",
							"Actor does not exist or in another virtual world");
							return false;
						}
						
						new Float:ax, Float:ay, Float:az;
						GetActorPos(strval(inputtext), ax, ay, az);
						SetPlayerPos(playerid, ax+1, ay+1, az);
					}
					#endif
				}
				case 4:
				{
					#if defined _FCNPC_included
					if(FCNPC_IsValid(strval(inputtext)))
					{
						if(FCNPC_GetVirtualWorld(strval(inputtext))
						!= GetPlayerVirtualWorld(playerid))
