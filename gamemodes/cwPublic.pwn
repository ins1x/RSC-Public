public OnPlayerGiveDamage(playerid, damagedid, Float:amount, weaponid, bodypart)
{
	/*The amount is always the maximum damage the weaponid can do, even when the health left is less than that maximum damage.
	So when a player has 100.0 health and gets shot with a Desert Eagle which has a damage value of 46.2, it takes 3 shots to kill that player. 
	All 3 shots will show an amount of 46.2, even though when the last shot hits, the player only has 7.6 health left.
	
	playerid	The ID of the player that gave damage.
	damagedid	The ID of the player that received damage.
	amount	The amount of health/armour damagedid has lost (combined).
	*/ 

	new string[128];

	if(AntiTK) // report about tk in dmgtracer
	{
		if(GetPVarInt(playerid, "Team") == GetPVarInt(damagedid, "Team"))
		{
			LastRejectHitReason[playerid] = 6;
		}
	}
	
	if(GetPVarInt(playerid, "Mobile") && GetPVarInt(playerid, "Admin") < 3)
	{
		KickPlayerEx(playerid, "Mobile client");
		return 0;
	}
	
	if(AC_DAMAGEHACKS)
	{	
		// the code has been moved in order to be able to disable options directly from the game for testing

		// Checks wrong player state
		if( damagedid == INVALID_PLAYER_ID ) {
			LastRejectHitReason[playerid] = 0;
			return 0;
		}
		if( !IsPlayerSpawned( damagedid ) ) {
			LastRejectHitReason[playerid] = 10;
			return 0;
		} 
		if( !IsPlayerStreamedIn( damagedid, playerid ) ) {
			LastRejectHitReason[playerid] = 7;
			return 0;
		}

		//if(NetStats_PacketLossPercent(playerid) < AC_DAMAGEWARN_IGNORE_PLOSS)
		
		// Ignore unreliable and invalid damage
		if ( weaponid < 0 || weaponid >= sizeof( s_ValidDamageGiven ) || !s_ValidDamageGiven[ weaponid ] )
		{
			switch(weaponid)
			{
				case 19..34: // ignore 16,17,18, 35..42 this weapons detect incorrectly
				{
					DamageHacksWarns[playerid]++;
					LastRejectHitReason[playerid] = 18;
					format(string, sizeof(string),
					"[WARN] %s(%d) s_ValidDamageGiven: %.2f - %.2f. [ploss: %.2f]",
					PlayerName(playerid), playerid, s_ValidDamageGiven,
					s_ValidDamageGiven[ weaponid ], NetStats_PacketLossPercent(playerid));
					SendSystemMessage(string);
					return 0;
				}
			}
			

			if( weaponid > 19 || weaponid >= sizeof( s_ValidMaxDamage ) 
			|| amount > s_ValidMaxDamage[ weaponid ] + 3.5 ){ // 3.5 safety margin
				DamageHacksWarns[playerid]++;
				LastRejectHitReason[playerid] = 18;
				format(string, sizeof(string),
				"[WARN] %s(%d) amount %.2f > ValidMaxDamage %.2f. [ploss: %.2f]",
				PlayerName(playerid), playerid, amount, s_ValidMaxDamage[ weaponid ], NetStats_PacketLossPercent(playerid));
				SendSystemMessage(string);
				return 0;
			}
		}
		
	
		if( IsPlayerInAnyVehicle( playerid ) && GetPlayerVehicleSeat( playerid ) == 0 
		&& ( weaponid == WEAPON_M4 || weaponid == WEAPON_MINIGUN ) ) {
			LastRejectHitReason[playerid] = 1;
			return 0;
		}
		
		// Collision damage should never be above 165
		if (weaponid == WEAPON_COLLISION) {
			if (amount > 165.0) {
				amount = 1.0;
			} else {
				amount /= 165.0;
			}
		}

		#if !defined _nex_ac_included
		if(playerid != INVALID_PLAYER_ID)
		{
			FakeKill[damagedid] = playerid;
		}
		#endif
	}
	
	if(GetPVarInt(damagedid, "AFKTime") < 5) {
		Stats[playerid][pHits]++;
	}
	
	// enemybar info
	if (!onspawnprotect[damagedid])
	{
		SetPVarInt(playerid, "enemybar", damagedid);
	}
	// specbar debug info
	Stats[playerid][pAmount] = amount;
	Stats[playerid][pBodypart] = bodypart; 
	
	// Kick damage cheater
	if(DamageHacksWarns[playerid] >= AC_DAMAGEWARN_KICKAFTER)
	{
		DamageHacksWarns[playerid] = 0;
		KickPlayerEx(playerid, "Weapon hacks");
	}
	
	// Protect spaectators
	if(Spawnlock && damagedid != INVALID_PLAYER_ID)
	{
		if(GetPVarInt(damagedid, "Team") == 2 && GetPVarInt(playerid, "Team") != 2)
		{
			GameTextForPlayer(playerid, "~r~Forbidden damage ~n~~y~Spectators", 3000, 5);
		}
	}
	
	// Player damage informer
	if(pData[playerid][pDmgInformer] > 0 && onspawnprotect[damagedid] == false)
	{
		if(damagedid != INVALID_PLAYER_ID)
		{
			new 
				dmg_string[9], PlayerText3D:DamageTextLabel,
				Float:pOrigPosX, Float:pOrigPosY, Float:pOrigPosZ,
				Float:pHitPosX, Float:pHitPosY,	Float:pHitPosZ
			;
			GetPlayerLastShotVectors(playerid, pOrigPosX, pOrigPosY, pOrigPosZ,
			pHitPosX, pHitPosY, pHitPosZ); 
			//format(dmg_string, sizeof(dmg_string), "%d", floatround(amount)); 
			valstr(dmg_string, floatround(amount));
			if(strlen(dmg_string))
			{
				DamageTextLabel = CreatePlayer3DTextLabel(playerid, dmg_string,
				0xFFFFFFFF, pHitPosX, pHitPosY, pHitPosZ, 150); 
				SetTimerEx("HideDamageInformer", 1250, false, "dd", playerid, _:DamageTextLabel); 
			}
		}
	}
	
    return false;
}

public OnPlayerTakeDamage(playerid, issuerid, Float: amount, weaponid, bodypart)
{
	/*
	If lagcompmode is OFF, OnPlayerTakeDamage is accurate. Because OnPlayerGiveDamage is called whenever a 
	player attacks other player, regardless if they other player receives a damage or even get shot.
	OnPlayerTakeDamage and OnPlayerGiveDamage are not fully synchronized. Due to the difference in ping,
	the OnPlayerTakeDamage function is called after a few milliseconds if the OnPlayerGiveDamage
	function is successfully called.
	
	IMPORTANT:	GetPlayerHealth and GetPlayerArmour will return the old amounts of the player before this callback.
	*/
		
	new weapn, ammo;
	new Float: distance = 0.0;
	if(issuerid != INVALID_PLAYER_ID)
	{
		distance = GetDistanceBetweenPlayers( playerid, issuerid );
		Stats[issuerid][pDistance] = distance;
		Stats[issuerid][pDamagedid] = playerid;
	}
	
	GetPlayerWeaponData(playerid, 0, weapn, ammo);
	new
        Float: health,
        Float: armour
    ;
    GetPlayerHealth(playerid, health); 
    GetPlayerArmour(playerid, armour); 

	if(issuerid != INVALID_PLAYER_ID)
	{
		if(bodypart == 9 && weaponid == 34)
		{
			GameTextForPlayer(issuerid, "~y~Headshot", 3000, 4);
			GameTextForPlayer(playerid, "~y~Headshot", 3000, 4);
			if(pData[playerid][pSfx]) PlayAudioStreamForPlayer(playerid,
			"https://www.myinstants.com/media/sounds/headshot_1.mp3");
			if(pData[issuerid][pSfx]) PlayAudioStreamForPlayer(issuerid,
			"https://www.myinstants.com/media/sounds/headshot_1.mp3");
			SetPlayerHealth(playerid, 0);
		}
	}
	
	// Kill Assist
	new slot = -1;
	for(new assist; assist < 3; assist++)
	{
		if(KillAssist[playerid][assist] == issuerid) {
			slot = -1;
			break;
		}
	
		if((slot == -1) && (KillAssist[playerid][assist] == INVALID_PLAYER_ID))	{
			slot = assist;
		}
	}
	if(slot != -1)	{
		KillAssist[playerid][slot] = issuerid;
	}

	new string[128];
	if(AC_DAMAGEHACKS && issuerid != INVALID_PLAYER_ID)
	{
		if(NetStats_PacketLossPercent(issuerid) < AC_DAMAGEWARN_IGNORE_PLOSS)
		{
			if(distance < 1000.0 && distance > s_WeaponRange[ weaponid ]+3.5 
			&& GetPlayerWeapon(issuerid) != 0) {
				switch (weaponid)
				{
					case 19..34: // ignore 16,17,18, 35..42 this weapons detect incorrectly
					{
						DamageHacksWarns[issuerid]++;
						LastRejectHitReason[issuerid] = 11;
						format(string, sizeof(string),
						"%s(%d) Incorrect range distance: %.2f > %.2f s_WeaponRange[weaponid: %d].",
						PlayerName(issuerid), issuerid, distance, s_WeaponRange[ weaponid ], weaponid);
						SendSystemMessage(string);
						if(DamageHacksWarns[issuerid] >= AC_DAMAGEWARN_KICKAFTER)
						{
							DamageHacksWarns[issuerid] = 0;
							KickPlayerEx(issuerid, "Incorrect shooting range");
						}
						return 0;
					}
				}
			}
		}
	}
	
	if(AC_DAMAGEHACKS && issuerid != INVALID_PLAYER_ID)
	{
		// Ignore unreliable and invalid damage
		if (weaponid < 0 || weaponid >= sizeof(s_ValidDamageTaken) || !s_ValidDamageTaken[weaponid]) {
			LastRejectHitReason[issuerid] = 18;
			return 0;
		}
	}
	
	if(AC_DAMAGEHACKS && issuerid != INVALID_PLAYER_ID)
	{
		new shootrate = GetTickCountDifference(LastShotTick[issuerid], GetTickCount());
		//if (shootrate > 0) {
		if (s_MaxWeaponShootRate[weaponid] - shootrate < s_MaxWeaponShootRate[weaponid]) {
			LastRejectHitReason[issuerid] = 13;
			format(string, sizeof(string),
			"%s(%d) Shoot rate too fast %i > %i MaxWeaponShootRate[weaponid: %d].",
			PlayerName(issuerid), issuerid, s_MaxWeaponShootRate[weaponid]-shootrate, s_MaxWeaponShootRate[weaponid], weaponid);
			SendSystemMessage(string);
			
			if(DamageHacksWarns[issuerid] >= AC_DAMAGEWARN_KICKAFTER)
			{
				DamageHacksWarns[issuerid] = 0;
				KickPlayerEx(issuerid, "High Weapon Shootrate");
			}
			DamageHacksWarns[issuerid]++;
			return 0;
		}
	}

	if(AC_DAMAGEHACKS && issuerid != INVALID_PLAYER_ID)
	{
		if(amount>3.0)
	    {
	        new low;

			if(weaponid==22) if(amount<5) low=1;
			if(weaponid==23) if(amount<7) low=1;
			if(weaponid==24) if(amount<40) low=1;
			if(weaponid==28 || weaponid==32) if(amount<4.0) low=1;
			if(weaponid==33) if(amount<10) low=1;
			if(weaponid==30 || weaponid==31) if(amount<5) low=1;
			if(weaponid==34) if(amount<17) low=1;

			if(low)
			{
			    if(amount>=3.29 && amount<=3.31) low=0;
				if(amount>=3.95 && amount<=3.97) low=0;
	            if(amount>=4.61 && amount<=4.63) low=0;
	            if(weaponid!=31 && weaponid!=30) if(amount>=4.94 && amount<=4.96) low=0;
				if(weaponid!=23) if(amount>=6.59 && amount<=6.61) low=0;
				if(amount>=8.24 && amount<=8.26) low=0;
				if(amount>=16.16 && amount<=16.17) low=0;
				if(amount>=13.52 && amount<=13.54) low=0;
			}

			if(low)
			{
			    AntiDamageCheck[playerid]++;
			    if(AntiDamageCheck[playerid] == 10)
			    {
			        format(string,sizeof(string),"%s[%d] has reduced damage weaponid: %d amount: %f",
					PlayerName(playerid), playerid, weaponid, amount);
					SendSystemMessage(string);
					AntiDamageCheck[playerid] = 0;
			    }
			}
		}
	}
	// damage bell (if not on spawn protect)
	if(issuerid != INVALID_PLAYER_ID && !onspawnprotect[playerid]) 
	{
		if (pData[issuerid][pBell] > 0) {
			PlayerPlaySound(issuerid, pData[issuerid][pBell] ,0,0,0);
		}
	}
	
	// fists hits statistics ignore
	if(weaponid == 0 || weaponid == 1) return 0;
	
	if(weaponid == 50 && GetPlayerVirtualWorld(issuerid) == 0)
	{
		KickPlayerEx(issuerid, "Heliblades abuse");
		return 0;
	}
	
	if(GetPlayerVirtualWorld(issuerid) != 0 && issuerid != INVALID_PLAYER_ID)
	{
		Stats[issuerid][pDamage]+=amount;
		Stats[playerid][pInjuries]+=amount;
		
		if(Stats[playerid][pDamage] > 0.0 && Stats[playerid][pInjuries] > 0.0)
		{
			Stats[playerid][pEfficiency] = Stats[playerid][pDamage] / Stats[playerid][pInjuries];
		}
		
		if(Stats[playerid][pKills] > 0 && Stats[playerid][pDeath] > 0)
		{
			Stats[playerid][pKD] = Stats[playerid][pKills] / Stats[playerid][pDeath];
		}
		return true;
	}
		
	if (GetPlayerTeam(playerid) == NO_TEAM || GetPlayerTeam(playerid) != GetPlayerTeam(issuerid))
	{
		if (GetPVarInt(playerid, "Team") == 2) return 0;
		if (GetPlayerVirtualWorld(issuerid) != 0 || GetPlayerVirtualWorld(playerid) != 0) return 0;
	    if (amount > health)
	    {
	        amount = health +floatround(GetPVarFloat(playerid, "LastHP") -floatround(GetPVarFloat(playerid, "LastHP"), floatround_round), floatround_ceil);
	    }
	    if (!freeze_score)
		{
	        SetPVarFloat(playerid, "cwinjuries", GetPVarFloat(playerid, "cwinjuries") +amount);
	        PlayerRefreshScore(playerid);
		    if (issuerid != INVALID_PLAYER_ID)
		    {
	        	SetPVarFloat(issuerid, "cwdamage", GetPVarFloat(issuerid, "cwdamage") +amount);
				GivePlayerMoney(issuerid, floatround(amount, floatround_round));
	        	if (!AntiTK)
	        	{
					if (GetPVarInt(playerid, "Team") == GetPVarInt(issuerid, "Team"))
					{
						SetPVarFloat(issuerid, "cwteamdamage", GetPVarFloat(issuerid, "cwteamdamage") +amount);
					}
			 	}
		        PlayerRefreshScore(issuerid);
		    }
	    }
	    SetPVarFloat(playerid, "LastHP", GetPVarInt(playerid, "LastHP") -amount);
	}
	if (GetPVarInt(issuerid, "Team") == 2 && GetPVarInt(playerid, "Team") != 2) 
	{
		if(!IsPlayerAFK(playerid)) 
		{
			if (GetPVarInt(issuerid,"SpectatorAbuse") >= 2)
			{
				KickPlayerEx(issuerid, "Spectators are not allowed to interrupt the match");
			} else {
				SetPVarInt(issuerid,"SpectatorAbuse", GetPVarInt(issuerid,"SpectatorAbuse") + 1);
				SendClientMessageEx(issuerid, COLOR_RED,
				"[Предупреждение] {FFFFFF}Наблюдателям запрещено мешать игре.",
				"[WARNING] {FFFFFF}Spectators are not allowed to interrupt the match.");
				ReSpawnPlayer(issuerid);
			}
		}
		return 0;
	}
	if (ammo == 1000)
	{
		KickPlayerEx(issuerid, "Anticheat. Sobeit detected (1000)");
		return 0;
	}
	return true;
}
#endif

public AuxTimer()
{
	// Auxiliary timer. (work every 5 sec)
	// Used where there is no need to do checks every second but the minute interval is too small
	// (for example, some types of anti-cheat)
	static string[128], stringru[128];
	new Float:x, Float:y, Float:z;
	
	if(AuxTimerTick < 2) {
		AuxTimerTick++;
	} else {
		AuxTimerTick = 0;
	}
	
	foreach(new playerid : Player)
	{
		new worldid = GetPlayerVirtualWorld(playerid);
		
		LastRejectHitReason[playerid] = -1;
		
		#if defined _YSF_included
		if(FakePingBalancer)
		{
			TogglePlayerFakePing(playerid, true);
			SetPlayerFakePing(ChosenPlayer[playerid], 40+random(20));
			SetPVarInt(playerid, "FakePing", 1);
		}
		#endif
		
		// used to display data on the player's packet loss when disconnected
		PlayerPloss[playerid] = NetStats_PacketLossPercent(playerid);
		
		#if defined _sampcac_included
			//ESC MENU
			//if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) CAC_ReadMemory(playerid, 0xB7CB49, 1); 
			CAC_ReadMemory(playerid, 0xB729A0, 1); // FPS Limit 
		#endif
		
		// Hide Textdraws
		PlayerTextDrawHide(playerid, TDnames[playerid]);
		
		// Fix Spectating invalid player bug
		if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING && GetPlayerTeam(playerid) == TEAM_SPEC)
		{
			if(GetPVarInt(playerid, "Specing") == INVALID_PLAYER_ID && !GetPVarInt(playerid, "FlyMode"))
			{
				CheckSpec(playerid);
			}
		}
		
		/*if(worldid!= 0 && World[worldid][wRespawnInWater])
		{
			if(GetPlayerAnimationIndex(playerid) == 1538)
			{
				ReSpawnPlayer(playerid);
			}
		}*/
		
		if(worldid!= 0 && World[worldid][wHoldInVehicle])
		{
			if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER)
			{
				ReSpawnPlayer(playerid);
			}			
		}
		
		// Update player cw satats backup data
		if(CWmode)
		{
			if(IsPlayerConnected(playerid) && !frz)
			{
				GetPlayerPos(playerid, CwData[playerid][cwPosX],
				CwData[playerid][cwPosY], CwData[playerid][cwPosZ]);
				GetPlayerFacingAngle(playerid, CwData[playerid][cwPosA]);
				GetPlayerHealth(playerid, CwData[playerid][cwHealth]);
				GetPlayerArmour(playerid, CwData[playerid][cwArmour]);
				CwData[playerid][cwTeam] = GetPVarInt(playerid,"Team");
				CwData[playerid][cwKills] = GetPVarInt(playerid,"cwkills");
				CwData[playerid][cwDeaths] = GetPVarInt(playerid,"cwdeath");
				CwData[playerid][cwTeamkills] = GetPVarInt(playerid,"cwteamkills");
				CwData[playerid][cwDamage] = GetPVarFloat(playerid,"cwdamage");
				CwData[playerid][cwInjuries] = GetPVarFloat(playerid,"cwinjuries");	
				CwData[playerid][cwTeammateDamage] = GetPVarFloat(playerid,"cwteamdamage");
				CwData[playerid][cwRoundKills] =  GetPVarInt(playerid,"round_kills");
				CwData[playerid][cwRoundDeaths] = GetPVarInt(playerid,"round_death");
				CwData[playerid][cwRoundTeamkills] = GetPVarInt(playerid,"round_teamkills");
				CwData[playerid][cwRoundDamage] = GetPVarFloat(playerid,"round_damage");
				CwData[playerid][cwRoundInjuries] = GetPVarFloat(playerid,"round_injuries");
				CwData[playerid][cwRoundTeammateDamage] = GetPVarFloat(playerid,"round_teamdamage");
			}
		}
		
		if(AuxTimerTick == 2) //every 10 sec 
		{
			//hide enemy bar
			if(ShowEnemyBar) SetPVarInt(playerid, "enemybar", -1); 
			// Change fight style
			new Styles[6] = {4,5,6,7,15,16};
			SetPlayerFightingStyle(playerid, Styles[random(6)]);	
			// Antispam counter
			if(ServerAntiSpam) 
			{
				if(GetPVarInt(playerid, "spamcount") >= 8)
				{
					format(string, sizeof(string),
					"Server has muted player %s(%d) for 5 minutes (reason: Flood)",
					PlayerName(playerid), playerid);
					format(stringru, sizeof(stringru),
					"Сервер заглушил игрока %s(%d) на 5 минут (причина: Flood)",
					PlayerName(playerid), playerid);
					pData[playerid][pMuted] = 5*60; //unix time + min
					SendClientMessageToAllEx(COLOR_GREY, stringru, string);
					SetPVarInt(playerid, "spamcount", 0);
				} else {
					SetPVarInt(playerid, "spamcount", 0);
				}
			}
		}
		// High ping detect
		if( GetPlayerPing(playerid) > MAX_PING && GetPVarInt(playerid, "Team") != 2)
		{
			if(!KICK_LAGERS)
			{
				SetPVarInt(playerid, "HighPingCount", GetPVarInt(playerid,"HighPingCount")+1);
				if (GetPVarInt(playerid,"HighPingCount") >= 3)
				{
					SetPlayerChatBubble(playerid, "Lager", COLOR_RED, 50.0, 5000);
				}
			}
			if(KICK_LAGERS == 3)
			{
				SetPVarInt(playerid, "HighPingCount", GetPVarInt(playerid,"HighPingCount")+1);
			
				if (GetPVarInt(playerid,"HighPingCount") >= 3)
				{
					ResetPlayerWeapons(playerid);
					SetPlayerTeamEx(playerid, TEAM_SPEC);
					format(string, sizeof(string),
					"%s[%i] has been moved to spectators. Reason: High ping [%d | MAX: %d]",
					PlayerName(playerid), playerid, GetPlayerPing(playerid), MAX_PING);
					format(stringru, sizeof(stringru),
					"%s[%i] был перемещен в наблюдатели. Причина: Высокий пинг [%.1f | MAX: %.1f]",
					PlayerName(playerid), playerid, GetPlayerPing(playerid), MAX_PING);
					SendClientMessageToAllEx(COLOR_GREY, stringru, string);
				}
			} 
			else if(KICK_LAGERS == 2)
			{
				if(GetPVarInt(playerid,"HighPingCount") >= 3)
				{
					SetPVarInt(playerid, "HighPingCount", GetPVarInt(playerid,"HighPingCount")+1);
					if (pData[playerid][pLang] == 1) {
						format(string, sizeof(string),
						"Warning [%d/3] Reason: High ping [%d | MAX: %d]",
						GetPVarInt(playerid,"HighPlossCount"), GetPlayerPing(playerid), MAX_PING);
					} else {
						format(string, sizeof(string),
						"Предупреждение [%d/3] Причина: Высокий пинг [%.1f | MAX: %.1f]",
						GetPVarInt(playerid,"HighPlossCount"), GetPlayerPing(playerid), MAX_PING);
					}
					SetPlayerChatBubble(playerid, "Lager", COLOR_RED, 50.0, 5000);
					SendClientMessage(playerid, COLOR_WHITE, string);
				} else {
					format(string, sizeof(string),  "%s[%i] was kicked. Reason: High ping [%d | MAX: %d]",
					PlayerName(playerid), playerid, GetPlayerPing(playerid), MAX_PING);
					printf("%s", string);
					SendClientMessageEx(playerid, COLOR_RED,
					"Проверьте Ваше интернет-соединение", "Check your internet connection");
					SendClientMessageEx(playerid, COLOR_RED,
					"Если вы подключены через wi-fi, попробуйте перезагрузить модем",
					"If you are connected via wi-fi, try rebooting you modem");
					if (pData[playerid][pLang] == 1) KickPlayerEx(playerid, "High ping");
					else if (pData[playerid][pLang] == 0) KickPlayerEx(playerid, "Высокий пинг");
				}
			}
			else if(KICK_LAGERS == 1)
			{
				format(string, sizeof(string),
				"Warning %s[%i] Reason: High ping [%d | MAX: %d]", 
				PlayerName(playerid), playerid, GetPlayerPing(playerid), MAX_PING);
				format(stringru, sizeof(stringru),
				"Предупреждение %s[%i] Причина: Высокий пинг [%d | MAX: %d]", 
				PlayerName(playerid), playerid, GetPlayerPing(playerid), MAX_PING);
				SendClientMessageToAllEx(COLOR_RED, stringru, string);
				SetPlayerChatBubble(playerid, "Lager", COLOR_RED, 50.0, 5000);
			}
		}
		// Ploss Lagers detect
		if( NetStats_PacketLossPercent(playerid) > MAX_PACKETLOSS 
		&& NetStats_GetConnectedTime(playerid)/60000 > 5 && GetPVarInt(playerid, "Team") != 2)
		{
			if(KICK_LAGERS == 3)
			{
				SetPVarInt(playerid, "HighPlossCount", GetPVarInt(playerid,"HighPlossCount")+1);
			
				if (GetPVarInt(playerid,"HighPlossCount") >= 3)
				{
					ResetPlayerWeapons(playerid);
					SetPlayerTeamEx(playerid, TEAM_SPEC);
					format(string, sizeof(string),
					"%s[%i] has been moved to spectators. Reason: High packetloss [%.1f | MAX: %.1f]",
					PlayerName(playerid), playerid, NetStats_PacketLossPercent(playerid), MAX_PACKETLOSS);
					format(stringru, sizeof(stringru),
					"%s[%i] был перемещен в наблюдатели. Причина: Высокая потеря пакетов [%.1f | MAX: %.1f]",
					PlayerName(playerid), playerid, NetStats_PacketLossPercent(playerid), MAX_PACKETLOSS);
					SendClientMessageToAllEx(COLOR_GREY, stringru, string);
				}
			} 
			else if(KICK_LAGERS == 2)
			{
				if (GetPVarInt(playerid,"HighPlossCount") >= 3)
				{
					SetPVarInt(playerid, "HighPlossCount", GetPVarInt(playerid,"HighPlossCount")+1);
					if (pData[playerid][pLang] == 1) {
						format(string, sizeof(string),
						"Warning [%d/3] Reason: High packetloss [%.1f | MAX: %.1f]",
						GetPVarInt(playerid,"HighPlossCount"), NetStats_PacketLossPercent(playerid), MAX_PACKETLOSS);
					} else { 
						format(string, sizeof(string),
						"Предупреждение [%d/3] Причина: Высокая потеря пакетов [%.1f | MAX: %.1f]",
						GetPVarInt(playerid,"HighPlossCount"), NetStats_PacketLossPercent(playerid), MAX_PACKETLOSS);
					}
					SendClientMessage(playerid, COLOR_WHITE, string);
					SetPlayerChatBubble(playerid, "Lager", COLOR_RED, 50.0, 5000);
				} else {
					SendClientMessageEx(playerid, COLOR_GREY,
					"Проверьте Ваше интернет-соединение", "Check your internet connection");
					SendClientMessageEx(playerid, COLOR_GREY,
					"Если вы подключены через wi-fi, попробуйте перезагрузить модем",
					"If you are connected via wi-fi, try rebooting you modem");
					if (pData[playerid][pLang] == 1) KickPlayerEx(playerid, "High packetloss");
					else if (pData[playerid][pLang] == 0) KickPlayerEx(playerid, "Высокая потеря пакетов");
				}
			}		
			else if(KICK_LAGERS == 1)
			{
				format(string, sizeof(string),
				"Warning %s[%i] Reason: High packetloss [%.1f | MAX: %.1f]",
				PlayerName(playerid), playerid, NetStats_PacketLossPercent(playerid), MAX_PACKETLOSS);
				format(stringru, sizeof(stringru),
				"Предупреждение %s[%i] Причина: Высокая потеря пакетов [%.1f | MAX: %.1f]",
				PlayerName(playerid), playerid, NetStats_PacketLossPercent(playerid), MAX_PACKETLOSS);
				SendClientMessageToAllEx(COLOR_RED, stringru, string);
				SetPlayerChatBubble(playerid, "Lager", COLOR_RED, 50.0, 5000);
			}
		}
		// FPS lager detect
		if(GetPVarInt(playerid, "fps") >= 10 && GetPVarInt(playerid, "fps") <= MIN_FPS)
		{
			// if player online > 1 minute and not spectator
			if(NetStats_GetConnectedTime(playerid)/60000 > 1 && GetPVarInt(playerid, "Team") != 2)
			{ 
				// Fixes a bug with AC triggering folding the game menu
				if(!IsPlayerAFK(playerid))
				{	
					if(!KICK_LAGERS)
					{
						SetPVarInt(playerid, "LowFpsCount", GetPVarInt(playerid,"LowFpsCount")+1);
						if ((GetPVarInt(playerid,"LowFpsCount") % 3) == 0)
						{
							SetPlayerChatBubble(playerid, "LOW FPS", COLOR_RED, 50.0, 5000);
						}
					}
					
					if(KICK_LAGERS == 3)
					{
						SetPVarInt(playerid, "LowFpsCount", GetPVarInt(playerid,"LowFpsCount")+1);
						
						if (GetPVarInt(playerid,"LowFpsCount") >= 5)
						{
							ResetPlayerWeapons(playerid);
							SetPlayerTeamEx(playerid, TEAM_SPEC);
							format(string, sizeof(string),
							"%s[%i] has been moved to spectators. Reason: Low FPS [%d | MIN: %d]",
							PlayerName(playerid), playerid, GetPVarInt(playerid, "fps"), MIN_FPS);
							format(stringru, sizeof(stringru),
							"%s[%i] был перемещен в наблюдатели. Причина: Низкий FPS [%d | MIN: %d]",
							PlayerName(playerid), playerid, GetPVarInt(playerid, "fps"), MIN_FPS);
							SendClientMessageToAllEx(COLOR_GREY, stringru, string);
						} 
					}
					else if(KICK_LAGERS == 2)
					{
						SetPVarInt(playerid, "LowFpsCount", GetPVarInt(playerid,"LowFpsCount")+1);
						if ((GetPVarInt(playerid,"LowFpsCount") % 3) == 0)
						{
							format(string, sizeof(string),
							"Warning %s[%i] Reason: Low FPS [%d | MIN: %d]",
							PlayerName(playerid), playerid, GetPVarInt(playerid, "fps"), MIN_FPS);
							format(stringru, sizeof(stringru),
							"Предупреждение %s[%i] Причина: Низкий FPS [%d | MIN: %d]",
							PlayerName(playerid), playerid, GetPVarInt(playerid, "fps"), MIN_FPS);
							SendClientMessageToAllEx(COLOR_GREY, stringru, string);
							SetPlayerChatBubble(playerid, "LOW FPS", COLOR_RED, 50.0, 5000);
						} 
						if (GetPVarInt(playerid,"LowFpsCount") >= 15) 
						{
							if (pData[playerid][pLang] == 1) KickPlayerEx(playerid, "Low FPS");
							else if (pData[playerid][pLang] == 0) KickPlayerEx(playerid, "Низкий FPS");
						}
					}
					else if(KICK_LAGERS == 1)
					{
						if ((GetPVarInt(playerid,"LowFpsCount") % 10) == 0 
						&& GetPVarInt(playerid,"LowFpsCount") > 20) //even 10
						{
							format(string, sizeof(string),
							"Warning %s[%i] Reason: Low FPS [%d | MIN: %d]",
							PlayerName(playerid), playerid, GetPVarInt(playerid, "fps"), MIN_FPS);
							format(stringru, sizeof(stringru),
							"Предупреждение %s[%i] Причина: Низкий FPS [%d | MIN: %d]",
							PlayerName(playerid), playerid, GetPVarInt(playerid, "fps"), MIN_FPS);
							SendClientMessageToAllEx(COLOR_GREY, stringru, string);
							SetPlayerChatBubble(playerid, "LOW FPS", COLOR_RED, 50.0, 5000);
						}
					}
				}
			}
		}
		// FPS Unlockers
		if(!fpsunlock)
		{
			if(GetPVarInt(playerid, "Team") != 2 && GetPVarInt(playerid, "fps") > MAX_FPS)
			{			
				// Fixes a bug with AC triggering folding the game menu
				#if defined _YSF_included
				if(!IsPlayerPaused(playerid)) SetPVarInt(playerid,"AC_FPSUNLOCK", GetPVarInt(playerid,"AC_FPSUNLOCK") + 1);
				#else
				if(!IsPlayerAFK(playerid)) { 
					SetPVarInt(playerid,"AC_FPSUNLOCK", GetPVarInt(playerid,"AC_FPSUNLOCK") + 1);
				}
				#endif
				if(GetPVarInt(playerid,"AC_FPSUNLOCK") >= 3) {
					format(string, sizeof(string), "FPS Unlocker [%i | MAX: %i]",
					GetPVarInt(playerid, "fps"), MAX_FPS);
					KickPlayerEx(playerid, string);
				}
			}
			
			#if defined _sampcac_included
			if(GetPVarInt(playerid, "Team") != 2 && GetPVarInt(playerid, "CAC_FPS") > MAX_FPS)
			{			
				// Fixes a bug with AC triggering folding the game menu
				#if defined _YSF_included
				if(!IsPlayerPaused(playerid)) SetPVarInt(playerid,"AC_FPSUNLOCK", GetPVarInt(playerid,"AC_FPSUNLOCK") + 1);
				#else
				if(!IsPlayerAFK(playerid)) {
					SetPVarInt(playerid,"AC_FPSUNLOCK", GetPVarInt(playerid,"AC_FPSUNLOCK") + 1);
				}
				#endif
				if(GetPVarInt(playerid,"AC_FPSUNLOCK") >= 2) {
					format(string, sizeof(string), "[SAMPCAC] Cheat FPS Unlocker [%i | MAX: %i]",
					GetPVarInt(playerid, "CAC_FPS"), MAX_FPS);
					KickPlayerEx(playerid, string);
				}
			}
			#endif
		}
		if(AC_Rapidfire)
		{
			// high shootrate check
			new maxshots;
			switch(GetPlayerWeapon(playerid))
			{
				case 26: maxshots = 20;
				default: maxshots = 40;
			}
			if((LastShotVal[playerid]) > maxshots)
			{
				format(string, sizeof(string),
				"Warning %s(%d) high shootrate, possible Rapidfire [code 2]. Shots: %d [MAX:%d] ",
				PlayerName(playerid), playerid, LastShotVal[playerid], maxshots);
				SendSystemMessage(string);
				LastRejectHitReason[playerid] = 14;
				ClearAnimations(playerid);
				ApplyAnimation(playerid, "PED", "IDLE_stance", 4.1, 0, 1, 1, 1, 1000, 1);
			}
			LastShotVal[playerid] = 0;
			
			// high ratio check
			if(Stats[playerid][pHits] > 25)
			{
				new Float:shotsratio = (Stats[playerid][pShots] / Stats[playerid][pHits]);
				if(shotsratio <= 1.25)
				{
					if (GetPVarInt(playerid,"HighRatio") >= 12)
					{
						SetPVarInt(playerid, "HighRatio", GetPVarInt(playerid,"HighRatio")+1);
						format(string, sizeof(string),
						"Warning %s[%i] high shot/hits ratio. Shots: %i Hits:%i [%.1f | Normal < 1.25]",
						PlayerName(playerid), playerid, Stats[playerid][pShots], Stats[playerid][pHits], shotsratio);
						SendSystemMessage(string);
						SetPVarInt(playerid, "HighRatio",0);
						LastRejectHitReason[playerid] = 15;
						ClearAnimations(playerid);
						ApplyAnimation(playerid, "PED", "IDLE_stance", 4.1, 0, 1, 1, 1, 1000, 1);
						//KickPlayerEx(playerid, "Rapidfire [code 3]");
					}
				}
			}
		}
		// drop mute 
		if(pData[playerid][pMuted] > 0)
		{
			if((pData[playerid][pMuted] - 5) <= 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы больше не заглушены", "You are no longer muted");
				new szQuery[128], DBResult: query;
				new ip[16], mutedip[16+1], nickname[24];
				GetPlayerIp(playerid, ip, sizeof ip);
				format(szQuery, sizeof(szQuery),
				"SELECT Lastip, Nickname FROM Accounts WHERE Muted > 0");
				query = db_query(dbaccounts, szQuery);
				new rows = db_num_rows(query);
				for(new p; p < rows; p++)
				{			
					db_get_field(query, 0, mutedip, sizeof(mutedip));
					new len = strlen(mutedip);
					strdel(mutedip, len-2, len);
					
					db_get_field(query, 1, nickname, sizeof(nickname));
					if(strfind(ip, mutedip) != -1)
					{
						format(szQuery, sizeof(szQuery),
						"UPDATE Accounts SET Muted = 0 WHERE (Nickname = '%q')",
						db_escape(nickname));
						db_query(dbaccounts, szQuery);
					}
					db_next_row(query);
				}
				db_free_result(query);
			}
			pData[playerid][pMuted] -= 5;
		}
		
		// Fly troll
		if(GetPVarInt(playerid, "FlyTroll"))
		{
			GetPlayerPos(playerid, x,y,z);
			SetPlayerPos(playerid, x, y, z + 200.0);
		}
		
	}
	return true;
}

public TechTimer() 
{
	/* Server service timer. Work every 60 sec */
	new hour, minute, second;
	gettime(hour, minute, second);
	new tmpstr[128];

	// Drop counters every 60 sec
	foreach(new playerid : Player)
	{
		SetPVarInt(playerid, "HighPingCount", 0);
		SetPVarInt(playerid, "HighPlossCount", 0);
		SetPVarInt(playerid, "AC_SPRINTHOOK", 0);
		SetPVarInt(playerid, "AC_AUTOSCROLL", 0);
		SetPVarInt(playerid, "SpectatorAbuse", 0);
		SetPVarInt(playerid, "AC_FPSUNLOCK",0);
		#if !defined _INC_WEAPON_CONFIG
		DamageHacksWarns[playerid] = 0;
		SetPVarInt(playerid, "rapidinfractions",0);
		#endif
		PlayerPloss[playerid] = 0;
		// delete test car
		if(GetPVarInt(playerid, "modsa_test") > 0) DestroyVehicle(GetPVarInt(playerid, "modsa_test"));
	}
	
	// Drop geoip limit protect counter
	GeoIPAsklimit = 0;
	
	// Change mapname in samp client every minute
	if(soucet[0] == 0 && soucet[1] == 0)
	{
		// if teams score 0 show mapname
		format(tmpstr, sizeof(tmpstr), "mapname %s", MapNames[Map]);
		SendRconCommand(tmpstr);
	} else {
		// Update score and soucet in samp client
		format(tmpstr, sizeof(tmpstr), "mapname (%d) %i:%i (%d)",
		RoundScore[0], soucet[0], soucet[1], RoundScore[1]);
		SendRconCommand(tmpstr);
	}
	
	if((minute % 2) == 0) // every 2 min
	{
		if(GoTpOpened)
		{
			foreach(Player, playerid)
			{
				DeletePVar(playerid, "TeleportInvited");
			}
			GoTpOpened = false;
		}
	}
	
	// 5,10,15 min
	if((minute % 5) == 0) // every 5 min
	{
		//drop desync trigger
		foreach(Player, playerid) {
			SetPVarInt(playerid, "desynced",0);
			SetPVarInt(playerid, "AC_FASTRESPAWN", 0);
		}
		// Load default game settings
		if(CWmode && Online == 0) DefaultGameSettings();
	}
	
	#if defined _nex_ac_included
	if((minute % 10) == 0) // every 10 min
	{
		// drop nexac counters for all
		if(!CWmode) 
		{
			NEXAC_DETECT_ACTION = 2;
			DropAntiCheatCounters(); // Embedded ac function
			// Drop internal RSC gamemode counters
			foreach(Player, i)
			{
				for(new code = 0; code != 52; code++)
				{
					NEXAC_DETECT_COUNTERS[i][code] = 0;
				}
			}
		}
	}
	#endif
	
	if((minute % 10) == 0) // every 10min
	{	
		new online = 0;
		new stringen[128], stringru[128];
		foreach(Player, i) 
		{
			online++;
			if(GetPVarType(i, "Youtuber"))
			{
				new youtubechannel[32];
				GetPVarString(i, "YoutubeChannel", youtubechannel, sizeof youtubechannel);
				if(strlen(youtubechannel) >= 3)
				{
					format(stringen, sizeof(stringen),
					"The game is being recorded for the channel youtube.com\%s");
					format(stringru, sizeof(stringru),
					"Идет запись игры для канала youtube.com\%s");
					SendClientMessageToAllEx(0xFFD700FF, stringru, stringen);
				}
			}
		}
		
		// Drop map to default
		if(online == 0 && Map != 2) Map = 2;
		
		new randitem; randitem = random(21);
		switch(randitem)
		{
			/*case 0:
			{
				if(Online > 0)
				{
					// server announce
					// if edit this code, add changes to /credits command
					SendClientMessageToAllEx(0xFFD700FF,
					"Добавьте в избранное наш второй сервер:",
					"Add our second server to your favorites:");
					if(Host == 0) // ru host
					{
						SendClientMessageToAll(0xFFD700FF,
						"Russian Sawn-off Community | Lagshot  | EU host - 82.208.17.10:27445");
						SendClientMessageToAll(0xFFD700FF,
						"Russian Sawn-off Community | Skinshot | EU host - 82.208.17.10:27981");
					}
					if(Host == 1 && lagcomp)//skin eu
					{
						SendClientMessageToAll(0xFFD700FF,
						"Russian Sawn-off Community | Lagshot | EU host -  82.208.17.10:27445");
					}
					if(Host == 1 && !lagcomp)//lagshot eu
					{
						SendClientMessageToAll(0xFFD700FF,
						"Russian Sawn-off Community | Skinshot | EU host -  82.208.17.10:27981");
					}
				}
			} */
			case 1:
			{
				SendAdMessageToAllEx(0xFFD700FF,
				"Если Вы обнаружили на нашем сервере баг, сообщите о нём в discord канале #bug-reports",
