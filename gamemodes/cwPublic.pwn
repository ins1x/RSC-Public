			return SendClientMessageEx(playerid, COLOR_GREY,
			"Для использования этих функций Вы должны быть администратором 3 уровня!",
			"To use these functions you need to have 3 level admin rights!");
		}
		ShowPlayerDialog(playerid, 280, DIALOG_STYLE_LIST, "Change spawn place",
		"{33AA33}GREEN Team\n\
		{3A5FCD}BLUE Team\n\
		{FFFF00}SPEC Team\n\
		{00FF00}>> Apply <<\n\
		{AFAFAF}Restore defaults\n\
		{FFFFFF}Save map to scriptfiles",
		"Select", "Cancel");
