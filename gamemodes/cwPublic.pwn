						db_get_field(query, 4, city, sizeof(city));
						format(buffer, sizeof(buffer), "Last City\t{FFD700}%s\n", city);
						strcat(tbtext, buffer);
						
						db_free_result(query);
						
						format(header, 64, "%s - geolocation information", nickname);
						ShowPlayerDialog(playerid, 242, DIALOG_STYLE_TABLIST,
						header, tbtext, "Ok", "");
					
					}
					else return SendClientMessageEx(playerid, COLOR_GREY, "Для использования этих функций Вы должны быть администратором 3 уровня!", "To use these functions you need to have 3 level admin rights!");
				}
				case 2:
				{
					if(GetPVarInt(playerid, "Admin") >= 3)
					{
						new tbtext[512], szQuery[256], DBResult: query;
						new buffer[64], header[64];
						new banned, muted, hwban, hwmute, forceac;
						new nickname[MAX_PLAYER_NAME];
						GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
						format(szQuery, sizeof(szQuery),
						"SELECT Banned, Muted FROM Accounts WHERE Nickname = '%q'", db_escape(nickname));
						query = db_query(dbaccounts, szQuery);
						
						banned = db_get_field_int(query, 0);
						format(buffer, sizeof(buffer), "Banned\t{FFD700}%i\n", banned);
						strcat(tbtext, buffer);
						
						muted = db_get_field_int(query, 1);
						format(buffer, sizeof(buffer), "Muted\t{FFD700}%i\n", muted);
						strcat(tbtext, buffer);
						
						db_free_result(query);
						
						format(szQuery, sizeof(szQuery),
						"SELECT HwBan, HwMute, Forceac FROM Banlist WHERE Nickname = '%q'",
						db_escape(nickname));
						query = db_query(dbcore, szQuery);
						
						hwban = db_get_field_int(query, 0);
						format(buffer, sizeof(buffer), "HwBan\t{FFD700}%i\n", hwban);
						strcat(tbtext, buffer);
						
						hwmute = db_get_field_int(query, 1);
						format(buffer, sizeof(buffer), "HwMute\t{FFD700}%i\n", hwmute);
						strcat(tbtext, buffer);
						
						forceac = db_get_field_int(query, 2);
						format(buffer, sizeof(buffer), "ForceAC\t{FFD700}%i\n", forceac);
						strcat(tbtext, buffer);
						
						db_free_result(query);
						
						format(header, 64, "%s - ban information", nickname);
						ShowPlayerDialog(playerid, 242, DIALOG_STYLE_TABLIST,
						header, tbtext, "Ok", "");
					
					}
					else return SendClientMessageEx(playerid, COLOR_GREY, "Для использования этих функций Вы должны быть администратором 3 уровня!", "To use these functions you need to have 3 level admin rights!");
				}
				case 3:
				{
					if(GetPVarInt(playerid, "Admin") >= 3)
					{
						new tbtext[512], buffer[128], header[64];
						new szQuery[256], DBResult: query;
						new subQuery[256], DBResult: subquery;
						new serial[41], hwid[64];
						new nickname[MAX_PLAYER_NAME];
						GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
						format(szQuery, sizeof(szQuery),
						"SELECT Serial FROM Accounts WHERE Nickname = '%q'", db_escape(nickname));
						query = db_query(dbaccounts, szQuery);
						
						db_get_field(query, 0, serial, sizeof(serial));
						format(buffer, sizeof(buffer), "Serial\t{FFD700}%s\n", serial);
						strcat(tbtext, buffer);
						db_free_result(query);
						
						if(fexist("logs.db"))
						{
							format(subQuery, sizeof(subQuery),
							"SELECT Hwid FROM Connectionlog WHERE Serial = '%q' LIMIT 1");
							subquery = db_query(dblogs, subQuery);
							if(db_num_rows(subquery))
							{
								db_get_field(subquery, 0, hwid, sizeof(hwid));
								format(buffer, sizeof(buffer), "Hwid\t{FFD700}%s\n", hwid);
								strcat(tbtext, buffer);
							}
							db_free_result(subquery);
						}
						
						format(buffer, sizeof(buffer), "%s  serial: %s | hwid: %s",
						nickname, serial, hwid);
						SendClientMessage(playerid, -1, buffer);
						
						format(header, 64, "%s - hardware information", nickname);
						ShowPlayerDialog(playerid, 242, DIALOG_STYLE_TABLIST,
						header, tbtext, "Ok", "");
					
					}
					else return SendClientMessageEx(playerid, COLOR_GREY, "Для использования этих функций Вы должны быть администратором 3 уровня!", "To use these functions you need to have 3 level admin rights!");
				}
				case 4:
				{
					if (GetPVarInt(playerid, "Admin") < 3) 
					{
						return SendClientMessageEx(playerid, COLOR_GREY,
						"Для использования этих функций Вы должны быть администратором 3 уровня!",
						"To use these functions you need to have 3 level admin rights!");
					}
					new nickname[MAX_PLAYER_NAME];
					GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
					FindSimilarAccs(playerid, nickname);
				}
				case 5:
				{
					ShowPlayerDialog(playerid, 243, DIALOG_STYLE_INPUT,
					"Change Nickname", "{FFFFFF}Enter new nickname", "Select", "Cancel");
				}
				case 6: // setadmin
				{
					if(GetPVarInt(playerid, "Admin") >= 3)
					{
						ShowPlayerDialog(playerid, 180, DIALOG_STYLE_INPUT,
						"Set admin",
						"{cdcdcd}[0 = nothing | 1 = CW organizer | 2 = administrator | 3 = head administrator]\n\
						{FFFFFF}Enter the new admin level for the player:",
						"Select", "Cancel");
					}
					else return SendClientMessageEx(playerid, COLOR_GREY, "Для использования этих функций Вы должны быть администратором 3 уровня!", "To use these functions you need to have 4 level admin rights!");
				}
	
				case 7:
				{	
					ShowPlayerDialog(playerid, 266, DIALOG_STYLE_MSGBOX,
					"Verification", "{FFFFFF}Are you sure you want to force account verification??",
					"{00FF00}Accept", "{FF0000}Decline");
				}
				case 8:
				{
					if (pData[playerid][pLang] == 1)
					{
						ShowPlayerDialog(playerid, 284, DIALOG_STYLE_LIST,
						"Change account settings",
						"{FF0000}Reset{FFFFFF} lang to English\n\
						{FF0000}Reset{FFFFFF} player skin and attaches\n\
						{FF0000}Reset{FFFFFF} account password\n\
						{FF0000}Full account settings reset",
						"Select", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 284, DIALOG_STYLE_LIST,
						"Сброс настроек на аккаунте",
						"{FF0000}Сбросить{FFFFFF} язык на англ. \n\
						{FF0000}Сбросить{FFFFFF} скин и аттачи\n\
						{FF0000}Сбросить{FFFFFF} пароль на аккаунте\n\
						{FF0000}Полный cброс настроек на стандартные",
						"Выбрать", "Отмена");
					}
				}
				case 9:
				{
					if (pData[playerid][pLang] == 1)
					{
						ShowPlayerDialog(playerid, 232, DIALOG_STYLE_LIST,
						"Unlock account",
						"Unmute account\n\
						Unban account\n\
						Unban player by hardware\n\
                        Unmute player by hardware\n\
						Allow play without AC\n\
						{FF0000}Remove an entry from the ban table",
						"Select", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 232, DIALOG_STYLE_LIST,
						"Снять ограничения",
						"Снять мут с аккаунта\n\
						Снять бан с аккаунта\n\
						Снять бан по железу\n\
						Снять мут по железу\n\
						Разрешить играть без античита\n\
						{FF0000}Удалить запись из таблицы банов",
						"Выбрать", "Отмена");
					}
				}
				case 10:
				{
					if (pData[playerid][pLang] == 1)
					{
						ShowPlayerDialog(playerid, 233, DIALOG_STYLE_LIST,
						"Ban account",
						"Account ban (by IP)\n\
						Account mute (by IP)\n\
						Ban by hardware (hwban)\n\
						Mute by hardware (hwmute)\n\
						Force to play with AC\n\
						Remove all accounts by IP\n",
						"Select", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 233, DIALOG_STYLE_LIST,
						"Ban acc",
						"Забанить аккаунт (по ip)\n\
						Замутить аккаунт (по ip)\n\
						Бан по железу (hwban)\n\
						Мут по железу (hwmute)\n\
						Запретить играть без античита\n\
						Снести все аккаунты по IP\n",
						"Выбрать", "Отмена");
					}
				}
				case 11:
				{
					if(GetPVarInt(playerid, "Admin") >= 4 || !strcmp(PlayerName(playerid), "1NS", true))
					{
						ShowPlayerDialog(playerid, 249, DIALOG_STYLE_MSGBOX,
						"Delete account",
						"Are you sure want to delete account?\n{FF0000}This action is irreversible!!",
						"Remove", "Cancel");
					}
					else return SendClientMessageEx(playerid, COLOR_RED, "Для использования этих функций Вы должны быть администратором 4 уровня!", "To use these functions you need to have 4 level admin rights!");
				}
			}
		} else {
			if(LAST_DIALOG[playerid] == 32) ADMIN_MENU(playerid);
		}
	}
	if(dialogid == 241) // DB Search main
	{
		if(response)
		{
			#if defined _YSF_included
			if(!IsValidNickName(inputtext))	{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное имя! Придумайте другое имя.",
				"Incorrect nickname. Choose another nickname!");
			}
			#endif
			if(strlen(inputtext) > 1 && !isnull(inputtext))
			{
				if(fexist("accounts.db"))
				{
					new szQuery[128], DBResult: query;
					format(szQuery, sizeof(szQuery),
					"SELECT Nickname FROM Accounts WHERE (Nickname = '%q')",
					db_escape(inputtext));
					query = db_query(dbaccounts, szQuery);
					if(db_num_rows(query))
					{
						SetPVarString(playerid, "OfflineAccountName", db_escape(inputtext));
						OFFLINE_ACC(playerid);
						db_free_result(query);
					} else { 
						SendClientMessage(playerid, COLOR_GREY, "Error: Account not found");
					}
				}
			}
			else SendClientMessage(playerid, COLOR_GREY, "Incorrect value");
		}
		else ADMIN_MENU(playerid);
	}
	if(dialogid == 242) // db accinfo
	{
		if(!response) OFFLINE_ACC(playerid);
	}
	if(dialogid == 243) // db changename
	{
		if(response)
		{
			if (GetPVarInt(playerid, "Admin") < 3) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 3+ уровня!",
				"To use these functions you need to have 3+ level admin rights!");
			}
			if(strlen(inputtext) >= 3 && !isnull(inputtext) && strlen(inputtext) <= 24)
			{
				new string[128], nickname[MAX_PLAYER_NAME];
				GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
				
				#if defined _YSF_included
				if(!IsValidNickName(inputtext))	{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Некорректное имя! Придумайте другое имя.",
				 	"Incorrect nickname. Choose another nickname!");
				}
				#endif
				
				new szQuery[128], DBResult: query;
				format(szQuery, sizeof(szQuery),
				"SELECT Nickname FROM Accounts WHERE (Nickname = '%q')",
				db_escape(inputtext));
				query = db_query(dbaccounts, szQuery);
				if(db_num_rows(query))
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Это имя уже занято. Придумайте другое имя.",
					"This nickname already exists. Choose another nickname!");
				} else {
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET Nickname = '%q' WHERE (Nickname = '%q')",
					db_escape(inputtext), nickname);
					query = db_query(dbaccounts, szQuery);
					db_free_result(query);
					
					format(string, sizeof(string), "%s(%d) has changed nickname %s to %s.",
					PlayerName(playerid), playerid, nickname, inputtext);
					SendSystemMessage(string);
					AdminActionsLog(string);
					
					new year, month, day, hour, minute, datetime[20];
					getdate(year, month, day); gettime(hour, minute, _);
					format(datetime, sizeof(datetime), "%d.%d.%d %d:%02d",
					year, month, day, hour, minute);

					format(szQuery, sizeof(szQuery),
					"INSERT INTO Nicknameslog (Datetime, Nickname, NewNickname) \
					VALUES ('%s', '%q', '%q')",
					datetime, nickname, inputtext);
					db_query(dblogs, szQuery);					
				}
			} else {
				SendClientMessage(playerid, COLOR_GREY, "Error: Incorrect nickname");
			}
		} else {
			OFFLINE_ACC(playerid);
		}
	}
	if(dialogid == 244) // db changepass
	{
		if(response)
		{
			new szQuery[256], string[128], hash[64+1], nickname[MAX_PLAYER_NAME];
			if (GetPVarInt(playerid, "Admin") < 4 || !strcmp(PlayerName(playerid), "1NS", true)) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 4 уровня!",
				"To use these functions you need to have 4 level admin rights!");
			}
			if(strlen(inputtext) < 4 || strlen(inputtext) > 20)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Пароль должен состоять из 3-20 символов",
				"Password must consist of at least 3 characters, but no more than 20 characters!");
			}
			
			GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
			SHA256_PassHash(inputtext, KEY, hash, sizeof(hash));
			
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Password = '%s' WHERE (Nickname = '%q')", hash, db_escape(nickname));
			db_query(dbaccounts, szQuery);
			
			format(string, sizeof(string), "%s(%d) has reset %s account password",
			PlayerName(playerid), playerid, nickname);
			SendSystemMessage(string);
			AdminActionsLog(string);
			
		} else {
			OFFLINE_ACC(playerid);
		}
	}
	if(dialogid == 245) // db findsimilaraccs offline
