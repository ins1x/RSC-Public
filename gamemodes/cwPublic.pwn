			new nick[24+8], verified, serial[41], ip[16], tmpstr[128];
			new szQuery[256], DBResult: query;
			new subQuery[256], DBResult: subquery;
			format(szQuery, sizeof(szQuery),
			"SELECT Nickname, Verified, Serial, LastIP FROM Accounts \
			WHERE Nickname LIKE '%%%s%%' LIMIT 20",
			db_escape(inputtext));
			query = db_query(dbaccounts, szQuery);
			new rows = db_num_rows(query);
			if(rows)
			{
				for(new i; i < rows; i++)
				{
					db_get_field(query, 0, nick, sizeof(nick));
					format(nick, sizeof(nick), "%s", nick);
					
					verified = db_get_field_int(query, 1);
					
					if(verified) format(tmpstr, 128, "{00FF00}%s", nick);
					else format(tmpstr, 128, "%s", nick);
					
					db_get_field(query, 2, serial, sizeof(serial));
					format(serial, sizeof(serial), "%s", serial);
					
					db_get_field(query, 3, ip, sizeof(ip));
					format(ip, sizeof(ip), "%s", ip);
					
					//SendClientMessage(playerid, -1, tmpstr);
					
					new subrows, bannedip[16], bannickname[24];
					new hwban, hwmute, forceac, ipban;
					format(subQuery, sizeof(subQuery),
					"SELECT Nickname, HwBan, HwMute, Forceac FROM Banlist \
					WHERE Serial = '%s' LIMIT 20", serial);
					subquery = db_query(dbcore, subQuery);
					subrows = db_num_rows(subquery);
					if(subrows)
					{
						db_get_field(subquery, 0, bannickname, sizeof(bannickname));
						format(bannickname, sizeof(bannickname), "%s", bannickname);
					
						hwban = db_get_field_int(subquery, 1);
						hwmute =  db_get_field_int(subquery, 2);
						forceac = db_get_field_int(subquery, 3);
						
						format(tmpstr, sizeof(tmpstr),
						"%s serial match was found %s | hwban: %d | hwmute: %d | forceac: %d",
						nick, bannickname, hwban, hwmute, forceac);
						SendClientMessage(playerid, -1, tmpstr);
						db_next_row(subquery);
					}
					db_free_result(subquery);
					
					format(subQuery, sizeof(subQuery),
					"SELECT Nickname, IP, IpBan FROM Banlist \
					WHERE IP = '%s' LIMIT 20", ip);
					subquery = db_query(dbcore, subQuery);
					subrows = db_num_rows(subquery);
					if(subrows)
					{
						db_get_field(subquery, 0, bannickname, sizeof(bannickname));
						format(bannickname, sizeof(bannickname), "%s", bannickname);
					
						db_get_field(subquery, 1, bannedip, sizeof(bannedip));
						format(bannedip, sizeof(bannedip), "%s", bannedip);
						
						ipban = db_get_field_int(subquery, 2);
						
						format(tmpstr, sizeof(tmpstr),
						"%s ip match was found for %s | IP: %s | IpBan: %d",
						nick, bannickname, bannedip, ipban);
						SendClientMessage(playerid, -1, tmpstr);
						db_next_row(subquery);
					}
					db_free_result(subquery);
					
					db_next_row(query);
				}
				
				if(rows < 1)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
