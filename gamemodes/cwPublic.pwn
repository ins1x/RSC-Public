stock SAMPCAC_OPTIONS(playerid)
{
	// SAMPCAC Anticheat settings easy GUI access
	#if defined _sampcac_included
	new tbtext[450], tmpstr[64], ReportType[28], FS_SAMPCAC_STATE[24];
	
	if(CAC_GetGameResourceReportType() == CAC_GAMERESOURCE_REPORTTYPE__DISABLED) {
		ReportType = "{FF0000}[Disabled]"; 
	} else {
		if(CAC_GetGameResourceReportType() == CAC_GAMERESOURCE_REPORTTYPE__FULL) {
			ReportType = "{00FF00}[FULL]"; 
		}
		if(CAC_GetGameResourceReportType() == CAC_GAMERESOURCE_REPORTTYPE__ONLY_IF_MODDED) {
			ReportType = "{00FF00}[ONLY_IF_MODDED]";
		}
	}
	
	FS_SAMPCAC_STATE = "{FF0000}[Not loaded]";
	#if defined _YSF_included
	new scriptname[32];
	for(new i; i != 16; i++)
	{
		//printf("%s:%s", cmp, scriptname);
		GetFilterScriptName(i, scriptname);
		if(isnull(scriptname)) continue; // If no FS
		if(!strcmp(scriptname, "sampcac_base", true)) FS_SAMPCAC_STATE = "{00FF00}[Loaded]";
	}
	#else 
		#if defined _sampcac_included
		FS_SAMPCAC_STATE = "{00FF00}[Loaded]";
		#else 
		FS_SAMPCAC_STATE = "{FF0000}[Not loaded]";
		#endif
	#endif
	
	format(tbtext, sizeof(tbtext),
	"AC option\tState\n"\
	"C-Bug\t%s\n"\
	"Fast fire\t%s\n"\
	"Sprint surfaces\t%s\n"\
	"Infinite sprint\t%s\n"\
	"Quick Stand\t%s\n"\
	"Fast Move\t%s\n"\
	"PED.IFP mods\t%s\n"\
	"CLEO\t%s\n"\
	"[>] Modded gameresources report type\t%s\n"\
	"[>] Modded gameresources model type\t\n",
	(CAC_GetGlitchStatus(CAC_GLITCH__CROUCHBUG)) ? "{00FF00}[Allowed]" : "{FF0000}[Blocked]",
	(CAC_GetGlitchStatus(CAC_GLITCH__FASTFIRE)) ? "{00FF00}[Allowed]" : "{FF0000}[Blocked]",
	(CAC_GetGameOptionStatus(CAC_GAMEOPTION__SPRINT)) ? "{00FF00}[All surfaces]" : "{FF0000}[Default]",
	(CAC_GetGameOptionStatus(CAC_GAMEOPTION__INFINITESPRINT)) ? "{00FF00}[Allowed]" : "{FF0000}[Blocked]",
	(CAC_GetGlitchStatus(CAC_GLITCH__QUICKSTAND)) ? "{00FF00}[Allowed]" : "{FF0000}[Blocked]",
	(CAC_GetGlitchStatus(CAC_GLITCH__FASTMOVE)) ? "{00FF00}[Allowed]" : "{FF0000}[Blocked]",
	(CAC_KICK_MODDED_PEDIFP) ? "{FF0000}[Blocked]" : "{00FF00}[Allowed]",
	(CAC_KICK_CLEO) ? "{FF0000}[Blocked]" : "{00FF00}[Allowed]",
	ReportType);

	if(Debug)
	{
		format(tmpstr, sizeof(tmpstr),"{FFFF00}Load{FFFFFF} SAMPCAC\t%s\n",FS_SAMPCAC_STATE);
		strcat(tbtext, tmpstr);
		strcat(tbtext, "{FF0000}Unload SAMPCAC{FFFFFF}\t\n");
	}
	
	if(GetPVarInt(playerid, "Admin") >= 3) {
		return ShowPlayerDialog(playerid, 55, DIALOG_STYLE_TABLIST_HEADERS,
		"SAMPCAC: Anti-cheat settings", tbtext, "Ok", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_GREY, "Для использования этих функций Вы должны быть администратором 3+ уровня!", "To use these functions you need to have 3+ level admin rights!");
	}
	#else
	return SendClientMessage(playerid, COLOR_GREY, "SAMPCAC not connected");
	#endif
}

stock NexAcOptionsInfo(playerid)
{
	#if defined _nex_ac_included
	new output[2096], string[48];
	strcat(output, "{FFFFFF}");
	for(new i; i != 53; i++)
	{
		format(string, sizeof(string), "%s = %i\t\t\t\t", reasonslist[i], IsAntiCheatEnabled(i));
		if((i % 2) == 0) strcat(output, "\n");
		strcat(output, string);
	}
	ShowPlayerDialog(playerid, 101, DIALOG_STYLE_MSGBOX, "Nex-ac options", output , "OK", "Cancel");
	#else
	return SendClientMessageEx(playerid, COLOR_GREY, "NEXAC не подключен", "NEXAC not connected");	
	#endif
}

