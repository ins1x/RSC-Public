			SetPlayerName(ChosenPlayer[playerid], NewName);
			format(stringru, sizeof(stringru), "%s(%d) удалил тег игроку %s(%d)",
			PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
			format(stringen, sizeof(stringen), "%s(%d) has removed the clan tag of player %s(%d)",
