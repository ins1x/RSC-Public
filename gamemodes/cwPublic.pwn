	if (dialogid == 157) 
	{
		if(response)
		{
			if (GetPVarInt(playerid, "Admin") < 3) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 3 уровня!",
				"To use these functions you need to have 3 level admin rights!");
			}
			
			if(strlen(inputtext) < 1 || isnull(inputtext) || strlen(inputtext) > 24)
			{
				return SendClientMessage(playerid, COLOR_GREY, "Error: Incorrect value");
			}
			
			if(!fexist("logs.db"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Нет логов для отображения", "No logs to display");
				return 0;
			}
			
			if(GetPVarInt(playerid, "Admin") < 3)
			{
				if(strfind(inputtext, "Can") != -1 || strfind(inputtext, "1NS") != -1)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Нет результатов для отображения", "No results to display");
					return true;
				}
			}
			
			new nickname[24], newnickname[24], datetime[16], tmpstr[128];
	
			new szQuery[256], DBResult: query;
			format(szQuery, sizeof(szQuery),
			"SELECT Datetime, Nickname, NewNickname FROM Nicknameslog \
			WHERE Nickname LIKE '%%%s%%' ORDER BY rowid DESC LIMIT 50",
			db_escape(inputtext));
			query = db_query(dblogs, szQuery);
			new rows = db_num_rows(query);
			for(new i; i < rows; i++)
			{
				db_get_field(query, 0, datetime, sizeof(datetime));
				format(datetime, sizeof(datetime), "%s", datetime);
				
				db_get_field(query, 1, nickname, sizeof(nickname));
				format(nickname, sizeof(nickname), "%s", nickname);
				
				db_get_field(query, 2, newnickname, sizeof(newnickname));
				format(newnickname, sizeof(newnickname), "%s", newnickname);
				
				format(tmpstr, 128, "%s {AFAFAF}%s{FFFFFF} change nickname to {AFAFAF}%s",
				datetime, nickname, newnickname);
				SendClientMessage(playerid, -1, tmpstr);
				
				db_next_row(query);
			}
			db_free_result(query);
			
			if(rows < 1)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Нет результатов для отображения", "No results to display");
			} else {
				format(tmpstr, 128, "Found results: %i", rows);
				SendClientMessage(playerid, -1, tmpstr);
			}
			
		}
		else DBFIND_MENU(playerid);
	}
	if (dialogid == 158)
	{
		if(response)
		{
			if (!IsPlayerConnected(strval(inputtext)))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
			ChosenPlayer[playerid] = strval(inputtext);
			new stringru[128], stringen[128];
			new NewName[MAX_PLAYER_NAME];
