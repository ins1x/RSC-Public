		else WORLD_MENU(playerid);
	}
	if(dialogid == 303) // WORLD_VEHICLES
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			switch(listitem)
			{
				case 0: OnPlayerCommandText(playerid, "/v");
				case 1:
				{
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 185, DIALOG_STYLE_INPUT,
						"Spawn new vehicle for all",
						"{FFFFFF}Enter vehicle {AFAFAF}ID{FFFFFF} or {AFAFAF}vehicle name{FFFFFF}:",
						"Spawn", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 185, DIALOG_STYLE_INPUT,
						"Создать транспорт для всех",
						"{FFFFFF}Введите {AFAFAF}ID{FFFFFF} или {AFAFAF}название{FFFFFF} транспорта:",
						"Создать", "Отмена");
					}
				}
				case 2:
				{
					ShowPlayerDialog(playerid, 351, DIALOG_STYLE_LIST,
					"Unical vehicles",
					"Muscle Sabre\n\
					Death Cheetah\n\
					Allqueda truck\n\
					HMMWV\n\
					Derby Rancher\n\
					The Truth Car\n\
					Tornado\n\
					Farm Blade\n\
					Twinsitters Monster\n\
					Jeep\n\
					Clown truck\n\
					Regina\n\
					Rock Remington",
					"Spawn", "Cancel");
				}
				case 3:
				{
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 119, DIALOG_STYLE_INPUT,
						"Set hp for all world vehicles",
						"{FFFFFF}Enter hp value:", "Set", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 119, DIALOG_STYLE_INPUT,
						"Установаить хп для транспорта",
						"{FFFFFF}Введите хп для транспорта в мире:",
						"Применить", "Отмена");
					}
				}
				case 4: ListVehiclesInWorld(playerid, worldid);
				case 5: OnPlayerCommandText(playerid, "/respawnveh");
				case 6:
				{
					#if defined _YSF_included
					for(new v = MAX_VEHICLES +1; --v != 0;)
					{
						if(GetVehicleVirtualWorld(v) == worldid)
						{
							if(!IsVehicleOccupied(v))
							{
								DestroyVehicle(v);
							}
						}
					}
					SendClientMessageEx(playerid, COLOR_GREY,
					"Весь незанятый транспорт был обнулен",
					"All unocuppied vehicles have been removed");
					WORLD_VEHICLES(playerid);
					#endif
				}
				case 7:
				{
					foreach(Player, i)
					{
						if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid))
						{
							SetPVarInt(i, "vehCollision", !GetPVarInt(i, "vehCollision"));
							DisableRemoteVehicleCollisions(i, GetPVarInt(i, "vehCollision"));
						}
					}			
					new string[64];
					format(string, sizeof(string),
					"Vehicle collision for all is now '%s'",
					(GetPVarInt(playerid, "vehCollision") != 1) ? ("Disabled") : ("Enabled"));
					SendClientMessage(playerid, COLOR_GREY, string);
				}
				case 8: AUTOTUNE_MENU(playerid);
				case 9:
				{
					new Float:x,Float:y, Float:z;
					new Float:radius = 10.0;
					for(new v = MAX_VEHICLES +1; --v != 0;)
					{
						if(GetVehicleVirtualWorld(v) == worldid)
						{
							GetVehiclePos(v, x, y, z);
							if(!IsPlayerInRangeOfPoint(playerid, radius, x,y,z)) continue;
							DestroyVehicle(v);
						}
					}
					SendClientMessageEx(playerid, COLOR_GREY,
					"Весь транспорт в радиусе 10.0 метров был уничтожен",
					"All vehicles at 10.0 meter radius have been destroyed");
					WORLD_VEHICLES(playerid);
				}
				case 10:
				{
					DestroyAllVehicles(worldid);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Весь транспорт в мире был уничтожен",
					"All vehicles at virtual world have been destroyed");
					WORLD_VEHICLES(playerid);
				}
			}
		}
		else WORLD_MENU(playerid);
	}
	if(dialogid == 304) // WORLD_WEAPONS
	{
		if(response)
		{
			//new worldid = GetPlayerVirtualWorld(playerid);
			switch(listitem)
			{
				case 0:
				{
					ChosenPlayer[playerid] = playerid;
					WeaponChoiceMode[playerid] = 1;
					ShowPlayerDialog(playerid, 140, DIALOG_STYLE_LIST, "Weapon pack",
					"Pistols\nShotguns\nSub-machine guns\nRifles\nGrenades\nHand held\nMelee\n{FF0000}Reset weapons{FFFFFF}",
					"Select", "Exit");
					//OnPlayerCommandText(playerid, "/weapons");
				}
				case 1:
				{					
					WeaponChoiceMode[playerid] = 0;
					ShowPlayerDialog(playerid, 140, 2, "Weapon pack",
					"Pistols\nShotguns\nSub-machine guns\nRifles\nGrenades\nHand held\nMelee\n{FF0000}Reset weapons{FFFFFF}",
					"Select", "Exit");
				}
				case 2: 
				{
					OnPlayerCommandText(playerid, "/refill");
					WORLD_WEAPONS(playerid);
				}
				case 3:
				{
					ShowPlayerDialog(playerid, 296, DIALOG_STYLE_INPUT,
					"World default ammo",
					"{FFFFFF}Enter enter the number of bullets [0-9999]:",
					"Select", "Cancel");
				}
				case 4:
				{
					ShowPlayerDialog(playerid, 297, DIALOG_STYLE_INPUT,
					"World default skills", "{FFFFFF}Enter skill level [0-999]:",
					"Select", "Cancel");
				}
				case 5: WORLD_PICKUP_WEAPONS(playerid);
				case 6: 
				{
					foreach(Player, i)
					{
						if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid))
						{
							Streamer_Update(i, STREAMER_TYPE_PICKUP);
						}
					}
					// Note: dynamic objects are restored in 50 ms 
					// (or through the specified value by the Streamer_TickRate function).
					Streamer_DestroyAllVisibleItems(playerid, STREAMER_TYPE_PICKUP);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Все пикапы оружия были обновлены", "All weapons pickups have been updated");
				}
				case 7:
				{
					new items[64];
					new Float:x, Float:y, Float:z;
					new worldid = GetPlayerVirtualWorld(playerid);
					GetPlayerPos(playerid, x , y, z);
					Streamer_GetNearbyItems(x, y, z, STREAMER_TYPE_PICKUP,
					items, sizeof(items), 1.5, worldid);
					for(new pickup = 0; pickup < sizeof(items); pickup++)
					{
						if(IsValidDynamicPickup(pickup)) DestroyDynamicPickup(pickup);
					}
					SendClientMessageEx(playerid, COLOR_GREY,
					"Ближайшие пикапы были удалены", "Nearest pickups has been removed");
				}
				case 8:
				{
					ResetWorldWeapons(GetPlayerVirtualWorld(playerid));
					foreach(Player, i) 
					{
						if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid))
						{
							GiveDefaultWeapons(i);
						}
					}
					WORLD_WEAPONS(playerid);
				}
				case 9:	
				{
					OnPlayerCommandText(playerid, "/disarm");
					WORLD_WEAPONS(playerid);
				}
			}
		}
		else WORLD_MENU(playerid);
	}
	if(dialogid == 305) // WORLD_PLAYERS
	{
		if(response)
		{
			new nickname[MAX_PLAYER_NAME];
			format(nickname, MAX_PLAYER_NAME, "%s", inputtext);
			new id = GetPlayerID(nickname);
			new worldid = GetPlayerVirtualWorld(playerid);
			
			if(IsPlayerConnected(id))
			{
				if(id == INVALID_PLAYER_ID || id > _MAX_PLAYERS) return false;
				ChosenPlayer[playerid] = id;
				if(WorldModerator[playerid] || World[worldid][wHosted] == playerid)
				{
					WORLD_TABMENU(playerid);
				}
				else PlayerStatistics(id, playerid);
			}
		}
		else WORLD_MENU(playerid);
	}
