						}
						db_free_result(query);
					}
					
					
					format(szQuery, sizeof(szQuery),
					"SELECT Lastcountry, Lastip, Discord FROM Accounts WHERE \
					Nickname = '%q'", db_escape(nickname));
					query = db_query(dbaccounts, szQuery);
					new rows = db_num_rows(query);
					for(new i; i < rows; i++)
					{
						db_get_field(query, 0, lastcountry, sizeof(lastcountry));
						format(lastcountry, sizeof(lastcountry),
						"{FFFFFF}Player from {AFAFAA}%s \t", lastcountry);
						strcat(tbtext, lastcountry);
						
						db_get_field(query, 1, lastip, sizeof(lastip));
						format(lastip, sizeof(lastip), "%s\n", lastip);
						strcat(tbtext, lastip);
						
						db_get_field(query, 2, discord, sizeof(discord));
						format(discord, sizeof(discord), "%s", discord);
						
						db_next_row(query);
					}
					db_free_result(query);
					
					if(strlen(discord) > 1)
					{
						format(header, 100, "{FFFFFF}Discord: %s\n", discord);
					} else {
						format(header, 100, "{FFFFFF} \n", discord);
					}
					strcat(tbtext, header);
					strcat(tbtext, "{00FF00}>> Accept verification <<\n");
					strcat(tbtext, "{FF0000}>> Remove verification <<\n");
					
					format(header, 100, "Verification - %s ", nickname);
					ShowPlayerDialog(playerid, 275, DIALOG_STYLE_LIST,
					header, tbtext, "Select", "Close");
				}
			}
