			if(strlen(inputtext) < 6 || isnull(inputtext) || strlen(inputtext) > 15)
			{
				return SendClientMessage(playerid, COLOR_GREY,
				"Error: Incorrect value. Example: 122.133.144.251 or 122.133");
			}
			
			new nick[24+8],lastcountry[64+1],lastip[16+1], verified;
			new tbtext[1024], tmpstr[128];
			new szQuery[256], DBResult: query;
			
			format(szQuery, sizeof(szQuery),
			"SELECT Nickname, Lastcountry, Lastip, Verified FROM Accounts \
			WHERE Lastip LIKE '%%%s%%' LIMIT 100",
			db_escape(inputtext));
			query = db_query(dbaccounts, szQuery);
			
			new rows = db_num_rows(query);
			if(rows > 10)
			{
				for(new i; i < rows; i++)
				{
					db_get_field(query, 0, nick, sizeof(nick));
					format(nick, sizeof(nick), "%s", nick);
					
					db_get_field(query, 1, lastcountry, sizeof(lastcountry));
					format(lastcountry, sizeof(lastcountry), "%s", lastcountry);
					
					db_get_field(query, 2, lastip, sizeof(lastip));
					format(lastip, sizeof(lastip), "%s", lastip);
					
					verified = db_get_field_int(query, 3);
					if(verified) format(nick, sizeof(nick), "{00FF00}%s", nick);
					
					format(tmpstr, 128, "%s - %s - %s", nick, lastcountry, lastip);
					SendClientMessage(playerid, -1, tmpstr);
					
					db_next_row(query);
				}
				db_free_result(query);
				
				if(rows < 1)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Нет результатов для отображения", "No results to display");
				} else {
					format(tmpstr, 128, "Found results: %i", rows);
					SendClientMessage(playerid, -1, tmpstr);
				}
			} else {
				for(new i; i < rows; i++)
				{
					db_get_field(query, 0, nick, sizeof(nick));
					format(nick, sizeof(nick), "%s\t", nick);
					
					db_get_field(query, 1, lastcountry, sizeof(lastcountry));
					format(lastcountry, sizeof(lastcountry), "%s\t", lastcountry);
					
					db_get_field(query, 2, lastip, sizeof(lastip));
					format(lastip, sizeof(lastip), "%s\n", lastip);
					
					verified = db_get_field_int(query, 3);
					if(verified) format(nick, sizeof(nick), "{00FF00}%s", nick);
					
					strcat(tbtext, nick);
					strcat(tbtext, lastcountry);
					strcat(tbtext, lastip);
					
					db_next_row(query);
				}
				db_free_result(query);
				
				if(strlen(tbtext) < 1)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Нет результатов для отображения", "No results to display");
				}
				else ShowPlayerDialog(playerid, 253, DIALOG_STYLE_LIST,
				"Players accs", tbtext, "Select", "Cancel");
			}
		}
		else DBFIND_MENU(playerid);
	}
