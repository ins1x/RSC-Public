					if (pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 352, DIALOG_STYLE_INPUT,
						"Audiostream",
						"{FFFFFF}You can start an audio stream for all players.\n\
						If you want to start a stream from YouTube, then you need to convert the video stream\n\
						to an audio stream via any online service, for example https://mp3youtube.cc\n\
