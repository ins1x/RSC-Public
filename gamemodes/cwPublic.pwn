					"%s(%d) has restored default round settings.", PlayerName(playerid), playerid);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					DefaultGameSettings();
				}
			}
		}
		else ROUNDSET_MENU(playerid);
	}
	if(dialogid == 128) // asay
	{
		if(response)
		{
			if (isempty(inputtext)) {
				return 0;
			}
			if(strlen(inputtext) > 128) {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Слишком длинное сообщение!","Too long message");
				return 0;
			}
			if(strlen(inputtext) <= 2) {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Слишком короткое сообщение!","Too short message");
				return 0;
			}
			SendClientMessageToAll( 0xFFD700FF , inputtext ); // COLOR_GOLD
			foreach(Player, i) PlayerPlaySound(i, 31205, 0.0, 0.0, 0.0); // WINNER Sound
			if(LAST_DIALOG[playerid] == 53) YOUTUBER_MENU(playerid);
		}
	}
	if(dialogid == 129) // VEH_MENU
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			
			switch(listitem)
			{
				case 0:
				{	
					if (GetPVarInt(playerid, "Admin") >= 2)
					{
						ShowPlayerDialog(playerid, 186, DIALOG_STYLE_INPUT,
						"Spawn new vehicle", "{FFFFFF}Enter vehicle ID:", "Spawn", "Cancel");
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 2+ уровня!",
						"To use these functions you need to have 2+ level admin rights!");
					}
				}
				case 1:
				{
					if (GetPVarInt(playerid, "Admin") >= 2)
					{
						ShowPlayerDialog(playerid, 119, DIALOG_STYLE_INPUT,
						"Set hp for all vehicles", "{FFFFFF}Enter hp value:", "Set", "Cancel");
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 2+ уровня!",
						"To use these functions you need to have 2+ level admin rights!");
					}
				}
				case 2:
				{
					ShowPlayerDialog(playerid, 184, DIALOG_STYLE_INPUT,
					"Hijack player from vehicle", "{FFFFFF}Enter player ID:", "Ok", "Cancel");
				}
				case 3:
				{
					if (GetPVarInt(playerid, "Admin") >= 2)
					{
						foreach(Player, i)
						{
							if(GetPlayerState(i) == PLAYER_STATE_DRIVER ||
							GetPlayerState(i) == PLAYER_STATE_PASSENGER)
							{
								new Float:x, Float:y, Float:z;
								GetPlayerPos(i, x, y, z);
								SetPlayerPos(i, x, y, z+1);
							}
						}
						SendClientMessageEx(playerid, COLOR_GREY,
						"Все игроки были выброшены из транспорта",
						"All players have been hijacked from vehicles");
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have 3+ level admin rights!");
					}
				}
				case 4:
				{
					if (GetPVarInt(playerid, "Admin") >= 1)
					{						
						new vehicles = 0;
						new string[128];
						
						for(new vehicle = GetVehiclePoolSize() +1; --vehicle != 0;) 
						{
							if(GetVehicleVirtualWorld(vehicle) == worldid)
							{
								vehicles++;
								new modelid = GetVehicleModel(vehicle);
								
								new Float: vehX, Float: vehY, Float: vehZ;
								GetVehiclePos(vehicle, vehX, vehY, vehZ);
								new Float:distance = GetPlayerDistanceFromPoint(playerid,
								vehX, vehY, vehZ);
								
								format(string, sizeof(string),
								"%i - {AFAFAF}%s - {FFFFFF}%.1f m. - %s",
								vehicle, VehicleNames[modelid-400], distance,
								(IsVehicleOccupied(vehicle)) ? "{FF0000}Occupied" : "{00FF00}Empty");
								SendClientMessage(playerid, -1, string);
							}
						}
						
						format(string, sizeof(string),
						"Total vehicles: {AFAFAF}%i {FFFFFF}(world: {AFAFAF}%i)",
						vehicles, worldid);
						SendClientMessage(playerid, -1, string);
						
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have 3+ level admin rights!");
					}
				}
				case 5:
				{
					if (GetPVarInt(playerid, "Admin") >= 3)
					{
				
						for(new i = GetVehiclePoolSize() +1; --i != 0;) SetVehicleToRespawn(i);
						SendClientMessageToAllEx(COLOR_GREY,
						"Весь транспорт был возвращен на точку появления администратором",
						"All vehicles have been returned to the spawn point");
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have 3+ level admin rights!");
					}
				}
				case 6:
				{
					new Float:x,Float:y, Float:z;
					new Float:radius = 20.0;
					for(new v = MAX_VEHICLES +1; --v != 0;)
					{
						GetVehiclePos(v, x, y, z);
						if(!IsPlayerInRangeOfPoint(playerid, radius, x,y,z)) continue;
						DestroyVehicle(v);
					}
					SendClientMessageEx(playerid, COLOR_GREY,
					"Весь транспорт в радиусе 20.0 метров был уничтожен",
					"All vehicles at 20.0 meter radius have been destroyed");
				}
				case 7: 
				{
					SendClientMessageToVirtualWorld(worldid, COLOR_GREY,
					"Весь транспорт был уничтожен администратором",
					"All vehicles have been destroyed");
					DestroyAllVehicles(-1);
				}
			}
		} else {
			if(LAST_DIALOG[playerid] == 62) MODSET_MENU(playerid);
		}
	}
