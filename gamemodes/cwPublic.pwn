stock ROUNDSET_MENU(playerid)
{
	// Round settings menu
	// Used to set various round options.
	new 
		header[64], tbtext[660], teamsnames[64], rounds_state[24],
		KICK_LAGERS_State[24], ServerLock_state[32]
	;
	
	format(teamsnames, sizeof(teamsnames), "%s%s{FFFFFF} vs %s%s",
	THC[0], ClanName[0], THC[1], ClanName[1]);
	
	if(KICK_LAGERS == 0) KICK_LAGERS_State = "{808080}[NO CHECK]";
	else if (KICK_LAGERS == 1) KICK_LAGERS_State = "{FFFF00}[WARNING]";
	else if (KICK_LAGERS == 2) KICK_LAGERS_State = "{00FF00}[KICK]";
	else if (KICK_LAGERS == 3) KICK_LAGERS_State = "{00FF00}[MOVESPEC]";
	
	switch(ServerLock)
	{
		case 0: ServerLock_state = "{808080}[NO LIMITS]";
		case 1: ServerLock_state = "{00FF00}[REGISTERED]";
		case 2: ServerLock_state = "{00FF00}[VERIFIED]";
		case 3: ServerLock_state = "{00FF00}[TEAMMATES]";
		case 4: ServerLock_state = "{00FF00}[AC ONLY]";
	}
	
	if(frz)	format(header, sizeof(header), "   .:: CW/TG Round settings ::.  [PAUSED] ");
	else format(header, sizeof(header), "   .:: CW/TG Round settings ::.   ");
    
	if(MaxRounds) format(rounds_state, sizeof(rounds_state), "%d", MaxRounds);
	else rounds_state = "{808080}[Unlimited]";
	
	if(pData[playerid][pLang] == 1)
	{
		format(tbtext, sizeof(tbtext),
		"How to start a CW/TG\t\n"\
		"Team settings\t%s\n"\
		"Map № %d\t%s\n"\
		"CW mode\t%s\n"\
		"Heal after kill\t%s\n"\
		"Pause\t%s\n"\
		"Round kills\t%i\n"\
		"Game health\t%i\n"\
		"Rounds\t%s\n"\
		"Anti-Teamkill\t%s\n"\
		"Check lagers\t%s\n"\
		"Login settings\t%s\n"\
		"Client anticheat\t%s\n"\
		"Server anticheat\t\n"\
		"Weapons config\t\n"\
		"Spawn all\t\n"\
		"{FF0000}Reset\t\n"\
		"{00FF00}Start round\t\n",
		teamsnames, Map, MapNames[Map], 
		(CWmode) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(HPDead) ? "{00FF00}[ON]" : "{808080}[OFF]",
		(frz) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		Roundkills, GameHealth, rounds_state, 
		(AntiTK) ? "{00FF00}[Allowed]" : "{808080}[Blocked]",
		KICK_LAGERS_State,
		ServerLock_state,
		(!AConly) ? "{808080}[Free AC]" : "{00FF00}[ON]");
		
		if(GetPVarInt(playerid, "Admin") >= 1)
		{ 	
			ShowPlayerDialog(playerid, 33, DIALOG_STYLE_TABLIST,
			header, tbtext, "Select", "Cancel");
		}
	} else {
		format(tbtext, sizeof(tbtext),
		"Как запустить КВ/ТКВ\t\n"\
		"Настройки команды\t%s\n"\
		"Карта № %d\t%s\n"\
		"CW режим\t%s\n"\
		"Лечение после убийства\t%s\n"\
		"Пауза\t%s\n"\
		"Кол-во убийств в раунде\t%i\n"\
		"Кол-во жизни и брони\t%i\n"\
		"Кол-во раундов\t%s\n"\
		"Анти-тимкилл\t%s\n"\
		"Обнаружение лагеров\t%s\n"\
		"Вход на сервер\t%s\n"\
		"Клиентский античит\t%s\n"\
		"Серверный античит\t\n"\
		"Параметры оружия\t\n"\
		"Заспавнить всех\t\n"\
		"{FF0000}Сбросить\t\n"\
		"{00FF00}Запустить раунд\t\n",
		teamsnames, Map, MapNames[Map], 
		(CWmode) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(HPDead) ? "{00FF00}[ON]" : "{808080}[OFF]",
		(frz) ? "{00FF00}[ON]" : "{FF0000}[OFF]", 
		Roundkills, GameHealth, rounds_state, 
		(AntiTK) ? "{00FF00}[Allowed]" : "{808080}[Blocked]",
		KICK_LAGERS_State,
		ServerLock_state,
		(!AConly) ? "{808080}[Free AC]" : "{00FF00}[ON]");
		
		if(GetPVarInt(playerid, "Admin") >= 1)
		{ 	
			ShowPlayerDialog(playerid, 33, DIALOG_STYLE_TABLIST,
			header, tbtext, "Выбрать", "Отменить");
		}
	}
	SetPlayerChatBubble(playerid, "..opens round settings..", COLOR_GREY, 50.0, 5000);
}

stock ROUND_TEAMSET_MENU(playerid)
{
	new 
		header[100], tbtext[520], 
		teamsnames[64], teamsbalance[64], players_c[48]	
	;
	
	format(teamsnames, sizeof(teamsnames), "%s%s{FFFFFF} vs %s%s",
	THC[0], ClanName[0], THC[1], ClanName[1]);
	
	/*new swapteams[64];
	format(swapteams, sizeof(swapteams), "%s%s {FFFFFF}<> %s%s",
	THC[0], ClanName[0], THC[1], ClanName[1]);*/
	
	new team0_c, team1_c, team2_c = 0; //players counter
	foreach(Player, i)
	{
		if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid))
		{
			if(GetPVarInt(i,"Team") == 0) team0_c += 1;
			if(GetPVarInt(i,"Team") == 1) team1_c += 1;
			if(GetPVarInt(i,"Team") == 2) team2_c += 1; // spec
		}
	}
	format(players_c, sizeof(players_c), "%s%i | %s%i | %s%i",
	THC[0], team0_c, THC[1], team1_c, THC[2], team2_c);
	
	format(teamsbalance, sizeof(teamsbalance), "%s%s (%d){FFFFFF} vs %s%s (%d)",
	THC[0], ClanName[0], team0_c, THC[1], ClanName[1], team1_c);
	
	if(pData[playerid][pLang] == 1)
	{
		if(CWmode) format(header, sizeof(header), ".:: Team settings ::. | %s", teamsbalance);
		else format(header, sizeof(header), ".:: Team settings ::. | %s", teamsbalance);
	} else {
		if(CWmode) format(header, sizeof(header), ".:: Настройки команд ::.  | %s", teamsbalance);
		else format(header, sizeof(header), ".:: Настройки команд ::. | %s", teamsbalance);
	}

	if(pData[playerid][pLang] == 1)
	{
		format(tbtext, sizeof(tbtext),
		"Change team name\t\n\
		Change team color\t\n\
		Change team nickname color\t\n\
		Move player\t%s\n\
		{FFFF00}Reset teams\t\n\
		Lock teams change\t%s\n\
		Lock spectators chat\t%s\n\
		{FFFF00}Speconly mode\t%s\n\
		Keep spectators on spawn\t%s\n\
		Autoset clan tags\t%s\n\
		Set up a single skin for the team\t\n",
		players_c, 
		(LockedTeams) ? ("{00FF00}[ON]") : ("{808080}[OFF]"),
		(Mutespec) ? ("{00FF00}[ON]") : ("{808080}[OFF]"),
		(speconly) ? "{00FF00}[ON]" : "{808080}[OFF]",
		(Spawnlock) ? ("{00FF00}[ON]") : ("{808080}[OFF]"),
		(AutosetClanTags) ? ("{00FF00}[ON]") : ("{808080}[OFF]"));
		
		if(GetPVarInt(playerid, "Admin") >= 1)
		{ 	
			ShowPlayerDialog(playerid, 41, DIALOG_STYLE_TABLIST,
			header, tbtext, "Select", "Cancel");
		}
	} else {
		format(tbtext, sizeof(tbtext),
		"Сменить название команды\t\n\
		Сменить цвет команды\n\
		Сменить цвет никнеймов команды\n\
		Переместить игрока\t%s\n\
		{FFFF00}Очистить команды\t\n\
		Запрет на смену команды\t%s\n\
		Запрет использовать чат наблюдателям\t%s\n\
		{FFFF00}Принудительное наблюдение\t%s\n\
		Удерживать наблюдателей на спавне\t%s\n\
		Автоподстановка тегов клана\t%s\n\
		Выставить единый скин для команды\t\n",
		players_c,
		(LockedTeams) ? ("{00FF00}[ON]") : ("{808080}[OFF]"),
		(Mutespec) ? ("{00FF00}[ON]") : ("{808080}[OFF]"),
		(speconly) ? "{00FF00}[ON]" : "{808080}[OFF]",
		(Spawnlock) ? ("{00FF00}[ON]") : ("{808080}[OFF]"),
		(AutosetClanTags) ? ("{00FF00}[ON]") : ("{808080}[OFF]"));

		if(GetPVarInt(playerid, "Admin") >= 1)
		{ 	
			ShowPlayerDialog(playerid, 41, DIALOG_STYLE_TABLIST,
			header, tbtext, "Выбрать", "Отменить");
		}
	}
	SetPlayerChatBubble(playerid, "..opens team settings..", COLOR_GREY, 50.0, 5000);
}

