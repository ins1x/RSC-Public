	printf(string);
}

public CAC_OnCheatDetect(player_id, cheat_id, opt1, opt2)
{
	// Look sampcac.inc for more info
	// VK_keys https://docs.microsoft.com/en-us/windows/win32/inputdev/virtual-key-codes
	// NOTE: some recording softwares (eg: Fraps, Bandicam) are false detected 
	
	new string[128];
	new worldid = GetPlayerVirtualWorld(player_id);
	// Disable Anticheat at Virtual World (optional)
	if(worldid != 0 && !World[worldid][wAnticheat]) return 1;
	CAC_TotalDetectedCheaters += 1;
	
	switch(cheat_id)
	{
		case 0: KickPlayerEx(player_id, "[CAC] aimbot (0)");
		case 1: KickPlayerEx(player_id, "[CAC] aimbot (1)");
		case 2: KickPlayerEx(player_id, "[CAC] triggerbot (2)");
		case 3: KickPlayerEx(player_id, "[CAC] triggerbot (3)");
		case 4: // nametag ESP
		{
			if(GetPVarInt(player_id, "CAC_CHEAT_ESP") <= 3)
			{
				if(GetPlayerState(player_id) == PLAYER_STATE_ONFOOT) //(Spectrator bug) 
				{
					format(string, sizeof(string),
					"%s(%d) detected affecting ESP. code(4)",
					PlayerName(player_id), player_id);
					SendSystemMessage(string);
					SetPVarInt(player_id, "CAC_CHEAT_ESP", GetPVarInt(player_id, "CAC_CHEAT_ESP") + 1);
				}
				else KickPlayerEx(player_id, "[CAC] ESP (5)");
			}
		}
		case 5:  // general ESP. False positives on players with screen recording
		{
			if(GetPVarInt(player_id, "CAC_CHEAT__D3D9") <= 3)
			{
				format(string, sizeof(string),
				"%s(%d) detected affecting the rendering (D3D9). code(5)",
				PlayerName(player_id), player_id);
				SendSystemMessage(string);
				SendSystemMessage("It possible a video recording program, but may be a private multicheat");
				SetPVarInt(player_id, "CAC_CHEAT__D3D9", GetPVarInt(player_id, "CAC_CHEAT__D3D9") + 1);
			}
			else KickPlayerEx(player_id, "[CAC] aimbot (5)");
		}
		//case 6: return 1; // macro/keybinder. is used another way look (CAC_CHEAT__MACRO)
		case 7: KickPlayerEx(player_id, "[CAC] fakeping (7)");
		case 8: KickPlayerEx(player_id, "[CAC] modified weapon.dat (8)");
		case 9: KickPlayerEx(player_id, "[CAC] norecoil (9)");
		case 10: KickPlayerEx(player_id, "[CAC] norecoil (10)");
		case 11: KickPlayerEx(player_id, "[CAC] aimbot (11)");
		case 12: KickPlayerEx(player_id, "[CAC] aimbot (12)");
		case 13: SetPVarInt(player_id, "CacCLEO", 1); //KickPlayerEx(player_id, "[SAMPAC] cleo.asi (13)");
		case 14: KickPlayerEx(player_id, "[CAC] aimbot (14)");
		case 15:
		{
			if(GetPVarInt(player_id, "CAC_CHEAT__D3D9") != -1)
			{
				format(string, sizeof(string),
				"%s(%d) detected affecting the rendering (D3D9). code(15)",
				PlayerName(player_id), player_id);
				SendSystemMessage(string);
				SendSystemMessage("It possible a video recording program, but may be a private multicheat");
				SetPVarInt(player_id, "CAC_CHEAT__D3D9", -1);
			}
			//else KickPlayerEx(player_id, "[SAMPAC] aimbot (15)");	
		}
		case 16: KickPlayerEx(player_id, "[CAC] norecoil (16)");
		default: CAC_TotalDetectedCheaters -= 1; // dirty fix counter
	}
	if(cheat_id == CAC_CHEAT__CLEO)
	{
		if(CAC_KICK_CLEO) KickPlayerEx(player_id, "[CAC] detect CLEO Library");
	}
	// Macro
    if(cheat_id == CAC_CHEAT__MACRO_1)
    {		
		if(opt1 == 0x01) // Left mouse button (LMB)
		{
			format(string, sizeof(string), "Detected left mouse button key macro. %s[%i]",
			PlayerName(player_id), player_id);
			printf("%s", string);
			KickPlayerEx(player_id, "[CAC] detect Macro (LMB)");
		}
		if(opt1 == 0x02) // RMB mouse button (LMB)
		{
			format(string, sizeof(string), "Detected right mouse button key macro. %s[%i]",
			PlayerName(player_id), player_id);
			printf("%s", string);
			KickPlayerEx(player_id, "[CAC] detect Macro (RMB)");
		}
        if(opt1 == 0x09) // virtual key code for TAB
        {
            format(string, sizeof(string), "Detected VK_TAB key macro. %s[%i]",
			PlayerName(player_id), player_id);
            printf("%s", string);
			KickPlayerEx(player_id, "[CAC] Macro (TAB key)");
        }
		if(opt1 == 0xA0) // virtual key code for shift
        {
            format(string, sizeof(string), "Detected VK_LSHIFT key macro. %s[%i]",
			PlayerName(player_id), player_id);
            printf("%s", string);
			KickPlayerEx(player_id, "[CAC] Macro (SHIFT key)");
        }
		if(opt1 == 0x20) // virtual key code <space>
        {
            format(string, sizeof(string), "Detected VK_SPACE key macro. %s[%i]",
			PlayerName(player_id), player_id);
            printf("%s", string);
			KickPlayerEx(player_id, "[CAC] Macro (SPACE key)");
        }
		if(opt1 == 0x71) // virtual key code <F2>
        {
            format(string, sizeof(string),
			"Detected %s[%i] bind F2 key. This key is usually used to various cheats functions activation",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
        }
		if(opt1 == 0x72) // virtual key code <F3>
        {
            format(string, sizeof(string),
			"Detected %s[%i] bind F3 key. This key is usually used to various cheats functions activation",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
        }
		if(opt1 == 0x73) // virtual key code <F4>
        {
            format(string, sizeof(string), "Detected %s[%i] bind F4 key. This key is usually used to WH",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
        }
		if(opt1 == 0x74) // virtual key code <F5>
        {
            format(string, sizeof(string), "Detected %s[%i] use F5 key. This is fine but can be used for UltraWH.",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
        }
		if(opt1 == 0x78) // virtual key code <F9>
        {
            format(string, sizeof(string), "Detected %s[%i] use F9 key. This is fine but can be used for CLEO scripts unloader",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
        }
		if(opt1 == 0x7B) // virtual key code <F12> (7B not 78!)
        {
            format(string, sizeof(string), "Detected %s[%i] bind F12 key. This key is usually used to Sobeit",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
        }
		if(opt1 == 0x7A) // virtual key code <F11>
        {
            format(string, sizeof(string),
			"Detected %s[%i] bind F11 key. This key can be used to activate AIMBOT or multicheat menu",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
        }
		if(opt1 == 0x24) // VK_HOME
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind HOME key. This key can be used to call multicheats",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x2D) // VK_INS
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind INSERT key. This key can be used to call sampcac legit cheats",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x2E) // VK_DELETE
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind DELETE key.",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x23) // VK_END
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind END key. This key can be used to unload AIM GONWIK",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x6B) // + VK_ADD
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind VK_ADD key. This key is usually used to increase GameSpeed cheat",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x4A) // J
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind J key. This key is usually used to activate GameSpeed changer",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x52) // R
		{
			if(GetPlayerWeapon(player_id) == 24)
			{
				format(string, sizeof(string),
				"Detected %s[%i] Auto CBUG (R key binded).",
				PlayerName(player_id), player_id);
			} else {
				format(string, sizeof(string),
				"Detected %s[%i] bind R key. This key is usually used to activate OP-HAX or ULTRAHACK",
				PlayerName(player_id), player_id);
			}
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x58) //X
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind X key. This key is usually used to activate Surfly or VENOM",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x5A) // Z
		{
			format(string, sizeof(string),
			"Detected %s[%i] bind Z key. This key is usually used to activate AIMBOT",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x6D) //VK_SUBTRACT
		{
			format(string, sizeof(string),
			"Detected %s[%i] hook VK_SUBTRACT key. This player might be using OP-HaX multicheat",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0xC0) //VK_OEM_3
		{
			format(string, sizeof(string),
			"Detected %s[%i] hook ~ (tilde) key. This player using SAMPFUNCS has an in-game console.",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x0D) // VK_RETURN
		{
			format(string, sizeof(string),
			"Detected %s[%i] sampcac keyhook lock. This player might be using sampcac bypass.",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		if(opt1 == 0x13) // VK_PAUSE/BREAK
		{
			format(string, sizeof(string),
			"Detected %s[%i] sampcac keyhook lock. This player might be using Rampage hack.",
			PlayerName(player_id), player_id);
            printf("%s", string);
			SendSystemMessage(string);
		}
		//0xA2 - VK_LCONTROL
    }
    return 1;
}

