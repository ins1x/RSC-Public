public CAC_OnMemoryRead(player_id, address, size, const content[])
{
	// CAC_ReadMemory 
	// https://gtamods.com/wiki/Memory_Addresses_(SA)
	// https://gtaforums.com/topic/194199-documenting-gta-sa-memory-addresses/page/18/#comments
	new string[128];
	
	//const CPed = 0xB6F5F0;
	//const CVehicle = 0xBA18FC;
	
	// Rough Frame Rate (FPS)
	// Offset: 0xB729A0 (4-Byte ulong)
	// Total game loop iterations in the previous second, only updated every second,
	// but possibly useful for people wishing to display a crude frame rate without any api hooking.
	if(address == 0xB729A0 && size == 1) SetPVarInt(player_id, "CAC_FPS", content[0]);
	
	// Gamespeed (float)
	if(address == 0xB7CB64 && size == 4) 
	{
		if(content[0] > 0) 
		{
			format(string, sizeof(string), "[SAMPAC] gamespeed (%d)", content[0]);
			KickPlayerEx(player_id, string);
		}
	}
	
	// REAL aiming mode offset, not menu. 0 = joypad 1 = mouse + keys
	// address 0xBA6818 menu joypad
	if(address == 0xB6EC2E && size == 1) 
	{
		if(content[0] == 0 && GetPVarInt(player_id, "Admin") < 3) 
		{
			KickPlayerEx(player_id, "[SAMPAC] mobile player");
		}
	}
	
	// HUD Test. If recieve 0 this usually happens when player using custom HUD
	if(address == 0xA444A0 && size == 1) 
	{
		if(content[0] == 0)
		{
			format(string, sizeof(string),
			"Player %s(%d) has a custom HUD", PlayerName(player_id), player_id);
			SendSystemMessage(string);
		}
	}
	
	if(address == 0x96916D && size == 1) 
	{
		if(content[0] > 0) KickPlayerEx(player_id, "[SAMPAC] bulletproof");
	}
	
	// 0x00863984 gta_gravity (float)
	
	/*if(address == 0xB7CEE4 && size == 1) 
	{
		if(content[0] > 0) KickPlayerEx(player_id, "[SAMPAC] infinity run (2)");
	}*/
	
	/*if(address == 0xB7CB49 && size == 1)
	{
		if(content[0] == 0x1) SetPlayerChatBubble(player_id, "..ESC menu..", COLOR_GREY, 50.0, 5000);
	}*/
	
	// Jumpstate (bad data)
	// if(address == CPed+0x46D && size == 1) SendClientMessagef(player_id, -1, "%d", content[0]);
	
	// Test LATER / unused
	// 0xB7CDE0 -- Breath Meter current value (float) [uS v1.0 exe]
	// 0x8E4CB4 : (DWORD) UsedDevKitMemory (AKA Used Streaming Memory)
	// 0xB7CE50 dword money
	//[4]0xB7CDB4 - sprinting time left //springfield
	//[4]0xB7CDE0 - breathing time left //springfield
	// gta_menu_active  (int)( *(uint8_t *)0x00BA67A4 );
	//{0x969168,  sizeof(byte),       0,          -1},        // Cheat_StopGameClock
    //  {0xC402B8,  sizeof(byte),       0,          -1},        // Night Vision
    //{0xC402B9,  sizeof(byte),       0,          -1},        // Thermal Vision
	
	// Anti aliasing
	//if(address == 0xBA6814 && size == 1)
	//{
		/*if(content[0] == 0x1) SendClientMessage(player_id, -1, "Anti aliasing 0x (off)");
		else if(content[0] == 0x2) SendClientMessage(player_id, -1, "Anti aliasing 1x (off)");
		else if(content[0] == 0x3) SendClientMessage(player_id, -1, "Anti aliasing 2x (off)");
		else if(content[0] == 0x4) SendClientMessage(player_id, -1, "Anti aliasing 3x (off)");
		*/
	//}
	
	// 0xB6EC1C – [float] Mouse sensitivity CAC_ReadMemory(i, 0xB6EC1C, 4); 
	// if(address == 0xB6EC1C && size == 4) printf("Mouse %d", content[0]);
	
	// Weather id
	//if(address == 0xC81320 && size == 2) {
		//SendClientMessagef(player_id, -1, "weather id: %d", content[0]);
	//}
	
	// default fpslimiter
	//if(address == 0xBA6794 && size == 1)
	//{
	//	if(content[0] == 0x1) SetPVarInt(player_id, "DefaultFPSLimiterON", 1);
	//}
	// Default Frame Limit for Frame Limiter
	// 38 = 30fps
	// 46 = 35fps
	// 55 = 40fps
	// 65 = 45fps
	// 76 = 50fps
	// 88 = 55fps
	// 105 = 60fps
	// 200 = 100fps 
	//if(address == 0xC1704C && size == 1) printf("Default FPS %d", content[0]);
	
    return 1;
}

