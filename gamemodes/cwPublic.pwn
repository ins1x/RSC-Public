				}
			}

			SendClientMessage(playerid, COLOR_GREY, string);
			SendClientMessageEx(playerid, -1,
			"Для переключения на {008000}следующую{FFFFFF} карту нажмите {008000}<LMB>{FFFFFF} (Левая кнопка мыши)",
			"Switch to {008000}next{FFFFFF} map by pressing {008000}<LMB>{FFFFFF} (Left Mouse Button)");
			SendClientMessageEx(playerid, -1,
			"Для переключения на {008000}предыдущую{FFFFFF} карту нажмите {008000}<RMB>{FFFFFF} (Правая кнопка мыши)",
			"Switch to {008000}previous{FFFFFF} map by pressing {008000}<RMB>{FFFFFF} (Right Mouse Button)");
			SendClientMessageEx(playerid, -1,
			"Для {008000}сохранения выбранной карты{FFFFFF} нажмите {008000}<KEY_JUMP>{FFFFFF} (Прыжок)",
			"Save selected map by pressing {008000}<KEY_JUMP>{FFFFFF} (PED JUMP)");
