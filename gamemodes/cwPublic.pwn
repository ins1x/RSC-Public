		if (!strcmp("/troll", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			
			if (strlen(tmp) == 0) 
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /troll [ID]", "Use: /troll [ID]");
				return true;
			}
			new id = strval(tmp);
			if (!IsPlayerConnected(id))
			{
			    SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
			    return true;
			}
			//if(pData[playerid][pSfx]) PlayAudioStreamForPlayer(playerid,
			//"https://www.myinstants.com/media/sounds/test-your-might.MP3");
			ChosenPlayer[playerid] = id;
			TROLL_MENU(playerid);
			return true;
		}
		if (!strcmp(cmdtext, "/plugins", true)) 
		{
			SendRconCommand("plugins");
			SendClientMessageEx(playerid, COLOR_GREY,
		    "Список плагинов выведен в консоль (в server_log тоже)",
			"The plugins list is output in server console (in server_log too)");
			return true;
		}
		if (!strcmp(cmdtext, "/filterscripts", true)) 
		{
			#if defined _YSF_included
				new scriptname[32];
				new buffer[144];
				format(buffer,sizeof(buffer), "filterscripts (%i): ", GetFilterScriptCount());
				for(new i; i != 16; i++)
				{
					GetFilterScriptName(i, scriptname);
					if(isnull(scriptname)) continue; // If no FS
					format(scriptname,sizeof(scriptname), "%s ", scriptname);
					strcat(buffer, scriptname);
				}
				SendClientMessagef(playerid, -1, "%s", buffer);
				return true;
			#endif
		}
		if (!strcmp(cmdtext, "/invis", true)) 
		{
			#if defined _YSF_included
				InvisToggle(playerid);
				return true;
			#else 
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно. YSF не подключен", "Error.YSF not connected");
			#endif
		}
		if (!strcmp(cmdtext, "/fakedisconnect", true)) 
		{
			#if defined _YSF_included
				InvisToggle(playerid, true);
				return true;
			#else 
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно. YSF не подключен", "Error.YSF not connected");
			#endif
		}
		if (!strcmp(cmdtext, "/reconnect ", true, 9))
		{
			#if defined _YSF_included
			if (!cmdtext[10])
			{
			    SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /reconnect [id]", "Use: /reconnect [id]");
		    	return true;
			}
			
			new id = strval(cmdtext[10]);
			if(id != INVALID_PLAYER_ID)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное значение", "Incorrect value");
			}
		
			if(IsPlayerConnected(id))
			{
				///GetPlayerConnectMode(playerid);
				new string[100];
				SetPlayerConnectMode(id, E_PLAYER_CONNECT_MODE:REQUESTED_CONNECTION);
				format(string, sizeof(string), "%s(%d) has reconnected player %s(%d)",
				PlayerName(playerid), playerid, PlayerName(id), id);
				SendSystemMessage(string);
			}
			return 1;
			#else 
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно. YSF не подключен", "Error.YSF not connected");
			#endif
		}
		if (!strcmp(cmdtext, "/hideplayer ", true, 10))
		{
			new id = strval(cmdtext[11]);
			new stringru[100], stringen[100];
			//RemovePlayerForPlayer(id, playerid);
			if(GetPVarInt(id, "Removed") > 0) {
				#if defined _YSF_included
				foreach(Player, i) ShowPlayerForPlayer(i, id);
				HidePlayerMarker(id, 0);
				#else 
				SetPlayerVirtualWorld(id, 666666);
				#endif 
				SetPVarInt(id, "Removed", 0);
				ReSpawnPlayer(id);
				format(stringru, sizeof(stringru), "%s(%d) вернул игрока %s(%d)",
				PlayerName(playerid), playerid, PlayerName(id), id);
				format(stringen, sizeof(stringen), "%s(%d) has returned player %s(%d) back to game",
				PlayerName(playerid), playerid, PlayerName(id), id);
			} else {
				#if defined _YSF_included
				foreach(Player, i) {
					HidePlayerForPlayer(i, id);
					SetPlayerMarkerForPlayer(i, id, 0xFFFFFF00);
				}
				#else
				SetPlayerVirtualWorld(id, GetPlayerVirtualWorld(playerid));
				ReSpawnPlayer(id);
				#endif
				SetPVarInt(id, "Removed", 1);
				format(stringru, sizeof(stringru), "%s(%d) удалил игрока %s(%d)",
				PlayerName(playerid), playerid, PlayerName(id), id);
				format(stringen, sizeof(stringen), "%s(%d) has removed player %s(%d)",
				PlayerName(playerid), playerid, PlayerName(id), id);
			}
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			return true;
		}
		if (!strcmp("/pos", cmd, true) || !strcmp(cmdtext, "/coord", true))
		{
			tmp = strtok(cmdtext, idx);
			new id = strval(tmp);
			if (!IsPlayerConnected(id)) id = playerid; 				
			
			new string[100];
			new Float:x,Float:y,Float:z,Float:a;
			if(GetPlayerState(id) != PLAYER_STATE_SPECTATING)
			{
				GetPlayerPos(id, x,y,z);
				GetPlayerFacingAngle(id, a);
				format(string,sizeof(string),"OnFoot position: %.3f, %.3f, %.3f, %.1f", x, y, z, a);
				SendClientMessage(playerid, -1, string);
				format(string,sizeof(string),"OnFoot position: {%.3f, %.3f, %.3f, %.1f}", x, y, z, a);
				if(GetPVarInt(id,"Admin") >= 3) printf(string);
			} else {
				GetPlayerCameraPos(id, x, y, z);
				format(string, sizeof(string),
				"~w~Cam position: %.3f, %.3f, %.3f", x, y, z);
				SendClientMessage(playerid, -1, string);
				if(GetPVarInt(id,"Admin") >= 3) printf(string);
			}
			format(string,sizeof(string),"Interior: %i, VirtualWorld %i",
			GetPlayerInterior(id),GetPlayerVirtualWorld(id));
			SendClientMessage(playerid, -1, string);
			return true;
		}
		if (!strcmp(cmdtext, "/soundtest", true)) 
		{
			ShowPlayerDialog(playerid, 76, DIALOG_STYLE_INPUT, "Soundtest",
			"{FFFFFF}SOUND_BONNET_DENT 1009 \t\t SOUND_WHEEL_OF_FORTUNE_CLACKER 1027 \n"\
			"SOUND_AMMUNATION_BUY_WEAPON 1052 \t SOUND_AMMUNATION_BUY_WEAPON_DENIED 1053\n" \
			"SOUND_SHOP_BUY 1054 \t\t SOUND_SHOP_BUY_DENIED 1055\n"\
			"SOUND_RACE_321 1056 \t\t SOUND_RACE_GO 1057\n"\ 
			"SOUND_PART_MISSION_COMPLETE 1058 \t SOUND_PUNCH_PED 1130\n"\ 
			"SOUND_CAMERA_SHOT 1132 \t\t SOUND_BUY_CAR_MOD 1133 \n"\
			"SOUND_BUY_CAR_RESPRAY 1134 \t SOUND_CHECKPOINT_AMBER 1137 \n"\
			"SOUND_PROPERTY_PURCHASED 1149 \t SOUND_PICKUP_STANDARD 1150\n"\
			"\nEnter sound ID:\n",
			"Play", "Stop");
			return true;
		}
		if (!strcmp(cmdtext, "/audiotest", true)) 
		{
			ShowPlayerDialog(playerid, 166, DIALOG_STYLE_INPUT, "Audiostream test",
			"{FFFFFF}Notice: use /audiomsg to show audio URL information in chat\n"\
			"Turn ON radio at game settings ESC - Audio settings\n"\
			"Example: https://zaycevfm.cdnvideo.ru/ZaycevFM_rock_128.mp3\n"\
			"\nEnter stream url:\n",
			"Play", "Stop");
			return true;
		}
		if (!strcmp(cmdtext, "/weaponid", true) || !strcmp(cmdtext, "/weaponsid", true)) 
		{
			new string[64];
			SendClientMessage(playerid, -1, "Weapons IDs:");
			for(new i = 1; i < sizeof(WeaponNamesEN); i++)
			{
				if(strlen(WeaponNamesEN[i]))
				{
					format(string, sizeof(string), "{AFAFAF}%d = {FFFFFF}%s", i, WeaponNamesEN[i]);
					SendClientMessage(playerid, -1, string);
				}
			}
			return true;
		}
		if (!strcmp(cmdtext, "/getweapon", true) || !strcmp(cmdtext, "/getw", true))
		{
			ShowPlayerDialog(playerid, 159, DIALOG_STYLE_LIST, "Select mode",
			"Only for me\nFor all players", "Select", "Exit");
			return true;
		}
		if (!strcmp(cmdtext, "/panel", true) || !strcmp(cmdtext, "/apanel", true)
		|| !strcmp(cmdtext, "/amenu", true) || !strcmp(cmdtext, "/adm", true))
		{
			ADMIN_MENU(playerid);
			return true;
		}
		if (!strcmp(cmdtext, "/players", true))
		{
			new tmpstr[128], pstate[24];
			foreach(Player, i)
			{
				if(GetPlayerState(i) == PLAYER_STATE_NONE) {
					format(pstate, sizeof(pstate), "Initializing");
				} else if(GetPlayerState(i) == PLAYER_STATE_WASTED) {
					format(pstate, sizeof(pstate), "ClassSelection");
				} else if(GetPlayerState(i) == PLAYER_STATE_SPECTATING) {
					format(pstate, sizeof(pstate), "Spectating");
				} else if(IsPlayerAFK(i)) {
					format(pstate, sizeof(pstate), "AFK");
				} else if (GetPVarInt(i, "MapSelect") > 0) {
					format(pstate, sizeof(pstate), "MapSelect");
				} else if(GetPlayerState(i) == PLAYER_STATE_SPAWNED) {
					format(pstate, sizeof(pstate), "Respawning");
				} 
				
				new Float:distance = GetDistanceBetweenPlayers(i, playerid);
				new Float:health, Float:armour;
				GetPlayerHealth(i, health);
				GetPlayerArmour(i, armour);
				new team = GetPVarInt(i, "Team");
				
				format(tmpstr, sizeof(tmpstr),
				"(%d)%s%s - {FF0000}%.1f{FFFFFF}(%.1f) - {AFAFAF}%s {FFFFFF}dist: %i",
				i, THC[team], PlayerName(i), health, armour, pstate, distance);
				SendClientMessage(playerid, -1, tmpstr);
			}
			return true;
		}
		if (!strcmp(cmdtext, "/password", true) || !strcmp(cmdtext, "/passwd", true))
		{
			if(NetStats_GetConnectedTime(playerid)/60000 < 5)
			{
				return SendClientMessageEx(playerid, COLOR_GREY, 
				"Вы должны быть онлайн не менее 5 минут",
				"You must be online for at least 5 minutes");
			}
            #if defined DISCORD_VERIFICATION
			if(pData[playerid][pVerified] == 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY, 
				"Пройдите верификацию для защиты аккаунта",
				"Get verified to secure your account");
			}
            #endif
			if(pData[playerid][pLang] == 0)
			{
				ShowPlayerDialog(playerid, 28, DIALOG_STYLE_INPUT,"Смена пароля от аккаунта",
				"{FFFF00}Рекомендации\n\
				{ffffff}- Длина пароля должна быть не менее 4 и не более 20 символов.\n\
				- Пароль может состоять из букв латинского алфавита (A-z), арабских цифр (0-9) и специальных символов\n\
				\nВведите новый пароль ниже:", "Сменить", "Отменить");
			} else {
				ShowPlayerDialog(playerid, 28, DIALOG_STYLE_INPUT,"Change account password",
				"{FFFF00}Recommendations\n\
				{ffffff}- Password length must be at least 4 and not more than 20 characters.\n\
				- The password can consist of Latin letters (A-z), Arabic numerals (0-9) and special characters\n\
				\nEnter your new password below:", "Change", "Cancel");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/clientpassword", true, 9))
		{
		    if (strlen(cmdtext) < 17)
		    {
			    if (strlen(clientpass) == 0)
			    {
			        //SendClientMessageEx(playerid, COLOR_GREY, "Сервер уже разблокирован.", "Server is already unlocked.");
			        SendClientMessageEx(playerid, COLOR_GREY, "Используйте: /clientpassword password либо /clientpassword 0 для сброса.",
					"Use: /clientpassword password or /clientpassword 0 to reset.");
			        return true;
			    }
			    SendRconCommand("password 0");
			    clientpass[0] = 0;
			    new stringru[65], stringen[68];
			    format(stringru, sizeof(stringru), "%s(%d) разблокировал сервер в SA:MP клиенте.", name, playerid);
			    format(stringen, sizeof(stringen), "%s(%d) has unlocked server in SA:MP client.", name, playerid);
				AdminActionsLog(stringen);
			    SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			}else{
			    if (strlen(cmdtext[16]) > sizeof(clientpass))
			    {
			        SendClientMessageEx(playerid, COLOR_GREY,
					"Максимальная длина пароля 32 символа.",
					"Maximum password lenght is 32 characters.");
			        return true;
			    }
			    if (clientpass[0] && !strcmp(cmdtext[16], clientpass, true))
			    {
			        SendClientMessageEx(playerid, COLOR_GREY,
					"Этот пароль уже установлен.", "This password is already set up.");
			        return true;
			    }
			    format(clientpass, sizeof(clientpass), "%s", cmdtext[16]);
			    new stringru[64], stringen[128];
			    format(stringru, 41, "password %s", cmdtext[16]);
			    SendRconCommand(stringru);
				format(stringen, sizeof(stringen),
				"%s(%d) has locked server in SA:MP client.", name, playerid);
				AdminActionsLog(stringen);
			    format(stringen, sizeof(stringen), "%s(%d) has set up password to server in SA:MP client: \"%s\".", name, playerid, cmdtext[16]);
				SendSystemMessage(stringen);
			    
			}
			return true;
		}
		if (!strcmp(cmdtext, "/refreshscore", true))
		{
			RefreshScore();
			SendClientMessage(playerid, COLOR_GREY, "Counters data has been updated.");
			return true;
		}
		#if defined _sampcac_included
		if (!strcmp(cmdtext, "/kickac", true) || !strcmp(cmdtext, "/cac", true))
		{
			if (GetPVarInt(playerid, "Admin") >= 1)
			{
				for(new i = 0; i < _MAX_PLAYERS; i++)
				{
					if (IsPlayerConnected(i))
					{
						new major, minor, patch;
						CAC_GetClientVersion(i, major, minor, patch);
						if(CAC_GetStatus(i) == 0 ) KickPlayerEx(i, "SAMPCAC is not installed");
						if(minor != 10) KickPlayerEx(i, "SAMPCAC is outdated");
					}
				}
			} else {
				SendClientMessageEx(playerid, COLOR_RED,
				"Только администраторы могут использовать эту команду",
				"Only administrators can use this command");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/aconly", true) || !strcmp(cmdtext, "/ac", true))
		{
			if (GetPVarInt(playerid, "Admin") >= 3)
			{
				AConlyToggle(playerid);
				return true;
			}
		}
		#endif
		if (!strcmp(cmdtext, "/skill", true))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /skill [0-999]", "Use: /skill [0-999]");
			return true;
		}
		if (!strcmp(cmdtext, "/skill ", true, 7))
		{
		    if (!cmdtext[7])
		    {
		        SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /skill [0-999]", "Use: /skill [0-999]");
		        return true;
		    }
		    new weapon1 = GetPlayerWeapon(playerid), string[85];
			format(string, 5, "%s", cmdtext[7]);
			new PARAM = strval(string);
			if (0 <= PARAM <= 999)
		    {
			    if (22 <= weapon1 <= 31)
			    {
			        if (Skill[weapon1 -22] == PARAM)
			        {
			            SendClientMessageEx(playerid, COLOR_GREY,
						"Этот уровень навыка уже выставлен.", "This skill level is already set up.");
			            return true;
			        }
			        Skill[weapon1 -22] = PARAM;
			        for(new i = 0; i < MAX_PLAYER_ID; i++)
				    {
				        if (IsPlayerConnected(i))
				        {
				        	SetPlayerSkillLevel(i, weapon1 -22, PARAM);
						}
					}
					format(string, sizeof(string), "%s(%d) has set weapon %s skill to %d.",
					name, playerid, WeaponNamesEN[weapon1], PARAM);
					SendClientMessageToAll(COLOR_GREY, string);
				}
				else if (weapon1 == 34)
				{
				    if (Skill[10] == PARAM)
			        {
			            SendClientMessageEx(playerid, COLOR_GREY,
						"Этот уровень навыка уже выставлен.", "This skill level is already set up.");
			            return true;
			        }
				    Skill[10] = PARAM;
				    for(new i = 0; i < MAX_PLAYER_ID; i++)
				    {
				        if (IsPlayerConnected(i))
				        {
				        	SetPlayerSkillLevel(i, 10, PARAM);
						}
					}
					format(string, sizeof(string), "%s(%d) has set weapon %s skill to %d.",
					name, playerid, WeaponNamesEN[weapon1], PARAM);
					SendClientMessageToAll(COLOR_GREY, string);
				}else{
				    SendClientMessage(playerid, COLOR_GREY,
					"Вы не можете установить уровень навыка для этого оружия.");
				}
			}else{
			    SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /skill [0-999]", "Use: /skill [0-999]");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/settime", true))
		{
		    SendClientMessageEx(playerid, COLOR_GREY, "Использование: /settime [час]", "Use: /settime [hour]");
		    return true;
		}
		if (!strcmp(cmdtext, "/settime ", true, 9))
		{
			if (!cmdtext[9])
			{
			    SendClientMessageEx(playerid, COLOR_GREY, "Использование: /settime [час]", "Use: /settime [hour]");
		    	return true;
			}
			new stringru[100], stringen[100];
			format(stringru, 3, "%s", cmdtext[9]);
			new PARAM = strval(stringru);
			if (!(-1 < PARAM < 24))
			{
			    SendClientMessageEx(playerid, COLOR_GREY, "Доступное время 0-23 часов.", "Available hours are 0-23.");
			    return true;
			}
			SetWorldTime(PARAM);
			format(stringru, sizeof(stringru), "%s(%d) установил время на %d ч.", name, playerid, PARAM);
			format(stringen, sizeof(stringen), "%s(%d) has set up time to %d hour.", name, playerid, PARAM);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			return true;
		}
		if (!strcmp(cmdtext, "/listfs", true))
		{
			#if defined _YSF_included
			new scriptname[64];
			for(new i; i != 16; i++)
			{
				GetFilterScriptName(i, scriptname);
				if(isnull(scriptname)) continue; // If no FS
				SendClientMessagef(playerid, -1, "%d. - %s", i, scriptname);
			}
			#else 
				SendClientMessageEx(playerid, COLOR_GREY,
				"Нужен YSF для использования этой функции", "Need YSF plugin for use it");
			#endif
			return true;
		}
		if (!strcmp("/loadfs", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			
			if (strlen(tmp) == 0 || strlen(tmp) > 24) {
				ShowPlayerDialog(playerid, 122, DIALOG_STYLE_INPUT,
				"{FF0000}Loadfs","{FFFFFF}Enter filterscript name", "Load", "Exit");
				return true;
			}
			if(GetPVarInt(playerid, "Admin") < 3) return 0;
			SetPVarString(playerid, "lastfs", tmp);
			new tmpstr[64];
			format(tmpstr, sizeof tmpstr, "loadfs %s", tmp);
			SendRconCommand(tmpstr);
			return true;
		}
		if (!strcmp("/unloadfs", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
					
			if (strlen(tmp) == 0 || strlen(tmp) > 24) {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Используй /listfs чтобы показать загруженые фильтрскрипты",
				"Use /listfs to show loaded filterscripts");
				return true;
			}
			if(GetPVarInt(playerid, "Admin") < 3) return 0;
			new tmpstr[64];
			format(tmpstr, sizeof tmpstr, "unloadfs %s", tmp);
			SendRconCommand(tmpstr);
			return true;
		}
		if (!strcmp("/reloadfs", cmd, true))
		{
			if(GetPVarInt(playerid, "Admin") < 3) return 0;
			tmp = strtok(cmdtext, idx);
			new tmpstr[64];
			if (strlen(tmp) == 0 || strlen(tmp) > 24)
			{
				new lastfs[24];
				GetPVarString(playerid, "lastfs", lastfs, sizeof lastfs);
				if(strlen(lastfs) > 0)
				{
					format(tmpstr, sizeof tmpstr, "unloadfs %s", tmp);
					SendRconCommand(tmpstr);
					format(tmpstr, sizeof tmpstr, "loadfs %s", tmp);
					SendRconCommand(tmpstr);
					SendClientMessage(playerid, COLOR_GREY, "Filtescript reloaded");
				} 
				else SendClientMessage(playerid, COLOR_GREY, "Last filtescript not found");
			} else {
				format(tmpstr, sizeof tmpstr, "unloadfs %s", tmp);
				SendRconCommand(tmpstr);
				format(tmpstr, sizeof tmpstr, "loadfs %s", tmp);
				SendRconCommand(tmpstr);
				SendClientMessage(playerid, COLOR_GREY, "Filtescript reloaded");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/sskip", true))
		{
			RestartRound();
			return true;
		}
		if (!strcmp(cmdtext, "/skick", true))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Silent kick. Использование: /skick [ID] <причина>",
			"Silent kick. Use: /skick [ID] <reason>");
			return true;
		}
		if (!strcmp(cmdtext, "/skick ", true, 7))
		{
		    if (!cmdtext[7])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Silent kick. Использование: /skick [ID] <причина>",
				"Silent kick. Use: /skick [ID] <reason>");
				return true;
			}
		    new len = strlen(cmdtext[7]), string[128];
		 	format(string, 7, "%s", cmdtext[7]);
		 	new PARAM = strval(string);
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
