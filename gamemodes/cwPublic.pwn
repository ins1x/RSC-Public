				new Float:angle, Float:x, Float:y, Float:z;
				GetPlayerPos(playerid, x,y,z);
				GetPlayerFacingAngle(playerid, angle);
				GetXYInFrontOfPlayer(playerid, x, y, 1.5);
				
				new actorid = CreateDynamicActor(strval(inputtext), x+0.1, y+0.1, z, 0.0,
				false, 100.0, worldid, GetPlayerInterior(playerid), -1);
				ChosenActor[playerid] = actorid;
				WORLD_EDITACTORS(playerid);
			#endif
		}
