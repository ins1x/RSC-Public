			"{FFFFFF}Полный список комманд для администраторов можно найти в разделе{FF3333}/help{FFFFFF}\n\
			\n\
			{FF3333}[Наказания]{FFFFFF}\n\
			- Слапнуть или пнуть игрока {FF3333}/slap [ID] и /punch [ID]{FFFFFF}\n\
			- Заморозить игрока {FF3333}/frz [ID]{FFFFFF}\n\
			- Забрать оружие у игрока {FF3333}/disarm [ID]{FFFFFF}\n\
			- Кикнуть игрока {FF3333}/kick [ID] <время> {FFFFFF}\n\
			- Заглушить игрока по IP {FF3333}/mute [ID] <время>{FFFFFF} где в время указывается в секундах\n\
			- Запретить использование команд игроку {FF3333}/lockcmds [ID]{FFFFFF}\n\
			\n{FF3333}[BAN]{FFFFFF}\n\
			Администраторы 2-го уровня не могут банить игроков, но могут кикнуть игрока {FF3333}/kick [ID] <причина> {FFFFFF}\n\
			\n\
			В случае злоупотребления админ-командами или неверной выдачи наказаний,\n\
			{FF0000}права администратора будут удалены.{FFFFFF}\n\
			",
			"OK", "");
		} else {
			ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX,
			"{FFD700}Ban help [LVL 3+]",
			"{FFFFFF}Полный список комманд для администраторов можно найти в разделе {FF3333}/help{FFFFFF}\n\
			\n\
			{FF3333}[BAN]{FFFFFF}\n\
