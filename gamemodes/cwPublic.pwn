	if (!strcmp(cmdtext, "/reset", true))
	{
		if (GetPlayerVirtualWorld(playerid) == 0 && GetPVarInt(playerid, "Admin") < 1)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Для использования этих функций Вы должны быть администратором 1+ уровня!",
			"To use these functions you need to have 1+ level admin rights!");
			SendClientMessageEx(playerid, COLOR_GREY,
			"Чтобы заспавнить себя используйте /respawn", "To spawn yourself use /respawn");
			return true;
		}
		
		if(GetPlayerVirtualWorld(playerid) == 0) 
		{
			ResetGameScore(playerid, false);
		} else {
			if(!WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
			
			new worldid = GetPlayerVirtualWorld(playerid);
			
			if(World[worldid][wUseTimer])
			{
				new timestamp;
				timestamp = gettime() - World[worldid][wStartTime];
				if(timestamp > 60)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Нельзя сбрасывать счет. Прошла минута с начала раунда!",
					"You can't reset the score. A minute has passed since the start of the round!");
					return true;
				}
			}
			
			foreach(Player, i)
			{
				if (GetPlayerState(i) == PLAYER_STATE_ONFOOT && !GetPVarInt(i, "UnBug"))
				{
					if(GetPlayerVirtualWorld(playerid) == GetPlayerVirtualWorld(i))
					{
						Stats[i][pKills] = 0;
						Stats[i][pDeath] = 0;
						Stats[i][pKD] = 0.0;
						Stats[i][pInjuries] = 0.0;
						Stats[i][pEfficiency] = 0.0;
						SetPlayerScore(i, 0);
					}
				}
			}
			
			new stringru[100], stringen[100];
			format(stringru, sizeof(stringru),
			"%s(%d) сбросил счет для всех игроков в мире",
			PlayerName(playerid), playerid);
			format(stringen, sizeof(stringen),
			"%s(%d) reset score for all players on virtual world",
			PlayerName(playerid), playerid);
			SendClientMessageToVirtualWorld(GetPlayerVirtualWorld(playerid), 
			COLOR_GREY, stringru, stringen);
		}
		return true;
	}
	if (!strcmp(cmdtext, "/marker", true) || !strcmp(cmdtext, "/markers", true))
	{
