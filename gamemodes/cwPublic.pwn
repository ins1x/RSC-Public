stock SpecOff(playerid)
{
    GameTextForPlayer(playerid, " ", 1, 3);
    new bool: spected;
    for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
	    if (IsPlayerConnected(i))
	    {
	        if (GetPVarInt(i, "Specing") == GetPVarInt(playerid, "Specing"))
	        {
	            if (i != playerid)
	            {
	            	spected = true;
	            	break;
				}
	        }
	    }
	}
	
	TogglePlayerSpectating(playerid, false);
	// Fix spec exit player postion
	if(GetPlayerVirtualWorld(playerid) != 0 && GetPVarInt(playerid, "MapSelect") != 1) {
		SetPVarInt(playerid, "UnBug", true);
	}
	
	SetPVarInt(playerid, "MapSelect", 0); //disable mapselect mode
	DeletePVar(playerid, "FlyMode");
	//CancelEdit(playerid);
    DestroyPlayerObject(playerid, noclipdata[playerid][flyobject]);
    noclipdata[playerid][cameramode] = CAMERA_MODE_NONE;
	SetPVarInt(GetPVarInt(playerid, "Specing"), "Spected", spected);
    
	SetPVarInt(playerid, "Specing", -1);
	SetPVarInt(playerid, "specbar", -1);
	RefreshHud(playerid);
	
	SetPlayerVirtualWorld(playerid, GetPVarInt(playerid, "world"));
	SetPlayerInterior(playerid, GetPVarInt(playerid, "interior"));
	SpawnPlayer(playerid);
}

stock Spectate(playerid, specid)
{
	// Custom spectating function
	if (score[0] == Roundkills || score[1] == Roundkills)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Сейчас Вы не можете использовать данную функцию.", "You can't use this function right now.");
		return true;
	}
	if (!IsPlayerConnected(specid))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Игрок не подключен либо вышел.", "This player isn't connected.");
		return true;
	}
	if (playerid == specid)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Вы не можете наблюдать за собой.",	"You can't spectate yourself.");
		return true;
	}
	if(GetPVarType(playerid, "FlyMode"))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Вы не можете перейти в наблюдение. Сначала выйдите из режима полета!",
		"Spectators can't switch to spectate mode right now. Exit flymode before!");
		return true;
	}
	if(GetPlayerState(specid) == PLAYER_STATE_SPECTATING)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Игрок в режиме наблюдения или в полете.","The player in spectate mode or flymode.");
		return true;
	}
	//if (GetPVarInt(playerid, "world") != GetPVarInt(specid, "world"))
	//{
		//SendClientMessageEx(playerid, COLOR_GREY,
		//"Вы должны находиться в одном виртуальном мире.",
		//"The player must be in the same virtual world.");
	//	return true;
	//}
	if(GetPVarInt(playerid, "Team") == 2 || GetPVarInt(playerid, "Admin") > 0)
	{
		if (pData[playerid][pLang] == 0)
		{
			SendClientMessage(playerid, -1, "Вы вошли в режим наблюдения. Для выхода используйте {008000}/specoff{FFFFFF} или нажмите {008000}F / ENTER{FFFFFF}");
			SendClientMessage(playerid, -1, "Для переключения на {008000}следующего{FFFFFF} игрока нажмите {008000}<LMB>{FFFFFF} (Левая кнопка мыши)");
			SendClientMessage(playerid, -1, "Для переключения на {008000}предыдущего{FFFFFF} игрока нажмите {008000}<RMB>{FFFFFF} (Правая кнопка мыши)");
		} else {
			SendClientMessage(playerid, -1, "You have entered spectate mode. To stop spectating use {008000}/specoff{FFFFFF} or press {008000}F / ENTER{FFFFFF}");
			SendClientMessage(playerid, -1, "Switch to {008000}next{FFFFFF} by pressing {008000}<LMB>{FFFFFF} (Left Mouse Button)");
			SendClientMessage(playerid, -1, "Switch to {008000}previous{FFFFFF} by pressing {008000}<RMB>{FFFFFF} (Right Mouse Button)");
		}
		if(pData[playerid][pFpsbar] > 0) PlayerTextDrawHide(playerid, FPSBAR[playerid]);
		if(pData[playerid][pHpbar] > 0) {
			PlayerTextDrawHide(playerid, PlayerHp[playerid]);
			PlayerTextDrawHide(playerid, PlayerArmour[playerid]);
		}
		if (GetPVarInt(playerid, "Specing") > -1)
		{
			new bool: spected;
			for(new i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i))
				{
					if (GetPVarInt(i, "Specing") == GetPVarInt(playerid, "Specing"))
					{
						spected = true;
						break;
					}
				}
			}
			SetPVarInt(GetPVarInt(playerid, "Specing"), "Spected", spected);
		}
		if (!GetPVarInt(specid, "Spected"))
		{
			SetPVarInt(specid, "Spected", true);
		}
		SetPVarInt(playerid, "world", GetPlayerVirtualWorld(playerid));
		SetPVarInt(playerid, "interior", GetPlayerInterior(playerid));
		SetPlayerInterior(playerid,GetPlayerInterior(specid));
		SetPlayerVirtualWorld(playerid, GetPlayerVirtualWorld(specid));
		TogglePlayerSpectating(playerid, true);
		SetPVarInt(playerid, "Specing", specid);
		PlayerSpectatePlayer(playerid, specid);
		PlayerPlaySound(playerid, 1132, 0.0, 0.0, 0.0);		
		return true;
	} 
	else SendClientMessageEx(playerid, COLOR_GREY,
	"Сейчас Вы не можете использовать данную функцию.",
	"You can't use this function right now.");
	
	return specid;
}

stock SpecNext(playerid) // spectoggle ++
{
	new i = GetPVarInt(playerid, "Specing") + 1;
	while(i < MAX_PLAYER_ID)
	{
		if (Specfunc(playerid, i)) return true;
		i++;
	}
	
	i = 0;
	while(i < GetPVarInt(playerid, "Specing"))
	{
		if (Specfunc(playerid, i)) return true;
		i++;
	}
	return true;
}

stock SpecPrev(playerid) // spectoggle --
{	
	new i = GetPVarInt(playerid, "Specing") -1;
	while(i > -1)
	{
		if (Specfunc(playerid, i)) return true;
		i--;
	}
	i = MAX_PLAYER_ID -1;
	while(i > GetPVarInt(playerid, "Specing"))
	{
		if (Specfunc(playerid, i)) return true;
		i--;
	}
	return true;
}

stock TogglePlayerMarkers(markertoggle)
{
	// Toggle on-off all player's markers on map
	if (markertoggle)
	{
		Marker = false;
		foreach(Player, i)
		{
			if (GetPVarInt(i, "Team") < 2)
			{
				foreach(Player, e)
				{
					if (GetPVarInt(e, "Team") < 2 && GetPVarInt(e, "Team") != GetPVarInt(i, "Team"))
					{
						if (GetPVarInt(e, "Team") == 0)
						{
							SetPlayerMarkerForPlayer(i, e, COLOR_INVGREEN);
						} else {
							SetPlayerMarkerForPlayer(i, e, COLOR_INVBLUE);
						}
					}
				}
			}
		}
	} else {
		Marker = true;
		foreach(Player, i)
		{
			if (GetPVarInt(i, "Team") < 2)
			{
				foreach(Player, e)
				{
					if (GetPVarInt(e, "Team") < 2 && GetPVarInt(e, "Team") != GetPVarInt(i, "Team"))
					{
						if (GetPVarInt(e, "Team") == 0)
						{
							SetPlayerMarkerForPlayer(i, e, TCC[0]);
						} else {
							SetPlayerMarkerForPlayer(i, e, TCC[1]);
						}
					}
				}
			}
		}
	}
	return Marker;
}

stock ToggleMarkersInWorld(worldid, markertoggle)
{
	// Toggle on-off all player's markers on map
	if (markertoggle)
	{
		World[worldid][wMarkers] = 1;
		foreach(Player, i)
		{
			foreach(Player, e)
			{
				if (GetPlayerVirtualWorld(e) == GetPlayerVirtualWorld(i)
				&& GetPVarInt(e, "Team") != GetPVarInt(i, "Team"))
				{
					if (GetPVarInt(e, "Team") == 0)
					{
						SetPlayerMarkerForPlayer(i, e, COLOR_INVGREEN);
					} else {
						SetPlayerMarkerForPlayer(i, e, COLOR_INVBLUE);
					}
				}
			}
			
		}
	} else {
		World[worldid][wMarkers] = 0;
		foreach(Player, i)
		{	
			foreach(Player, e)
			{
				if (GetPlayerVirtualWorld(e) == GetPlayerVirtualWorld(i)
				&& GetPVarInt(e, "Team") != GetPVarInt(i, "Team"))
				{
					if (GetPVarInt(e, "Team") == 0)
					{
						SetPlayerMarkerForPlayer(i, e, TCC[0]);
					} else {
						SetPlayerMarkerForPlayer(i, e, TCC[1]);
					}
				}
			}
		}
	}
}

public Specfunc(playerid, i)
{
	// Toggle spectate mode. Provide easy acess to switch spectated players 
	if (IsPlayerConnected(i) && GetPVarInt(i, "Team") < 2)
	{
        if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
		{
			if (GetPVarInt(playerid, "world") == GetPVarInt(i, "world"))
			{
				new bool: toggle;
				for(new e = 0; e < MAX_PLAYER_ID; e++)
				{
					if (IsPlayerConnected(e))
					{
						if (GetPVarInt(e, "Specing") == GetPVarInt(playerid, "Specing"))
						{
							toggle = true;
							break;
						}
					}
				}
				SetPVarInt(GetPVarInt(playerid, "Specing"), "Spected", toggle);
				if (!GetPVarInt(i, "Spected"))
				{
					SetPVarInt(i, "Spected", true);
				}
				
				if(GetPVarInt(playerid, "specbar") != -1) SetPVarInt(playerid, "specbar", i);
				SetPVarInt(playerid, "Specing", i);
				PlayerSpectatePlayer(playerid, i);
				PlayerPlaySound(playerid, 1132, 0.0, 0.0, 0.0);
				return true;
			}
		}
	}
	return false;
}

stock CheckSpec(playerid)
{
	/*
	Check spectate mode. Used in /spec command to switch beetwen spec players
	*/
	if (score[0] != Roundkills && score[1] != Roundkills)
	{
		if (speconly)
	    {
			if (GetPVarInt(playerid, "Specing") == -1)
			{
				new activeplayers[_MAX_PLAYERS], gg;
				foreach(Player, i)
				{
					if (GetPVarInt(i, "Team") < 2
					&& GetPVarInt(playerid, "world") == GetPVarInt(i, "world")
					&& GetPlayerState(i) == PLAYER_STATE_ONFOOT)
					{
						activeplayers[gg] = i;
						gg++;
					}
				}
		        if (gg > 0)
		        {
			        new rand = random(gg);
			        if (!GetPVarInt(activeplayers[rand], "Spected"))
					{
                        SetPVarInt(activeplayers[rand], "Spected", true);
					}
					TogglePlayerSpectating(playerid, true);
					SetPVarInt(playerid, "Specing", activeplayers[rand]);
					PlayerSpectatePlayer(playerid, activeplayers[rand]);
					PlayerPlaySound(playerid, 1132, 0.0, 0.0, 0.0);
				} else {
				    foreach(Player, i)
					{
						if (GetPVarInt(i, "Team") == 2
						&& GetPVarInt(i, "Specing") == -1
						&& GetPlayerState(i) == PLAYER_STATE_ONFOOT)
						{
							TogglePlayerSpectating(i, true);
							SetPVarInt(i, "Specing", i);
							PlayerSpectatePlayer(i, i);
							PlayerPlaySound(i, 1132, 0.0, 0.0, 0.0);
						}
					}
				}
			}
		}
	}
}

stock ReportLog(cwfinal = false)
{
	// Write report after Cw on scriptfiles\reports. Create this folder before use this function
	// This func call if you start cw (cwmode) and write log after cw ending
	
	new string[125];
	new i, stats_[3][13], ratio_[13];
	
	new File: file = fopen(reportfilename, io_append);
	if (file)
	{
		if(cwfinal)
		{
			// Global stat
			fwrite(file, "\r\n");
			fwrite(file, "Overall player statistics:\r\n");
			fwrite(file, "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\r\n");
			for(i = 0; i < _MAX_PLAYERS; i++)
			{
				if (IsPlayerConnected(i))
				{
					if (GetPVarInt(i, "Team") < 2)
					{
						new rto[MAX_PLAYER_NAME];
						GetPlayerName(i, rto, MAX_PLAYER_NAME);
						format(string, sizeof(string), "\t\tPlayer - %s:\r\n", rto);
						fwrite(file, string);
						if (GetPVarInt(i, "cwdeath") > 0)
						{
							format(rto, sizeof(rto), "%.2f", GetPVarInt(i, "cwkills") /float(GetPVarInt(i, "cwdeath")));
						}else{
							rto = "-";
						}
						format(string, sizeof(string), "Kills: %d | Deaths: %d | ratio: %s\r\n", GetPVarInt(i, "cwkills"), GetPVarInt(i, "cwdeath"), rto);
						fwrite(file, string);
						if (GetPVarInt(i, "cwdeath") > 0)
						{
							format(rto, sizeof(rto), "%.2f", (GetPVarInt(i, "cwkills") -GetPVarInt(i, "cwteamkills")) /float(GetPVarInt(i, "cwdeath")));
						}else{
							rto = "-";
						}
						format(string, sizeof(string), "TeamKills: %d | Kills without TK: %d | ratio without TK: %s\r\n", GetPVarInt(i, "cwteamkills"), GetPVarInt(i, "cwkills") -GetPVarInt(i, "cwteamkills"), rto);
						fwrite(file, string);
						
						if (GetPVarFloat(i, "cwinjuries") > 0)
						{
							format(rto, sizeof(rto), "%.2f", GetPVarFloat(i, "cwdamage") /GetPVarFloat(i, "cwinjuries"));
						}else{
							rto = "-";
						}
						format(string, sizeof(string), "Damage: %.2f | Injuries: %.2f | ratio: %s\r\n", GetPVarFloat(i, "cwdamage"), GetPVarFloat(i, "cwinjuries"), rto);
						fwrite(file, string);
						if (GetPVarFloat(i, "cwinjuries") > 0)
						{
							format(rto, sizeof(rto), "%.2f", (GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "cwteamdamage")) /GetPVarFloat(i, "cwinjuries"));
						}else{
							rto = "-";
						}
						format(string, sizeof(string), "Teammates damage: %.2f | Damage without team damage: %.2f | ratio without team damage: %s\r\n", GetPVarFloat(i, "cwteamdamage"), GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "cwteamdamage"), rto);
						fwrite(file, string);
					}
				}
			}
			fwrite(file, "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\r\n");
		}
		else 
		{
			// stats 
			fwrite(file, "\r\n");
			format(string, sizeof(string), "%d. round:", RoundScore[0] +RoundScore[1]);
			//SendClientMessageToAll(COLOR_WHITE, string);
			fwrite(file, string);
			fwrite(file, "\r\n");
			format(string, sizeof(string), "  Players %s:", ClanName[0]);
			//SendClientMessageToAll(COLOR_WHITE, string);
			fwrite(file, string);
			fwrite(file, "\r\n");
			
			for(i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i))
				{
					if (GetPVarInt(i, "Team") == 0)
					{
						for(new e = 0; e < 3; e++)
						{
							format(string, 13, "round_stats%d", e);
							if (GetPVarInt(i, string[6]) -GetPVarInt(i, string) < 10)
							{
								format(stats_[e], sizeof(stats_[]), "0%d", GetPVarInt(i, string[6]) -GetPVarInt(i, string));
							}else{
								valstr(stats_[e], GetPVarInt(i, string[6]) -GetPVarInt(i, string));
								//format(stats_[e], sizeof(stats_[]), "%d", GetPVarInt(i, string[6]) -GetPVarInt(i, string));
							}
						}
						if (GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death") > 0)
						{
							format(ratio_, sizeof(ratio_), "%.2f", (GetPVarInt(i, "cwkills") -GetPVarInt(i, "round_kills")) /float(GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death")));
						}else{
							ratio_ = "-";
						}
						new name[MAX_PLAYER_NAME];
						GetPlayerName(i, name, sizeof(name));
						format(string, sizeof(string), "    %s:\r\n      Kills: %s | Deaths: %s | TeamKills: %s | Ratio: %s.", name, stats_[0], stats_[1], stats_[2], ratio_);
						
						fwrite(file, string);
						fwrite(file, "\r\n");
						
						new Float: cwdamage = GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage");
						new Float: cwinjuries = GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries");
						new Float: cwteamdamage = GetPVarFloat(i, "cwteamdamage") -GetPVarFloat(i, "round_teamdamage");

						if (cwdamage < 10.0)
						{
							format(stats_[0], sizeof(stats_[]), "000%.2f", cwdamage);
						}
						else if (cwdamage < 100.0)
						{
							format(stats_[0], sizeof(stats_[]), "00%.2f", cwdamage);
						}
						else if (cwdamage < 1000.0)
						{
							format(stats_[0], sizeof(stats_[]), "0%.2f", cwdamage);
						}else{
							format(stats_[0], sizeof(stats_[]), "%.2f", cwdamage);
						}

						if (cwinjuries < 10.0)
						{
							format(stats_[1], sizeof(stats_[]), "000%.2f", cwinjuries);
						}
						else if (cwinjuries < 100.0)
						{
							format(stats_[1], sizeof(stats_[]), "00%.2f", cwinjuries);
						}
						else if (cwinjuries < 1000.0)
						{
							format(stats_[1], sizeof(stats_[]), "0%.2f", cwinjuries);
						}else{
							format(stats_[1], sizeof(stats_[]), "%.2f", cwinjuries);
						}

						if (cwteamdamage < 10.0)
						{
							format(stats_[2], sizeof(stats_[]), "0%.2f", cwteamdamage);
						}else{
							format(stats_[2], sizeof(stats_[]), "%.2f", cwteamdamage);
						}

						if (cwinjuries > 0)
						{
							format(ratio_, sizeof(ratio_), "%.2f", cwdamage /cwinjuries);
						}else{
							ratio_ = "-";
						}
						format(string, sizeof(string), "      Damage: %s | Injuries: %s | Teammate damage: %s | Ratio: %s.", stats_[0], stats_[1], stats_[2], ratio_);
						
						fwrite(file, string);
						fwrite(file, "\r\n");
					}
				}
			}
			format(string, sizeof(string), "  Players %s:", ClanName[1]);
			//SendClientMessageToAll(COLOR_WHITE, string);
			fwrite(file, string);
			fwrite(file, "\r\n");
			for(i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i))
				{
					if (GetPVarInt(i, "Team") == 1)
					{
						for(new e = 0; e < 3; e++)
