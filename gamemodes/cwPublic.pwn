		if(Mutespec && GetPVarInt(playerid, "Team") == 2)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете отправлять личные сообщения, используйте командный чат !Text",
			"You can't send pm right now, use team chat !Text");
			return true;
		}
		if(GetPVarInt(playerid,"Hwmuted"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы заглушены и не можете говорить.", "You can't speak, you're muted.");
			return true;
		}
		if (pData[playerid][pMuted] > 0)
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Вы заглушены и не можете говорить", "You can't speak, you're muted.");
			return true;
		}
	    if (!cmdtext[5])
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Использование: /tpm [название команды] [сообщение]", "Use: /tpm [team name] [message]");
			return true;
		}
		new gap, len = strlen(cmdtext[5]);
		for(gap = 0; gap < len; gap++)
		{
		    if (cmdtext[5 +gap] == ' ')
		    {
		        break;
		    }
		}
		if (!cmdtext[5 +gap] || !cmdtext[6 +gap])
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Использование: /tpm [название команды] [сообщение]", "Use: /tpm [team name] [message]");
			return true;
		}
		new string[128];
		format(string, gap +1, "%s", cmdtext[5]);
		for(new i = 0; i < 2; i++)
	 	{
	 		if (strfind(ClanName[i], string, true) != -1)
	 		{
	 		    format(string, sizeof(string), "(Team PM) -> %s: %s", ClanName[i], cmdtext[6 +gap]);
				SendClientMessage(playerid, 0xB5FF4AAA, string);
				format(string, sizeof(string), "(Team PM) <- %s(%d): %s", name, playerid, cmdtext[6 +gap]);
				for(new e = 0; e < MAX_PLAYER_ID; e++)
				{
					if (IsPlayerConnected(e))
					{
						if (GetPVarInt(e, "Team") == i)
						{
							SendClientMessage(e, 0xB5FF4AAA, string);
							continue;
						}
					}
				}
				return true;
	 		}
		}
		SendClientMessageEx(playerid, COLOR_GREY, "Использование: /tpm [название команды] [сообщение]", "Use: /tpm [team name] [message]");
	    return true;
	}
	if (!strcmp(cmdtext, "/stat", true))
	{
		SendClientMessageEx(playerid, COLOR_GREY, "Использование: /stats <ID>", "Use: /stats <ID>");
		return true;
	}
	if (!strcmp(cmdtext, "/stats", true, 6))
	{
	    new PARAM, string[106];
		if (strlen(cmdtext) < 8)
		{
			PARAM = playerid;
		}else{
		    if (cmdtext[6] != ' ')
		    {
		        SendClientMessageEx(playerid, COLOR_GREY, "Использование: /stats <ID>", "Use: /stats <ID>");
		        return true;
		    }
		    format(string, 5, "%s", cmdtext[7]);
			PARAM = strval(string);
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY, "Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
		}
		new ratio[MAX_PLAYER_NAME];
		GetPlayerName(PARAM, ratio, MAX_PLAYER_NAME);
		format(string, sizeof(string), "  Статистика - %s(%d):", ratio, PARAM);
		new stringen[108];
		format(stringen, sizeof(stringen), "  Stats - %s(%d):", ratio, PARAM);
		SendClientMessageEx(playerid, COLOR_RED, string, stringen);
		SendClientMessageEx(playerid, COLOR_RED, " Полная:", " Overall:");
		if (GetPVarInt(PARAM, "cwdeath") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", GetPVarInt(PARAM, "cwkills") /float(GetPVarInt(PARAM, "cwdeath")));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Убийств: %d | Смертей: %d | Ратио: %s", GetPVarInt(PARAM, "cwkills"), GetPVarInt(PARAM, "cwdeath"), ratio);
	    format(stringen, sizeof(stringen), "Kills: %d | Deaths: %d | Ratio: %s", GetPVarInt(PARAM, "cwkills"), GetPVarInt(PARAM, "cwdeath"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
	    if (GetPVarInt(PARAM, "cwdeath") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", (GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "cwteamkills")) /float(GetPVarInt(PARAM, "cwdeath")));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Тимкиллы: %d | Убийства без TK: %d | Ратио TK: %s", GetPVarInt(PARAM, "cwteamkills"), GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "cwteamkills"), ratio);
	    format(stringen, sizeof(stringen), "TeamKills: %d | Kills without TK: %d | Ratio without TK: %s", GetPVarInt(PARAM, "cwteamkills"), GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "cwteamkills"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
	    
	    if (GetPVarFloat(PARAM, "cwinjuries") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", GetPVarFloat(PARAM, "cwdamage") /GetPVarFloat(PARAM, "cwinjuries"));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Урон: %.2f | Полученный урон: %.2f | Ратио: %s", GetPVarFloat(PARAM, "cwdamage"), GetPVarFloat(PARAM, "cwinjuries"), ratio);
	    format(stringen, sizeof(stringen), "Damage: %.2f | Injuries: %.2f | Ratio: %s", GetPVarFloat(PARAM, "cwdamage"), GetPVarFloat(PARAM, "cwinjuries"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
	    if (GetPVarFloat(PARAM, "cwinjuries") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", (GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "cwteamdamage")) /GetPVarFloat(PARAM, "cwinjuries"));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Урон по тиммейтам: %.2f | Урон без повреждения тиммейтов: %.2f | Ратио: %s", GetPVarFloat(PARAM, "cwteamdamage"), GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "cwteamdamage"), ratio);
	    format(stringen, sizeof(stringen), "Teammates damage: %.2f | Damage without team damage: %.2f | Ratio without team damage: %s", GetPVarFloat(PARAM, "cwteamdamage"), GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "cwteamdamage"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
	    
	    
	    SendClientMessageEx(playerid, COLOR_RED, " Текущий раунд:", " This round:");
	    if (GetPVarInt(PARAM, "cwdeath") -GetPVarInt(PARAM, "round_death") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", (GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "round_kills")) /float(GetPVarInt(PARAM, "cwdeath") -GetPVarInt(PARAM, "round_death")));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Убийства: %d | Смерти: %d | Ратио: %s", GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "round_kills"), GetPVarInt(PARAM, "cwdeath") -GetPVarInt(PARAM, "round_death"), ratio);
	    format(stringen, sizeof(stringen), "Kills: %d | Deaths: %d | Ratio: %s", GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "round_kills"), GetPVarInt(PARAM, "cwdeath") -GetPVarInt(PARAM, "round_death"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
	    if (GetPVarInt(PARAM, "cwdeath") -GetPVarInt(PARAM, "round_death") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", (GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "round_kills") -GetPVarInt(PARAM, "cwteamkills") +GetPVarInt(PARAM, "round_teamkills")) /float(GetPVarInt(PARAM, "cwdeath") -GetPVarInt(PARAM, "round_death")));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Тимкиллы: %d | Убийства без TK: %d | Ратио без TK: %s", GetPVarInt(PARAM, "cwteamkills") -GetPVarInt(PARAM, "round_teamkills"), GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "round_kills") -GetPVarInt(PARAM, "cwteamkills") +GetPVarInt(PARAM, "round_teamkills"), ratio);
	    format(stringen, sizeof(stringen), "TeamKills: %d | Kills without TK: %d | Ratio without TK: %s", GetPVarInt(PARAM, "cwteamkills") -GetPVarInt(PARAM, "round_teamkills"), GetPVarInt(PARAM, "cwkills") -GetPVarInt(PARAM, "round_kills") -GetPVarInt(PARAM, "cwteamkills") +GetPVarInt(PARAM, "round_teamkills"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
	    
	    if (GetPVarFloat(PARAM, "cwinjuries") -GetPVarFloat(PARAM, "round_injuries") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", (GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "round_damage")) /(GetPVarFloat(PARAM, "cwinjuries") -GetPVarFloat(PARAM, "round_injuries")));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Урон: %.2f | Полученный урон: %.2f | Ратио: %s", GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "round_damage"), GetPVarFloat(PARAM, "cwinjuries") -GetPVarFloat(PARAM, "round_injuries"), ratio);
	    format(stringen, sizeof(stringen), "Damage: %.2f | Injuries: %.2f | Ratio: %s", GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "round_damage"), GetPVarFloat(PARAM, "cwinjuries") -GetPVarFloat(PARAM, "round_injuries"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
	    if (GetPVarFloat(PARAM, "cwinjuries") -GetPVarFloat(PARAM, "round_injuries") > 0)
		{
			format(ratio, sizeof(ratio), "%.2f", (GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "round_damage") -GetPVarFloat(PARAM, "cwteamdamage") +GetPVarFloat(PARAM, "round_teamdamage")) /(GetPVarFloat(PARAM, "cwinjuries") -GetPVarFloat(PARAM, "round_injuries")));
		}else{
			ratio = "-";
		}
	    format(string, sizeof(string), "Урон по тиммейтам: %.2f | Урон без повреждения тиммейтов: %.2f | Ратио: %s", GetPVarFloat(PARAM, "cwteamdamage") -GetPVarFloat(PARAM, "round_teamdamage"), GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "round_damage") -GetPVarFloat(PARAM, "cwteamkills") +GetPVarFloat(PARAM, "round_teamkills"), ratio);
	    format(stringen, sizeof(stringen), "Teammates damage: %.2f | Damage without team damage: %.2f | Ratio without team damage: %s", GetPVarFloat(PARAM, "cwteamdamage") -GetPVarFloat(PARAM, "round_teamdamage"), GetPVarFloat(PARAM, "cwdamage") -GetPVarFloat(PARAM, "round_damage") -GetPVarFloat(PARAM, "cwteamdamage") +GetPVarFloat(PARAM, "round_teamdamage"), ratio);
	    SendClientMessageEx(playerid, COLOR_WHITE, string, stringen);
		return true;
	}
	if (!strcmp(cmdtext, "/switch", true))
	{
		new stringru[64] ,stringen[64];
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED 
		|| GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if (GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if (LockedTeams)
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Вы не можете присоединиться к команде во время матча.", "Joining teams is locked right now.");
			return true;
		}
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
		{
			new Float: x, Float: y, Float: z;
			GetPlayerPos(playerid, x, y, z);
			SetPlayerPos(playerid, x, y, z);
		}
		if (frz)
		{
			TogglePlayerControllable(playerid, false);
			SetPVarInt(playerid, "frz", true);
		}
		
		if (GetPVarInt(playerid, "Team") == 0)
		{
			SetPlayerTeamEx(playerid, TEAM_BLUE);
			format(stringru, sizeof(stringru), "%s(%d) перешел в команду %s.", 
			name, playerid, ClanName[1]);
			format(stringen, sizeof(stringen), "%s(%d) has moved to %s team.",
			name, playerid, ClanName[1]);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
		else if (GetPVarInt(playerid, "Team") == 1)
		{
			SetPlayerTeamEx(playerid, TEAM_GREEN);
	   		format(stringru, sizeof(stringru), "%s(%d) перешел в команду %s.", 
			name, playerid, ClanName[0]);
	   		format(stringen, sizeof(stringen), "%s(%d) has moved to %s team.",
			name, playerid, ClanName[0]);
	   		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
		else return SendClientMessageEx(playerid, COLOR_GREY, "Сейчас Вы не можете сменить команду.", "You can't change the team right now.");
		
		RefreshHud(playerid);
		ReSpawnPlayer(playerid);
		return 1;
	}
	if (cmdtext[1]) 
	{
		if (!strcmp(cmdtext[1], ClanName[0], true)) // /green
		{
			if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED
			|| GetPVarType(playerid, "Lounge"))
			{
				SendClientMessageEx(playerid, COLOR_GREY, "Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
				return true;
			}
		    if (LockedTeams && GetPlayerVirtualWorld(playerid) == 0)
		    {
		        SendClientMessageEx(playerid, COLOR_GREY, "Вы не можете присоединиться к команде во время матча.", "Joining teams is locked right now.");
		        return true;
		    }
		    if (GetPVarInt(playerid, "Team") == 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY, "Вы уже в этой команде.", "You are already in this team.");
				return true;
			}
			if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
		    {
		        new Float: x, Float: y, Float: z;
		        GetPlayerPos(playerid, x, y, z);
		        SetPlayerPos(playerid, x, y, z);
		    }
			if (GetPVarType(playerid, "Lounge"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
				return true;
			}
		    if (GetPVarInt(playerid, "Team") == 2)
		    {
				ResetPlayerWeapons(playerid);
		        if (GetPVarInt(playerid, "Specing") > -1)
		        {
		            SpecOff(playerid);
		        }
				else if (!frz)
				{
					RestorePlayerWeapons(playerid);
				}
		    }
		    if (frz)
		    {
				TogglePlayerControllable(playerid, false);
				SetPVarInt(playerid, "frz", true);
		    }
			
			SetPlayerTeamEx(playerid, TEAM_GREEN);
	 		
			new stringru[63];
	   		format(stringru, sizeof(stringru), "%s(%d) перешел в команду %s.",
			name, playerid, ClanName[0]);
	   		new stringen[60];
	   		format(stringen, sizeof(stringen), "%s(%d) has moved to %s team.",
			name, playerid, ClanName[0]);
	   		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			
			RefreshHud(playerid);
			ReSpawnPlayer(playerid);
		    return true;
		}
		if (!strcmp(cmdtext[1], ClanName[1], true)) // /blue
		{
			if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED
			|| GetPVarType(playerid, "Lounge"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
				return true;
			}
		    if (LockedTeams && GetPlayerVirtualWorld(playerid) == 0)
		    {
		        SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете присоединиться к команде во время матча.",
				"Joining teams is locked right now.");
		        return true;
		    }
		    if (GetPVarInt(playerid, "Team") == 1)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы уже в этой команде.", "You are already in this team.");
				return true;
			}
			if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
		    {
		        new Float: x, Float: y, Float: z;
		        GetPlayerPos(playerid, x, y, z);
		        SetPlayerPos(playerid, x, y, z);
		    }
		    if (GetPVarInt(playerid, "Team") == 2)
		    {
		        if (GetPVarInt(playerid, "Specing") > -1)
		        {
		            SpecOff(playerid);
		        }
		        else if (!frz)
				{
					RestorePlayerWeapons(playerid);
	    	    }
		    }
		    if (frz)
		    {
				TogglePlayerControllable(playerid, false);
				SetPVarInt(playerid, "frz", true);
		    }
			
			SetPlayerTeamEx(playerid, TEAM_BLUE);
	 		
			new stringru[63];
	   		format(stringru, sizeof(stringru),
			"%s(%d) перешел в команду %s.", name, playerid, ClanName[1]);
	   		new stringen[60];
	   		format(stringen, sizeof(stringen),
			"%s(%d) has moved to %s team.", name, playerid, ClanName[1]);
	   		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			
			RefreshHud(playerid);
			ReSpawnPlayer(playerid);
		    return true;
		}
	}
	if (!strcmp(cmdtext, "/spectator", true))
	{
	    if (GetPVarInt(playerid, "Team") == 2)
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Вы уже в этой команде.", "You are already in this team.");
			return true;
		}
		if (frz && GetPVarInt(playerid, "frz"))
    	{
    	    TogglePlayerControllable(playerid, true);
   			SetPVarInt(playerid, "frz", false);
 		}
		if (GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if (!Marker)
		{
			for(new i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i))
				{
				    if (GetPVarInt(i, "Team") < 2)
				    {
				        if (GetPVarInt(i, "Team") != GetPVarInt(playerid, "Team"))
				        {
							if (GetPVarInt(i, "Team") == 0)
							{
							    SetPlayerMarkerForPlayer(playerid, i, TCC[0]);
							}else{
							    SetPlayerMarkerForPlayer(playerid, i, TCC[1]);
							}
							SetPlayerMarkerForPlayer(i, playerid, TCC[2]);
						}
					}
				}
			}
		}
	    SetPVarInt(playerid, "Team", 2);
		SetPlayerColor(playerid, TCC[2]);
		SetPlayerTeam(playerid, 2);
		ResetPlayerWeapons(playerid);
		new stringru[55];
   		format(stringru, sizeof(stringru), "%s(%d) стал наблюдателем.", name, playerid);
   		new stringen[59];
   		format(stringen, sizeof(stringen), "%s(%d) has moved to Spectator team.", name, playerid);
   		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
   		CheckSpec(playerid);
		RefreshHud(playerid);
		ReSpawnPlayer(playerid);
	    return true;
	}
	if (!strcmp(cmdtext, "/respawn", true) || !strcmp(cmdtext, "/fr", true))
	{
		new stringen[64], stringru[64];
	    if (GetPlayerState(playerid) != PLAYER_STATE_ONFOOT || score[0] == Roundkills || score[1] == Roundkills)
	    {
	        SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
	        return true;
	    }
		if(GetPVarInt(playerid, "EventPart") > 0)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Недоступно во время ивента", "Not available during the event");
			return 1;
		}
	    if (GetPVarInt(playerid, "UnBug"))
		{
			return true;
		}
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if (GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if(GetPVarInt(playerid, "LastSync") > gettime())
		{
			format(stringen, sizeof(stringen), "You can use /respawn after %d seconds",
			GetPVarInt(playerid, "LastSync")-gettime());
			format(stringru, sizeof(stringru), "Вы сможете использовать /respawn через %d секунд",
			GetPVarInt(playerid, "LastSync")-gettime());
			SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
			return true;
		} else {
            SetPVarInt(playerid,"LastSync",gettime() + 60);
		}
		ReSpawnPlayer(playerid);
		format(stringru, sizeof(stringru), "%s(%d) заспавнился.", name, playerid);
		format(stringen, sizeof(stringen), "%s(%d) has respawned.", name, playerid);
		SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		return true;
	}
	if (!strcmp(cmdtext, "/hashtest", true))
	{
		ShowPlayerDialog(playerid, 162, DIALOG_STYLE_INPUT,
