		"Цвет ника изменен", "Nickname color changed");
		return true;
	}
	if (!strcmp(cmdtext, "/special", true))
	{
	    SendClientMessageEx(playerid, COLOR_GREY,
		"Использование: /special [beer | wine | sprunk | joint | dance 1-4]",
		"Use: /special [beer | wine | sprunk | joint | dance 1-4]");
	    return true;
	}
	if (!strcmp(cmdtext, "/special ", true, 9))
	{
	    if (GetPVarInt(playerid, "frz") || GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED)
	    {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы не можете использовать специальные действия пока Вы заморожены.",
			"You can't use special action while you're frozen.");
	        return true;
		}
	    if (!cmdtext[9])
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /special [beer | wine | sprunk | joint | dance 1-4]",
			"Use: /special [beer | wine | sprunk | joint | dance 1-4]");
			return true;
		}
		if (strfind("beer", cmdtext[9], true) != -1)
		{
		    SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DRINK_BEER);
		    return true;
		}
		if (strfind("wine", cmdtext[9], true) != -1)
		{
		    SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DRINK_WINE);
		    return true;
		}
		if (strfind("sprunk", cmdtext[9], true) != -1)
		{
		    SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DRINK_SPRUNK);
		    return true;
		}
		if (strfind("joint", cmdtext[9], true) != -1)
		{
		    SetPlayerSpecialAction(playerid, SPECIAL_ACTION_SMOKE_CIGGY);
			return true;
		}
		if (!strcmp("dance", cmdtext[9], true, 5))
		{
		    new PARAM = strval(cmdtext[14]);
		    if (0 < PARAM < 5)
		    {
		    	SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DANCE1 +PARAM -1);
		    	return true;
			}
		}
		SendClientMessageEx(playerid, COLOR_GREY,
		"Использование: /special [beer | wine | sprunk | joint | dance 1-4]",
		"Use: /special [beer | wine | sprunk | joint | dance 1-4]");
	    return true;
	}
	if (!strcmp(cmdtext, "/sprunk", true))
	{
		if(GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_CUFFED){
			SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DRINK_SPRUNK);
		}
		return true;
	}
	if (!strcmp(cmdtext, "/wine", true))
	{
		if(GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_CUFFED){
			SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DRINK_WINE);
		}
		return true;
	}
	if (!strcmp(cmdtext, "/beer", true))
	{
		if(GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_CUFFED){
			SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DRINK_BEER);
		}
		return true;
	}
