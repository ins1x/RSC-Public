	if (!strcmp("/findmap", cmd, true))
	{
		tmp = strtok(cmdtext, idx);
		if(!strlen(tmp))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /findmap <часть названия карты>", "Use: /findmap <part of map name>");
			return true;
		}
		
		if(strlen(tmp) < 2 || strlen(tmp) > 10)
		{
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Некорректное значение (2 - 10 символов)", "Incorrect value (2 - 10 symbols)");
		}
		
		new results = 0;
		new tmpstr[64];
		for(new map = 0; map < MAX_MAPID; map++)
		{
			if(strfind(MapNames[map], tmp, true) != -1)
			{
				format(tmpstr, sizeof(tmpstr), "%d. {AFAFAF}%s", map, MapNames[map]);
				SendClientMessage(playerid, -1, tmpstr);
				results++;
			}
		}
		format(tmpstr, sizeof(tmpstr), "Found results: %d", results);
		SendClientMessage(playerid, -1, tmpstr);
		return true;
	}
	if (!strcmp(cmdtext, "/map", true) || !strcmp(cmdtext, "/maps", true)
