			}
			if(!WorldModerator[playerid] && World[worldid][wGamemode] == GAMEMODE_WOT)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Функция недоступна в текущем режиме игры.",
				"The function is not available in the current game mode");
			}
		}
		
		//SendNotify(playerid, "Press key ~g~2 ~w~for autotune", 3);
		
		if(!isnumeric(tmp)) 
		{
			for(new i = 0; i < sizeof(VehicleNames); i++)
			{
				if(!strcmp(tmp, VehicleNames[i], true)) 
				{
					SpawnPlayerVehicle(playerid, VehicleIds[i]);
					return true;
				}
			}
		} else {
			SpawnPlayerVehicle(playerid, id);
			return true;
		}
		return true;
	}
