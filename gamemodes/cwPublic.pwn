	if(dialogid == 309) // WORLD_TEAMS
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			
			if(worldid != 0 && !WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
			
			switch(listitem)
			{
				case 4:
				{
					foreach(Player, i)
					{
						if (GetPlayerVirtualWorld(i) == 0)
						{
							SetPVarInt(i, "Team", 3);
							SetPlayerColor(i, COLOR_WHITE);
							SetPlayerTeam(i, 3);
						}
					}
					SendClientMessageToVirtualWorld(0, COLOR_GREY,
					"Все игроки были перемещены в сток команду.",
					"All players have been moved to stock team.");
					SendNotify(playerid, "~r~Reset ~y~teams", 3);
					WORLD_TEAMS(playerid);
				}
			}
		}
	}
	// if(dialogid == 310) // WORLD_ 
	if(dialogid == 311)
	{
		if(response)
		{
			if(!strlen(inputtext)) return WORLD_MANAGE(playerid);
			new worldid = GetPlayerVirtualWorld(playerid);
			if(strval(inputtext) >= 1 && strval(inputtext) <= 200)
			{
				World[worldid][wGamehealth] = strval(inputtext);
				foreach(Player, i)
				{
					if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid))
					{
						ReSpawnPlayer(i);
					}
				}
			} else {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Неверное значение", "Incorrect value");
			}
		}
		else WORLD_HEALTH(playerid);
	}
	if(dialogid == 312) //WORLD_HEALTH
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			
			switch(listitem)
			{
				case 0: 
				{
					World[worldid][wGamehealth] = 100;
					WORLD_HEALTH(playerid);
				}
				case 1: // 100hp + 100arm
				{
					World[worldid][wGamehealth] = 200;
					WORLD_HEALTH(playerid);
				}
				case 2: // oneshot
				{
					World[worldid][wGamehealth] = 15;
					WORLD_HEALTH(playerid);
				}
				case 3: //custom
				{
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 311, DIALOG_STYLE_INPUT,
						"Change world default health",
						"{FFFFFF}Enter world default health [0-200]:",
						"Select", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 311, DIALOG_STYLE_INPUT,
						"Смена кол-ва хп и брони",
						"{FFFFFF}Введите количество хп и брони по умолчанию [0-200]:",
						"Выбрать", "Отмена");
					}
				}
			}
		}
		else WORLD_MANAGE(playerid);
	}
	if(dialogid == 313)
	{
		if(response)
		{
			switch(listitem)
			{
				case 0:
				{
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 314, DIALOG_STYLE_INPUT,
