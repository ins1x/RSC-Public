	if(dialogid == 339) // bot weaponid
	{
		if(response)
		{
			#if defined _FCNPC_included
				if(!strlen(inputtext)) return WORLD_BOTS(playerid);
				new weaponid = strval(inputtext);
				new worldid = GetPlayerVirtualWorld(playerid);
				if(!WorldModerator[playerid])
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Вы не модератор мира!", "You are not moderator!");
					return true;
				}
				
				if(IsBulletWeapon(weaponid))
				{
					World[worldid][wBotWeaponid] = weaponid;
					for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
					{
						if(FCNPC_IsValid(npcid) && FCNPC_GetVirtualWorld(npcid) == worldid)
						{
							FCNPC_SetWeapon(npcid, weaponid);
						}
					}
					if(weaponid == 26) {
						World[worldid][wBotShootrate] = World[worldid][wBotShootrate] * 2;
					} else if(weaponid == 24) {
						World[worldid][wBotShootrate] = World[worldid][wBotShootrate] / 3;
					}
					WORLD_BOTS(playerid);
				} else {
					SendClientMessageEx(playerid, COLOR_GREY,
					"Некорректный выбор оружия", "Incorrect choice of weapons");
					WORLD_BOTS(playerid);
				}
			#else
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно. На сервере не подключена система NPC",
				"Unavailable. The NPC system is not connected on the server");
				WORLD_BOTS(playerid); 
			#endif
		} else {
			WORLD_BOTS(playerid);
		}
	}
	if(dialogid == 340) // afkmessage
	{
		new stringen[100], stringru[100];
		new pid = GetPVarInt(playerid, "afkmessageid");
		
		if(response)
		{
			if(pid != INVALID_PLAYER_ID && IsPlayerConnected(pid))
			{
				format(stringru, sizeof(stringru),
				"%s(%d) подтвердил отправленный вами диалог",
				PlayerName(pid), pid);
				format(stringen, sizeof(stringen),
				"%s(%d) confirmed the dialog you sent",
				PlayerName(pid), pid);
				SendClientMessageEx(pid, COLOR_GREY, stringru, stringen);
			}
		} else {
			if(pid != INVALID_PLAYER_ID && IsPlayerConnected(pid))
			{
				format(stringru, sizeof(stringru),
				"%s(%d) отклонил отправленный вами диалог",
				PlayerName(pid), pid);
				format(stringen, sizeof(stringen),
				"%s(%d) reject the dialog you sent",
				PlayerName(pid), pid);
				SendClientMessageEx(pid, COLOR_GREY, stringru, stringen);
			}
		}
		DeletePVar(playerid, "afkmessageid");
	}
