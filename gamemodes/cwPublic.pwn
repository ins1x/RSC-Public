stock GetAveragePacketloss()
{
	//average players ploss
	new players,ploss;
	for(new i = 0; i < _MAX_PLAYERS; i++)
	{
		if (IsPlayerConnected(i))
		{
			ploss+=NetStats_PacketLossPercent(i);
			players++;
		}
	}
	if (players > 1) return ploss/players;
	else return 0;
}

// rapidfire ac
stock GetTickCountDifference(newtick, oldtick)
{
	if (oldtick < 0 && newtick >= 0) {
		return newtick - oldtick;
	} else if (oldtick >= 0 && newtick < 0 || oldtick > newtick) {
		return (cellmax - oldtick + 1) - (cellmin - newtick);
	}

	return newtick - oldtick;
}

stock Spawnkill(playerid)
{
	// Simple antispawnkill protection
	// This stock part of OnPlayerSpawn public
	// Set SPAWN_PROTECT == true, in order to enable this option
	if(GetPVarInt(playerid, "Team") != 2) //disable for spectators
	{
		#if defined _YSF_included
			// fixes players getting stuck at spawn
			TogglePlayerGhostMode(playerid, true);
		#endif
		onspawnprotect[playerid] = true;
		SetPlayerHealth(playerid, 99999);
		if(GameHealth > 100) SetPlayerArmour(playerid, 99999);
		#if defined _nex_ac_included
			new Float:sHeal, Float:sArm;
			AntiCheatGetHealth(playerid, sHeal);
			AntiCheatGetArmour(playerid, sArm);
		#endif
		SpawnKill_Timer[playerid] = SetTimerEx("RestoreHealth",
		SPAWNKILL_DELAY*1000, 0, "d", playerid);
	}
	return 1;
}

stock RefreshHud(playerid)
{	
	// Only refresh default HUD, without change player settings
	if(pData[playerid][pHud] > 0)
	{
		if(pData[playerid][pFpsbar] > 0 ) PlayerTextDrawShow(playerid, FPSBAR[playerid]);
		if(pData[playerid][pHpbar] > 0) PlayerTextDrawShow(playerid, PlayerHp[playerid]);
		if(pData[playerid][pHpbar] > 0) PlayerTextDrawShow(playerid, PlayerArmour[playerid]);
		PlayerTextDrawShow(playerid, Commands[playerid]);
		PlayerTextDrawShow(playerid, TDlagmode[playerid]);
	} else {
		PlayerTextDrawHide(playerid, FPSBAR[playerid]);
		PlayerTextDrawHide(playerid, Commands[playerid]);
		PlayerTextDrawHide(playerid, TDlagmode[playerid]);
		PlayerTextDrawHide(playerid, PlayerHp[playerid]);
		PlayerTextDrawHide(playerid, PlayerArmour[playerid]);
	}
}

public HudToggle(playerid, bool:toggle)
{
	// Allows you to control the display of the main hud
	if(playerid == INVALID_PLAYER_ID || playerid > _MAX_PLAYERS) return 0;
	if(!toggle)
	{
		// Disabled all additional textdraws
		PlayerTextDrawHide(playerid, FPSBAR[playerid]);
		PlayerTextDrawHide(playerid, Commands[playerid]);
		PlayerTextDrawHide(playerid, TDlagmode[playerid]);
		PlayerTextDrawHide(playerid, PlayerHp[playerid]);
		PlayerTextDrawHide(playerid, PlayerArmour[playerid]);
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			SetPVarInt(playerid, "ShowKDtxd", -1);
			SetPVarInt(playerid, "ShowScoretxd", -1);
			SetPVarInt(playerid, "ShowTimetxd", -1);
			PlayerTextDrawHide(playerid, TDkdstats[playerid]);
			PlayerTextDrawHide(playerid, TDscore[playerid]);
			PlayerTextDrawHide(playerid, TDtime[playerid]);
		}
		pData[playerid][pHud] = 0;
		pData[playerid][pFpsbar] = 0;
		pData[playerid][pHpbar] = 0;
	} else {
		// Enabled all additional textdraws
		PlayerTextDrawShow(playerid, FPSBAR[playerid]);
		PlayerTextDrawShow(playerid, PlayerHp[playerid]);
		PlayerTextDrawShow(playerid, PlayerArmour[playerid]);
		PlayerTextDrawShow(playerid, Commands[playerid]);
		PlayerTextDrawShow(playerid, TDlagmode[playerid]);
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			SetPVarInt(playerid, "ShowKDtxd", 1);
			SetPVarInt(playerid, "ShowScoretxd", 1);
			SetPVarInt(playerid, "ShowTimetxd", 1);
			PlayerTextDrawShow(playerid, TDkdstats[playerid]);	
			PlayerTextDrawShow(playerid, TDscore[playerid]);	
			PlayerTextDrawShow(playerid, TDtime[playerid]);	
		}
		pData[playerid][pHud] = 1;
		pData[playerid][pFpsbar] = 1;
		pData[playerid][pHpbar] = 1;
	}
	return 1;
}

stock CwModeToggle(playerid = -1) // cwswitch ( cwmode switch )
{
	/*	Auto-Switch on-off game to CW mode	*/
	new string[256], stringen[128];
	if (CWmode)
	{
		// Round statistics record is updated automatically every round
		ReportLog(true);
		// if not default clanname save report
		//if (strfind("Green", ClanName[0], true) == -1)
		WriteCWResults(); 
		
		// disable cw mode options
		CWmode = false;
		freeze_score = false;
		LockedTeams = false;
		fpsunlock = true;
		Round = 0;
		//AConly = false;
		frz = false;
		speconly = false;
		//Roundkills = 9999;
		// Restore AC settings
		AC_DAMAGEWARN_KICKAFTER = 4;
		#if defined _nex_ac_included
			NEXAC_DETECT_ACTION = 2;
		#endif
		
		SetGameModeText("CW/TG | Sandbox");
		// drop cw players data table
		for (new p = 0; p < _MAX_PLAYERS; p++) CwData[p] = NULL_CwData;
		
		// Show Airplanes
		for (new id = 0; id < 13; id++)
		{
			new Float:x, Float:y, Float:z;
			GetDynamicObjectPos(airplanes[id], x,y,z);
			SetDynamicObjectPos(airplanes[id], x,y,z+1000);
		}
		
		foreach(Player, i)
		{	
			if(GetPlayerVirtualWorld(i) == 0)
			{
				// Reset score in money hud
				ResetPlayerMoney(i);
				
				// Hide help textdraw
				CwHelpToggle(i, false);
				
				// Restore attaches
				if(HideAttachesOnCW)
				{
					// Player Attachments
					if(pData[i][pAttachSlot0] != -1) {
						PlayerAttachments(i, 0, pData[i][pAttachSlot0], false);
					}
					if(pData[i][pAttachSlot1] != -1) {
						PlayerAttachments(i, 1, pData[i][pAttachSlot1], false);
					}
					if(pData[i][pAttachSlot2] != -1) {
						PlayerAttachments(i, 2, pData[i][pAttachSlot2], false);
					}
					if(pData[i][pAttachSlot3] != -1) {
						PlayerAttachments(i, 3, pData[i][pAttachSlot3], false);
					}
				}
				if(GetPVarInt(i, "Team") != 2)
				{
					PlayerTextDrawHide(i, TDbigscore[playerid]);
				}
			}
		}
		
		if(playerid != -1 && playerid != INVALID_PLAYER_ID)
		{
			format(string, sizeof(string), "%s(%d) отключил clan war режим.",
			PlayerName(playerid), playerid);
			format(stringen, sizeof(stringen), "%s(%d) has switched off clan war mode.",
			PlayerName(playerid), playerid);
			SendClientMessageToVirtualWorld(0, COLOR_GREY, string, stringen);
			SendClientMessageEx(playerid, COLOR_GREY,
			"Не забудьте восстановить дефолтные настройки раунда! {FF0000}/default",
			"Don't forget to restore default round settings! {FF0000}/default");
		} else {
			format(string, sizeof(string), "Clan war режим был автоматически отключен");
			format(stringen, sizeof(stringen), "Сlan war mode auto-switched off");
			SendClientMessageToVirtualWorld(0, COLOR_GREY, string, stringen);
		}
		
		for(new i = GetVehiclePoolSize() +1; --i != 0;) 
		{
			if(GetVehicleVirtualWorld(i) == 66666) SetVehicleVirtualWorld(i, 0);
		}
	} else {
		// Start clan-war mode 
		CWmode = true;
		LockedTeams = true;
		Round = 1;
		FirstBlood = true;
		ResetGameScore(playerid, true, true);
		//Roundkills = 30;
		AC_DAMAGEWARN_KICKAFTER = 666;
		
		new gamemode[48];
		format(gamemode, sizeof(gamemode), "[%s]vs[%s]", ClanName[0], ClanName[1]);
		SetGameModeText(gamemode);
	
		for(new i = GetVehiclePoolSize() +1; --i != 0;)
		{
			if(GetVehicleVirtualWorld(i) == 0) SetVehicleVirtualWorld(i, 66666);
		}
		
		// Hide Airplanes
		for (new id = 0; id < 13; id++)
		{
			new Float:x, Float:y, Float:z;
			GetDynamicObjectPos(airplanes[id], x,y,z);
			SetDynamicObjectPos(airplanes[id], x,y,z-1000);
		}
		
		// Hide all players attaches
		if(HideAttachesOnCW)
		{
			foreach(Player, i)
			{
				if(GetPlayerVirtualWorld(i) == 0)
				{
					for(new s=0; s<MAX_PLAYER_ATTACHED_OBJECTS; s++)
					{
						if(IsPlayerAttachedObjectSlotUsed(i, s)) {
							RemovePlayerAttachedObject(i, s);
						}
					}
				}
			}
		}
		
		#if defined _nex_ac_included
			NEXAC_DETECT_ACTION = 1;
		#endif

		new lagcomp_State[18], TK_State[4];
		#if defined _INC_WEAPON_CONFIG
			if(lagcomp) {
				if(SYNCMODE == 0) lagcomp_State = "Default Skinshot";
				if(SYNCMODE == 2) lagcomp_State = "RSC Skinshot";
			} else {
				if(SYNCMODE == 1) lagcomp_State = "Lagshot"; else lagcomp_State = "Lagshot";
			}
		#else 
			if(lagcomp) lagcomp_State = "Skinshot"; else lagcomp_State = "Lagshot";
		#endif
		if(AntiTK) TK_State = "On"; else TK_State = "Off"; 
		
		if(playerid != -1 && playerid != INVALID_PLAYER_ID)
		{
			CwHelpToggle(playerid, true);
			format(string, sizeof(string), "%s(%d) включил clan war режим.",
			PlayerName(playerid), playerid);
			format(stringen, sizeof(stringen), "%s(%d) has switched on clan war mode.",
			PlayerName(playerid), playerid);
			SendClientMessageToVirtualWorld(0, COLOR_GREY, string, stringen);
		}

		foreach(Player, i)
		{
			if(GetPlayerVirtualWorld(i) == 0)
			{
				new tmpstr[MAX_PLAYER_NAME];
				format(tmpstr, sizeof(tmpstr), "%s", PlayerName(i));
				CwData[i][cwNickname] = tmpstr;
				CwData[i][cwTeam] = GetPVarInt(i, "Team");
				CwData[i][cwPlayerSkin] = GetPlayerSkin(i);
				ResetPlayerMoney(i);
				
				if(GetPVarInt(i, "Team") != 2)
				{
					if(GetPlayerVirtualWorld(i) == 0) PlayerTextDrawShow(i, TDbigscore[playerid]);
					if(IsPlayerAFK(i))
					{
						format(stringen, sizeof(stringen), "AFK %s(%d)", PlayerName(i), i);
						SendClientMessageToVirtualWorld(0, COLOR_RED, stringen, stringen);
					} else {
						if(GetPlayerFPS(i) > 110)
						{
							format(stringen, sizeof(stringen), "FPS of %s(%d) - %i",
							PlayerName(i), i, GetPlayerFPS(i));
							SendClientMessageToVirtualWorld(0, COLOR_RED, stringen, stringen);
						}
						if(GetPlayerFPS(i) < 40)
						{
							format(stringen, sizeof(stringen), "Low FPS lager %s(%d)",
							PlayerName(i), i);
							SendClientMessageToVirtualWorld(0, COLOR_RED, stringen, stringen);
						}
						if(GetPlayerPing(i) > 200)
						{
							format(stringen, sizeof(stringen), "High PING lager %s(%d) - %i",
							PlayerName(i), i, GetPlayerPing(i));
							SendClientMessageToVirtualWorld(0, COLOR_RED, stringen, stringen);
						}
						if(NetStats_GetConnectedTime(i)/60000 < 5 &&
						NetStats_PacketLossPercent(i) > 5.0)
						{
							format(stringen, sizeof(stringen), "High Packet Loss lager %s(%d) - %i",
							PlayerName(i), i, NetStats_PacketLossPercent(i));
							SendClientMessageToVirtualWorld(0, COLOR_RED, stringen, stringen);
						}
						#if defined _sampcac_included
						if(CAC_GetStatus(i) == 0)
						{
							format(stringen, sizeof(stringen), "No Anticheat %s(%d)",
							PlayerName(i), i);
							SendClientMessageToVirtualWorld(0, COLOR_RED, stringen, stringen);
						}
						#endif
					}
				}
				
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
			}
		}
		
		new year,month,day,hour,minute,second;
		getdate(year, month, day);
		gettime(hour,minute,second);
		format(reportfilename, sizeof(reportfilename), "reports/[%s]vs[%s]_%d.%d.%d_%d.%d.txt",
		ClanName[0], ClanName[1], year, month, day, hour, minute);
		new File: file = fopen(reportfilename, io_write);
		if (file) // look ShowGameSettings()
		{
			new 
				NEXAC_DETECT_ACTION_State[24],
				KICK_LAGERS_State[24],
				ServerLock_state[32]
			;
		
			#if defined _nex_ac_included
			if(!NEXAC_DETECT_ACTION) NEXAC_DETECT_ACTION_State = "Off";
			else NEXAC_DETECT_ACTION_State = "On";
			#else
			NEXAC_DETECT_ACTION_State = "Off";
			#endif
			
			switch(ServerLock)
			{
				case 0: ServerLock_state = "NoLimits";
				case 1: ServerLock_state = "Registered";
				case 2: ServerLock_state = "Verifed";
				case 3: ServerLock_state = "Teammates";
				case 4: ServerLock_state = "AConly";
			}
			
			if(KICK_LAGERS == 0) KICK_LAGERS_State = "Off";
			else if (KICK_LAGERS == 1) KICK_LAGERS_State = "Warning";
			else if (KICK_LAGERS == 2) KICK_LAGERS_State = "Kick";
			else if (KICK_LAGERS == 3) KICK_LAGERS_State = "Movespec";
		
			fwrite(file, "RSC CW/TG gamemode by Russian Sawn-off Community\r\n");
			format(string, sizeof(string), "[%s] vs [%s] %d.%d.%d %d:%d\r\n",
			ClanName[0], ClanName[1], year, month, day, hour, minute);
			fwrite(file, string);
			
			format(stringen, sizeof(stringen),"\r\nOptions:\r\n");
			fwrite(file, stringen);
			
			format(stringen, sizeof(stringen),"Map: %s, Hitbox: %s, Round points: %d\r\n",
			MapNames[Map], (lagcomp) ? ("Skinshot") : ("Lagshot"), Roundkills);
			fwrite(file, stringen);
			
			format(stringen, sizeof(stringen),
			"Anti-TK: %s, KillHeal: %s, GameHealth: %d\r\n",
			(AntiTK) ? ("On") : ("Off"),
			(HPDead) ? ("On") : ("Off"), GameHealth);
			fwrite(file, stringen);
			
			format(stringen, sizeof(stringen),
			"ServerAC: %s, ClientAC: %s, ServerLock: %s, AntiLag: %s\r\n",
			NEXAC_DETECT_ACTION_State,
			(AConly) ? "On" : "Off",
			ServerLock_state, KICK_LAGERS_State);
			fwrite(file, stringen);
			
			fclose(file);
		}

		SendClientMessageToVirtualWorld(0, COLOR_GREY,
		"Во время cw любой игрок может поставить матч на паузу с помощью команды {FF0000}/frz",
		"At cw every player can freeze the match by command {FF0000}/frz");
		
		if(playerid != -1 && playerid != INVALID_PLAYER_ID)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"После того как все опции выставлены, запустите матч с помощью команды {00FF00}/start",
			"After all options are set, start the match with the command {00FF00}/start");
		}
		
	}
}

stock ResetGameScore(playerid, allscore = false, silent = false)
{
	/* Reset game score */
	if (score[0] == Roundkills || score[1] == Roundkills)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Сейчас Вы не можете использовать данную функцию.",
		"You can't use this function right now.");
		return true;
	}
	if(allscore)
	{
		score[0] = 0;
		score[1] = 0;
		soucet[0] = 0;
		soucet[1] = 0;
		RoundScore[0] = 0;
		RoundScore[1] = 0;

		if(!silent)
		{
			new stringru[100], stringen[100];
			format(stringru, sizeof(stringru), "%s(%d) обнулил общий счет и показатели всех игроков.", PlayerName(playerid), playerid);
			format(stringen, sizeof(stringen), "%s(%d) has reset everything.", PlayerName(playerid), playerid);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
		
		foreach(Player, i)
		{
			if(GetPlayerVirtualWorld(i) == 0)
			{
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
				SetPVarInt(i, "cwkills", 0);
				SetPVarInt(i, "cwdeath", 0);
				SetPVarInt(i, "cwteamkills", 0);
				SetPVarFloat(i, "cwdamage", 0.0);
				SetPVarFloat(i, "cwinjuries", 0.0);
				SetPVarFloat(i, "cwteamdamage", 0.0);
				SetPVarInt(i, "round_kills", 0);
				SetPVarInt(i, "round_death", 0);
				SetPVarInt(i, "round_teamkills", 0);
				SetPVarFloat(i, "round_damage", 0.0);
				SetPVarFloat(i, "round_injuries", 0.0);
				SetPVarFloat(i, "round_teamdamage", 0.0);
				SetPlayerScore(i, 0);
				ResetPlayerMoney(i);
			}
		}
	} else {
		score[0] = 0;
		score[1] = 0;
		if(!silent)
		{
			new stringru[47], stringen[49];
			format(stringru, sizeof(stringru), 
			"%s(%d) обнулил счет в текущем раунде.", PlayerName(playerid), playerid);
			format(stringen, sizeof(stringen), 
			"%s(%d) has reset the round score.", PlayerName(playerid), playerid);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
		if(CWmode)
		{
			foreach(Player, i)
			{
				if(GetPlayerVirtualWorld(i) == 0)
				{
					SetPVarInt(i, "round_kills", GetPVarInt(i, "cwkills"));
					SetPVarInt(i, "round_death", GetPVarInt(i, "cwdeath"));
					SetPVarInt(i, "round_teamkills", GetPVarInt(i, "cwteamkills"));
					SetPVarFloat(i, "round_damage", GetPVarFloat(i, "cwdamage"));
					SetPVarFloat(i, "round_injuries", GetPVarFloat(i, "cwinjuries"));
					SetPVarFloat(i, "round_teamdamage", GetPVarFloat(i, "cwteamdamage"));
				}
			}
		}
	}
	RefreshScore();
	return 1;
}

stock ShowGameSettings()
{
	if(CWmode)
	{
		new 
			string[128],
			NEXAC_DETECT_ACTION_State[24],
			KICK_LAGERS_State[24],
			ServerLock_state[32]
		;
		
		#if defined _nex_ac_included
		if(!NEXAC_DETECT_ACTION) NEXAC_DETECT_ACTION_State = "Off";
		else NEXAC_DETECT_ACTION_State = "On";
		#else
		NEXAC_DETECT_ACTION_State = "Off";
		#endif
		
		switch(ServerLock)
		{
			case 0: ServerLock_state = "NoLimits";
			case 1: ServerLock_state = "Registered";
			case 2: ServerLock_state = "Verifed";
			case 3: ServerLock_state = "Teammates";
			case 4: ServerLock_state = "AConly";
		}
		
		if(KICK_LAGERS == 0) KICK_LAGERS_State = "Off";
		else if (KICK_LAGERS == 1) KICK_LAGERS_State = "Warning";
		else if (KICK_LAGERS == 2) KICK_LAGERS_State = "Kick";
		else if (KICK_LAGERS == 3) KICK_LAGERS_State = "Movespec";
		
		format(string, sizeof(string),"{FFFFFF}Game started! %s[%s]{FFFFFF} vs %s[%s]",
		THC[0], ClanName[0], THC[1], ClanName[1]);
		SendClientMessageToVirtualWorld(0, COLOR_GREY, string, string);
		SendClientMessageToVirtualWorld(0, COLOR_GREY, "Options:", "Options:");
		format(string, sizeof(string),"Map: %s, Hitbox: %s, Round points: %d",
		MapNames[Map], (lagcomp) ? ("Skinshot") : ("Lagshot"), Roundkills);
		SendClientMessageToVirtualWorld(0, COLOR_GREY, string, string);
		
		format(string, sizeof(string),
		"Anti-TK: %s, KillHeal: %s, GameHealth: %d",
		(AntiTK) ? ("On") : ("Off"),
		(HPDead) ? ("On") : ("Off"), GameHealth);
		SendClientMessageToVirtualWorld(0, COLOR_GREY, string, string);
		
		format(string, sizeof(string),
		"ServerAC: %s, ClientAC: %s, ServerLock: %s, AntiLag: %s",
		NEXAC_DETECT_ACTION_State,
		(AConly) ? "On" : "Off",
		ServerLock_state, KICK_LAGERS_State);
		SendClientMessageToVirtualWorld(0, COLOR_GREY, string, string);
	}
}

stock AConlyToggle(playerid)
{
	#if defined _sampcac_included
	new stringru[128], stringen[128];
	new major, minor, patch;
	CAC_GetClientVersion(playerid, major, minor, patch);
	if(!AConly)
	{
		AConly = true;
		LockedTeams = true;
		//if(!ServerLock) ServerLock = 4;
		
		format(stringru, sizeof(stringru), "%s(%d) включил режим AC only.",
		PlayerName(playerid), playerid);
		format(stringen, sizeof(stringen), "%s(%d) has enabled AC only mode.",
		PlayerName(playerid), playerid);
		SendClientMessageToVirtualWorld(0, COLOR_GREY, stringru, stringen);
		
		//format(string, sizeof(string), "(id:%d)%s - No SAMPCAC ", i, PlayerName(i));
		foreach(Player, i)
		{
			if(GetPlayerVirtualWorld(i) == 0)
			{
				if(CAC_GetStatus(i) == 0 || minor != 10) 
				{
					GameTextForPlayer(i, "~w~NO ~r~AC", 3000, 4);
					SetPlayerTeamEx(i, TEAM_SPEC);
					ReSpawnPlayer(i);
				}
			}
		}
		
		SendClientMessageToVirtualWorld(0, COLOR_GREY,
		"Все игроки без античита перемещены в наблюдатели",
		"All players without anti-cheat have been moved to spectators");
	} else {
		AConly = false;
		//if(ServerLock == 4) ServerLock = 0;
		if(!CWmode && LockedTeams) LockedTeams = false;
		
		format(stringru, sizeof(stringru), "%s(%d) отключил режим AC only.",
		PlayerName(playerid), playerid);
		format(stringen, sizeof(stringen), "%s(%d) has disabled AC only mode.",
		PlayerName(playerid), playerid);
		SendClientMessageToVirtualWorld(0, COLOR_GREY, stringru, stringen);
	}
    new query[128];
    format(query, sizeof(query),
	"UPDATE Settings SET Value = %i WHERE (Option = 'ac_only')", AConly);
	db_query(dbcore, query);
	#else
	SendClientMessage(playerid, COLOR_RED,
	"This option requred SAMPCAC. Load SAMPCAC before!!");
	#endif
}
					
stock DefaultGameSettings()
{
	/* Pre-set default round settings. */
	CWmode = false;
	frz = false;
	freeze_score = false;
	LockedTeams = false;
	speconly = false;
	//ServerLock = 0;
	Round = 0;
	Roundkills = 9999;
	FirstBlood = false;
	HPDead = true;
	AutosetClanTags = false;
	MaxRounds = 0;
	//AConly = false;
	Mutespec = false;
	Spawnlock = true;
	#if defined _nex_ac_included
		NEXAC_DETECT_ACTION = 2;
	#endif
	// Reload lager detection options from server config file
	new DBResult: query;
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'max_fps'");
	if(db_num_rows(query))
	{
		MAX_FPS = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		MAX_FPS = 110;
	}
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'max_ping'");
	if(db_num_rows(query))
	{
		MAX_PING = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		MAX_PING = 400;
	}
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'min_fps'");
	if(db_num_rows(query))
	{
		MIN_FPS = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		MIN_FPS = 25; 
	}
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'max_packetloss'");
	if(db_num_rows(query))
	{
		MAX_PACKETLOSS = db_get_field_float(query, 0);
		db_free_result(query);
	} else {
		MAX_PACKETLOSS = 20.0;
	}
	
	// Reload ac detection options from server config file
	AC_SPRINTHOOK_PROTECT = true;
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'ac_cbug'");
	if(db_num_rows(query))
	{
		AC_CBUG_PROTECT = db_get_field_int(query, 0);
		db_free_result(query);
		#if defined _sampcac_included
		if(AC_CBUG_PROTECT)	CAC_SetGlitchStatus(CAC_GLITCH__CROUCHBUG, 0);
		else CAC_SetGlitchStatus(CAC_GLITCH__CROUCHBUG, 1);						
		#endif
	} else {
		AC_CBUG_PROTECT = false;
		#if defined _sampcac_included
			CAC_SetGlitchStatus(CAC_GLITCH__CROUCHBUG, 1);
		#endif
	}
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'ac_autoscroll'");
	if(db_num_rows(query))
	{
		AC_AUTOSCROLL = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		AC_AUTOSCROLL = false;
	}
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'ac_slide'");
	if(db_num_rows(query))
	{
		AC_ANTISLIDE_PROTECT = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		AC_ANTISLIDE_PROTECT = false;
	}
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'fpsunlock'");
	if(db_num_rows(query))
	{
		fpsunlock = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		fpsunlock = true;
	}
	
	query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'spawn_protect'");
	if(db_num_rows(query))
	{
		SPAWN_PROTECT = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		SPAWN_PROTECT = true;
	}
	
    query = db_query(dbcore, "SELECT Value FROM Settings WHERE Option = 'serverlock'");
	if(db_num_rows(query))
	{
		ServerLock = db_get_field_int(query, 0);
		db_free_result(query);
	} else {
		ServerLock = 0;
	}
	// Restore team colors
	TDC[0] = "~g~";
	THC[0] = "{33AA33}";
	ClanName[0] = "Green";
	TCC[0] = COLOR_GREEN;

	TDC[1] = "~b~";
	THC[1] = "{3A5FCD}";
	ClanName[1] = "Blue";
	TCC[1] = COLOR_BLUE;

	foreach(Player, i) 
	{
		PlayerRefreshScore(i);
		if(GetPVarInt(i, "Team") == 0) {
			SetPlayerColor(i, TCC[0]);
		}
		if(GetPVarInt(i, "Team") == 1) {
			SetPlayerColor(i, TCC[1]);
		}
		// Reset skills in default world
		if(GetPlayerVirtualWorld(i) == 0)
		{
			for(new skill = 0; skill < sizeof(Skill); skill++) 
			{
				SetPlayerSkillLevel(i, skill, Skill[skill]);
			}
		}
	}
	
	GiveDefaultWeaponsForAll(0);
	
	SetGameModeText("CW/TG | Sandbox");

	// resetall
	score[0] = 0;
	score[1] = 0;
	soucet[0] = 0;
	soucet[1] = 0;
	RoundScore[0] = 0;
	RoundScore[1] = 0;
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);

	for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
		if (IsPlayerConnected(i))
		{
			SetPVarInt(i, "cwkills", 0);
			SetPVarInt(i, "cwdeath", 0);
			SetPVarInt(i, "cwteamkills", 0);
			SetPVarFloat(i, "cwdamage", 0.0);
			SetPVarFloat(i, "cwinjuries", 0.0);
			SetPVarFloat(i, "cwteamdamage", 0.0);
			SetPVarInt(i, "round_kills", 0);
			SetPVarInt(i, "round_death", 0);
			SetPVarInt(i, "round_teamkills", 0);
			SetPVarFloat(i, "round_damage", 0.0);
			SetPVarFloat(i, "round_injuries", 0.0);
			SetPVarFloat(i, "round_teamdamage", 0.0);
			SetPVarFloat(i, "efficiency", 0.0);
			SetPlayerScore(i, 0);
			ResetPlayerMoney(i);
		}
	}
	RefreshScore();
}

stock ShowDbTotalStistics(playerid)
{
	/* 	Displays total server statistics. */
	new tbtext[1024], string[128];
	new szQuery[256], DBResult: query;
	
	#if !defined _INC_SAMP_Community_fixes
	if(FIXES_gsKnownOS)
	{
		if(_FIXES_gIsWindows)
		{
			format(string, sizeof(string), "db hosted on OS: Windows\n");
			strcat(tbtext, string);
		} else {
			format(string, sizeof(string), "db hosted on OS: Linux\n");
			strcat(tbtext, string);
		}
	}
	#endif
	
	#if defined mysql_included
		format(string, sizeof(string), "db type: MySQL\n");
		strcat(tbtext, string);
	#else 
		#if defined _sampdb_included
			format(string, sizeof(string), "db type: Sqlite\n");
			strcat(tbtext, string);
		#endif
	#endif
	
	format(string, sizeof(string), "db open files: %d, db open resutls: %d\n", db_debug_openfiles(), db_debug_openresults());
	
	if(fexist("core.db")) format(string, sizeof(string), "core.db %d Kb\n",
	db_get_mem_handle(dbcore)/1024);
	strcat(tbtext, string);
	if(fexist("accounts.db")) format(string, sizeof(string), "accounts.db %d Kb\n",
	db_get_mem_handle(dbaccounts)/1024);
	strcat(tbtext, string);
	if(fexist("logs.db")) format(string, sizeof(string), "logs.db %d Kb",
	db_get_mem_handle(dblogs)/1024);
	strcat(string, "\n");
	strcat(tbtext, string);
	
	if(fexist("logs.db"))
	{
		new connectionstoday = 0;
		new connectionspermonth = 0;
	    new unicaltoday = 0;
	    new unicalpermonth = 0;
		new kickedtoday = 0;
		new kickedpermonth = 0;
		new bannedtoday = 0;
		new bannedpermonth = 0;
		new rows = 0;
		
		new year, month, day;
		getdate(year, month, day);
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(*) FROM Connectionlog WHERE Datetime LIKE '%%%d.%d.%d%%'",
		year, month, day);
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			connectionstoday = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT DISTINCT Nickname FROM Connectionlog WHERE Datetime LIKE '%%%d.%d.%d%%'",
		year, month, day);
		query = db_query(dblogs, szQuery);
		rows = db_num_rows(query);
		if(rows)
		{
			unicaltoday = db_get_field_int(query, 0);
		}
		db_free_result(query);
		rows = 0;
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(Nickname) FROM Kicklog WHERE Date LIKE '%%%d.%d.%d%%'",
		year, month, day);
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			kickedtoday = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(Action) FROM Adminactions WHERE \
		Action LIKE '%%banned%%' AND Datetime LIKE '%%%d.%d.%d%%'",
		year, month, day);
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			bannedtoday = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		// permonth
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(*) FROM Connectionlog WHERE Datetime LIKE '%%.%d.%%'", month);
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			connectionspermonth = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT DISTINCT Nickname FROM Connectionlog WHERE Datetime LIKE '%%.%d.%%'", month);
		query = db_query(dblogs, szQuery);
		rows = db_num_rows(query);
		if(rows)
		{
			unicalpermonth = db_get_field_int(query, 0);
		}
		db_free_result(query);
		rows = 0;
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(Nickname) FROM Kicklog WHERE Date LIKE '%%.%d.%%'", month);
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			kickedpermonth = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(Action) FROM Adminactions WHERE \
		Action LIKE '%%banned%%' AND Datetime LIKE '%%.%d.%%'",month);
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			bannedpermonth = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		strcat(tbtext, "\ntoday statistics:\n");
		format(string, sizeof(string),
		"connections: %d, unical players: %d\nkicked: %d banned: %d\n",
		connectionstoday, unicaltoday, kickedtoday, bannedtoday);
		strcat(tbtext, string);
		
		strcat(tbtext, "\nthis month statistics:\n");
		format(string, sizeof(string),
		"connections: %d, unical players: %d\nkicked: %d banned: %d\n",
		connectionspermonth, unicalpermonth, kickedpermonth, bannedpermonth);
		strcat(tbtext, string);
	}
	
	if(fexist("accounts.db"))
	{
		new registered = 0, muted = 0, banned = 0;
		new verified = 0, unverified = 0;
		
		format(szQuery, sizeof(szQuery),
		"SELECT count(Nickname) FROM Accounts");
		query = db_query(dbaccounts, szQuery);
		if(db_num_rows(query))
		{
			registered = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT count(Muted) FROM Accounts WHERE Muted > 0");
		query = db_query(dbaccounts, szQuery);
		if(db_num_rows(query))
		{
			muted = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT count(Banned) FROM Accounts WHERE Banned > 0");
		query = db_query(dbaccounts, szQuery);
		if(db_num_rows(query))
		{
			banned = db_get_field_int(query, 0);
		}
		db_free_result(query);

		format(szQuery, sizeof(szQuery),
		"SELECT count(Nickname) FROM Accounts WHERE Verified = 1");
		query = db_query(dbaccounts, szQuery);
		if(db_num_rows(query))
		{
			verified = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT count(Nickname) FROM Accounts WHERE Verified = 0");
		query = db_query(dbaccounts, szQuery);
		if(db_num_rows(query))
		{
			unverified = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		strcat(tbtext, "\ntotal accounts statistics:\n");
		format(string, sizeof(string),
		"registered: %d, muted: %d, banned: %d\nverified: %d unverified: %d\n",
		registered, muted, banned, verified, unverified);
		strcat(tbtext, string);
	}
	
	if(fexist("core.db"))
	{
		new hwbanned = 0, hwmuted = 0, forceac = 0;
		
		format(szQuery, sizeof(szQuery),
		"SELECT count(HwBan) FROM Banlist WHERE HwBan > 0");
		query = db_query(dbcore, szQuery);
		if(db_num_rows(query))
		{
			hwbanned = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		
		format(szQuery, sizeof(szQuery),
		"SELECT count(HwMute) FROM Banlist WHERE HwMute > 0");
		query = db_query(dbcore, szQuery);
		if(db_num_rows(query))
		{
			hwmuted = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT count(Forceac) FROM Banlist WHERE Forceac > 0");
		query = db_query(dbcore, szQuery);
		if(db_num_rows(query))
		{
			forceac = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		strcat(tbtext, "\ntotal ban statistics:\n");
		format(string, sizeof(string), "hwbanned: %d, hwmuted: %d, forceac: %d\n",
		hwbanned, hwmuted, forceac);
		strcat(tbtext, string);
	}
	
	if(fexist("logs.db"))
	{
		new connectionlog_num_entries = 0;
		new kicklog_num_entries = 0;
		new actionslog_num_entries = 0;
		new nicknameslog_num_entries = 0;
		new cwlog_num_entries = 0;
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(*) FROM Connectionlog");
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			connectionlog_num_entries = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(*) FROM Kicklog");
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			kicklog_num_entries = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(*) FROM Adminactions");
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			actionslog_num_entries = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(*) FROM Nicknameslog");
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			nicknameslog_num_entries = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		format(szQuery, sizeof(szQuery),
		"SELECT COUNT(*) FROM CWlog");
		query = db_query(dblogs, szQuery);
		if(db_num_rows(query))
		{
			cwlog_num_entries = db_get_field_int(query, 0);
		}
		db_free_result(query);
		
		strcat(tbtext, "\nlogs entries statistics:\n");
		format(string, sizeof(string),
		"connectionlog: %d\nkicklog: %d\n\
		actionlog: %d\nnicknameslog: %d\ncwlog: %d\n",
		connectionlog_num_entries, kicklog_num_entries,
		actionslog_num_entries,	nicknameslog_num_entries,
		cwlog_num_entries);
		strcat(tbtext, string);
	}
	
	ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX, "DB Stats", tbtext, " X ", "");
}

stock ShowServerTotalStistics(playerid)
{
	/* 	Displays total server statistics. */
	new string[128], header[64];
	
	new hostname[64];
	GetServerVarAsString("hostname", hostname, sizeof(hostname));
	format(header, sizeof(header), "%s version: v%s", hostname, VERSION);

	new Bind[16];
	GetServerVarAsString("bind", Bind, 16);
	format(string, sizeof(string), "Bind IP: %s Port: %i", Bind, GetServerVarAsInt("port"));
	if(strlen(Bind) > 1) SendClientMessage(playerid, -1, string);
	
	#if defined _YSF_included
		new scriptname[32];
		new buffer[144];
		format(buffer,sizeof(buffer), "filterscripts (%i): ", GetFilterScriptCount());
		for(new i; i != 16; i++)
		{
			GetFilterScriptName(i, scriptname);
			if(isnull(scriptname)) continue; // If no FS
			format(scriptname,sizeof(scriptname), "%s ", scriptname);
			strcat(buffer, scriptname);
		}
		SendClientMessagef(playerid, -1, "%s", buffer);
	#endif
	
	new onfoot_rate = GetServerVarAsInt("onfoot_rate");
	new incar_rate = GetServerVarAsInt("incar_rate");
	new weapon_rate = GetServerVarAsInt("weapon_rate");
	new stream_rate = GetServerVarAsInt("stream_rate");
	new maxplayers = GetServerVarAsInt("maxplayers");
	
	format(string, sizeof(string), "maxplayers: %d, players online: %d", maxplayers, Online);
	SendClientMessage(playerid, -1, string);
	format(string, sizeof(string), "onfoot_rate: %d, incar_rate: %d", onfoot_rate, incar_rate);
	SendClientMessage(playerid, -1, string);
	format(string, sizeof(string), "weapon_rate: %d, stream_rate: %d", weapon_rate, stream_rate);
	SendClientMessage(playerid, -1, string);

	#if defined _YSF_included
		if(GetRunningTimers() > 1000) {
			format(string,sizeof(string), "tickrate: %i, running timers: unavailable",
			GetServerTickRate());
		} else {
			format(string,sizeof(string), "tickrate: %i, running timers: %i",
			GetServerTickRate() , GetRunningTimers());
		}
		SendClientMessage(playerid, -1, string);
	#else
		format(string,sizeof(string), "tickrate: %i", GetServerTickRate());
		SendClientMessage(playerid, -1, string);
	#endif	

	#if defined _nex_ac_included
		format(string, sizeof(string), "Attempts hacking: %d, crashing: %d",
		GetHackingAttempts(), GetCrashingAttempts());
		SendClientMessage(playerid, -1, string);
	#endif
	
	#if defined _sampcac_included
		format(string, sizeof(string), "SAMPCAC detected: %d", CAC_TotalDetectedCheaters);
		SendClientMessage(playerid, -1, string);
	#endif
	
	#if defined _FCNPC_included
	    format(string, sizeof(string), "FCNPC updaterate: %d, tickrate: %d",
		FCNPC_GetUpdateRate(), FCNPC_GetTickRate());
		SendClientMessage(playerid, -1, string);
	#endif
	
	if(Online > 1)
	{
		new totalPing, totalFPS, mutes;
		foreach(new i : Player) {

			if(pData[i][pMuted] > 0) {
				mutes++;
			}
			totalPing += GetPlayerPing(i);
			totalFPS += GetPlayerFPS(i);
		}
		
		format(string, sizeof(string),
		"Average ping %.2f, Average FPS %.2f, Average packetloss: %.2f, max packetloss: %.2f", 
		float(totalPing)/Online, float(totalFPS)/Online,  GetAveragePacketloss(), MAX_PACKETLOSS);
		SendClientMessage(playerid, -1, string);
	}
	
	format(string, sizeof(string), "Server running without restarting since %s", ServerRun);
	SendClientMessage(playerid, -1, string);
	
	#if defined _YSF_included
	new 
		showplayermarkes, shownametags, stuntbonus, 
		useplayerpedanims, bLimitchatradius, disableinteriorenterexits,
		nametaglos, manualvehicleengine, limitplayermarkers,
		vehiclefriendlyfire, defaultcameracollision, 
		Float:fGlobalchatradius, Float:fNameTagDrawDistance, Float:fPlayermarkerslimit
	;
	GetServerSettings(showplayermarkes, shownametags, stuntbonus, useplayerpedanims, bLimitchatradius, disableinteriorenterexits, nametaglos ,manualvehicleengine, limitplayermarkers, vehiclefriendlyfire ,defaultcameracollision, fGlobalchatradius, fNameTagDrawDistance, fPlayermarkerslimit);
	
	new tbtext[400];
	format(tbtext, sizeof(tbtext), 
	" showplayermarkes: %i\n shownametags: %i\n stuntbonus: %i\n"\
	" useplayerpedanims: %i\n bLimitchatradius: %i\n disableinteriorenterexits: %i\n"\
	" nametaglos: %i\n manualvehicleengine: %i\n limitplayermarkers: %i\n"\
	" vehiclefriendlyfire: %i\n defaultcameracollision: %i\n"\
	" Globalchatradius: %.1f\n NameTagDrawDistance: %.1f\n Playermarkerslimit: %.1f\n",
	showplayermarkes, shownametags, stuntbonus, useplayerpedanims, bLimitchatradius, disableinteriorenterexits, nametaglos ,manualvehicleengine, limitplayermarkers,
	vehiclefriendlyfire ,defaultcameracollision , fGlobalchatradius , fNameTagDrawDistance, fPlayermarkerslimit);
	
	if(Debug) printf(tbtext);
	#endif
}

stock Speconly_mode(playerid)
{
	/*
	Used to put the gamers in speconly mode. 
	In this mode, spectators team cannot leave the specmode at the time of the CW. 
	Players are available in flight and spectate mode.
	*/
	
	new string[144], stringen[144];
	if (speconly)
	{
		#if defined _nex_ac_included
		// Disable false health/armour hacks detection
		foreach(Player, i)
		{
			if(IsAntiCheatEnabled(2)) EnableAntiCheatForPlayer(i, 2, 1);
			if(IsAntiCheatEnabled(17)) EnableAntiCheatForPlayer(i, 17, 1);
			if(IsAntiCheatEnabled(27)) EnableAntiCheatForPlayer(i, 27, 1);
		}
		#endif
		speconly = false;
		format(string, sizeof(string),
		"%s(%d) отключил принудительный режим наблюдения. \
		Чтобы выйти из наблюдения, используйте команду /specoff или нажмите F / ENTER",
		PlayerName(playerid), playerid);
		format(stringen, sizeof(stringen),
		"%s(%d) has switched off spectate only mode for spectators. \
		To stop spectating use /specoff or press F / ENTER",
		PlayerName(playerid), playerid);
	} else {
		#if defined _nex_ac_included
		// Disable false health/armour hacks detection
		foreach(Player, i)
		{
			if(IsAntiCheatEnabled(2)) EnableAntiCheatForPlayer(i, 2, 0);
			if(IsAntiCheatEnabled(17)) EnableAntiCheatForPlayer(i, 17, 0);
			if(IsAntiCheatEnabled(27)) EnableAntiCheatForPlayer(i, 27, 0);
		}
		#endif
		speconly = true;

		new activeplayers[_MAX_PLAYERS], gg;
		for(new i = 0; i < MAX_PLAYER_ID; i++)
		{
			if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == 0)
			{
				if (GetPVarInt(i, "Team") < 2 && GetPlayerState(i) == PLAYER_STATE_ONFOOT)
				{
					activeplayers[gg] = i;
					gg++;
				}
			}
		}
		if (gg >= 1)
		{
			new aa;
			for(new i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == 0)
				{
					if (GetPVarInt(i, "Team") == 2 && GetPVarInt(i, "Specing") == -1)
					{
						if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
						{
							if (!GetPVarInt(activeplayers[aa], "Spected"))
							{
								SetPVarInt(activeplayers[aa], "Spected", true);
							}
							
							TogglePlayerSpectating(i, true);
							SetPVarInt(i, "Specing", activeplayers[aa]);
							PlayerSpectatePlayer(i, activeplayers[aa]);
							PlayerPlaySound(i, 1132, 0.0, 0.0, 0.0);
							
							if (aa < gg -1)
							{
								aa++;
							} else {
								aa = 0;
							}
						}
					}
				}
			}
		} else {	
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Вы один на сервере поэтому вас не перевело в наблюдение", 
			"While you are alone on the server, you are not switched to speconly mode.");
		}
		format(string, sizeof(string), 
		"%s(%d) включил принудительный режим наблюдения (наблюдатели не отображаются для игроков - более высокий FPS).",
		PlayerName(playerid), playerid);
		format(stringen, sizeof(stringen),
		"%s(%d) has switched on spectate only mode for spectators (spectators aren't streamed for players - higher FPS).",
		PlayerName(playerid), playerid);
	}
	SendClientMessageToVirtualWorld(0, COLOR_GREY, string, stringen);
	if (GetPVarInt(playerid, "Team") == 2 && speconly)
	{
		SendClientMessageEx(playerid, COLOR_WHITE,
		"Для переключения на {008000}следующего{FFFFFF} игрока нажмите {008000}<LMB>{FFFFFF} (Левая кнопка мыши)",
		"Switch to {008000}next{FFFFFF} by pressing {008000}<LMB>{FFFFFF} (Left Mouse Button)");
		SendClientMessageEx(playerid, COLOR_WHITE,
		"Для переключения на {008000}предыдущего{FFFFFF} игрока нажмите {008000}<RMB>{FFFFFF} (Правая кнопка мыши)",
		"Switch to {008000}previous{FFFFFF} by pressing {008000}<RMB>{FFFFFF} (Right Mouse Button)");
	}
	return true;
}

