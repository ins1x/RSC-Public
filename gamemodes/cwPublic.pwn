	World[worldid][wMarkers] = 1;
	World[worldid][wGreenZone] = 0;
	World[worldid][wCammode] = 0;
	World[worldid][wBagoskins] = 0;
	World[worldid][wCJrun] = 1;
	World[worldid][wCbug] = 1;
	World[worldid][wSpawnPoint] = 0;
	World[worldid][wSpawnX] = 0.0;
	World[worldid][wSpawnY] = 0.0;
	World[worldid][wSpawnZ] = 0.0;
	World[worldid][wSpawnA] = 0.0;
	World[worldid][wColor1] = -1;
	World[worldid][wColor2] = -1;
	World[worldid][wPaintjob] = 3;	
	World[worldid][wBotType] = 1;
	World[worldid][wBotSkin] = 0;
	World[worldid][wBotAction] = 1;
	World[worldid][wBotAccuracy] = 50.0;
	World[worldid][wBotShootrate] = 1055;
	World[worldid][wBotShootdelay] = 1500;
	World[worldid][wBotReloadtime] = 1500;
	World[worldid][wBotWeaponid] = 28;
	World[worldid][wBotHealth] = 100;
	World[worldid][wBotMovetype] = -1;
	World[worldid][wMapRadar] = 1;
	World[worldid][wHoldInVehicle] = 1;
	World[worldid][wResetWeapons] = 0;
	World[worldid][wRandSpawn] = 0;
	World[worldid][wVehicleDefaultModel] = 0;
	World[worldid][wFreezeOnSpawn] = 0;
	World[worldid][wAnticheat] = 1;
	World[worldid][wUseTimer] = 0;
	World[worldid][wRoundTime] = 0;
	World[worldid][wStartTime] = 0;
	World[worldid][wPause] = 0;
	
	#if defined _streamer_included
		if(IsValidDynamicCP(WorldVehCheckpoint[worldid]))
		{
			DestroyDynamicCP(WorldVehCheckpoint[worldid]);
			WorldVehCheckpoint[worldid] = 0;
		}
	#endif
	/* for(new i = GetVehiclePoolSize() +1; --i != 0;)
	{
		if(GetVehicleVirtualWorld(i) == worldid) DestroyVehicle(i);
	}	 */
	DestroyAllVehicles(worldid);
	ResetWorldWeapons(worldid);
	ResetWorldObjects(worldid);
	return 1;
}

stock GetFreeWorldSlot()
{
	// Get first free world slot
	for(new slot = 1; slot < MAX_WORLD_SLOTS; slot++)
	{
		if(!World[slot][wHosted])
		{
			return slot;
		}
	}
	return 0;
}

stock AddVehicleComponentNearbyWorld(worldid, playerid, componentid, Float:radius = 50.0)
{
	// Add Vehicle Component to nearby vehicles in virtual world
	new stringru[128], stringen[128];
	new vcounter = 0;
	
	new componentname[24];
	switch(componentid)
	{
		case 1010: strcat(componentname, "NOS");
		case 1025: strcat(componentname, "Off-road wheels");
		case 1087: strcat(componentname, "Hydraulics");
		case 1073,1074,1075,1076,1077,1078,1079, 1080,1081,1082,1083,1084,1085:
		{
			strcat(componentname, "Wheels");
		}
	}
	
	for(new v = MAX_VEHICLES +1; --v != 0;)
	{
		if(GetVehicleVirtualWorld(v) == worldid)
		{
			new Float:vx, Float:vy, Float:vz;
			GetVehiclePos(v, vx, vy, vz);
			if(!IsPlayerInRangeOfPoint(playerid, radius, vx,vy,vz)) continue;
			switch(GetVehicleModel(v))
			{
				case 446,432,448,452,424,453,454,461,462,463,468,471,430,
				472,449,473,481,484,493,509,510,521,538,522,523,532,537,
				570,581,586,590,569,595,604,611: continue; 
			}
			AddVehicleComponent(v, componentid);
			vcounter++;
		}
	}
	
	if(vcounter > 0)
	{
		PlayerPlaySound(playerid,1133,0.0,0.0,0.0);
		format(stringru, sizeof(stringru),
		"На транспорте в радиусе %.0f метров установлен %s. (%d машин)",
		radius, componentname, vcounter);
		format(stringen, sizeof(stringen),
		"%s was installed on transport at radius of %.0f meters (%d vehicles)",
		componentname, radius, vcounter);
		SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
	}
	else SendClientMessageEx(playerid, COLOR_GREY,
	"Нет транспорта рядом", "There is no vehicles nearby");
	
	return 1;
}

stock GetDirectionInWhichPlayerLooks(playerid, Float:facing_angle = -1.0)
{
    static const
        Float: side_of_the_world = 20.0,//(0.0 - 45.0)
        Float: coord_indent = 0.1;

    new const
        Float: north_coord_min = 360.0-side_of_the_world,
        Float: north_coord_max = 0.0+side_of_the_world,

        Float: west_coord_min = 90.0-side_of_the_world,
        Float: west_coord_max = 90.0+side_of_the_world,

        Float: south_coord_min = 180.0-side_of_the_world,
        Float: south_coord_max = 180.0+side_of_the_world,

        Float: east_coord_min = 280.0-side_of_the_world,
        Float: east_coord_max = 280.0+side_of_the_world;


    if(!floatcmp(facing_angle, -1.0))
        GetPlayerFacingAngle(playerid, facing_angle);
    else if(floatcmp(facing_angle, 0.0) == -1)
        facing_angle = 0.0;
    else if(floatcmp(facing_angle, 360.0) == 1)
        facing_angle = 360.0;

    if(north_coord_min <= facing_angle <= 360.0 || 0.0 <= facing_angle <= north_coord_max)
        return 0;
    else if(north_coord_max+coord_indent <= facing_angle <= west_coord_min-coord_indent)
        return 1;

    else if(west_coord_min <= facing_angle <= west_coord_max)
        return 2;
    else if(west_coord_max+coord_indent <= facing_angle <= south_coord_min-coord_indent)
        return 3;

    else if(south_coord_min <= facing_angle <= south_coord_max)
        return 4;
    else if(south_coord_max+coord_indent <= facing_angle <= east_coord_min-coord_indent)
        return 5;

    else if(east_coord_min <= facing_angle <= east_coord_max)
        return 6;
    else //if(east_coord_max+coord_indent <= facing_angle <= north_coord_min-coord_indent)
        return 7;
}

stock GetPlayerCameraLookAt(playerid, &Float:rX, &Float:rY, &Float:rZ, Float:dist = 10.0) 
{
    new Float: locAt[6];
    GetPlayerCameraFrontVector(playerid, locAt[0], locAt[1], locAt[2]);
    GetPlayerCameraPos(playerid, locAt[3], locAt[4], locAt[5]);
    rX = locAt[0] * dist + locAt[3];
    rY = locAt[1] * dist + locAt[4];
    rZ = locAt[2] * dist + locAt[5]; 
}

stock Jump(playerid)
{
	// Jump forward
	new 
		Float:facing_angle,
		Float:adj = 4,
		Float:x, Float:y, Float:z,
		bool:useJetpack
	;
	if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK) useJetpack = true;
	GetPlayerFacingAngle(playerid, facing_angle);
	new LookAt = GetDirectionInWhichPlayerLooks(playerid, facing_angle);
	GetPlayerPos(playerid, x,y,z);
	switch(LookAt) 
	{
		case 0: SetPlayerPos(playerid,x,y+adj,z+1);
		case 1: SetPlayerPos(playerid,x-adj,y+adj,z+1);
		case 2: SetPlayerPos(playerid,x-adj,y,z+1);
		case 3: SetPlayerPos(playerid,x-adj,y-adj,z+1);
		case 4: SetPlayerPos(playerid,x,y-adj,z+1);
		case 5: SetPlayerPos(playerid,x+adj,y-adj,z+1);
		case 6: SetPlayerPos(playerid,x+adj,y,z+1);
		case 7: SetPlayerPos(playerid,x+adj,y+adj,z+1);
	}
	if(useJetpack) SetPlayerSpecialAction(playerid, SPECIAL_ACTION_USEJETPACK);
}

