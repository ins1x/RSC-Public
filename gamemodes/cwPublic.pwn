							if (GetPVarInt(i, "Team") != GetPVarInt(playerid, "Team"))
							{
								if (GetPVarInt(i, "Team") == 0)
								{
									SetPlayerMarkerForPlayer(playerid, i, TCC[0]);
								}else{
									SetPlayerMarkerForPlayer(playerid, i, TCC[1]);
								}
								SetPlayerMarkerForPlayer(i, playerid, TCC[2]);
							}
						}
					}
				}
			}
			SetPVarInt(playerid, "Team", 2);
			SetPlayerColor(playerid, TCC[2]);
			SetPlayerTeam(playerid, 2);
			ResetPlayerWeapons(playerid);
			new stringru[55];
			format(stringru, sizeof(stringru), "%s(%d) стал наблюдателем.", name, playerid);
			new stringen[59];
			format(stringen, sizeof(stringen), "%s(%d) has moved to Spectator team.", name, playerid);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			CheckSpec(playerid);
			RefreshHud(playerid);
			ReSpawnPlayer(playerid);
			return true;
		}
		return true;
