	}
	if (!strcmp("/changename", cmd, true) || !strcmp("/changenickname", cmd, true))
	{
		tmp = strtok(cmdtext, idx);
		new id = strval(tmp);
		#if defined DISCORD_VERIFICATION
		if(pData[playerid][pVerified] == 0)
		{
			return SendClientMessageEx(playerid, COLOR_GREY,
			"Ваш аккаунт не верифицирован, пройдите верификацию в Discord: dsc.gg/sawncommunity",
			"Your account is not verified, please verify in Discord: dsc.gg/sawncommunity");
		}
		#endif
		if (!strlen(tmp) || strval(tmp) == INVALID_PLAYER_ID)
		{
			if(GetPVarInt(playerid, "Admin") < 2)
			{
				if(NetStats_GetConnectedTime(playerid)/60000 < 5)
				{
					return SendClientMessageEx(playerid, COLOR_GREY, 
					"Вы должны быть онлайн не менее 5 минут",
					"You must be online for at least 5 minutes");
				}
				if(GetPVarInt(playerid, "ChangeNicknameTime") > gettime())
				{
					return SendClientMessageEx(playerid, COLOR_GREY, 
					"Слишком часто меняете никнейм.", "You change your nickname too often");
				}
			}
			
			if(CWmode)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно во время проведения матча", "Not available during CW match");
			}
			
			if (pData[playerid][pLang] == 0)
			{
				ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT,
				"Сменить ник",
				"{FF0000}- Запрещено использовать ники администраторов, других игроков \
				и теги чужих кланов\n\
				- Запрещено использовать никнеймы оскорбляющие личность\n\n\
				{FFFFFF}Введите новый ник (максимум 20 символов):", "Сменить", "Выйти");
			} else {
				ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT,
				"Change nickname",
				"{FF0000}- Impersonating administrators, other players and clantags\
				is forbidden!\n\
				- Forbidden to use nicknames insulting the person\n\n\
				{FFFFFF}Enter a new nickname (max 20 symbols):", "Save", "Cancel");
			}
		}
		
		if(IsPlayerConnected(id))
		{
			if(GetPVarInt(playerid, "Admin") < GetPVarInt(id, "Admin"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"У данного игрока выше уровень админки", "This player has a higher admin level");
				return true;
			}
			
			if (GetPVarInt(playerid, "Admin") < 2) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 2+ уровня!",
				"To use these functions you need to have 2+ level admin rights!");
			}
			ChosenPlayer[playerid] = id;
			new header[48];
			
			if (pData[playerid][pLang] == 0)
			{
				format(header, sizeof(header), "Сменить никнейм %s(%d)", PlayerName(id), id);
				return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
				"{FF0000}- Запрещено использовать ники администраторов, других игроков \
				и теги чужих кланов\n\
				- Запрещено использовать никнеймы оскорбляющие личность\n\n\
				{FFFFFF}Введите новый ник (максимум 20 символа):", "Сменить", "Выйти");
			} else {
				format(header, sizeof(header), "Change nickname %s(%d)", PlayerName(id), id);
				return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
				"{FF0000}- Impersonating administrators, other players and clantags\
				is forbidden!\n\
				- Forbidden to use nicknames insulting the person\n\n\
				{FFFFFF}Enter a new nickname (max 20 symbols):", "Save", "Cancel");
			}
		} else {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Игрок не подключен либо вышел.", "This player isn't connected.");
		}
		return true;
	}
	if (!strcmp(cmdtext, "/hidebar", true))
	{
		if(pData[playerid][pBottombar] == 0)
		{
			pData[playerid][pBottombar] = 0;
			TextDrawShowForPlayer(playerid, TD[playerid]);
		} else {
			pData[playerid][pBottombar] = 1;
			TextDrawHideForPlayer(playerid, TD[playerid]);
		}
		return true;
	}
	if (!strcmp(cmdtext, "/acoff", true))
	{// need for tests ac system
		if(GetPVarInt(playerid, "Admin") >= 3)
		{
			if(GetPVarInt(playerid, "Acoff"))
			{
				DeletePVar(playerid, "Acoff");
			} else {
				SetPVarInt(playerid, "Acoff",1);
				#if defined _nex_ac_included
				for(new code = 0; code != 53; code++) EnableAntiCheatForPlayer(playerid, code, false);
				#endif
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы отключили античит для себя", "You have disabled anti-cheat for yourself");
				SendClientMessageEx(playerid, COLOR_GREY,
				"Не забудьте перезайти после тестов", "Don't forget recoonect after testing.");
			}
			return true;
		}
	}
	if (!strcmp(cmdtext, "/acset", true))
	{
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Недоступно в виртуальном мире!", "Not available in the virtual world!");
			return 1;
		}
		if (GetPVarInt(playerid, "Admin") >= 2)
		{
			GAMEACSET(playerid);
			return true;
		} else { 
			return false;
		}
	}
	if (!strcmp("/results", cmd, true) || !strcmp("/result", cmd, true))
	{
		ShowCWResults(playerid);
		return true;
	}
	if (!strcmp("/ip", cmd, true) || !strcmp("/acnames", cmd, true))
	{
		tmp = strtok(cmdtext, idx);
		new id = strval(tmp);
		
		if (strlen(tmp) == 0 || strval(tmp) == INVALID_PLAYER_ID){
			if (GetPVarInt(playerid, "Admin") >= 3) {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /acnames [ID]",	"Use: /acnames [ID]");
				return true;
			}
		}
		if(!IsPlayerConnected(id))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Неверный ID игрока", "Incorrect player id");
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /acnames [ID]",	"Use: /acnames [ID]");
			return true;
		}
		
		if(GetPVarInt(id, "Admin") >= 3 && GetPVarInt(playerid, "Admin") < 3)
		{
			ShowPlayerDialog(playerid, 251, DIALOG_STYLE_LIST,
			"Player accs", "Not found\n", "Select", "Cancel");
			return true;
		}
		
		new nick[24+1],lastcountry[32],lastip[16+2], verified;
		new tbtext[2048], tmpstr[128];
		new szQuery[256], DBResult: query, rows;
		
		new serial[41];
		gpci(id,serial,40);
		
		if(GetPVarInt(playerid, "Admin") >= 3)
		{
			format(szQuery, sizeof(szQuery),
			"SELECT Nickname, Verified, Lastcountry, Lastip FROM Accounts WHERE (Serial = '%s')",
			serial);
			query = db_query(dbaccounts, szQuery);
			
			rows = db_num_rows(query);
			if(rows >= 10)
			{
				for(new i; i < rows; i++)
				{
					db_get_field(query, 0, nick, sizeof(nick));
					format(nick, sizeof(nick), "%s", nick);
					
					verified = db_get_field_int(query, 1);
					
					if(verified) format(tmpstr, 128, "{00FF00}%s", nick);
					else format(tmpstr, 128, "%s", nick);
					
					db_get_field(query, 2, lastcountry, sizeof(lastcountry));
					format(lastcountry, sizeof(lastcountry), "%s", lastcountry);
					
					db_get_field(query, 3, lastip, sizeof(lastip));
					format(lastip, sizeof(lastip), "%s", lastip);
					
					format(tmpstr, sizeof(tmpstr), "%s - %s - %s", nick, lastcountry, lastip);
					SendClientMessage(playerid, -1, tmpstr);
					db_next_row(query);
				}
				db_free_result(query);
			} else {
				for(new i; i < rows; i++)
				{
					db_get_field(query, 0, nick, sizeof(nick));
					format(nick, sizeof(nick), "%s\t", nick);
					
					verified = db_get_field_int(query, 1);
					
					if(verified) format(tmpstr, 128, "{00FF00}%s", nick);
					else format(tmpstr, 128, "%s", nick);
					
					db_get_field(query, 2, lastcountry, sizeof(lastcountry));
					format(lastcountry, sizeof(lastcountry), "%s\t", lastcountry);
					
					db_get_field(query, 3, lastip, sizeof(lastip));
					format(lastip, sizeof(lastip), "%s\n", lastip);
					
					strcat(tbtext, nick);
					strcat(tbtext, lastcountry);
					strcat(tbtext, lastip);
					
					db_next_row(query);
				}
				db_free_result(query);
			}
		} else {
			format(szQuery, sizeof(szQuery),
			"SELECT Admin, Nickname, Verified, Lastcountry FROM Accounts WHERE (Serial = '%s')",
			serial);
			query = db_query(dbaccounts, szQuery);
			
			rows = db_num_rows(query);
			if(rows >= 10)
			{
				for(new i; i < rows; i++)
				{
					new adminlvl = db_get_field_int(query, 0);
					
					if(adminlvl < 3)
					{
						db_get_field(query, 1, nick, sizeof(nick));
						format(nick, sizeof(nick), "%s", nick);
						
						verified = db_get_field_int(query, 2);
						
						if(verified) format(tmpstr, 128, "{00FF00}%s", nick);
						else format(tmpstr, 128, "%s", nick);
						
						db_get_field(query, 3, lastcountry, sizeof(lastcountry));
						format(lastcountry, sizeof(lastcountry), "%s", lastcountry);
						
						format(tmpstr, sizeof(tmpstr), "%s - %s", nick, lastcountry);
						SendClientMessage(playerid, -1, tmpstr);
					}
					
					db_next_row(query);
				}
				db_free_result(query);
			} else {
				for(new i; i < rows; i++)
				{
					new adminlvl = db_get_field_int(query, 0);
					
					if(adminlvl < 3)
					{
						db_get_field(query, 1, nick, sizeof(nick));
						format(nick, sizeof(nick), "%s\t", nick);
						
						verified = db_get_field_int(query, 2);
						
						if(verified) format(tmpstr, 128, "{00FF00}%s", nick);
						else format(tmpstr, 128, "%s", nick);
						
						db_get_field(query, 3, lastcountry, sizeof(lastcountry));
						format(lastcountry, sizeof(lastcountry), "%s\n", lastcountry);
						
						strcat(tbtext, nick);
						strcat(tbtext, lastcountry);
					}
					
					db_next_row(query);
				}
				db_free_result(query);
			}
		}
		
		if(rows < 10)
		{
			ShowPlayerDialog(playerid, 251, DIALOG_STYLE_LIST,
			"Player accs", tbtext, "Select", "Cancel");
		}
		return true;
	}
	if (!strcmp(cmdtext, "/nicknames", true) || !strcmp(cmdtext, "/nickname", true))
	{
		ShowNicknamesLog(playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/acdata", true))
	{
		ShowPlayerDialog(playerid, 163, DIALOG_STYLE_INPUT,
		"Show nex ac counters per player",
		"{FFFFFF}Enter Player ID:", "Ok", "Close");
		return 1;
	}
	if (!strcmp(cmdtext, "/stalk", true))
	{
		if(GetPVarInt(playerid, "LastActionDelay") > gettime())
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы слишком часто используете данную функцию.",
			"You are using this feature too often.");
		    return true;
		}
		if(GetPVarInt(playerid, "Admin") < 1) 
		{
			SetPVarInt(playerid, "LastActionDelay", gettime() + 10);
		}
		GeoIpTable(playerid, playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/default", true) || !strcmp(cmdtext, "/end", true))
	{
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Недоступно в виртуальном мире!", "Not available in the virtual world!");
			return 1;
		}
		if (GetPVarInt(playerid, "Admin") >= 1) 
		{
			DefaultGameSettings();
			new stringru[100], stringen[100];
			format(stringru, sizeof(stringru),
			"%s(%d) восстановил дефолтные настройки раунда.", PlayerName(playerid), playerid);
			format(stringen, sizeof(stringen),
			"%s(%d) has restored default round settings.", PlayerName(playerid), playerid);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		} else {
			new adminsonline = 0;
			foreach(Player, i) 
			{
				if(GetPVarInt(i, "Admin") > 0) {
					adminsonline++;
				}
			}
			if(adminsonline == 0)
			{
				if(GetPVarInt(playerid, "RestoreDefaultSettingsTime") > gettime())
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Слтшком часто! попробуйте позже", "Too often! try later");
				}
				DefaultGameSettings();
				new stringru[100], stringen[100];
				format(stringru, sizeof(stringru),
