		{
			switch(listitem)
			{
				case 0:	ChosenTeam[playerid] = 0;
				case 1:	ChosenTeam[playerid] = 1;
			}

			if (pData[playerid][pLang] == 0)
			{
				ShowPlayerDialog(playerid, 179, DIALOG_STYLE_INPUT,	"Set team skin",
				"{FFFFFF}Введите ид скина (0 - 301):", "Ok", "Выход");
			} else {
				ShowPlayerDialog(playerid, 179, DIALOG_STYLE_INPUT,	"Set team skin",
				"{FFFFFF}Enter new skinid (0 - 301):", "Apply", "Cancel");
			}
		}
		else ROUND_TEAMSET_MENU(playerid);
