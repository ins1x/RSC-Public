							{
								format(tmpstr, 48, "{AFAFAF}%s\t(%d)\n", PlayerName(i), i);
							} else {
								format(tmpstr, 48, "%s\t(%d)\n", PlayerName(i), i);
							}
							strcat(tbtext, tmpstr);
						}
					}
					ShowPlayerDialog(playerid, 305, DIALOG_STYLE_TABLIST,
					"Players in world", tbtext, "Select", "Cancel");
				}
				case 8: OnPlayerCommandText(playerid, "/whelp");
				case 9: WORLD_INFO(playerid, worldid);
			}
		}
	}
	if(dialogid == 301) // WORLD_MANAGE
	{
		if(response)
		{
			new stringru[128], stringen[128];
			new worldid = GetPlayerVirtualWorld(playerid);
