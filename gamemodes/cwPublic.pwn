							}
						}
						if (GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death") > 0)
						{
							format(ratio_, sizeof(ratio_), "%.2f", (GetPVarInt(i, "cwkills") -GetPVarInt(i, "round_kills")) /float(GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death")));
						}else{
							ratio_ = "-";
						}
						GetPlayerName(i, string, MAX_PLAYER_NAME);
						format(string, sizeof(string), "    %s:\r\n      Kills: %s | Deaths: %s | TeamKills: %s | Ratio: %s.", string, stats_[0], stats_[1], stats_[2], ratio_);
						
						fwrite(file, string);
						fwrite(file, "\r\n");
						
						new Float: cwdamage = GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage");
						new Float: cwinjuries = GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries");
						new Float: cwteamdamage = GetPVarFloat(i, "cwteamdamage") -GetPVarFloat(i, "round_teamdamage");

						if (cwdamage < 10.0)
						{
							format(stats_[0], sizeof(stats_[]), "000%.2f", cwdamage);
						}
						else if (cwdamage < 100.0)
						{
							format(stats_[0], sizeof(stats_[]), "00%.2f", cwdamage);
						}
						else if (cwdamage < 1000.0)
						{
							format(stats_[0], sizeof(stats_[]), "0%.2f", cwdamage);
						}else{
							format(stats_[0], sizeof(stats_[]), "%.2f", cwdamage);
						}

						if (cwinjuries < 10.0)
						{
							format(stats_[1], sizeof(stats_[]), "000%.2f", cwinjuries);
						}
						else if (cwinjuries < 100.0)
						{
							format(stats_[1], sizeof(stats_[]), "00%.2f", cwinjuries);
						}
						else if (cwinjuries < 1000.0)
						{
							format(stats_[1], sizeof(stats_[]), "0%.2f", cwinjuries);
						}else{
							format(stats_[1], sizeof(stats_[]), "%.2f", cwinjuries);
						}

						if (cwteamdamage < 10.0)
						{
							format(stats_[2], sizeof(stats_[]), "0%.2f", cwteamdamage);
						}else{
							format(stats_[2], sizeof(stats_[]), "%.2f", cwteamdamage);
						}

						if (cwinjuries > 0)
						{
							format(ratio_, sizeof(ratio_), "%.2f", cwdamage /cwinjuries);
						}else{
							ratio_ = "-";
						}
						format(string, sizeof(string), "      Damage: %s | Injuries: %s | Teammate damage: %s | Ratio: %s.", stats_[0], stats_[1], stats_[2], ratio_);
						
						fwrite(file, string);
						fwrite(file, "\r\n");
					}
				}
			}
			for(i = 0; i < 2; i++)
			{
				if (score[i] < 10)
				{
					format(stats_[i], sizeof(stats_[]), "0%d", score[i]);
				}else{
					valstr(stats_[i], score[i]);
					//format(stats_[i], sizeof(stats_[]), "%d", score[i]);
				}
			}
			fwrite(file, "  Score:\r\n");
			format(string, sizeof(string), "    [%s] %s:%s [%s]", ClanName[0], stats_[0], stats_[1], ClanName[1]);
			fwrite(file, string);
			fwrite(file, "\r\n");

			for(i = 0; i < 2; i++)
			{
				if (soucet[i] < 10)
				{
					format(stats_[i], sizeof(stats_[]), "0%d", soucet[i]);
				}else{
					valstr(stats_[i], soucet[i]);
					//format(stats_[i], sizeof(stats_[]), "%d", soucet[i]);
				}
			}
			fwrite(file, "  Total:\r\n");
			format(string, sizeof(string), "    [%s] %s:%s [%s]", ClanName[0], stats_[0], stats_[1], ClanName[1]);
			fwrite(file, string);
			fwrite(file, "\r\n");

			for(i = 0; i < 2; i++)
			{
				if (RoundScore[i] < 10)
				{
					format(stats_[i], sizeof(stats_[]), "0%d", RoundScore[i]);
				}else{
					valstr(stats_[i], RoundScore[i]);
					//format(stats_[i], sizeof(stats_[]), "%d", RoundScore[i]);
				}
			}
			fwrite(file, "  Round:\r\n");
			format(string, sizeof(string), "    [%s] %s:%s [%s]", ClanName[0], stats_[0], stats_[1], ClanName[1]);
			fwrite(file, string);
			fwrite(file, "\r\n");

			format(string, sizeof(string), "  %s stats:", ClanName[0]);
			//SendClientMessageToAll(COLOR_WHITE, string);
			fwrite(file, string);
			fwrite(file, "\r\n");
			new pocet[2][3];
			new Float: pocet2[2][3];
			for(i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i))
				{
					if (GetPVarInt(i, "Team") < 2)
					{
						pocet[GetPVarInt(i, "Team")][0] += GetPVarInt(i, "cwkills") -GetPVarInt(i, "round_kills");
						pocet[GetPVarInt(i, "Team")][1] += GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death");
						pocet[GetPVarInt(i, "Team")][2] += GetPVarInt(i, "cwteamkills") -GetPVarInt(i, "round_teamkills");
						pocet2[GetPVarInt(i, "Team")][0] += GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage");
						pocet2[GetPVarInt(i, "Team")][1] += GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries");
						pocet2[GetPVarInt(i, "Team")][2] += GetPVarFloat(i, "cwteamdamage") -GetPVarFloat(i, "round_teamdamage");
					}
				}
			}
			for(i = 0; i < sizeof(stats_); i++)
			{
				if (pocet[0][i] < 10)
				{
					format(stats_[i], sizeof(stats_[]), "0%d", pocet[0][i]);
				}else{
					valstr(stats_[i], pocet[0][i]);
					//format(stats_[i], sizeof(stats_[]), "%d", pocet[0][i]);
				}
			}
			if (pocet[0][1] > 0)
			{
				format(ratio_, sizeof(ratio_), "%.2f", pocet[0][0] /float(pocet[0][1]));
			}else{
				ratio_ = "-";
			}
			format(string, sizeof(string), "    Total Kills: %s | Total Deaths: %s | Total TeamKills: %s | Team Ratio: %s.", stats_[0], stats_[1], stats_[2], ratio_);
			
			fwrite(file, string);
			fwrite(file, "\r\n");
			
			if (pocet2[0][0] < 10.0)
			{
				format(stats_[0], sizeof(stats_[]), "000%.2f", pocet2[0][0]);
			}
			else if (pocet2[0][0] < 100.0)
			{
				format(stats_[0], sizeof(stats_[]), "00%.2f", pocet2[0][0]);
			}
			else if (pocet2[0][0] < 1000.0)
			{
				format(stats_[0], sizeof(stats_[]), "0%.2f", pocet2[0][0]);
			}else{
				format(stats_[0], sizeof(stats_[]), "%.2f", pocet2[0][0]);
			}

			if (pocet2[0][1] < 10.0)
			{
				format(stats_[1], sizeof(stats_[]), "000%.2f", pocet2[0][1]);
			}
			else if (pocet2[0][1] < 100.0)
			{
				format(stats_[1], sizeof(stats_[]), "00%.2f", pocet2[0][1]);
			}
			else if (pocet2[0][1] < 1000.0)
			{
				format(stats_[1], sizeof(stats_[]), "0%.2f", pocet2[0][1]);
			}else{
				format(stats_[1], sizeof(stats_[]), "%.2f", pocet2[0][1]);
			}

			if (pocet2[0][2] < 10.0)
			{
				format(stats_[2], sizeof(stats_[]), "0%.2f", pocet2[0][2]);
			}else{
				format(stats_[2], sizeof(stats_[]), "%.2f", pocet2[0][2]);
			}

			if (pocet2[0][1] > 0)
			{
				format(ratio_, sizeof(ratio_), "%.2f", pocet2[0][0] /pocet2[0][1]);
			}else{
				ratio_ = "-";
			}
			format(string, sizeof(string), "    Total Damage: %s | Total Injuries: %s | Total Teammate Damage: %s | Team Ratio: %s.", stats_[0], stats_[1], stats_[2], ratio_);
			
			fwrite(file, string);
			fwrite(file, "\r\n");

			format(string, sizeof(string), "  %s stats:", ClanName[1]);
			//SendClientMessageToAll(COLOR_WHITE, string);
			fwrite(file, string);
			fwrite(file, "\r\n");
			for(i = 0; i < sizeof(stats_); i++)
			{
				if (pocet[1][i] < 10)
				{
					format(stats_[i], sizeof(stats_[]), "0%d", pocet[1][i]);
				}else{
					valstr(stats_[i], pocet[1][i]);
					//format(stats_[i], sizeof(stats_[]), "%d", pocet[1][i]);
				}
			}
			if (pocet[1][1] > 0)
			{
				format(ratio_, sizeof(ratio_), "%.2f", pocet[1][0] /float(pocet[1][1]));
			}else{
				ratio_ = "-";
			}
			format(string, sizeof(string), "    Total Kills: %s | Total Deaths: %s | Total TeamKills: %s | Team Ratio: %s.", stats_[0], stats_[1], stats_[2], ratio_);
			
			fwrite(file, string);
			fwrite(file, "\r\n");
			
			if (pocet2[1][0] < 10.0)
			{
				format(stats_[0], sizeof(stats_[]), "000%.2f", pocet2[1][0]);
			}
			else if (pocet2[1][0] < 100.0)
			{
				format(stats_[0], sizeof(stats_[]), "00%.2f", pocet2[1][0]);
			}
			else if (pocet2[1][0] < 1000.0)
			{
				format(stats_[0], sizeof(stats_[]), "0%.2f", pocet2[1][0]);
			}else{
				format(stats_[0], sizeof(stats_[]), "%.2f", pocet2[1][0]);
			}

			if (pocet2[1][1] < 10.0)
			{
				format(stats_[1], sizeof(stats_[]), "000%.2f", pocet2[1][1]);
			}
			else if (pocet2[1][1] < 100.0)
			{
				format(stats_[1], sizeof(stats_[]), "00%.2f", pocet2[1][1]);
			}
			else if (pocet2[1][1] < 1000.0)
			{
				format(stats_[1], sizeof(stats_[]), "0%.2f", pocet2[1][1]);
			}else{
				format(stats_[1], sizeof(stats_[]), "%.2f", pocet2[1][1]);
			}

			if (pocet2[1][2] < 10.0)
			{
				format(stats_[2], sizeof(stats_[]), "0%.2f", pocet2[1][2]);
			}else{
				format(stats_[2], sizeof(stats_[]), "%.2f", pocet2[1][2]);
			}

			if (pocet2[1][1] > 0)
			{
				format(ratio_, sizeof(ratio_), "%.2f", pocet2[1][0] /pocet2[1][1]);
			}else{
				ratio_ = "-";
			}
			format(string, sizeof(string), "    Total Damage: %s | Total Injuries: %s | Total Teammate Damage: %s | Team Ratio: %s.", stats_[0], stats_[1], stats_[2], ratio_);
			
			fwrite(file, string);
			fwrite(file, "\r\n\r\n");
			//fclose(file);

			// Top Score 
			new Float:topdamage = GetPVarFloat(0, "cwdamage");
			new topkills = GetPVarInt(0, "cwkills");
			new Float:efficiency, Float:topefficiency;
			if (GetPVarFloat(0, "cwinjuries") > 0.0){
				topefficiency = GetPVarFloat(0, "cwdamage")/GetPVarFloat(0, "cwinjuries");
			} else {
				topefficiency = 0.0;
			}
			new Float:ratio, Float:topratio;
			if (GetPVarInt(0, "cwdeath") > 0){
				topratio = GetPVarInt(0, "cwkills")/float(GetPVarInt(0, "cwdeath"));
			} else {
				topratio = 0.0;
			}
			
			for(i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i))
				{
					if(GetPVarFloat(i, "cwdamage") > topdamage) topdamage = GetPVarFloat(i, "cwdamage"); 
					if(GetPVarInt(i, "cwkills") > topkills) topkills = GetPVarInt(i, "cwkills");
					if (GetPVarInt(i, "cwdeath") > 0){
						ratio = GetPVarInt(i, "cwkills")/float(GetPVarInt(i, "cwdeath"));
						if(ratio > topratio) topratio = ratio;
					}
					if(GetPVarFloat(i, "cwinjuries") > 0.0){
						efficiency = GetPVarFloat(i, "cwdamage")/GetPVarFloat(i, "cwinjuries");
						if(efficiency > topefficiency) topefficiency = efficiency;
					}
				}
			}
			new topdamageName[MAX_PLAYER_NAME];
			new topkillsName[MAX_PLAYER_NAME];
			new topratioName[MAX_PLAYER_NAME];
			new topefficiencyName[MAX_PLAYER_NAME];
			for(i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (IsPlayerConnected(i))
				{
					if(GetPVarFloat(i, "cwdamage") == topdamage)
					{
						GetPlayerName(i, topdamageName, MAX_PLAYER_NAME); 
					}
					if(GetPVarInt(i, "cwkills") == topkills)
					{
						GetPlayerName(i, topkillsName, MAX_PLAYER_NAME); 
					}
					if (GetPVarInt(i, "cwdeath") > 0)
					{
						ratio = GetPVarInt(i, "cwkills")/float(GetPVarInt(i, "cwdeath"));
						if(ratio == topratio) {
							GetPlayerName(i, topratioName, MAX_PLAYER_NAME);
						}
					}
					if(GetPVarFloat(i, "cwinjuries") > 0.0)
					{
						efficiency = GetPVarFloat(i, "cwdamage")/GetPVarFloat(i, "cwinjuries");
						if(efficiency == topefficiency) {
							GetPlayerName(i, topefficiencyName, MAX_PLAYER_NAME);
						}
						
					}
				}
			}
			if (score[0] == score[1]){ 
				format( string, sizeof(string), "Equal score of both teams! %i:%i (%i:%i)\r\n", score[0],score[1],soucet[0],soucet[1]);
				fwrite(file, string);
			}
			else if (score[0] > score[1]){
				format( string, sizeof(string), "Team %s has won this round! %i:%i (%i:%i)\r\n", ClanName[0],score[0],score[1],soucet[0],soucet[1]);
				fwrite(file, string);
			}
			else if (score[0] < score[1]){
				format( string, sizeof(string), "Team %s has won this round! %i:%i (%i:%i)\r\n", ClanName[1],score[0],score[1],soucet[0],soucet[1]);
				fwrite(file, string);
			} else {
				format( string, sizeof(string), "No winners in this round! %i:%i (%i:%i)\r\n", score[0],score[1],soucet[0],soucet[1]);
				fwrite(file, string);
			}
			format(string, sizeof(string), "Top damage: %s (%.2f)\r\n",
			topdamageName, topdamage);
			fwrite(file, string);
			format(string, sizeof(string), "Top kills: %s (%i)\r\n",
			topkillsName, topkills);
			fwrite(file, string);
			format(string, sizeof(string), "Top kill/death ratio: %s (%.2f)\r\n",
			topratioName, topratio);
			fwrite(file, string);
			format(string, sizeof(string), "Top efficiency: %s (%.2f)\r\n",
			topefficiencyName, topefficiency);
			fwrite(file, string);
		}	
		fclose(file);
	}
}

stock WriteCWResults()
{
	// Add CW Game results to logs database
	if(fexist("logs.db"))
	{
		new 
			TeamG[100],	TeamB[100],
			Rounds[6], TotalScore[32], KICK_LAGERS_State[24]
		;
		
		if(KICK_LAGERS == 0) KICK_LAGERS_State = "Off";
		else if (KICK_LAGERS == 1) KICK_LAGERS_State = "Warning";
		else if (KICK_LAGERS == 2) KICK_LAGERS_State = "Kick";
		else if (KICK_LAGERS == 3) KICK_LAGERS_State = "Movespec";
			
		format(Rounds, sizeof(Rounds), "%dx%d", Round, Roundkills);
		format(TotalScore, sizeof(TotalScore), "%s %d:%d %s",
		ClanName[0], soucet[0], soucet[1], ClanName[1]);
		foreach(Player, i)
		{
			if(GetPVarInt(i, "Team") == TEAM_GREEN) {
				format(TeamG, sizeof(TeamG), "%s %s", TeamG, PlayerName(i));
			}
			if(GetPVarInt(i, "Team") == TEAM_BLUE) {
				format(TeamB, sizeof(TeamB), "%s %s", TeamB, PlayerName(i));
			}
			//if(GetPVarInt(i, "Team") == TEAM_GREEN) strcat(TeamG, PlayerName(i));
			//if(GetPVarInt(i, "Team") == TEAM_BLUE) strcat(TeamB, PlayerName(i));
		}
		
		if(!strlen(TeamG) || !strlen(TeamB)) return 0;
		
		new szQuery[512];
		format(szQuery, sizeof(szQuery),
		"INSERT INTO CWlog (Datetime, TeamNameG, TeamNameB, TeamColorG, TeamColorB,\
		Map, Hitbox, Rounds, TeamG, TeamB, TotalScore, CAC, AntiLag) \
		VALUES ((datetime('now')), '%q', '%q', '%s', '%s', '%s', '%s', '%s', '%s', '%s',\
		'%q', '%s', '%s')",
		ClanName[0], ClanName[1], THC[0], THC[1], MapNames[Map],
		(lagcomp) ? ("Skinshot") : ("Lagshot"),
		Rounds, TeamG, TeamB, TotalScore,
		(AConly) ? "On" : "Off",
		KICK_LAGERS_State);
		db_query(dblogs, szQuery);
	}
	return 1;
}

stock ShowCWResults(playerid)
{
	// Show CW Game results from logs database
	if(!fexist("logs.db"))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Нет логов для отображения", "No logs to display");
		return 0;
	}
	
	new 
		datetime[32], tbtext[1024], tableitem[100],
		teamcolorg[16], teamcolorb[16],
		teamnameg[32], teamnameb[32]
	;
	
	new szQuery[512], DBResult: query;
	format(szQuery, sizeof(szQuery),
	"SELECT Datetime, TeamNameG, TeamNameB, TeamColorG, TeamColorB FROM CWlog \
	ORDER BY rowid DESC LIMIT 10");
	query =  db_query(dblogs, szQuery);
	new rows = db_num_rows(query);
	for(new i; i < rows; i++)
	{		
		db_get_field(query, 0, datetime, sizeof(datetime));
		format(datetime, sizeof(datetime), "%s", datetime);
		
		db_get_field(query, 1, teamnameg, sizeof(teamnameg));
		format(teamnameg, sizeof(teamnameg), "%s", teamnameg);
		
		db_get_field(query, 2, teamnameb, sizeof(teamnameb));
		format(teamnameb, sizeof(teamnameb), "%s", teamnameb);
		
		db_get_field(query, 3, teamcolorg, sizeof(teamcolorg));
		format(teamcolorg, sizeof(teamcolorg), "%s", teamcolorg);
	
		db_get_field(query, 4, teamcolorb, sizeof(teamcolorb));
		format(teamcolorb, sizeof(teamcolorb), "%s", teamcolorb);
		
		format(tableitem, sizeof(tableitem), "%s\t%s%s {FFFFFF}vs %s%s\n",
		datetime, teamcolorg, teamnameg, teamcolorb, teamnameb);
		strcat(tbtext, tableitem);
		db_next_row(query);
	}
	db_free_result(query);
	
	if(rows < 1)
	{
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Нет результатов для отображения", "No results to display");
	} else {
		return ShowPlayerDialog(playerid, 270, DIALOG_STYLE_TABLIST,
		"Cw game results", tbtext, "Select", "Cancel");
	}
}

stock ShowCWResultsFull(playerid, const timestamp[])
{
	// Show CW Game results from logs database
	if(!fexist("logs.db"))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Нет логов для отображения", "No logs to display");
		return 0;
	}
	
	new 
		tbtext[512], datetime[32], map[48],
		teamcolorg[16], teamcolorb[16],
		teamnameg[32], teamnameb[32],
		hitbox[32], rounds[32],
		teamg[100], teamb[100],
		totalscore[32], tmpstr[64],
		cac[16], antilag[16]
	;
	
	new szQuery[512], DBResult: query;
	format(szQuery, sizeof(szQuery),
	"SELECT Datetime, TeamNameG, TeamNameB, TeamColorG, TeamColorB, \
	Map, Hitbox, Rounds, TeamG, TeamB, TotalScore, CAC, AntiLag FROM CWlog WHERE Datetime = '%q' \
	ORDER BY rowid DESC LIMIT 1", timestamp);
	query =  db_query(dblogs, szQuery);
	new rows = db_num_rows(query);
		
	db_get_field(query, 0, datetime, sizeof(datetime));
	format(datetime, sizeof(datetime), "Date:\t%s\n", datetime);
	strcat(tbtext, datetime);
	
	db_get_field(query, 1, teamnameg, sizeof(teamnameg));
	format(teamnameg, sizeof(teamnameg), "%s", teamnameg);
	
	db_get_field(query, 2, teamnameb, sizeof(teamnameb));
	format(teamnameb, sizeof(teamnameb), "%s", teamnameb);
	
	db_get_field(query, 3, teamcolorg, sizeof(teamcolorg));
	format(teamcolorg, sizeof(teamcolorg), "%s", teamcolorg);
	
	db_get_field(query, 4, teamcolorb, sizeof(teamcolorb));
	format(teamcolorb, sizeof(teamcolorb), "%s", teamcolorb);
	
	format(tmpstr, sizeof(tmpstr), "Teams:\t%s%s {FFFFFF}vs %s%s\n",
	teamcolorg, teamnameg, teamcolorb, teamnameb);
	strcat(tbtext, tmpstr);
	
	db_get_field(query, 5, map, sizeof(map));
	format(map, sizeof(map), "Map:\t%s\n", map);
	strcat(tbtext, map);
	
	db_get_field(query, 6, hitbox, sizeof(hitbox));
	format(hitbox, sizeof(hitbox), "Hitbox:\t%s\n", hitbox);
	strcat(tbtext, hitbox);
	
	db_get_field(query, 7, rounds, sizeof(rounds));
	format(rounds, sizeof(rounds), "Mode:\t%s\n", rounds);
	strcat(tbtext, rounds);
	
	db_get_field(query, 8, teamg, sizeof(teamg));
	format(teamg, sizeof(teamg), "Team %s%s\t%s%s\n",
	teamcolorg, teamnameg, teamcolorg, teamg);
	strcat(tbtext, teamg);
	
	db_get_field(query, 9, teamb, sizeof(teamb));
	format(teamb, sizeof(teamb), "Team %s%s\t%s%s\n",
	teamcolorb, teamnameb, teamcolorb, teamb);
	strcat(tbtext, teamb);
	
	db_get_field(query, 10, totalscore, sizeof(totalscore));
	format(totalscore, sizeof(totalscore), "TotalScore:\t%s\n", totalscore);
	strcat(tbtext, totalscore);
	
	db_get_field(query, 11, cac, sizeof(cac));
	format(cac, sizeof(cac), "AC mode:\t%s\n", cac);
	strcat(tbtext, cac);
	
	db_get_field(query, 12, antilag, sizeof(antilag));
	format(antilag, sizeof(antilag), "Anti-Lag:\t%s\n", antilag);
	strcat(tbtext, antilag);
	
	db_free_result(query);
	
	if(rows < 1)
	{
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Нет результатов для отображения", "No results to display");
	} else {
		return ShowPlayerDialog(playerid, 271, DIALOG_STYLE_TABLIST,
		"Cw game results", tbtext, "Select", "Cancel");
	}
}

stock SetPlayerTeamEx(playerid, teamid)
{
	// extended SetPlayerTeam, sets playerid team with color and marker
	if(!Marker)	HidePlayerMarker(playerid, false);
	switch(teamid)
	{
		case 0: // TEAM_GREEN
		{
			SetPVarInt(playerid, "Team", 0);
			SetPlayerColor(playerid, TCC[0]);
			if(AntiTK) SetPlayerTeam(playerid, 0);
			else SetPlayerTeam(playerid, NO_TEAM);
		}
		case 1: // TEAM_BLUE
		{
			SetPVarInt(playerid, "Team", 1);
			SetPlayerColor(playerid, TCC[1]);
			if(AntiTK) SetPlayerTeam(playerid, 1);
			else SetPlayerTeam(playerid, NO_TEAM);
		}
		case 2: // TEAM_SPEC
		{
			SetPVarInt(playerid, "Team", 2);
			SetPlayerColor(playerid, TCC[2]);
			if(AntiTK) SetPlayerTeam(playerid, 2);
			else SetPlayerTeam(playerid, NO_TEAM);
		}
	}
	return teamid;
}

stock GameTextForPlayerEx(playerid, const ru[], const en[], time, style)
{
	if (string[0] == '\0' || (string[0] == '\1' && string[1] == '\0'))
	{
	    return GameTextForPlayer(playerid, " ", time, style);
	}
	if (pData[playerid][pLang] == 0)
	{
	    GameTextForPlayer(playerid, ru, time, style);
	}
	else if (pData[playerid][pLang] == 1)
	{
	    GameTextForPlayer(playerid, en, time, style);
	}
}

stock SendClientMessageEx(playerid, color, const ru[], const en[])
{
	if (pData[playerid][pLang] == 0)
	{
	    SendClientMessage(playerid, color, ru);
	}
	else if (pData[playerid][pLang] == 1)
	{
	    SendClientMessage(playerid, color, en);
	}
	return true;
}

stock SendClientMessageToAllEx(color, const ru[], const en[])
{
	for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
	    if (IsPlayerConnected(i))
	    {
	        SendClientMessageEx(i, color, ru, en);
	    }
	}
	return true;
}

stock SendClientMessageToVirtualWorld(worldid, color, const ru[], const en[])
{
	for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
	    if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == worldid)
	    {
	        SendClientMessageEx(i, color, ru, en);
	    }
	}
	return true;
}

stock SendAdMessageToAllEx(color, const ru[], const en[])
{
	foreach(Player, i)
	{
		if(!GetPVarType(i, "HideChatAds"))
		{
			SendClientMessageEx(i, color, ru, en);
		}
	}
	return true;
}

#if !defined _YSF_included
stock GetWeaponSlot(weaponid)
{
    switch(weaponid)
	{
	    case 0, 1: return 0;
	    case 2..9: return 1;
	    case 10..15: return 10;
	    case 16..18, 39: return 8;
	    case 22..24: return 2;
	    case 25..27: return 3;
	    case 28, 29, 32: return 4;
	    case 30, 31: return 5;
	    case 33, 34: return 6;
	    case 35..38: return 7;
	    case 41..43: return 9;
	    case 44..46: return 11;
	    default: return 12; // + 19, 20, 21, 40.
	}
	return 0;
}
#endif

stock GetPlayerID(const name[MAX_PLAYER_NAME])
{
	new GetPlayerID_NAME[MAX_PLAYER_NAME];
    for(new i = GetMaxPlayers() - 1; i != -1; i--)
    {
		if(!IsPlayerConnected(i)) continue;
		GetPlayerName(i, GetPlayerID_NAME, MAX_PLAYER_NAME);
		if(strcmp(name, GetPlayerID_NAME, true) == 0) return i;
    }
	return -1;
} 

stock PlayerName(playerid)
{
	// Return player login name
	new NickName[MAX_PLAYER_NAME]; 
	GetPlayerName(playerid, NickName, sizeof(NickName));
	return NickName;
}

stock PlayerAttachments(playerid, slot, attachid, savedata = true)
{
	// Attaches objets to the player
	// Note attachid is not objectid !! 
	// Slots 1-3 used for players, slots 5-9 used for costumes
	// 0 slot reserved for a global system needs
	switch(attachid)
	{
		case -1:
		{
			// Clear slot object
			if(IsPlayerAttachedObjectSlotUsed(playerid, slot))
			{
				RemovePlayerAttachedObject(playerid, slot);
				switch(slot)
				{
					case 0: pData[playerid][pAttachSlot0] = -1;
					case 1: pData[playerid][pAttachSlot1] = -1;
					case 2: pData[playerid][pAttachSlot2] = -1;
					case 3: pData[playerid][pAttachSlot3] = -1;
				}
			}
			// Clear costumes
			for(new s=5; s<MAX_PLAYER_ATTACHED_OBJECTS; s++)
			{
				if(IsPlayerAttachedObjectSlotUsed(playerid, s)) {
					RemovePlayerAttachedObject(playerid, s);
				}
			}
			
		}
		case 0: pData[playerid][pAttachSlot0] = -1;
		case 2: // Belarus hat
		SetPlayerAttachedObject(playerid, slot, 18946, 2,  0.142999, 0.0, -0.001000, 0.0, 0.0, 0.0,  1.000000, 1.000000, 1.000000);
