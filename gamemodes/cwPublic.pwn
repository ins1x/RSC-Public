	if (!strcmp(cmdtext, "/fps", true, 4))
	{
		if (Drunk > 0)
		{
		    SendClientMessageEx(playerid, COLOR_GREY,
			"Данная опция сейчас недоступна.", "FPS can't be detected with drunk level.");
		    return true;
		}
	    new PARAM, string[58];
		if (strlen(cmdtext) < 6)
		{
			PARAM = playerid;
		}else{
		    if (cmdtext[4] != ' ')
		    {
		        SendClientMessageEx(playerid, COLOR_GREY, "Использование: /fps <ID>", "Use: /fps <ID>");
		        return true;
		    }
		    format(string, 5, "%s", cmdtext[5]);
			PARAM = strval(string);
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY, "Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
		}
		if (GetPVarInt(PARAM, "fps") == 0)
		{
		    if (PARAM == playerid)
			{
		    	SendClientMessageEx(playerid, COLOR_GREY, "Невозможно определить FPS прямо сейчас.", "Your FPS are undetectable right now.");
			}else{
			    SendClientMessageEx(playerid, COLOR_GREY, "Невозможно определить FPS игрока прямо сейчас.", "Player's FPS are undetectable right now.");
			}
		    return true;
		}
		new FPS = GetPVarInt(PARAM, "fps");
	    if (FPS > 87)
	    {
	        FPS = 64;
	    }
	    else if (FPS < 23)
	    {
	        FPS = 0;
	    }else{
	        FPS -= 23;
	    }
	    new color1 = 256*256*(255-FPS*255/64) +256*(FPS*255/64);
	    new FPSstr[7];
	    if (color1 < 0x10000)
	    {
	        format(FPSstr, sizeof(FPSstr), "00%x", color1);
	    }
	    else if (color1 < 0x100000)
	    {
	        format(FPSstr, sizeof(FPSstr), "0%x", color1);
	    }else{
	        format(FPSstr, sizeof(FPSstr), "%x", color1);
	    }
		new stringen[58];
		if (PARAM == playerid)
		{
			format(string, sizeof(string), "У вас {%s}%d {FFFFFF}FPS.", FPSstr, GetPVarInt(PARAM, "fps"));
			format(stringen, sizeof(stringen), "You have {%s}%d {FFFFFF}FPS.", FPSstr, GetPVarInt(PARAM, "fps"));
		}else{
		    GetPlayerName(PARAM, name, sizeof(name));
		    format(string, sizeof(string), "%s(%d) с {%s}%d {FFFFFF}FPS.", name, PARAM, FPSstr, GetPVarInt(PARAM, "fps"));
		    format(stringen, sizeof(stringen), "%s(%d) has {%s}%d {FFFFFF}FPS.", name, PARAM, FPSstr, GetPVarInt(PARAM, "fps"));
		}
		SendClientMessageEx(playerid, COLOR_GREY, string, stringen);
		return true;
	}
	if (!strcmp(cmdtext, "/afk", true))
	{
		SendClientMessageEx(playerid, COLOR_GREY, "Использование: /afk [ID]", "Use: /afk [ID]");
		return true;
	}
	if (!strcmp(cmdtext, "/afk ", true, 5))
	{
	    if (!cmdtext[5])
		{
		    SendClientMessageEx(playerid, COLOR_GREY, "Использование: /afk [ID]", "Use: /afk [ID]");
			return true;
		}
		if (strlen(cmdtext[5]) > 5)
		{
		    strdel(cmdtext[5], 5, strlen(cmdtext[5]));
		}
		new PARAM = strval(cmdtext[5]);
		if (!IsPlayerConnected(PARAM))
		{
			SendClientMessageEx(playerid, COLOR_GREY, "Игрок не подключен либо вышел.", "This player isn't connected.");
			return true;
		}
		if (GetPlayerState(PARAM) != PLAYER_STATE_ONFOOT)
		{
		    SendClientMessageEx(playerid, COLOR_GREY, "Игрок не заспавнился.", "The player isn't spawned.");
		    return true;
		}
		tick = GetTickCount();
		if (GetPVarInt(PARAM, "afk") < tick -4000)
		{
		    new Float: hod = (tick -GetPVarInt(PARAM, "afk")) /3600000.0;
			new Float: minu = (hod -floatround(hod, floatround_floor)) *60.0;
			new Float: secu = (minu -floatround(minu, floatround_floor)) *60.0;
			new Float: set = (secu -floatround(secu, floatround_floor)) *1000.0;
			new cas[15];
			if (hod < 10)
			{
				format(cas, sizeof(cas), "0%.0f", hod);
			}else{
			    format(cas, sizeof(cas), "%.0f", hod);
			}
			if (minu < 10)
			{
			    format(cas, sizeof(cas), "%s:0%.0f", cas, minu);
			}else{
			    format(cas, sizeof(cas), "%s:%.0f", cas, minu);
			}
			if (secu < 10)
			{
			    format(cas, sizeof(cas), "%s:0%.0f", cas, secu);
			}else{
			    format(cas, sizeof(cas), "%s:%.0f", cas, secu);
			}
			if (set < 10)
			{
			    format(cas, sizeof(cas), "%s.00%.0f", cas, set);
			}
			else if (set < 100)
			{
			    format(cas, sizeof(cas), "%s.0%.0f", cas, set);
			}else{
			    format(cas, sizeof(cas), "%s.%.0f", cas, set);
			}
			GetPlayerName(PARAM, name, sizeof(name));
			new stringru[58];
			format(stringru, sizeof(stringru), "%s(%d) находится в АФК уже %s.", name, PARAM, cas);
			new stringen[58];
			format(stringen, sizeof(stringen), "%s(%d) has been AFK for %s.", name, PARAM, cas);
			SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
		}else{
			GetPlayerName(PARAM, name, sizeof(name));
		    new stringru[40];
			format(stringru, sizeof(stringru), "%s(%d) не в АФК.", name, PARAM);
			new stringen[41];
			format(stringen, sizeof(stringen), "%s(%d) isn't AFK.", name, PARAM);
			SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
		}
	    return true;
	}
