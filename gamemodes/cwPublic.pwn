	if (dialogid == 179)
	{
		if(response)
		{
			new skinid = strval(inputtext);
			new worldid = GetPlayerVirtualWorld(playerid);
			
			if (IsPlayerInAnyVehicle(playerid)){
				return SendClientMessage(playerid, COLOR_GREY, "Exit from vehicle!");
			}
			if(skinid < 0 || skinid >= 300 || skinid == 74) {
				return 0;
			}
			if(!World[worldid][wBagoskins] || worldid == 0)
			{
				switch(skinid)
				{
					case 0,1,2,74,86,92,99,149,265,266,267,268,269,270,271,272:
					{
						return 0;
					}
				}
			}
			foreach(Player, i)
			{
				new team = GetPVarInt(i, "Team");
				if(team == ChosenTeam[playerid])
				{
					SetPlayerSkin(i, skinid);
					SetSpawnInfo(i, 0, GetPlayerSkin(i),
					CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
					0, 0, 0, 0, 0, 0, 0);
				}
			}

			new stringen[128], stringru[128];
			format(stringen, sizeof stringen, "%s(%d) has changed team %s skins to #%i",
			PlayerName(playerid), playerid, ClanName[ChosenTeam[playerid]],skinid);
			format(stringru, sizeof stringru, "%s(%d) сменил команде %s скин на #%i",
			PlayerName(playerid), playerid, ClanName[ChosenTeam[playerid]],skinid);
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
	}
	if (dialogid == 180) // offline /setadmin
	{
		if(response)
		{
			new lvl = strval(inputtext);
			if (GetPVarInt(playerid, "Admin") < 3) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 3+ уровня!",
				"To use these functions you need to have 3+ level admin rights!");
			}
			if (lvl < 0 || lvl > 4)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное значение!",
				"Invalid value!");
			}
			if(lvl >= GetPVarInt(playerid, "Admin")) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете выставить уровень админки равный либо выше вашего!",
				"You cannot set the admin level to be equal to or higher than yours!");
			}
			new string[128], nickname[MAX_PLAYER_NAME];
			GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
			
			new szQuery[256];
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Admin = %i WHERE (Nickname = '%q')", lvl, db_escape(nickname));
			db_query(dbaccounts, szQuery);
		
			if (lvl == 1 || lvl == 2 || lvl == 3)
			{
				format(string, sizeof(string), "%s(%d) has set %s's admin level to %d",
				PlayerName(playerid), playerid, nickname, lvl);
				SendSystemMessage(string);
				AdminActionsLog(string);
			}
			else if (lvl == 0)
			{
				format(string, sizeof(string), "%s(%d) has deleted %s's admin rights.",
				PlayerName(playerid), playerid, nickname);
				SendSystemMessage(string);
				AdminActionsLog(string);
			}
		}
	}
	if(dialogid == 181) //offline unmute
	{
		if(response)
		{
			new nickname[MAX_PLAYER_NAME];
			GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
			
			if(fexist("accounts.db"))
			{
				new szQuery[128], DBResult: query;
				format(szQuery, sizeof(szQuery),
				"SELECT Muted FROM Accounts WHERE (Nickname = '%q')",
				db_escape(nickname));
				query = db_query(dbaccounts, szQuery);
				if(db_num_rows(query))
				{
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET Muted = 0 WHERE (Nickname = '%q')",
					db_escape(nickname));
					db_free_result(query);
				} else { 
					SendClientMessage(playerid, COLOR_GREY, "Error: Account not found");
				}
			}
			OFFLINE_ACC(playerid);
		}
	}
	if(dialogid == 182) //offline unban
	{
		if(response)
		{
			new string[128], p_lastip[16+1], p_serial[41];
			new nickname[MAX_PLAYER_NAME];
			GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
			
			/*if(fexist("core.db"))
			{
				new szQuery[128], DBResult: query;
				
				format(szQuery, sizeof(szQuery),
				"SELECT IpBan FROM Banlist WHERE (Serial = '%s')", p_serial);
				query = db_query(dbcore, szQuery);
				if(db_num_rows(query))
				{
					format(szQuery, sizeof(szQuery),
					"DELETE FROM Banlist WHERE (Serial = '%s')", p_serial);
					query = db_query(dbcore, szQuery);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Снят бан по железу", "Reset hardware ban");
				}
				db_free_result(query);
			}*/
			
			
			if(fexist("accounts.db"))
			{
				new szQuery[256], DBResult: query;
				format(szQuery, sizeof(szQuery),
				"SELECT Serial, Lastip, Banned FROM Accounts WHERE (Nickname = '%q')",
				db_escape(nickname));
				query = db_query(dbaccounts, szQuery);
				if(db_num_rows(query))
				{
					db_get_field(query, 0, p_serial, sizeof(p_serial));
					db_get_field(query, 1, p_lastip, sizeof(p_lastip));
					new banned = db_get_field_int(query, 2);
					
					if(banned)
					{
						format(szQuery, sizeof(szQuery),
						"UPDATE Accounts SET Banned = 0 WHERE (Nickname = '%q')",
						db_escape(nickname));
						query = db_query(dbaccounts, szQuery);
					
						format(szQuery, sizeof(szQuery),
						"UPDATE Banlist SET IpBan = 0 WHERE (Serial = '%s')", db_escape(p_serial));
						query = db_query(dbcore, szQuery);
						
						#if defined _YSF_included
						if(IsBanned(p_lastip)){
							format(string, sizeof string, "unbanip %s", p_lastip);
							SendRconCommand(string);
						}
						#endif
						
						format(string, sizeof(string), "%s(%d) has unban %s account (IP: %s)",
						PlayerName(playerid), playerid, nickname, p_lastip);
						SendSystemMessage(string);
						AdminActionsLog(string);
					}
					
					db_free_result(query);
				}
			}
		}
	}
	if(dialogid == 183) // ban offline acc
	{
		if(response)
		{
			new string[128], nickname[MAX_PLAYER_NAME];
			GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
			
			/* #if defined _YSF_included
			if(IsBanned(p_lastip)){
				SendClientMessageEx(playerid, COLOR_GREY,
				"Аккаунт уже был забанен. IP найден в samp.ban",
				"The account has is banned. IP found in samp.ban");
			} else {
				format(string, sizeof string, "banip %s", p_lastip);
				SendRconCommand(string);
			}
			#endif */
			
			new szQuery[256], DBResult: query;	
			new adminlvl, serial[41], lastip[16];
			format(szQuery, sizeof(szQuery),
			"SELECT Admin, Serial, Lastip FROM Accounts WHERE (Nickname = '%q')",
			db_escape(nickname));
			query = db_query(dbaccounts, szQuery);
			if(db_num_rows(query))
			{
				adminlvl = db_get_field_int(query, 0);
				if(adminlvl >= GetPVarInt(playerid, "Admin"))
				{
					db_free_result(query);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Вы не можете забанить администратора выше уровня",
					"You cannot ban admin above level");
					return 0;
				}
				db_get_field(query, 1, serial, sizeof(serial));
				db_get_field(query, 2, lastip, sizeof(lastip));
				db_free_result(query);
			} else {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Аккаунт с таким именем не найден",
				"Account not founded");
				db_free_result(query);
				return 1;
			}
			
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Banned = 1 WHERE (Nickname = '%q')",
			db_escape(nickname));
			query = db_query(dbaccounts, szQuery);
			db_free_result(query);
			
			new date[14], year, month, day;	getdate(year, month, day);
			format(date, sizeof(date), "%d.%d.%d", year, month, day);
			
			format(szQuery, sizeof(szQuery),
			"INSERT INTO Banlist (Nickname, Serial, IpBan, IP, Date, Reason) \
			VALUES('%s','%s',%i,'%s','%s','%s')",
			nickname, serial, 1, lastip, date, "by Administrator N/A");
			db_query(dbcore, szQuery);
			
			format(string, sizeof(string), "%s(%d) has offline ban %s account (IP: %s)",
			PlayerName(playerid), playerid, nickname, lastip);
			SendSystemMessage(string);
			AdminActionsLog(string);
			OFFLINE_ACC(playerid);
		}
	}
	if(dialogid == 184) //hijack player
	{
		if(response)
		{
			if(!strlen(inputtext)) return 0;
			if(!isnumeric(inputtext)) return 0;
			if(GetPVarInt(playerid, "Admin") < 3) return 0;
			
			if(strval(inputtext) == INVALID_PLAYER_ID) return 0;
			
			if(GetPlayerState(strval(inputtext)) == PLAYER_STATE_DRIVER ||
			GetPlayerState(strval(inputtext)) == PLAYER_STATE_PASSENGER)
			{
				new Float:x, Float:y, Float:z;
				GetPlayerPos(strval(inputtext), x, y, z);
				SetPlayerPos(strval(inputtext), x, y, z+1);
			}
		}
	}
	if(dialogid == 185) //veh create all
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			
			if(!strlen(inputtext)) return 0;
			//if(!isnumeric(inputtext)) return 0;
			if (strlen(inputtext) < 3)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /v [Vehicle ID or Vehicle Name]",
				"Use: /v [Vehicle ID or Vehicle Name]");
			}
			
			if(GetPlayerVirtualWorld(playerid) == 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Можно использовать только в виртуальном мире",
				"Can only be used in the virtual world");
				return true;
			}
			
			if(!WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
			
			if(worldid != 0)
			{
				if(!World[worldid][wVehicles] && !WorldModerator[playerid])
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Использование транспорта в мире было запрещено.",
					"Using transport in virtual world was forbidden.");
				}
			}
			
			foreach(Player, p)
			{
				if(GetPlayerVirtualWorld(p) == worldid)
				{
					if(!isnumeric(inputtext)) 
					{
						for(new i = 0; i < sizeof(VehicleNames); i++)
						{
							if(!strcmp(inputtext, VehicleNames[i], true)) 
							{
								SpawnPlayerVehicle(p, VehicleIds[i]);
								return true;
							}
						}
					} else {
						SpawnPlayerVehicle(p, strval(inputtext));
						return true;
					}
				}
			}
		}
	}
