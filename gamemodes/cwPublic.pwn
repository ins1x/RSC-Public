						} else {
							ShowBodyLabel = true;
							foreach(Player, i)
							{
								Delete3DTextLabel(BodyLabel[i]);
								BodyLabel[i] = Create3DTextLabel("_", 0x008080FF, 0, 0, 0, TXT_DRAW_DISTANCE, 0, 1);
    							Attach3DTextLabelToPlayer(BodyLabel[i], i, 0.0, 0.0, -0.955);
							}
							SendClientMessageEx(playerid,COLOR_GREY,
							"Вы включили отображение FPS и Ping на игроке",
							"You enabled the display of FPS and Ping on the player");
						}						
						SendClientMessageEx(playerid,COLOR_GREY,
						"Требуется перезагрузка чтобы изменения вступили в силу для всех игроков",
						"Reboot required for changes to take effect for all players");
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have 3+ level admin rights!");
					}
					MODSET_MENU(playerid);
				}
				case 1:
				{
					if (GetPVarInt(playerid, "Admin") >= 3)
					{
						if(ShowEnemyBar) {
							ShowEnemyBar = false;
							SendClientMessageEx(playerid,COLOR_GREY,
							"Вы отключили отображение информации о сопернике над радаром",
							"You disabled information about the opponent above the radar");
						} else {
							ShowEnemyBar = true;
							SendClientMessageEx(playerid,COLOR_GREY,
							"Вы включили отображение FPS и Ping на игроке",
							"You enabled information about the opponent above the radar");
						}
						SendClientMessageEx(playerid,COLOR_GREY,
						"Информация появляется только при уроне сопернику",
						"Information appears only when the opponent is damaged");
					} else {
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have 3+ level admin rights!");
					}
					MODSET_MENU(playerid);
				}
				case 2: 
				{
					ShowPlayerDialog(playerid, 154, DIALOG_STYLE_INPUT, "Tag and labels draw distance",
					"Default value 70, Recommended 25\nEnter distance (1-400):", "Confirm", "Cancel");
				}
				case 3:
				{
					if(ToggleNameTags)
					{
						foreach(Player, i) ShowPlayerNameTagForPlayer(playerid, i, false);
						ToggleNameTags = false;
						SendClientMessageEx(playerid,COLOR_GREY,
						"Вы отключили отображение полосок здоровья и полос брони над игроками",
						"Disable the drawing of health bars and armor bars above player");
					} else {
						foreach(Player, i) ShowPlayerNameTagForPlayer(playerid, i, true);
						ToggleNameTags = true;
						SendClientMessageEx(playerid,COLOR_GREY,
						"Вы включили отображение полосок здоровья и полос брони над игроками",
						"Enable the drawing of health bars and armor bars above player");
					}
					SendClientMessageEx(playerid,COLOR_GREY,
					"Требуется перезагрузка чтобы изменения вступили в силу для всех игроков",
					"Reboot required for changes to take effect for all players");
					MODSET_MENU(playerid);
				}
			}
		} else {
			if(GetPVarInt(playerid, "Admin") >= 2) MODSET_MENU(playerid);
		}
	}
