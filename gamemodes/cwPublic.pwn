						SendSystemMessage(string);
					}
					else return SendClientMessageEx(playerid, COLOR_RED, "Для использования этих функций Вы должны быть администратором 3 уровня!", "To use these functions you need to have 3 level admin rights!");
				}
				case 14:
				{
					SendClientMessage(playerid, -1, "See also:  https://www.open.mp/docs/server/ControllingServer");
					ShowPlayerDialog(playerid, 15, DIALOG_STYLE_INPUT,
					"RCON",
					"{FF3333}hostname [name]{FFFFFF} change the hostname text (example: hostname RSC).\n\
					{FF3333}gamemodetext [name]{FFFFFF} change the gamemode text (example: gamemodetext CwPublicStable).\n\
					{FF3333}mapname [name]{FFFFFF} change the map name text (example: mapname Dust2).\n\
					{FF3333}exec [filename]{FFFFFF} Executes the file which contains server cfg (example: exec blah.cfg).\n\
					{FF3333}kick [ID]{FFFFFF} Kick the player with the given ID (example: kick 2).\n\
					{FF3333}ban [ID]{FFFFFF} Ban the player with the given ID (example: ban 2).\n\
					{FF3333}changemode [mode]{FFFFFF} This command will change the current gamemode (example: changemode CwPublicStable).\n\
					{FF3333}gmx{FFFFFF} Will load the next gamemode in server.cfg.\n\
					{FF3333}reloadbans{FFFFFF} Reloads the samp.ban file (Should be used after unbanning and IP address).\n\
					{FF3333}reloadlog{FFFFFF} Reloads the server_log.txt.\n\
					{FF3333}say{FFFFFF} shows a message to the players in the client-console (example: say hello will show as Admin: hello).\n\
					{FF3333}players{FFFFFF} Shows the players that are in the server (with their name, IP and ping).\n\
					{FF3333}banip [IP]{FFFFFF} Ban the given IP (example: banip 127.0.0.1).\n\
					{FF3333}unbanip [IP]{FFFFFF} Unban the given IP (example: unbanip 127.0.0.1).\n\
					{FF3333}weather [ID]{FFFFFF} Changes the weather (example: weather 1).\n\
					{FF3333}loadfs{FFFFFF} Loads the given filterscript (example: loadfs adminfs).\n\
					{FF3333}weburl [server url]{FFFFFF} Changes the server URL in the SA-MP client.\n\
					{FF3333}unloadfs{FFFFFF} Unload the given filterscript (example: unloadfs adminfs).\n\
					{FF3333}reloadfs{FFFFFF} Reloads the given filterscript (example: reloadfs adminfs).\n\
					{FF3333}password [password]{FFFFFF} Sets/resets the server password\n\
					{FF3333}messageslimit [count]{FFFFFF} Change the number of messages per second a client sends to the server. (default 500)\n\
					{FF3333}ackslimit [count]{FFFFFF} Change the limit of acks (default 1000)\n\
					{FF3333}messageholelimit [count]{FFFFFF} Change the limit of message holes (default 3000)\n\
					{FF3333}playertimeout [limit m/s]{FFFFFF} Change the time in ms. until a player not sending any packets. (default 1000)\n\
					{FF3333}language [language]{FFFFFF} Change the server language (example: language English). Shown in SA-MP-client.\n\n\
					Enter RCON command:","Exec", "Cancel");
				}
				case 15:
				{
					if(GetPVarInt(playerid, "Admin") < 3)
					{
						return SendClientMessageEx(playerid, COLOR_RED, "Для использования этих функций Вы должны быть администратором 3 уровня!", "To use these functions you need to have 3 level admin rights!");
					}
					
					new tbtext[1024], buffer[100];
					if(pData[playerid][pLang]) {
						strcat(tbtext, "{AFAFAF}#  {FFFFFF}Name\t{AFAFAF}Gamemode\t{FFFFFF}Status\n");
					}
					else strcat(tbtext, "{AFAFAF}#  {FFFFFF}Название\t{AFAFAF}Режим\t{FFFFFF}Статус\n");
					
					for(new slot=1; slot < MAX_WORLD_SLOTS; slot++)
					{
						new worldmode[24];
						format(worldmode, sizeof(worldmode), "{AFAFAF}%s",
						WorldModes[World[slot][wGamemode]]);
						
						new worldname[24];
						if(strlen(World[slot][wName])) {
						format(worldname, sizeof(worldname), "%s",World[slot][wName]);
						}
						else format(worldname, sizeof(worldname), "%s", MapNames[World[slot][wMap]]);
						
						if(pData[playerid][pLang]) 
						{
							if(World[slot][wHosted] != -1)
							{
								format(buffer, sizeof(buffer),
								"{AFAFAF}%d  {FFFFFF}%s\t%s\t%s\n",
								slot, worldname, worldmode,
								(World[slot][wLocked]) ? ("{FF0000}[Locked]") : ("{00FF00}[Open]"));
							} else {
								format(buffer, sizeof(buffer),
								"{AFAFAF}%d  {AFAFAF}[Free slot]\t\t\n", slot);
							}
						} else {
							if(World[slot][wHosted] != -1)
							{
								format(buffer, sizeof(buffer),
								"{AFAFAF}%d  {FFFFFF}%s\t%s\t%s\n",
								slot, worldname, worldmode,
								(World[slot][wLocked]) ? ("{FF0000}[Закрыт]") : ("{00FF00}[Открыт]"));
							} else {
								format(buffer, sizeof(buffer),
								"{AFAFAF}%d  {AFAFAF}[Свободный слот]\t\t\n", slot);
							}
						}
						strcat(tbtext, buffer);
					}
					
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 377, DIALOG_STYLE_TABLIST_HEADERS,
						"Wipe world", tbtext, "Select", "Cancel");
					} else {
						ShowPlayerDialog(playerid, 377, DIALOG_STYLE_TABLIST_HEADERS,
						"Вайпнуть мир", tbtext, "Выбрать", "Отмена");
					}
					return true;
				}
				case 16:
				{
					ShowPlayerDialog(playerid, 118, DIALOG_STYLE_LIST,
					"Restart Server",
					"Restart server\n\
					{00FF00}Back to previous mod version\n\
