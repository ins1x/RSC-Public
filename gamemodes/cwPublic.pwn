	if (!strcmp(cmdtext, "/weather", true))
	{
	    SendClientMessageEx(playerid, COLOR_GREY,
		"Использование: /weather [№ погоды]",
		"Use: /weather [weather ID]");
		SendClientMessageEx(playerid, COLOR_GREY,
		"Погода с наилучшими показателями FPS - /fpsweather",
		"Weather for the best FPS perfomance - /fpsweather");
		
