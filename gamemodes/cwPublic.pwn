					fwrite(tmpfile, buffer);
					
					format(buffer, sizeof(buffer),
					"\t{%.2f, %.2f, %.2f, %.2f}, //GREEN\r\n",
					CwMaps[0][TEAM_GREEN][0], 
					CwMaps[0][TEAM_GREEN][1],
					CwMaps[0][TEAM_GREEN][2],
					CwMaps[0][TEAM_GREEN][3]);
					fwrite(tmpfile, buffer);
					
					format(buffer, sizeof(buffer),
					"\t{%.2f, %.2f, %.2f, %.2f}, //BLUE\r\n",
					CwMaps[0][TEAM_BLUE][0], 
					CwMaps[0][TEAM_BLUE][1],
					CwMaps[0][TEAM_BLUE][2],
					CwMaps[0][TEAM_BLUE][3]);
					fwrite(tmpfile, buffer);
					
					format(buffer, sizeof(buffer),
					"\t{%.2f, %.2f, %.2f, %.2f} //SPEC\r\n",
					CwMaps[0][TEAM_SPEC][0], 
					CwMaps[0][TEAM_SPEC][1],
					CwMaps[0][TEAM_SPEC][2],
					CwMaps[0][TEAM_SPEC][3]);
					fwrite(tmpfile, buffer);
					fwrite(tmpfile, "},\r\n");
					
					fclose(tmpfile);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Карта сохранена в /scriptfiles/newmaps.pwn",
					"Map saved to /scriptfiles/newmaps.pwn");
				}
			}
		}
	}
