					"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 1: //fast 
				{
					#if defined _sampcac_included
					new status = CAC_GetGlitchStatus(CAC_GLITCH__FASTFIRE);
					if(status)
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Fast fire был запрещен", "Fast fire was forbidden");
						CAC_SetGlitchStatus(CAC_GLITCH__FASTFIRE, 0);
					}
					else
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Fast fire был разрешен", "Fast fire was allowed");
						CAC_SetGlitchStatus(CAC_GLITCH__FASTFIRE, 1);
					}
					#else
					SendClientMessageEx(playerid, COLOR_GREY,
					"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 2:
				{
					#if defined _sampcac_included
					new status = CAC_GetGameOptionStatus(CAC_GAMEOPTION__SPRINT);
					if(status == 0)
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Спринт на всех поверхностях был разрешен",
						"Sprint on all surfaces (+ interiors) was enabled.");
						SendClientMessageToAllEx(COLOR_GREY,
						"Для использования требуется установленный клео-скрипт",
						"To use it, a client-side cleo script must be installed");
						CAC_SetGameOptionStatus(CAC_GAMEOPTION__SPRINT, 1);
					}
					else
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Спринт только на определенных поверхностях (Стандарт GTA:SA)",
						"Sprint on certain surfaces only (Default GTA:SA)");
						CAC_SetGameOptionStatus(CAC_GAMEOPTION__SPRINT, 0);
					}
					#else
					SendClientMessageEx(playerid, COLOR_GREY,
					"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 3:
				{
					#if defined _sampcac_included
					new status = CAC_GetGameOptionStatus(CAC_GAMEOPTION__INFINITESPRINT);
					if(status)
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Бесконечный спринт был запрещен",
						"Infinite sprint was forbidden (swimming too)");
						CAC_SetGameOptionStatus(CAC_GAMEOPTION__INFINITESPRINT, 0);
					}
					else
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Бесконечный спринт был разрешен",
						"Infinite sprint was allowed (swimming too)");
						SendClientMessageToAllEx(COLOR_GREY,
						"Для использования требуется установленный клео-скрипт",
						"To use it, a client-side cleo script must be installed");
						CAC_SetGameOptionStatus(CAC_GAMEOPTION__INFINITESPRINT, 1);
					}
					#else
					SendClientMessageEx(playerid, COLOR_GREY,
					"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 4: 
				{
					#if defined _sampcac_included
					new status = CAC_GetGlitchStatus(CAC_GLITCH__QUICKSTAND);
					if(status)
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Qickstand был запрещен", "Qickstand was forbidden");
						CAC_SetGlitchStatus(CAC_GLITCH__QUICKSTAND, 0);
					}
					else
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Qickstand был разрешен", "Qickstand was allowed");
						CAC_SetGlitchStatus(CAC_GLITCH__QUICKSTAND, 1);
					}
					#else
					SendClientMessageEx(playerid, COLOR_GREY,
					"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 5: 
				{
					#if defined _sampcac_included
					new status = CAC_GetGlitchStatus(CAC_GLITCH__FASTMOVE);
					if(status)
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Fastmove был запрещен", "Fastmove was forbidden");
						CAC_SetGlitchStatus(CAC_GLITCH__FASTMOVE, 0);
					}
					else
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Fastmove был разрешен", "Fastmove was allowed");
						CAC_SetGlitchStatus(CAC_GLITCH__FASTMOVE, 1);
					}
					#else
					SendClientMessageEx(playerid, COLOR_GREY, 
					"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 6:
				{
					#if defined _sampcac_included
					if(CAC_KICK_MODDED_PEDIFP)
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"Модифицированный PED.IFP был разрешен", "Modified PED.IFP was allowed");
						CAC_KICK_MODDED_PEDIFP = false;
					} else {
						SendClientMessageToAllEx(COLOR_GREY,
						"Модифицированный PED.IFP был запрещен", "Modified PED.IFP was forbidden");
						CAC_KICK_MODDED_PEDIFP = true;
						foreach(Player, i)
						{
							if(GetPVarInt(i, "CacModPED") > 0)
							{
								KickPlayerEx(i, "[SAMPAC] Modded PED.IFP");
							}
						}
					}
					#else
						SendClientMessageEx(playerid, COLOR_GREY,
						"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 7:
				{
					#if defined _sampcac_included
					if(CAC_KICK_CLEO)
					{
						SendClientMessageToAllEx(COLOR_GREY,
						"CLEO был разрешен", "CLEO was allowed");
						CAC_KICK_CLEO = false;
					} else {
						SendClientMessageToAllEx(COLOR_GREY,
						"CLEO был запрещен", "CLEO was forbidden");
						CAC_KICK_CLEO = true;
						foreach(Player, i)
						{
							if(GetPVarInt(i, "CacCLEO") > 0)
							{
								KickPlayerEx(i, "[SAMPAC] detect CLEO Library");
							}
						}
					}					
					#else
						SendClientMessageEx(playerid, COLOR_GREY,
						"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 8: 
				{
					#if defined _sampcac_included
						new tbtext[64];
						new status = CAC_GetGameResourceReportType();
						if(status == CAC_GAMERESOURCE_REPORTTYPE__FULL) {
							format(tbtext, 64, "{00FF00}Full\nOnly if modded\nDisabled");
						}
						if(status == CAC_GAMERESOURCE_REPORTTYPE__ONLY_IF_MODDED){
							format(tbtext, 64, "Full\n{00FF00}Only if modded\nDisabled");
						}
						if(status == CAC_GAMERESOURCE_REPORTTYPE__DISABLED){
							format(tbtext, 64, "Full\nOnly if modded\n{00FF00}Disabled");
						}
						ShowPlayerDialog(playerid, 151, DIALOG_STYLE_LIST,
						"SAMPCAC Reporttype", tbtext, "Select", "Cancel");
					#else
						SendClientMessageEx(playerid, COLOR_GREY,
						"Функция недоступна без SAMPCAC","Feature not available without SAMPCAC");
					#endif
				}
				case 9:
				{
					#if defined _sampcac_included
						new tbtext[400];
						new type_peds, type_vehs, type_weap, type_oth, type_pedifp, type_all;
						type_peds = CAC_GetGameResourceReportStatus(CAC_GAMERESOURCE_MODELTYPEFLAG__PEDS);
						type_vehs = CAC_GetGameResourceReportStatus(CAC_GAMERESOURCE_MODELTYPEFLAG__VEHICLES);
						type_weap = CAC_GetGameResourceReportStatus(CAC_GAMERESOURCE_MODELTYPEFLAG__WEAPONS);
						type_oth = CAC_GetGameResourceReportStatus(CAC_GAMERESOURCE_MODELTYPEFLAG__OTHERS);
						type_pedifp = CAC_GetGameResourceReportStatus(CAC_GAMERESOURCE_MODELTYPEFLAG__PEDIFP);
						type_all = CAC_GetGameResourceReportStatus(CAC_GAMERESOURCE_MODELTYPEFLAG__ALL);

						format(tbtext, sizeof(tbtext), 
						"option\tdescription\tstatus\n\
						PEDS\tped/skin models (0.3.7 only skins are included)\t%d\n\
						VEHICLES\tvehicle models (paintjobs are not included)\t%d\n\
						WEAPONS\tweapon models\t%d\n\
						OTHERS\tremaining models (eg: buildings, fences, streets etc)\t%d\n\
						PEDIFP\tped.ifp file (anim)\t%d\n\
						ALL\tinclude all\t%d\n",
						type_peds, type_vehs, type_weap, type_oth, type_pedifp, type_all);  
						
						ShowPlayerDialog(playerid, 152, DIALOG_STYLE_TABLIST_HEADERS,
						"SAMPCAC Model type", tbtext, "Select", "Cancel");
					#endif
				}
				case 10:
				{
					SendRconCommand("loadfs sampcac_base");
					SendRconCommand("loadfs sampcac_gameresource");
					SendClientMessageToAllEx(COLOR_GREY,
					 "Администратор загрузил SAMPCAC", "Administrator load SAMPCAC");
				}
				case 11:
				{
					SendRconCommand("unloadfs sampcac_base");
					SendRconCommand("unloadfs sampcac_gameresource");	
					SendClientMessageToAllEx(COLOR_GREY,
					 "Администратор выгрузил SAMPCAC", "Administrator unload SAMPCAC");
				}
			}
		}
		else AC_MENU(playerid);
	}
	if(dialogid == 56) //sethp
	{
		if(response)
		{
			if(strlen(inputtext) > 3) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Максимум 3 символа","Maximum 3 symbols");
			}
			if (IsPlayerConnected(strval(inputtext))) ChosenPlayer[playerid] = strval(inputtext);
			if (pData[playerid][pLang] == 0) {
				ShowPlayerDialog(playerid,57,DIALOG_STYLE_INPUT, "Sethp","Введите кол-во hp [0-100]?","OK","Закрыть");
			} else {
				ShowPlayerDialog(playerid,57,DIALOG_STYLE_INPUT, "Sethp","How much to add hp [0-100]?","OK","Close");
			}
		}
	}
	if(dialogid == 57) //sethp
	{
		if(response)
		{
			if(strlen(inputtext) > 3) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Максимум 3 символа","Maximum 3 symbols");
			}
			if(strval(inputtext) == 0) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Не должно быть равно 0","Must not be equal to 0");
			}
			new PARAM = ChosenPlayer[playerid];
			SetPlayerHealth(ChosenPlayer[playerid],strval(inputtext));
			new stringen[128], stringru[128];
			format(stringen, sizeof(stringen), "%s(%d) has set %s's(%d) health to %d.", PlayerName(playerid), playerid, PlayerName(PARAM), PARAM, strval(inputtext));
			format(stringru, sizeof(stringru), "%s(%d) выставил игроку %s(%d) %d хп.", PlayerName(playerid), playerid, PlayerName(PARAM), PARAM, strval(inputtext));
			SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		}
	}
	if(dialogid == 58) //setarm
	{
		if(response)
		{
			if(strlen(inputtext) > 3) return SendClientMessageEx(playerid, COLOR_GREY, "Максимум 3 символа","Maximum 3 symbols");
			if (IsPlayerConnected(strval(inputtext))) ChosenPlayer[playerid] = strval(inputtext);
			if (pData[playerid][pLang] == 0) {
				ShowPlayerDialog(playerid,59,DIALOG_STYLE_INPUT,
				"Setarm","Введите кол-во брони [0-100]?","OK","Закрыть");
			} else {
				ShowPlayerDialog(playerid,59,DIALOG_STYLE_INPUT,
				"Sethp","How much to add armour [0-100]?","OK","Close");
