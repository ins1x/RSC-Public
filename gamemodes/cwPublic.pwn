}
forward strexplode(output[][], const input[], const delimiter[] = !",",
limit = cellmax, bool:trim = true,bool:ignorecase = false,
size1 = sizeof(output), size2 = sizeof(output[]));// Split a string by a given delimiter
forward strreplace(string[], const search[], const replacement[],
bool:ignorecase = false, pos = 0, limit = -1, maxlength = sizeof(string));
#endif

