			if(worldid != 0)
			{
				if(World[worldid][wLocked])
				{
					return SendClientMessageEx(playerid, COLOR_RED,
					"Мир должен быть открыт для входа (/unlockworld)",
					"The world should be open to entry (/unlockworld)");
				}
			}
			new stringen[144], stringru[144];
			
			format(stringen, sizeof(stringen), "Teleport opened. %s", db_escape(inputtext));
			format(stringru, sizeof(stringru), "Открыт телепорт. %s", db_escape(inputtext));
			SendAdMessageToAllEx(0xFFD700FF, stringru, stringen);
			
			foreach(Player, pid)
			{
				GoTpOpened = true;
				SetPVarInt(pid, "TeleportInvited", playerid);
				SendClientMessageEx(pid, 0xFFD700FF,
				"Введите /gotp чтобы присоедениться. Время ожидания 2 минуты.",
				"Type /gotp to join. The waiting time is 2 minutes.");
				SendNotify(pid, "~g~/gotp~w~ to join~n~", 7);
			}
		} else {
			if(LAST_DIALOG[playerid] == 53) YOUTUBER_MENU(playerid);
			else if(LAST_DIALOG[playerid] == 300) TELEPORT_MENU(playerid);
		}
	}
