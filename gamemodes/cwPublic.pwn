					}
				}
				case 2:
				{
					if(pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 316, DIALOG_STYLE_INPUT,
						"Set paintjob",
						"{FFFFFF}Enter vehicle paintjob [0-3]:",
