stock WORLD_TABMENU(playerid)
{
	/*	Administrators dialog. Admin extra options	*/
	new tbtext[420], header[64];
	format(header, sizeof(header), "TAB menu - %s(%d)",
	PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
	
	new worldid = GetPlayerVirtualWorld(playerid);
	if(GetPlayerVirtualWorld(playerid) != GetPlayerVirtualWorld(ChosenPlayer[playerid]))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Игрок в другом вирт.мире либо вышел.",
		"A player in another virt.world or is either out.");
		return true;
	}
	
	if (!IsPlayerConnected(ChosenPlayer[playerid]))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Игрок не подключен либо вышел.", "This player isn't connected.");
		return true;
	}
	
	if(pData[playerid][pLang] == 1)
	{
		format(tbtext, sizeof(tbtext),
		"{AFAFAF}Player statistics\n"\
		"Respawn\n"\
		"{AFAFAF}Sync\n"\
		"Restore hp and armour\n"\
		"{AFAFAF}Disarm\n"\
		"Spectate\n"\
		"{AFAFAF}Teleport to player\n"\
		"{FF0000}%s moderator rights\n"\
		"{FF0000}Kick from world",
		(WorldModerator[ChosenPlayer[playerid]]) ? ("Remove") : ("Grant"));
	} else {
		format(tbtext, sizeof(tbtext),
		"{AFAFAF}Статистика игрока\n"\
		"Отправить на респавн\n"\
		"{AFAFAF}Синхронизировать\n"\
		"Пополнить хп и броню\n"\
		"{AFAFAF}Забрать оружие\n"\
		"Наблюдать за игроком\n"\
		"{AFAFAF}Телепортироваться к игроку\n"\
		"{FF0000}%s права модератора\n"\
		"{FF0000}Кикнуть с мира",
		(WorldModerator[ChosenPlayer[playerid]]) ? ("Забрать") : ("Выдать"));
	}

	if(WorldModerator[playerid] || World[worldid][wHosted] == playerid)
	{ 	
		ShowPlayerDialog(playerid, 380, DIALOG_STYLE_LIST,
		header, tbtext, "Select", "Cancel");
	}
	return true;
}

