						SendClientMessageEx(playerid, COLOR_WHITE, "Для переключения на {008000}предыдущую{FFFFFF} карту нажмите {008000}<RMB>{FFFFFF} (Правая кнопка мыши)", "Switch to {008000}previous{FFFFFF} map by pressing {008000}<RMB>{FFFFFF} (Right Mouse Button)");
