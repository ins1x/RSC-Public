							"{FFFFFF}Change the default health for bots.\n\
							{FFFFFF}Enter the new hp value:", "Change", "Exit");
						}
					#else
						SendClientMessageEx(playerid, COLOR_GREY,
						"Недоступно. На сервере не подключена система NPC",
						"Unavailable. The NPC system is not connected on the server");
						WORLD_BOTS(playerid); 
					#endif
				}
				case 2:
				{
					#if defined _FCNPC_included
						if(!pData[playerid][pLang])
						{
							ShowPlayerDialog(playerid, 339, DIALOG_STYLE_INPUT,
							"Bot weapons",
							"{FFFFFF}Сменить оружие по умолчанию для ботов.\n\
							{FFFFFF}Чтобы узнать ID оружия, используйте: {33AA33}/weaponsid\n\
							{FFFFFF}Оружие по умолчанию: {33AA33}28 (Uzi)\n\
							{FFFFFF}Введите ID огнестрельного оружия:", "Сменить", "Выйти");
						} else {
							ShowPlayerDialog(playerid, 339, DIALOG_STYLE_INPUT,
							"Bot weapons",
							"{FFFFFF}Change the default weapon for bots.\n\
							{FFFFFF}To find out the weapon ID, use: {33AA33}/weaponsid\n\
							{FFFFFF}Default weapon: {33AA33}28 (Uzi)\n\
							{FFFFFF}Enter the weapon ID:", "Change", "Exit");
						}
					#else
						SendClientMessageEx(playerid, COLOR_GREY,
						"Недоступно. На сервере не подключена система NPC",
						"Unavailable. The NPC system is not connected on the server");
						WORLD_BOTS(playerid); 
					#endif
				}
				case 3:
				{
					#if defined _FCNPC_included
						if(!pData[playerid][pLang])
						{
							ShowPlayerDialog(playerid, 338, DIALOG_STYLE_LIST,
							"Bot Action",
							"Преследует и стреляет в игрока\n\
							Стоит на месте и отвечает одим выстрелом\n\
							Преследует игрока\n\
							Падает на спину\n\
							Спавнится в случайном месте\n",
							"Сменить", "Выйти");
						} else {
							ShowPlayerDialog(playerid, 338, DIALOG_STYLE_LIST,
							"Bot Action",
							"Chases and shoots at the player\n\
							Stands still and responds with one shot\n\
							Stalking the player\n\
							Fall back\n\
							Spawn in a random place\n",
							"Confirm", "Cancel");
						}
					#endif
				}
				case 4:
				{
					#if defined _FCNPC_included
						new tbtext[320];
						if(!pData[playerid][pLang])
						{
							format(tbtext, sizeof(tbtext),
							"Аккуратность\t{AFAFAF}%.1f\n\
							Скорость\t{AFAFAF}%d\n\
							Задержка\t{AFAFAF}%d\n\
							Время перезарядки\t{AFAFAF}%d\n\
							{FF0000}Сбросить{FFFFFF} на дефолтные\t\n",
							World[worldid][wBotAccuracy],
							World[worldid][wBotShootrate],
							World[worldid][wBotShootdelay],
							World[worldid][wBotReloadtime]);
						} else {
							format(tbtext, sizeof(tbtext),
							"Accuracy\t{AFAFAF}%.1f\n\
							Shoot rate\t{AFAFAF}%d\n\
							Shoot delay\t{AFAFAF}%d\n\
							Reload time\t{AFAFAF}%d\n\
							{FF0000}Reset{FFFFFF} to default\t\n",
							World[worldid][wBotAccuracy],
							World[worldid][wBotShootrate],
							World[worldid][wBotShootdelay],
							World[worldid][wBotReloadtime]);
						}
						
						ShowPlayerDialog(playerid, 361, DIALOG_STYLE_TABLIST,
						"Damage set", tbtext, "Select", "Cancel");
					#endif
				}
				case 5:
				{
					ShowPlayerDialog(playerid, 374, DIALOG_STYLE_LIST,
					"Move type", "Auto\nWalk\nRun\nSprint", "Select", "Cancel");
				}
				case 6:
				{
					if(World[worldid][wBotType]) World[worldid][wBotType] = 0;
					else World[worldid][wBotType] = 1;
					WORLD_BOTS(playerid);
				}
				case 7:
				{
					#if defined _FCNPC_included
					for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
					{
						if(FCNPC_IsValid(npcid))
						{
							if(FCNPC_GetVirtualWorld(npcid) == worldid)
							{
								FCNPC_StopAttack(npcid);
								FCNPC_StopAim(npcid);
							}
						}
					}
					#endif
					WORLD_BOTS(playerid);
				}
				case 8:
				{
					new nearestplayerid = 0;
					new Float:nearestdistance = 1000.0;
					foreach(Player, i)
					{
						 new Float:distance = GetDistanceBetweenPlayers( playerid, i );
						 if(distance < nearestdistance) 
						 {
							 nearestdistance = distance;
							 nearestplayerid = i;
						 }
					}
					#if defined _FCNPC_included
					for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
					{
						if(FCNPC_IsValid(npcid))
						{
							if(FCNPC_GetVirtualWorld(npcid) == worldid)
							{
								if(!FCNPC_IsMovingAtPlayer(npcid, nearestplayerid))
								{
									FCNPC_AimAtPlayer(npcid, nearestplayerid, .shoot = true,
									.shoot_delay = World[worldid][wBotShootdelay]);
								}
							}
						}
					}
					#endif
					WORLD_BOTS(playerid);
				}
				case 9:
				{
					#if defined _FCNPC_included
						for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
						{
							if(FCNPC_IsValid(npcid))
							{
								if(FCNPC_GetVirtualWorld(npcid) == worldid)
								{
									FCNPC_Destroy(npcid);
								}
							}
						}
						
						new string[128];
						new botskin;
						new hobos[] = {134,135,136,137,167,212,200,230,239};
						GetPlayerPos(playerid, x,y,z);
						GetPlayerFacingAngle(playerid, angle);
						GetXYInFrontOfPlayer(playerid, x, y, 1.5);
					
						for(new i = 0; i < MAX_WORLD_BOTS; i++)
						{
							if(!World[worldid][wBotSkin])
							{
								new randskin = random(sizeof(hobos));
								botskin = hobos[randskin];
							}
							else botskin = World[worldid][wBotSkin];
						
							new npcname[MAX_PLAYER_NAME];
							format(npcname, sizeof(npcname), "BOMJGANG%d", i);
							new npcid = FCNPC_Create(npcname);
							FCNPC_Spawn(npcid, botskin, x, y, z);
							
							FCNPC_SetAngle(npcid, angle);
							FCNPC_SetVirtualWorld(npcid, worldid);
							FCNPC_SetInterior(npcid, World[worldid][wInterior]);
							FCNPC_SetPosition(npcid, x+i*5, y+i*5, z);
							FCNPC_Respawn(npcid);
							if(Debug && FCNPC_IsValid(npcid))
							{
								format(string, sizeof(string), "Bot %s[%d] created", npcname, npcid);
								SendClientMessageToVirtualWorld(FCNPC_GetVirtualWorld(npcid),
								COLOR_GREY, string, string);
							}
						}
						WORLD_BOTS(playerid);
					#else
						ShowPlayerDialog(playerid, 347, DIALOG_STYLE_LIST,
						"Crowd set",
						"Random civilians\n\
						S.W.A.T line\n\
						Slaves party\n\
						Girls dance\n\
						Hobos fight\n",
						"Confirm", "Cancel");
					#endif
				}
				case 10: WORLD_ACTORS(playerid);
				case 11: WORLD_BOTS(playerid);
				case 12:
				{
					new botstotal = 0;
					#if defined _FCNPC_included
					for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
					{
						if(FCNPC_IsValid(npcid))
						{
							if(FCNPC_GetVirtualWorld(npcid) == worldid)
							{
								botstotal++;
							}
						}
					}
					#endif 
					
					if(botstotal >= MAX_WORLD_BOTS)
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Создано максимальное кол-во ботов для мира!",
						"The maximum number of bots for the world has been created!");
						return WORLD_BOTS(playerid);
					}
					
					new botskin;
					new gangs[] = {102,103,104,105,106,107,108,109,110,111,112,113,114,115,116};
					GetPlayerPos(playerid, x,y,z);
					GetPlayerFacingAngle(playerid, angle);
					GetXYInFrontOfPlayer(playerid, x, y, 1.5);
					
					if(!World[worldid][wBotSkin]) {
						new randskin = random(sizeof(gangs));
						botskin = gangs[randskin];
					}
					else botskin = World[worldid][wBotSkin];
					
					#if defined _FCNPC_included
						new npcname[MAX_PLAYER_NAME];
						format(npcname, sizeof(npcname), "RSC%d", worldid);
						new npcid = FCNPC_Create(npcname);
						FCNPC_Spawn(npcid, botskin, x, y, z);
						
						FCNPC_SetAngle(npcid, angle);
						FCNPC_SetVirtualWorld(npcid, worldid);
						FCNPC_SetInterior(npcid, World[worldid][wInterior]);
						
						FCNPC_Respawn(npcid);
						if(FCNPC_IsValid(npcid))
						{
							new string[128];
							format(string, sizeof(string), "Bot %s[%d] created", npcname, npcid);
							SendClientMessageToVirtualWorld(FCNPC_GetVirtualWorld(npcid),
							COLOR_GREY, string, string);
						}
					#else
						#if defined _streamer_included
						//CreateDynamicActor(modelid, Float:x, Float:y, Float:z, Float:r, invulnerable = 1, //Float:health = 100.0, worldid = -1, interiorid = -1, playerid = -1, //Float:streamdistance = STREAMER_ACTOR_SD, areaid = -1, priority = 0)
						new actorid = CreateDynamicActor(botskin, x, y, z, 0.0, false, 100.0,
						worldid, -1, playerid = -1);
						SetDynamicActorInvulnerable(actorid, false);
						SetDynamicActorVirtualWorld(actorid, worldid);
						//if(IsValidDynamicActor(actorid))
						#endif
					#endif
					WORLD_BOTS(playerid);
				}
				case 13: ListBotsInWorld(playerid);
				case 14:
				{
					if(!pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 336, DIALOG_STYLE_LIST, 
						"{FF0000}Удалить ботов",
						"Удалить {FF0000}ближайшего бота{FFFFFF}\nУдалить {FF0000}всех ботов",
						"Выбрать", "Отмена");
					} else {
						ShowPlayerDialog(playerid, 336, DIALOG_STYLE_LIST, 
						"{FF0000}Delete Bots",
						"Delete the {FF0000}nearest bot{FFFFFF}\nDelete {FF0000}all bots",
						"Select", "Cancel");
					}
				}
				case 15:
				{
					if(!pData[playerid][pLang])
					{
						ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX, 
						"Информация о ботах и актерах",
						"{FFFFFF}Вы можете создавать до 3-х ботов для тренировки в виртуальном мире\n\
						Логика ботов на данный момент весьма примитивна, но для тренировок достаточна\n\
						Синхронизация ботов местами выглядит странно\n\
						Данная система в процессе доработки разработчиком\n\
						Актеры статичны и в отличии от ботов могут только использовать анимации\n\
						Актеры не занимают слоты игроков, поэтому их можно создавать до 50 в мире\n\
						{FFD700}Статичные боты{FFFFFF} - боты не двигаются, но реагируют\n\
						{FFD700}Динамичные боты{FFFFFF} - двигаются и реагируют на игрока по ряду настраиваемых параметров\n",
						" X ", "");
					} else {
						ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX, 
						"Bots and actors information",
						"{FFFFFF}You can create up to 3 bots for training in the virtual world\n\
						The logic of bots is very primitive at the moment, but it is sufficient for training\n\
						Bots synchronization can be looks strange\n\
						This system is in the process of being finalized by the developer\n\
						Actors are static and unlike bots can only use animations\n\
						Actors do not occupy player slots, so they can be created up to 50 in the world\n\
						{FFD700}Static bots{FFFFFF} - bots don't move, but react\n\
						{FFD700}Dynamic bots{FFFFFF} - they move and react to the player according to a number of configurable parameters\n",
						" X ", "");
					}
				}
			}
		} else {
			if(WorldModerator[playerid] || World[worldid][wHosted] == playerid)
			{
				WORLD_MENU(playerid);
			}
		}
	}
	if(dialogid == 334)
	{
		if(response)
		{
			if(GetPlayerVirtualWorld(playerid) == 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы должны быть в виртуальном мире!", "You must be in the virtual world!");
				return true;
			}
			
			new worldid = GetPlayerVirtualWorld(playerid);
			
			if (!strlen(inputtext))
			{	
				if(pData[playerid][pLang])
				{		
					ShowPlayerDialog(playerid, 334, DIALOG_STYLE_INPUT,
					"World name",
					"{FF0000}The name of the world should not contain insults and provocations!\n\
					\n{FFFFFF}Enter the name for the virtual world", "Submit", "Cancel");
				} else {
					ShowPlayerDialog(playerid, 334, DIALOG_STYLE_INPUT,
					"Название мира",
					"{FF0000}Название мира не должно содержать оскорблений и провокаций!\n\
					\n{FFFFFF}Введите новое название для мира", "Сменить", "Отмена");
				}
				return true;
			}
			
			if(strlen(inputtext) > 23 || strlen(inputtext) < 2)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Имя должно быть 2-24 символов", "Name must be 2-24 characters");
				return true;
			}
			
			if(!WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
			
			format(World[worldid][wName], 24, "%s", inputtext);
			
			new stringru[100], stringen[100];
			format(stringru, sizeof(stringru), "Вы установили имя для мира - %s", World[worldid][wName]);
			format(stringen, sizeof(stringen), "You set world name - %s", World[worldid][wName]);
			SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);	
		}
		else WORLD_MANAGE(playerid);
	}
	if(dialogid == 335)
	{
		new Float:x, Float:y, Float:z;
		GetPlayerPos(playerid, x, y, z);
		new worldid = GetPlayerVirtualWorld(playerid);
		new type = 2, Float:dist = 0.5;
		if(!WorldModerator[playerid])
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы не модератор мира!", "You are not moderator!");
			return true;
		}
		// https://www.open.mp/docs/scripting/resources/pickupids
		#if defined _streamer_included
		// Example: CreateDynamicPickup(modelid, type, Float:x, Float:y, Float:z,
		//worldid = -1, interiorid = -1, playerid = -1, Float:streamdistance = 100.0);
		if(response)
		{
			switch(listitem)
			{
				case 0:// armourpickup
				{
					GetXYInFrontOfPlayer(playerid, x, y, dist);
					CreateDynamicPickup(1242, type, x, y, z+0.25,
					GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid), -1);
				}
				case 1:// hppickup
				{
					GetXYInFrontOfPlayer(playerid, x, y, dist);
					CreateDynamicPickup(1240, type, x, y, z+0.25,
					GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid), -1);
				}
				case 2:// pill
				{
					GetXYInFrontOfPlayer(playerid, x, y, dist);
					CreateDynamicPickup(1241, type, x, y, z+0.25,
					GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid), -1);
				}
				case 3:// jetpickup
				{
					GetXYInFrontOfPlayer(playerid, x, y, dist);
					CreateDynamicPickup(370, type, x, y, z+0.25,
					GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid), -1);
				}
				case 4:// fix vehicle
				{
					GetXYInFrontOfPlayer(playerid, x, y, dist);
					CreateDynamicPickup(3096, type, x, y, z+0.25,
					GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid), -1);
				}
				case 5: WORLD_PICKUP_WEAPONS(playerid);
				case 6:
				{
					new items[64];
					Streamer_GetNearbyItems(x, y, z, STREAMER_TYPE_PICKUP,
					items, sizeof(items), 2.0, worldid);
					for(new pickup = 0; pickup < sizeof(items); pickup++)
					{
						if(IsValidDynamicPickup(pickup)) DestroyDynamicPickup(pickup);
					}
					SendClientMessageEx(playerid, COLOR_GREY,
					"Ближайший пикап был удален", "Nearest pickup has been removed");
				}
				case 7: 
				{
					if(GetPVarInt(playerid, "Admin") < 3)
					{
						return SendClientMessageEx(playerid, COLOR_RED,
						"Для использования этих функций Вы должны быть администратором 3+ уровня!",
						"To use these functions you need to have level 3+ admin rights!");
					}
					
					for(new i = 0, j = GetPlayerPoolSize(); i <= j; i++){
						Streamer_Update(i);
					}
					// Note: dynamic objects are restored in 50 ms 
					// (or through the specified value by the Streamer_TickRate function).
					Streamer_DestroyAllVisibleItems(playerid, STREAMER_TYPE_PICKUP);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Все динамические пикапы были обновлены", "All dynamic pickups have been updated");
				}
				
			}
		}
		#endif
	}
	if(dialogid == 336) // bot remove
	{
		if(response)
		{
			new Float:x, Float:y, Float:z;
			GetPlayerPos(playerid, x, y, z);
			new worldid = GetPlayerVirtualWorld(playerid);
			if(worldid != 0 && !WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
			
			switch(listitem)
			{
				case 0:
				{
					#if defined _FCNPC_included
					new Float: mindist = 1000.0;
					new nearestnpcid = INVALID_PLAYER_ID;
					
					for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
					{
						if(FCNPC_IsValid(npcid))
						{
							if(FCNPC_GetVirtualWorld(npcid) == worldid)
							{
								new Float: distance = GetDistanceBetweenPlayers( playerid, npcid );
								if(distance < mindist) 
								{
									mindist = distance;
									nearestnpcid = npcid;
								}
							}
						}
					}
					if(FCNPC_IsValid(nearestnpcid)) FCNPC_Destroy(nearestnpcid);
					new string[128];
					format(string, sizeof(string), "Nearest bot (id:%i) has been removed", nearestnpcid);
					SendClientMessage(playerid, COLOR_GREY, string);
					#else
						#if defined _streamer_included
						new items[64];
						Streamer_GetNearbyItems(x, y, z, STREAMER_TYPE_ACTOR,
						items, sizeof(items), 5.0, worldid);
						for(new actor = 0; actor < sizeof(items); actor++)
						{
							if(IsValidDynamicActor(actor)) DestroyDynamicActor(actor);
						}
						SendClientMessageEx(playerid, COLOR_GREY,
						"Ближайший актер был удален", "Nearest actor has been removed");
						#endif
					#endif
				}
				case 1:
				{
					#if defined _FCNPC_included
					for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
					{
						if(FCNPC_IsValid(npcid))
						{
							if(FCNPC_GetVirtualWorld(npcid) == worldid)
							{
								FCNPC_Destroy(npcid);
							}
						}
					}
					#else
						#if defined _streamer_included
						new items[128];
						Streamer_GetNearbyItems(x, y, z, STREAMER_TYPE_ACTOR,
						items, sizeof(items), 1000.0, worldid);
						for(new actor = 0; actor < sizeof(items); actor++)
						{
							if(IsValidDynamicActor(actor)) DestroyDynamicActor(actor);
						}
						SendClientMessageEx(playerid, COLOR_GREY,
						"Все боты удалены", "All bots has been removed");
						#endif
					#endif
				}
			}
		}
	}
	if(dialogid == 337) // WORLD skin
	{
		if(response)
		{
			if(!strlen(inputtext)) return WORLD_BOTS(playerid);
			new skinid = strval(inputtext);
			new worldid = GetPlayerVirtualWorld(playerid);
			if(!WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
			
			if(skinid < 0 || skinid >= 300 || skinid == 74) 
			{
				SendClientMessageEx(playerid,COLOR_GREY,
				"Ошибка: неверный № скина", "ERROR: Invalid skin id!");
				return WORLD_BOTS(playerid);
			}
			if(skinid == 0)
			{
				World[worldid][wBotSkin] = 0;
				return WORLD_BOTS(playerid);
			}
			
			World[worldid][wBotSkin] = skinid;
			WORLD_BOTS(playerid);
		}
		else WORLD_BOTS(playerid);
	}
	if(dialogid == 338) // WORLD Actor action
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			World[worldid][wBotAction] = listitem+1;
			WORLD_BOTS(playerid);
		}
		else WORLD_BOTS(playerid);
