				new actorstotal = 0;
				if(worldid != 0)
				{
					for(new actorid = 0; actorid < MAX_ACTORS; actorid++)
					{				
						if(GetDynamicActorVirtualWorld(actorid) == worldid)
						{
							actorstotal++;
						}
					}
							
					if(actorstotal >= MAX_WORLD_ACTORS)
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Создано максимальное кол-во актеров для мира!",
