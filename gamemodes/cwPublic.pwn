			{
				SetPlayerWeather(playerid, 42);
				pData[playerid][pWeather] = 42;
			} else {
				SetPlayerWeather(playerid, listitem+1); 
				pData[playerid][pWeather] = listitem+1; 
			}
			new szQuery[128];
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Weather = %i WHERE (Nickname = '%q')",
