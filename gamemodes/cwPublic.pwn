#if defined _nex_ac_included
// NEXAC https://github.com/NexiusTailer/Nex-AC

stock CheatDetectedAction(playerid, code)
{
	/* Performs an action when detected, depending on the mod settings */
	new string[128];
	// Ignore lageers
	if(NEXAC_IGNORE_LAGERS)
	{
		if(NetStats_PacketLossPercent(playerid) > 1.0 || GetPlayerPing(playerid) > 150)
		{
			return 1;
		}
	}

	switch(NEXAC_DETECT_ACTION)
	{
		case 1:
		{
			format(string, sizeof(string), "%s(%d) cheat detected %s",
			PlayerName(playerid), playerid, reasonslist[code]);
			SendSystemMessage(string);
		}
		case 2: 
		{
			format(string, sizeof(string), "%s(%d) cheat detected %s [%d/%d]",
			PlayerName(playerid), playerid, reasonslist[code],
			NEXAC_DETECT_COUNTERS[playerid][code], NEXAC_KICK_AFTER);
			SendSystemMessage(string);

			if(NEXAC_DETECT_COUNTERS[playerid][code] >= NEXAC_KICK_AFTER && NEXAC_KICK_AFTER != 0)
			{
				KickPlayerEx(playerid, reasonslist[code]);
			}
		}
		case 3:
		{
			format(string, sizeof(string), "%s(%d) cheat detected %s [%d/%d]",
			PlayerName(playerid), playerid, reasonslist[code],
			NEXAC_DETECT_COUNTERS[playerid][code], NEXAC_KICK_AFTER);
			SendSystemMessage(string);

			if(NEXAC_DETECT_COUNTERS[playerid][code] >= NEXAC_KICK_AFTER && NEXAC_KICK_AFTER != 0)
			{
				BanPlayerEx(playerid, reasonslist[code]);
			}
		}
	}

	return 1;
}

public OnCheatDetected(playerid, ip_address[], type, code)
{
	/*
	Called when triggers one of the anti-cheats
	This callback does not handle returns by default
	*/

	new string[128];
	new worldid = GetPlayerVirtualWorld(playerid);
	// Disable Anticheat at Virtual World (optional)
	if(worldid != 0 && !World[worldid][wAnticheat]) return 1;
	// Increase ac trigger counters
	NEXAC_DETECT_COUNTERS[playerid][code]++;
	// Special actions when it detects some cheats
	switch(code)
	{
		case 0:	CheatDetectedAction(playerid, code);
		case 2://Anti-teleport hack (onfoot)
		{
			if(GetPVarInt(playerid, "UnBug")) return 1;
			//return 1;
		}
		case 5: // Anti-teleport (in veh)
		{
			if(worldid != 0) return 1;
		}
		case 9: //Anti-SpeedHack
		{
			if(OnFly[playerid]) return 1;
		}
		case 12: //Anti-Health hack (onfoot)
		{
			if(onspawnprotect[playerid]) return 1;
			if(HPDead == true) return 1;
			if(GetPlayerState(playerid) != PLAYER_STATE_ONFOOT) return 1;
			if(worldid != 0) return 1;
			CheatDetectedAction(playerid, code);
		}
		case 14:
		{
			format(string, sizeof(string), "%s(%d) possible sobeit detected",
			PlayerName(playerid), playerid);
			SendSystemMessage(string);
			CheatDetectedAction(playerid, code);
		}
		case 15: //Anti-Ammo hack (desync/add)
		{
			if(GetPlayerVirtualWorld(playerid) != 0) return 1;
		}
		case 16: //Anti-Ammo hack (add)
		{
			if(speconly) return 1;
			if(onspawnprotect[playerid]) return 1;
			if(worldid != 0) return 1;
			CheatDetectedAction(playerid, code);
		}
		case 17:
		{
			if(IsPlayerSpawned(playerid))
			{
				format(string, sizeof(string),
				"%s(%d) infinite ammo (noreload) detected code: %d",
				PlayerName(playerid), playerid, code);
				SendSystemMessage(string);
				CheatDetectedAction(playerid, code);
			}
		}
		case 18:
		{
			// Special actions. Full Ignore because the mod is provided
			return 1;
		}
		case 19: //Anti-GodMode from bullets (onfoot)
		{
			if(onspawnprotect[playerid]) return 1;
			//if(SPAWN_PROTECT == true) return 1;
			if(HPDead == true) return 1;
			CheatDetectedAction(playerid, code);
		}
		case 21: return 1; // InvisHack (unnecessary in this gamemode)
		case 26: 
		{
			//// so much incorrect triggering on lagers		
			CheatDetectedAction(playerid, code);// Rapidfire
		}
		case 27: // FakeSpawn  
		{
			if(freeze_score == true) return 1;
			if(speconly) return 1;
			CheatDetectedAction(playerid, code);
		}
		//case 28: return 1;// Pro AIM
		case 39:
		{			
			if(strcmp(ip_address, "127.0.0.1", false))
			{
				if(GetPVarInt(playerid, "Admin") < 3) 
				{
					SendClientMessage(playerid, COLOR_RED, "Take a screenshot of the dialog you open");
					KickPlayerEx(playerid, "DLG Spoofing");
				}
			}
		}
		case 40: SendClientMessage(playerid, -1, MAX_CONNECTS_MSG);
		case 41: SendClientMessage(playerid, -1, UNKNOWN_CLIENT_MSG);
		case 43..47:
		{
			KickPlayerEx(playerid, "Crasher");
			//Kick(playerid); // Crashers fast kick without delay bacause can crash players
		}
		case 50:
		{					
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				if(World[worldid][wGamemode] == GAMEMODE_WOT
				|| World[worldid][wGamemode] == GAMEMODE_DERBY)
				{
					return 1; // Ignore false triggering on exit vehicle
				}
			}
		}
		case 51: return 1; //Fixlater
		default: // Actions of cheater detected
		{
			CheatDetectedAction(playerid, code);
		}
	}
	return 1;
}

public OnCheatWarning(playerid, ip_address[], type, code, code2, count)
{
	// Called when triggers any warnings of one of the anti-cheats
	new string[128];
	new worldid = GetPlayerVirtualWorld(playerid);
	// Disable Anticheat at Virtual World (optional)
	if(worldid != 0 && !World[worldid][wAnticheat]) return 1;
	
	switch(code)
	{
		case 0: return 1; // So much airbreak warns
		case 2: return 1; // So much teleport warns
		case 8: //Anti-flyhack (in vehicle)
		{
			if(worldid != 0)
			{
				if(World[worldid][wGamemode] == GAMEMODE_DERBY)
				{
					return 1; // Ignore false triggering on fall vehicle
				}
			}
		}
		case 16:
		{
			if(speconly) return 1;
			if(onspawnprotect[playerid]) return 1;
		}
		case 12, 17, 19: // Anti health - hacks 
		{
			if(onspawnprotect[playerid]) return 1;
			//if(SPAWN_PROTECT == true) return 1;
			if(HPDead == true) return 1; 
		}
		case 27: // FakeSpawn Spawn 
		{
			if(freeze_score == true) return 1;
			if(speconly) return 1;
		}
		case 50:
		{					
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				if(World[worldid][wGamemode] == GAMEMODE_WOT
				|| World[worldid][wGamemode] == GAMEMODE_DERBY)
				{
					return 1; // Ignore false triggering on exit vehicle
				}
			}
		}
		default:
		{
			// Actions of cheater detected
			switch(NEXAC_DETECT_ACTION)
			{
				case 1:
				{
					format(string, sizeof(string), "%s(%d) warning code %s [count: %d]",
					PlayerName(playerid), playerid, reasonslist[code], count);
					if(count > 1) SendSystemMessage(string);
				}
				case 2: 
				{
					if(count == NEXAC_KICK_AFTER && NEXAC_KICK_AFTER != 0) {
						KickPlayerEx(playerid, reasonslist[code]);
					}
				}
				case 3:
				{
					if(count == NEXAC_KICK_AFTER && NEXAC_KICK_AFTER != 0) {
						BanPlayerEx(playerid, reasonslist[code]);
						if(type) BlockIpAddress(ip_address, 0);
					}
				}
			}
		}
	}
	return 1;// This callback does not handle returns by default
}

public OnFloodWarning(playerid, publicid, count)
{
	//Called when triggers any anti-flood warnings on one of the protected publics
	new string[128];
	
	new worldid = GetPlayerVirtualWorld(playerid);
	// Disable Anticheat at Virtual World (optional)
	if(worldid != 0 && !World[worldid][wAnticheat])	return 1;
	
	switch(publicid)
	{
		// Ignore false AC positives on class selection
		case 9: count = 0; // OnPlayerRequestClass
		case 11: // OnPlayerStateChange
		{
			if(count >= NEXAC_PUBLICFLOOD_MAX)
			{ 
				format(string, sizeof(string), "%s(%d) publicflood code %s [count: %d | MAX: %d]",
				PlayerName(playerid), playerid, publicflood_codes[publicid], count, NEXAC_PUBLICFLOOD_MAX);
				SendSystemMessage(string);

				if(pData[playerid][pLang] == 0) {
					format(string, sizeof(string),
					"Причина может быть в плохой синхронизации. \
					Если будут повторные сработки попросите игрока перезайти");
				} else {
					format(string, sizeof(string),
					"This could be due to bad synchronization. \
					If there are repeated, ask the player to relog");	
				}
				SendSystemMessage(string);
				count = 0;
			}
		}
		// Action by default
		default:
		{
			if(count >= NEXAC_PUBLICFLOOD_MAX) {
				format(string, sizeof(string), "%s(%d) publicflood %s [count: %d | MAX: %d]",
				PlayerName(playerid), playerid, publicflood_codes[publicid],
				count, NEXAC_PUBLICFLOOD_MAX);
				SendSystemMessage(string);
			}
			//if(count == NEXAC_KICK_AFTER && NEXAC_KICK_AFTER != 0) KickPlayerEx(playerid, string);
		}
	}
	return 1;
}

public OnNOPWarning(playerid, nopid, count)
{
	//Called when triggers any NOP warnings on one of the protected functions
	new string[128];
	new worldid = GetPlayerVirtualWorld(playerid);
	// Disable Anticheat at Virtual World (optional)
	if(worldid != 0 && !World[worldid][wAnticheat]) return 1;
	
	switch(nopid)
	{
		case 2: if(speconly) count = 0; //ignore 2 reason on speconlymode
		default: 
		{
			format(string, sizeof(string), "%s(%d) NOP %s [%d]",
			PlayerName(playerid), playerid, nopslist[nopid], nopid);
			if(count == NEXAC_KICK_AFTER && NEXAC_KICK_AFTER != 0) KickPlayerEx(playerid, string);
		}
	}
	return 1;
}
#endif

public SecTimer()
{	
	foreach(new playerid : Player)
	{
		new string[128];
		
		#if defined _YSF_included
		if(GetPVarInt(playerid, "AFKHidden") > 0 && GetPVarInt(playerid, "AFKTime") < 3)
		{
			SetPVarInt(playerid, "AFKHidden", 0);
			foreach(Player, p)
			{
				ShowPlayerForPlayer(p, playerid, true);
				SetPlayerMarkerForPlayer(p, playerid, TCC[GetPVarInt(playerid, "Team")]);
			}
		}
		#endif
		// AFK Checker
		if(!IsPlayerConnected(playerid) || IsPlayerNPC(playerid)) continue;
		new afktime = GetPVarInt(playerid, "AFKTime");
		SetPVarInt(playerid, "AFKTime", afktime + 1);
		if(afktime >= 5)
		{
			#if defined _YSF_included
			if(afktime >= 60 && GetPVarInt(playerid, "Team") != 2)
			{
				if(GetPVarInt(playerid, "AFKHidden") != 1)
				{
					SetPVarInt(playerid, "AFKHidden", 1);
					foreach(Player, p)
					{
						HidePlayerForPlayer(p, playerid);
						SetPlayerMarkerForPlayer(p, playerid, 0xFFFFFF00);
					}
				}
			}
			#endif
			new afkstr[18];
			format(afkstr, sizeof(afkstr), "AFK %d sec", afktime);
			SetPlayerChatBubble(playerid, afkstr, COLOR_WHITE, 50.0, 1250);
		}
		// returns spectatorss to spawn
		if(Spawnlock && !Finalscreen)
		{			
			new team = GetPVarInt(playerid, "Team");
			if (team == TEAM_SPEC && GetPlayerState(playerid) == PLAYER_STATE_ONFOOT
			&& !OnFly[playerid] && !GetPVarType(playerid, "Lounge"))
			{
				new Float:x, Float:y, Float:z;
				GetPlayerPos(playerid, x,y,z);
				if(GetPlayerVirtualWorld(playerid) == 0)
				{
					if(floatround(CwMaps[Map][team][2]) - floatround(z) > 2)
					{
						SetPlayerPos(playerid, CwMaps[Map][team][0], CwMaps[Map][team][1]+random(2),
						CwMaps[Map][team][2]);
					}
				}
			}
		}
		
		if(AC_AUTOSCROLL)
		{
			if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT 
			&& GetPlayerAnimationIndex(playerid) == 363
			&& GetPVarInt(playerid, "PR_LMB") && !GetPVarInt(playerid, "PR_RMB"))
			{
				// if have bullets 
				if(GetPlayerWeaponState(playerid) == 2) {
					SetPVarInt(playerid, "AC_AUTOSCROLL", GetPVarInt(playerid, "AC_AUTOSCROLL") + 1);
				}
				
				if(GetPVarInt(playerid, "AC_AUTOSCROLL") >= 3)
				{
					ClearAnimations(playerid);
					ApplyAnimation(playerid, "PED", "IDLE_stance", 4.1, 0, 1, 1, 1, 1000, 1);
					format(string, sizeof(string),
					"Warning %s[%d] fast scroll bug (anim dropped)", PlayerName(playerid), playerid);
					SendSystemMessage(string);
					SetPVarInt(playerid, "AC_AUTOSCROLL", 0);
					LastRejectHitReason[playerid] = 13;
				}
			}
		}
		
		if(GetPVarType(playerid, "Lounge"))
		{
			if(!LockedTeams && !CWmode)
			{
				if(IsPlayerInRangeOfPoint(playerid, 1.0, 1709.7710,-1642.8160, 20.2188))
				{
					if (LockedTeams && GetPlayerVirtualWorld(playerid) == 0)
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Вы не можете присоединиться к команде во время матча.",
						"Joining teams is locked right now.");
						return true;
					}
					if (GetPVarInt(playerid, "Team") == 1)
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Вы уже в этой команде.", "You are already in this team.");
						return true;
					}
					if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
					{
						new Float: x, Float: y, Float: z;
						GetPlayerPos(playerid, x, y, z);
						SetPlayerPos(playerid, x, y, z);
					}
					if (GetPVarInt(playerid, "Team") == 2)
					{
						if (GetPVarInt(playerid, "Specing") > -1)
						{
							SpecOff(playerid);
						}
						else if (!frz)
						{
							RestorePlayerWeapons(playerid);
						}
					}
					if (frz)
					{
						TogglePlayerControllable(playerid, false);
						SetPVarInt(playerid, "frz", true);
					}
					
					SetPlayerTeamEx(playerid, TEAM_GREEN);
					
					new stringru[63];
					format(stringru, sizeof(stringru),
					"%s(%d) перешел в команду %s.", PlayerName(playerid), playerid, ClanName[0]);
					new stringen[60];
					format(stringen, sizeof(stringen),
					"%s(%d) has moved to %s team.", PlayerName(playerid), playerid, ClanName[0]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					
					RefreshHud(playerid);
					ReSpawnPlayer(playerid);
					DeletePVar(playerid, "Lounge");
				}
				if(IsPlayerInRangeOfPoint(playerid, 1.0, 1712.2874,-1640.1340,20.2239))
				{
					if (LockedTeams && GetPlayerVirtualWorld(playerid) == 0)
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Вы не можете присоединиться к команде во время матча.",
						"Joining teams is locked right now.");
						return true;
					}
					if (GetPVarInt(playerid, "Team") == 1)
					{
						SendClientMessageEx(playerid, COLOR_GREY,
						"Вы уже в этой команде.", "You are already in this team.");
						return true;
					}
					if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
					{
						new Float: x, Float: y, Float: z;
						GetPlayerPos(playerid, x, y, z);
						SetPlayerPos(playerid, x, y, z);
					}
					if (GetPVarInt(playerid, "Team") == 2)
					{
						if (GetPVarInt(playerid, "Specing") > -1)
						{
							SpecOff(playerid);
						}
						else if (!frz)
						{
							RestorePlayerWeapons(playerid);
						}
					}
					if (frz)
					{
						TogglePlayerControllable(playerid, false);
						SetPVarInt(playerid, "frz", true);
					}
					
					SetPlayerTeamEx(playerid, TEAM_BLUE);
					
					new stringru[63];
					format(stringru, sizeof(stringru),
					"%s(%d) перешел в команду %s.", PlayerName(playerid), playerid, ClanName[1]);
					new stringen[60];
					format(stringen, sizeof(stringen),
					"%s(%d) has moved to %s team.", PlayerName(playerid), playerid, ClanName[1]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					
					RefreshHud(playerid);
					ReSpawnPlayer(playerid);
					DeletePVar(playerid, "Lounge");
				}
			}
			if(IsPlayerInRangeOfPoint(playerid, 1.5, 1701.2568,-1667.8860,20.2188))
			{
				OnPlayerCommandText(playerid, "/leave");
			}
		}
		
		if(GetPVarInt(playerid, "ShowScoretxd") != -1)
		{	
			static tmp[32];
			format(tmp, sizeof(tmp), "~w~Score:~g~%d", GetPlayerScore(playerid));
			PlayerTextDrawSetString(playerid, TDscore[playerid], tmp);
			PlayerTextDrawShow(playerid, TDscore[playerid]);
		} else {
			PlayerTextDrawHide(playerid, TDscore[playerid]);
		}
		
		if(GetPVarInt(playerid, "ShowTimetxd") != -1)
		{	
			new ctime, timestamp;
			new worldid = GetPlayerVirtualWorld(playerid);
			static tmpstr[64];
			
			if(World[worldid][wUseTimer])
			{
				timestamp = World[worldid][wStartTime] + World[worldid][wRoundTime];
				ctime = timestamp - gettime();
				if(ctime > 0)
				{
					format(tmpstr, sizeof(tmpstr), 
					"~w~RoundTime:~g~%d:%d", ctime/60, ctime%60);
					PlayerTextDrawSetString(playerid, TDtime[playerid], tmpstr);
					PlayerTextDrawShow(playerid, TDtime[playerid]);
					
					//if(ctime == 3) Countdown(3, GetPlayerVirtualWorld(playerid));
					if(ctime == 1)
					{
						if(World[worldid][wGamemode] == GAMEMODE_SKILLTEST)
						{
							RespawnPlayersAtWorld(worldid, true);
							World[worldid][wStartTime] = gettime();
						} else {
							PlayerTextDrawHide(playerid, TDtime[playerid]);
							World[worldid][wStartTime] = 0;
							new topplayerid = -1;
							new topscore = 0;
							new totalplayers = 0;
							foreach(Player, i)
							{
								if(GetPlayerVirtualWorld(i) == worldid)
								{
									totalplayers++;
									if(topscore < GetPlayerScore(i))
									{
										topscore = GetPlayerScore(i);
										topplayerid = i;
									}
								}
							}
							if(totalplayers > 1)
							{
								GivePlayerCookies(topplayerid, 1, true);
								PlayerPlaySound(topplayerid, 1183, 0, 0, 0);
								format(tmpstr, sizeof(tmpstr), "%s win this round with score %d",
								PlayerName(topplayerid), topscore);
								SendClientMessageToVirtualWorld(worldid, COLOR_GREY, tmpstr, tmpstr);
							} else {
								SendClientMessageToVirtualWorld(worldid, COLOR_GREY,
								"Нет победителей в этом раунде", "No winners on this round");
							}
							foreach(Player, i)
							{
								if(GetPlayerVirtualWorld(i) == worldid)
								{
									if(totalplayers > 1) {
										format(tmpstr, sizeof(tmpstr), "~w~%s ~g~win~w~ this round!",
										PlayerName(topplayerid));
										GameTextForPlayer(i, tmpstr, 3000, 4);
									}
									SetPlayerScore(i, 0);
								}
							}
							World[worldid][wStartTime] = gettime();
							RespawnPlayersAtWorld(worldid, true);
						}
					}
				} else {
					PlayerTextDrawHide(playerid, TDtime[playerid]);
					World[worldid][wStartTime] = 0;
				}
			}
		} else {
			PlayerTextDrawHide(playerid, TDtime[playerid]);
		}
	}
	return 1;
}

public OnScriptUpdate()
{
	// The main task of this function is to replace the public OnScriptUpdate
	// call interval: 200 ms
	static string[128];
	new specbartext[500];
	new dynboxtext[1024];
	
	foreach(new playerid : Player)
	{
		// Specbar info preset
		if (GetPVarInt(playerid, "specbar") != -1 && IsPlayerConnected(GetPVarInt(playerid,"specbar")))
		{
			new specid = GetPVarInt(playerid, "specbar");
			new team = GetPVarInt(specid, "Team");
					
			switch(team)
			{
				case 0: 
				{
					format(string, sizeof(string), "%s%s(%d) ~w~team: %s%s~n~",
					TDC[team], PlayerName(specid), specid, TDC[team], ClanName[0]);
				}
				case 1: 
				{
					format(string, sizeof(string), "%s%s(%d) ~w~team: %s%s~n~",
					TDC[team], PlayerName(specid), specid, TDC[team], ClanName[1]);
				}
				case 2:
				{
					format(string, sizeof(string), "%s%s(%d) ~w~team: %sSPECTATOR~n~",
					TDC[team], PlayerName(specid), specid, TDC[team]);
				}
				default: format(string, sizeof(string), "~r~%s(%d) ~n~",PlayerName(specid), specid);
			}
			strcat(specbartext, string);	
			
			new Float: health, Float: armour;
			GetPlayerHealth(specid, health);
			GetPlayerArmour(specid, armour);
			format(string, sizeof(string), "~r~HP %.1f ~b~~h~~h~~h~Armour %.1f~n~", health, armour);
			strcat(specbartext, string);			
			
			if(GetPVarInt(specid, "cwdeath") > 0 &&
			GetPVarInt(specid, "cwkills")/float(GetPVarInt(specid, "cwdeath")) > 0)
			{
				format(string, sizeof(string),
				"~w~FPS:~r~%.0f ~w~Ping:~r~%d ~w~P.Loss:~r~%.1f ~w~K/d:~r~%.1f~n~",
				floatabs(GetPVarInt(specid, "fps")), GetPlayerPing(specid),
				GetPVarFloat(specid, "ploss"), 
				GetPVarInt(specid, "cwkills")/float(GetPVarInt(specid, "cwdeath")));
			} else {
				format(string, sizeof(string), "~w~FPS:~r~%.0f ~w~Ping:~r~%d ~w~P.Loss:~r~%.1f ~n~",
				floatabs(GetPVarInt(specid, "fps")), GetPlayerPing(specid),
				GetPVarFloat(specid, "ploss"));
			}
			strcat(specbartext, string);			

			#if defined _sampcac_included
			new major, minor, patch, client_version[10];
			CAC_GetClientVersion(specid, major, minor, patch);
			GetPlayerVersion(specid, client_version, sizeof(client_version));
			if(CAC_GetStatus(specid) > 0)
			{
				if(minor != 10)
				{
					format(string, sizeof(string),
					"~w~SAMPCAC ~r~outdated:~w~ v%i.%02i.%i client: %s~n~",
					major, minor, patch, client_version);
				} else {
					format(string, sizeof(string),
					"~g~~h~~h~SAMPCAC ~w~v%i.%02i.%i client: %s~n~",
					major, minor, patch, client_version);
				}
				strcat(specbartext, string);
			} else {
				format(string, sizeof(string),
				"~r~SAMPCAC OFF~w~ client: %s~n~", client_version);
				strcat(specbartext, string);
			}
			#else
			new client_version[10];
			GetPlayerVersion(specid, client_version, sizeof(client_version));
			format(string, sizeof(string), "~w~client: %s~n~",client_version);
			strcat(specbartext, string);
			#endif
			
			if(GetPVarInt(playerid, "specbarmode") == 1) // Dmgtracer
			{
				//format(string, sizeof(string), "~g~[DMGTRACER] ~w~[SYNCDATA] ~n~~n~");
				//strcat(dynboxtext, string);
				// Damage tracer info preset
				
				new newstate[36];
				switch(GetPlayerState(specid))
				{
					case 0: format(newstate, sizeof(newstate), "NONE");
					case 1:	format(newstate, sizeof(newstate), "ONFOOT");
					case 2:	format(newstate, sizeof(newstate), "DRIVER");
					case 3:	format(newstate, sizeof(newstate), "PASSENGER");
					case 4:	format(newstate, sizeof(newstate), "EXIT_VEHICLE");
					case 5:	format(newstate, sizeof(newstate), "ENTER_VEHICLE_DRIVER");
					case 6:	format(newstate, sizeof(newstate), "ENTER_VEHICLE_PASSENGER");	
					case 7:	format(newstate, sizeof(newstate), "WASTED");
					case 8:	format(newstate, sizeof(newstate), "SPAWNED");
					case 9:	format(newstate, sizeof(newstate), "SPECTATING");
					default: format(newstate, sizeof(newstate), "NONE");
				}
				
				format(string, sizeof(string),
				"~w~W:%d I:%d %s %s %s %s %s %s~n~",
				GetPlayerVirtualWorld(specid), GetPlayerInterior(specid),
				newstate,
				//(!WC_IsPlayerSpawned(specid)) ? "~r~NotSpawned" : " ",
				//(!IsPlayerSpawned(specid)) ? "~r~NotSpawned" : "",
				(IsPlayerAFK(specid)) ? "~r~AFK" : "",
				(GetPVarInt(specid, "FlyMode")) ? "~w~Flymode" : "",
				(GetPVarInt(specid, "Specing") != -1) ? "~w~Specing" : "",
				(GetPVarInt(specid, "frz")) ? "~w~Freezed" : "",
				(GetPVarInt(specid, "Removed")) ? "~w~Hidden" : "");
				strcat(dynboxtext, string);
				
				new weaponid = GetPlayerWeapon(specid);
				new weapstate[20];
				switch(GetPlayerWeaponState(specid))
				{
					case -1: weapstate = "not in hands";
					case 0: weapstate = "no bullets";
					case 1: weapstate = "last bullet";
					case 2: weapstate = "have bullets";
					case 3: weapstate = "reload";
				}

				format(string, sizeof(string), "~r~%s (%d)~w~ slot: ~r~%d ~w~ammo: ~r~%d ~w~%s~n~",
				WeaponNamesEN[weaponid], weaponid, GetWeaponSlot(weaponid),
				GetPlayerAmmo(specid), weapstate);
				strcat(dynboxtext, string);
				
				new shootrate_str[24];
				if(LastShotTime[specid] < 1000) {
					format(shootrate_str, sizeof(shootrate_str), "~r~%d ~w~ms",
					LastShotTime[specid]);
				} else {
					format(shootrate_str, sizeof(shootrate_str), "~r~None ~w~ms");
				}

				if(Stats[specid][pShots] && Stats[specid][pShots] != 0)
				{
					new Float:shotsper = floatdiv(Stats[specid][pShots], Stats[specid][pHits]);
					format(string, sizeof(string),
					"~w~Shots ~r~%i ~w~hits ~r~%i ~w~shot/hits ratio ~r~%.2f~w~ rate %s~n~", 
					Stats[specid][pShots], Stats[specid][pHits], shotsper, shootrate_str);
					strcat(dynboxtext, string);
				} else {
					format(string, sizeof(string),
					"~w~Shots ~r~%i ~w~hits ~r~%i ~w~shot/hits ratio ~r~%.2f~w~ rate %s~n~",
					Stats[specid][pShots], Stats[specid][pHits], 0.0, shootrate_str);
					strcat(dynboxtext, string);
				}

				format(string, sizeof(string),
				"~w~Shot distance ~r~%.1f~w~ m. between players ~r~%.1f~w~ m.~n~",
				Stats[specid][pShotDistance], Stats[specid][pDistance]);
				strcat(dynboxtext, string);

				if(Stats[specid][pDamagedid] != INVALID_PLAYER_ID 
				&& Stats[specid][pDamagedid] != specid)
				{
					new str_bodypart[10];
					switch(Stats[specid][pBodypart])
					{
						case 3:	format(str_bodypart, sizeof str_bodypart, "Torso");
						case 4:	format(str_bodypart, sizeof str_bodypart, "Groin");
						case 5:	format(str_bodypart, sizeof str_bodypart, "Left arm");
						case 6:	format(str_bodypart, sizeof str_bodypart, "Right arm");
						case 7:	format(str_bodypart, sizeof str_bodypart, "Left leg");
						case 8:	format(str_bodypart, sizeof str_bodypart, "Right leg");
						case 9:	format(str_bodypart, sizeof str_bodypart, "Head");
						default: format(str_bodypart, sizeof str_bodypart, "None");
					}
					
					format(string, sizeof(string),
					"~w~Damage ~r~%s(%d)~w~ amount ~r~%.0f~w~ to bodypart ~r~%s~n~",
					PlayerName(Stats[specid][pDamagedid]),
					Stats[specid][pDamagedid],
					Stats[specid][pAmount],
					str_bodypart);
					
					strcat(dynboxtext, string);
				}

				/*format(string, sizeof(string), "~w~Total damage ~r~%.0f~n~",
				GetPVarFloat(specid, "cwdamage"));
				strcat(dynboxtext, string);*/

				new tmpstr[26], damageassist[80], assigned_slots = 0;
				for(new assist; assist < 3; assist++)
				{
					if(KillAssist[specid][assist] != INVALID_PLAYER_ID)
					{
						assigned_slots++;
						format(tmpstr, sizeof(tmpstr), "%s(%d) ",
						PlayerName(KillAssist[specid][assist]), KillAssist[specid][assist]);
						strcat(damageassist, tmpstr);
					}
				}
				if(assigned_slots > 0) {
					format(string, sizeof(string),
					"~w~Get injures from ~r~%s~n~", damageassist);
					strcat(dynboxtext, string);
				}

				#if defined _INC_WEAPON_CONFIG
					format(string, sizeof(string), "~w~Hitrate ~r~%d ~w~ms Shootrate ~r~%d ~w~ms ~n~",
					AverageHitRate(specid, 10, weaponid), AverageShootRate(specid, 10, weaponid));
					strcat(dynboxtext, string);
				#endif
				
				format(string, sizeof(string),
				"~w~Anim ~r~%d~w~ ~w~Speed ~r~%d~w~ Mps ~r~%d~n~", 
				GetPlayerAnimationIndex(specid), GetPlayerSpeed(playerid),
				NetStats_MessagesRecvPerSecond(specid));
				strcat(dynboxtext, string);
				
				// https://sampwiki.blast.hk/wiki/CameraModes
				new cammode[48];
				switch(GetPlayerCameraMode(specid))
				{
					case 3: cammode = "Train/tram camera";
					case 4: cammode = "Cam follow ped";
					case 7: cammode = "Sniper aiming";
					case 8: cammode = "Rocket Launcher aiming";
					case 15: cammode = "Fixed camera";
					case 16: cammode = "Vehicle front or side cam";
					case 18: cammode = "Normal vehicle cam";
					case 22: cammode = "Normal boat camera";
					case 46: cammode = "Camera weapon aiming";
					case 51: cammode = "Heat-seeking R.Launcher aiming";
					case 53: cammode = "Aiming any other weapon";
					case 55: cammode = "Vehicle passenger drive-by";
					case 56: cammode = "Helicopter/bird view";
					case 57: cammode = "Ground cam, zooms in very quickly";
					case 58: cammode = "Horizontal flyby past vehicle";
					case 59: cammode = "Airveh looking up ground camera";
					case 62: cammode = "Airveh vertical flyby past airveh";
					case 63: cammode = "Airveh horizontal flyby past airveh";
					case 64: cammode = "Airveh camera focused on pilot";
				}

				format(string, sizeof(string),"~w~%s~n~",cammode);
				strcat(dynboxtext, string);
				
				#if defined _streamer_included
				format(string, sizeof(string),
				"~w~Streamed objects ~r~%i/1000~n~",
				Streamer_CountVisibleItems(specid, STREAMER_OBJECT_TYPE_GLOBAL, 1));
				strcat(dynboxtext, string);
				#endif
				
				if(LastRejectHitReason[specid] > 0)
				{
					format(string, sizeof(string),"~r~[%d] %s~n~", 
					LastRejectHitReason[specid], 
					HitRejectReasons[LastRejectHitReason[specid]]);
					strcat(dynboxtext, string);	
				}
				
				if(GetPVarInt(specid, "PR_LMB") == 0 && 
				GetPVarInt(specid, "PR_RMB") == 0)
				{
					format(string, sizeof(string),"~w~LMB ~w~RMB~w~ ");
				} 
				else if(GetPVarInt(specid, "PR_LMB") == 0 && 
				GetPVarInt(specid, "PR_RMB") == 1)
				{
					format(string, sizeof(string),"~w~LMB ~r~RMB~w~ ");
				}
				else if(GetPVarInt(specid, "PR_LMB") == 1 && 
				GetPVarInt(specid, "PR_RMB") == 0)
				{
					format(string, sizeof(string),"~r~LMB ~w~RMB~w~ ");
				}
				else if(GetPVarInt(specid, "PR_LMB") == 1 && 
				GetPVarInt(specid, "PR_RMB") == 1)
				{
					format(string, sizeof(string),"~r~LMB ~r~RMB~w~ ");
				}
				strcat(dynboxtext, string);
				// Next row
				if(GetPVarInt(specid, "PR_JUMP") == 0 && 
				GetPVarInt(specid, "PR_SPRINT") == 0)
				{
					format(string, sizeof(string),"~w~JUMP ~w~SPRINT~w~~n~");
				} 
				else if(GetPVarInt(specid, "PR_JUMP") == 0 && 
				GetPVarInt(specid, "PR_SPRINT") == 1)
				{
					format(string, sizeof(string),"~w~JUMP ~r~SPRINT~w~~n~");
				}
				else if(GetPVarInt(specid, "PR_JUMP") == 1 && 
				GetPVarInt(specid, "PR_SPRINT") == 0)
				{
					format(string, sizeof(string),"~r~JUMP ~w~SPRINT~w~~n~");
				}
				else if(GetPVarInt(specid, "PR_JUMP") == 1 && 
				GetPVarInt(specid, "PR_SPRINT") == 1)
				{
					format(string, sizeof(string),"~r~JUMP SPRINT~w~~n~");
				}
				strcat(dynboxtext, string);
			}
			/*else if(GetPVarInt(playerid, "specbarmode") == 2) // SYNC_DATA
			{
				format(string, sizeof(string), "~w~[DMGTRACER] ~g~[SYNCDATA] ~n~~n~");
				strcat(dynboxtext, string);
			}*/
			
			// Write data to specbar
			PlayerTextDrawSetString(playerid, TDspecbar[playerid], specbartext);
			specbartext[0] = EOS;
			PlayerTextDrawSetString(playerid, TDspecbarDynBox[playerid], dynboxtext);
			dynboxtext[0] = EOS;
		}
		
		if(GetPVarInt(playerid, "teamtab") != -1)
		{
			UpdateteamtabTable();
			//PlayerTextDrawSetString(playerid, TDteamtab[playerid], teamtdtext);
			PlayerTextDrawSetString(playerid, TDteamtab1[playerid],teamtdtext1);
			PlayerTextDrawSetString(playerid, TDteamtab2[playerid],teamtdtext2);
			teamtdtext1[0] = EOS;
			teamtdtext2[0] = EOS;
		}
	
		if(ShowEnemyBar)
		{
			if(GetPVarInt(playerid, "enemybar") != -1)
			{
				//FPS - Ping player label
				new damagedid = GetPVarInt(playerid, "enemybar");
				static tmp[250];
				new TeamColorEmb[10];
				if (GetPVarInt(damagedid, "Team") == 0) TeamColorEmb = TDC[0];
				if (GetPVarInt(damagedid, "Team") == 1) TeamColorEmb = TDC[1];
				if (GetPVarInt(damagedid, "Team") == 2) TeamColorEmb = TDC[2];
				if(IsPlayerNPC(damagedid))
				{
					new Float: health, Float: armour;
					GetPlayerHealth(damagedid, health);
					GetPlayerArmour(damagedid, armour);
					if(health > 100.0) health = 100.0;
					
					format(tmp, sizeof(tmp),
					"~w~Name:%s%s(%d)~n~\
					~w~HP:%s%.1f ~w~Armour:%s%.1f",
					TeamColorEmb, PlayerName(damagedid), damagedid,
					TeamColorEmb, health, TeamColorEmb, armour);
				} else if(GetPVarInt(damagedid, "AFKTime") >= 5) {
					format(tmp, sizeof(tmp),
					"~w~Name:%s%s(%d) ~w~is ~r~AFK~n~", 
					TeamColorEmb, PlayerName(damagedid), damagedid);
				} else {
					new Float: health, Float: armour;
					GetPlayerHealth(damagedid, health);
					GetPlayerArmour(damagedid, armour);
					if(health > 100.0) health = 100.0;
					
					format(tmp, sizeof(tmp),
					"~w~Name:%s%s(%d)~n~\
					~w~FPS:%s%.0f ~w~Ping:%s%i ~w~PL:%s%.2f~n~\
					~w~HP:%s%.1f ~w~Armour:%s%.1f",
					TeamColorEmb, PlayerName(damagedid), damagedid,
					TeamColorEmb, floatabs(GetPVarInt(damagedid, "fps")),
					TeamColorEmb, GetPlayerPing(damagedid),
					TeamColorEmb, GetPVarFloat(damagedid, "ploss"),
					TeamColorEmb, health, TeamColorEmb, armour);
				}

				PlayerTextDrawSetString(playerid, TDenemybar[playerid], tmp);
				PlayerTextDrawShow(playerid, TDenemybar[playerid]);
			} else {
				PlayerTextDrawHide(playerid, TDenemybar[playerid]);
			}
		}
		
		if(GetPVarInt(playerid, "ShowKDtxd") != -1)
		{	
			static tmp[250];
			format(tmp, sizeof(tmp),
			"~w~Kills: ~g~%i~n~\
			~w~Death: ~g~%i~n~\
			~w~K/D: ~g~%.2f~n~\
			~w~Damage: ~g~%.2f~n~\
			~w~Efficiency: ~g~%.2f~n~",
			Stats[playerid][pKills],
			Stats[playerid][pDeath],
			Stats[playerid][pKD],
			Stats[playerid][pDamage],
			Stats[playerid][pEfficiency]);
			PlayerTextDrawSetString(playerid, TDkdstats[playerid], tmp);
			PlayerTextDrawShow(playerid, TDkdstats[playerid]);	
		} else {
			PlayerTextDrawHide(playerid, TDkdstats[playerid]);
		}
		
		if(ShowBodyLabel)
		{
			//FPS - Ping player label
			static tmp[128];
			new TeamColorEmb[10];
			if (GetPVarInt(playerid, "Team") == 0) TeamColorEmb = THC[0];
			if (GetPVarInt(playerid, "Team") == 1) TeamColorEmb = THC[1];
			if (GetPVarInt(playerid, "Team") == 2) TeamColorEmb = THC[2];

			format(tmp, sizeof(tmp),
			"%sPL: {FFFFFF}%.1f%%\n%sPing: {FFFFFF}%i\n%sFPS: {FFFFFF}%.0f",
			TeamColorEmb, GetPVarFloat(playerid, "ploss"),
			TeamColorEmb, GetPlayerPing(playerid),
			TeamColorEmb, floatabs(GetPVarInt(playerid, "fps"))
			);

			Update3DTextLabelText(BodyLabel[playerid], 0xFFFFFFFF, tmp);
		}
		
		if(OnFly[playerid])
		{
			new k, ud,lrk;
			GetPlayerKeys(playerid,k,ud,lrk);
			new Float:v_x,Float:v_y,Float:v_z,
				Float:x,Float:y,Float:z;
			if(ud < 0)	// forward
			{
				GetPlayerCameraFrontVector(playerid,x,y,z);
				v_x = x+0.1;
				v_y = y+0.1;
			}
			if(k & 128)	// down
				v_z = -0.4;
			else if(k & KEY_FIRE)// up
				v_z = 0.2;
			if(k & KEY_JUMP)	// fast
			{
				v_x *=4.0;
				v_y *=4.0;
				v_z *=4.0;
			}
			if(k & KEY_SPRINT)	// up
			{
				v_z = 0.2;
			}
			if(k & KEY_WALK)	// down
			{
				v_z = -0.4;
			}
			if(v_z == 0.0) 
				v_z = 0.025;
			SetPlayerVelocity(playerid,v_x,v_y,v_z);
			if(v_x == 0 && v_y == 0)
			{	
				if(GetPlayerAnimationIndex(playerid) == 959)	
					ApplyAnimation(playerid,"PARACHUTE","PARA_steerR",6.1,1,1,1,1,0,1);
			}
			else 
			{
				GetPlayerCameraFrontVector(playerid,v_x,v_y,v_z);
				GetPlayerCameraPos(playerid,x,y,z);
				SetPlayerLookAt(playerid,v_x*500.0+x,v_y*500.0+y);
				if(GetPlayerAnimationIndex(playerid) != 959)
					ApplyAnimation(playerid,"PARACHUTE","FALL_SkyDive_Accel",6.1,1,1,1,1,0,1);
			}
		}
		
		// Date time bottom bar
		new year,month,day; getdate(year, month, day);
		new hour,minute,second; gettime(hour,minute,second);
		new fmin[3]; // formatted minute
		if(minute < 10)
		{
			format(fmin, sizeof(fmin), "0%d", minute);
		} else {
			format(fmin, sizeof(fmin), "%d", minute);
		}
		if(CWmode && MaxRounds != 0)		
		{
			new cwlagmode[10];
			if(lagcomp == true) cwlagmode = "Skinshot"; else cwlagmode = "Lagshot";
			format(string, sizeof(string), "  [CW/TG] RSC v%s %d.%d.%d %s CW %d x %d Round: %d",
			VERSION, day,month,year, cwlagmode, MaxRounds, Roundkills, Round);
		} else {
			format(string, sizeof(string), "  [CW/TG] RSC v%s %d.%d.%d",
			VERSION, day,month,year);
		}
		PlayerTextDrawSetString(playerid, TDdatetime[playerid], string);
	
		if(CWmode && GetPlayerVirtualWorld(playerid) == 0)
		{
			format(string, sizeof(string), "%s%d~w~:%s%d", TDC[0], soucet[0], TDC[1], soucet[1]);
			PlayerTextDrawSetString(playerid, TDbigscore[playerid], string);
		}
		
		#if defined _streamer_included
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			//if(IsValidDynamicArea())
			if(World[GetPlayerVirtualWorld(playerid)][wGreenZone]) 
			{
				if(IsPlayerInDynamicArea(playerid, World[GetPlayerVirtualWorld(playerid)][wGreenZone]))
				{
					SetPlayerArmedWeapon(playerid, 0);
				}
			}
		}
		#endif
	}
	return 1;
}

public OnPlayerUpdate(playerid)
{
	// Dirty desync
	if(ForceDesynced[playerid]) return 0;
	if(Kicked[playerid]) return false;
	// AFK update
	// DeletePVar(playerid, "AFKTime");
	SetPVarInt(playerid, "AFKTime", -1);
	// To reduce the  server load, some functions are transferred to OnScriptUpdate
	SetPVarInt(playerid, "afk", GetTickCount());
	SetPVarFloat(playerid, "ploss", NetStats_PacketLossPercent(playerid));
	GetPlayerFPS(playerid);
	new fpsbardata[256];
	PlayerTextDrawColor(playerid, FPSBAR[playerid], 0xFFFFFFFF);
	if(GetPVarInt(playerid, "fps") < 450 && GetPVarInt(playerid, "fps") > 20)
	{
		format(fpsbardata,sizeof(fpsbardata),"~w~FPS:~g~%.0f ~w~Ping:~g~%d ~w~P.Loss:~g~%.2f",
		floatabs(GetPVarInt(playerid, "fps")),GetPlayerPing(playerid),GetPVarFloat(playerid, "ploss"));
		PlayerTextDrawSetString(playerid, FPSBAR[playerid], fpsbardata);
	}
	
	// HP and Armour bar
	if(pData[playerid][pHpbar])
	{
		new barstring[6];
		new Float: health, Float: armour;
		GetPlayerHealth(playerid, health);
		GetPlayerArmour(playerid, armour);
		
		if(health <= 100.0)
		{
			format(barstring,sizeof(barstring),"%.0f", health);
			PlayerTextDrawSetString(playerid, PlayerHp[playerid], barstring);
		} else {
			PlayerTextDrawSetString(playerid, PlayerHp[playerid], "GM");
		}
		
		if (armour > 0.0 && armour <= 100.0)
		{
			format(barstring,sizeof(barstring),"%.0f", armour);
			PlayerTextDrawSetString(playerid, PlayerArmour[playerid], barstring);
			// fixes a bug with stuck numbers armor in spectating
			if(GetPlayerState(playerid) != PLAYER_STATE_SPECTATING)
			{
				if(!Finalscreen) PlayerTextDrawShow(playerid, PlayerArmour[playerid]);
			}
		} else if(armour > 100.0) {
			PlayerTextDrawSetString(playerid, PlayerArmour[playerid], "GM");
		} else {
			PlayerTextDrawHide(playerid, PlayerArmour[playerid]);
		}
	}
	
	// Sprinthook protection
	if(AC_SPRINTHOOK_PROTECT)
	{
		new speed = GetPlayerSpeed(playerid); 
		if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT && speed >= AC_SPRINTHOOK_SPEED)
		{
			if(GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_USEJETPACK && !OnFly[playerid] &&
			GetPlayerAnimationIndex(playerid) != 1130 && GetPlayerAnimationIndex(playerid) != 1195)
			{
				if(GetPVarInt(playerid,"AC_SPRINTHOOKTIME") < gettime())
				{
					SetPVarInt(playerid,"AC_SPRINTHOOKTIME",gettime() + AC_SPRINTHOOK_DELAY); 
					if(GetPVarInt(playerid,"AC_SPRINTHOOK") >= AC_SPRINTHOOK_KICKAFTER){
						// Uncomment bellow if ypu need freeze player instead of kick
						//GameTextForPlayer(playerid, "Anti-sprint macro has stopped for tapping sprint key too fast.", 3000, 3);
						//TogglePlayerControllable(playerid, false);
						//SetPVarInt(playerid,"AC_SPRINTHOOK", 0);
						//SetTimerEx("TogglePlayerControllable", 1500, false, "ii", playerid, 1);
						KickPlayerEx(playerid, "Sprinthook");
					} else {
						SetPVarInt(playerid,"AC_SPRINTHOOK", GetPVarInt(playerid,"AC_SPRINTHOOK") + 1);
						new string[128];
						format(string, sizeof(string),
						"Anticheat: %s[%d] sprinthook warning. Speed: %d : MAX %d [%d/%d]",
						PlayerName(playerid), playerid,
						GetPlayerSpeed(playerid), AC_SPRINTHOOK_SPEED,
						GetPVarInt(playerid,"AC_SPRINTHOOK"), AC_SPRINTHOOK_KICKAFTER);
						if(GetPVarInt(playerid,"AC_SPRINTHOOK") == AC_SPRINTHOOK_KICKAFTER - 1) { 
							SendSystemMessage(string);
						}
					}
				}
			}
		}
	}

	// anti-slide by OKstyle
	if(AC_ANTISLIDE_PROTECT)
	{
		new Keys, ud, lr;
		GetPlayerKeys(playerid, Keys, ud, lr);
		if(ud < 0) SetPVarInt(playerid, "Slide", 1);
		else SetPVarInt(playerid, "Slide", 0);
	}
	
	// knifebug protect
	if(GetPlayerAnimationIndex(playerid) == 748)
	{
		SetPlayerSpecialAction(playerid, SPECIAL_ACTION_CUFFED);
		//GivePlayerWeapon(playerid, 4, 0); //reset knife
		SetTimerEx("ResetPlayerSpecialAction", 3000, false, "d", playerid);
		GameTextForPlayer(playerid, "~r~Don't do bullshit!", 3000, 5);
	}
	
	// AC anti-joypad
	if(lagcomp)
	{
		new keys, ud, lr;
		GetPlayerKeys(playerid, keys, ud, lr);
		if ((ud != 128 && ud != 0 && ud != -128) || (lr != 128 && lr != 0 && lr != -128))
		{
			SetPVarInt(playerid, "Mobile", 1);
		}
	}
	
	// Fly Mode
	if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY)
    {
        new keyss,ud,lr;
        GetPlayerKeys(playerid,keyss,ud,lr);

        if(noclipdata[playerid][mode] && (GetTickCount() - noclipdata[playerid][lastmove] > 100))
        {
            MoveCamera(playerid);
        }

        if(noclipdata[playerid][udold] != ud || noclipdata[playerid][lrold] != lr)
        {
            if((noclipdata[playerid][udold] != 0 || noclipdata[playerid][lrold] != 0) 
				&& ud == 0 && lr == 0)
            {
                StopPlayerObject(playerid, noclipdata[playerid][flyobject]);
                noclipdata[playerid][mode]      = 0;
                noclipdata[playerid][accelmul]  = 0.0;
            }
            else
            {  
                noclipdata[playerid][mode] = GetMoveDirectionFromKeys(ud, lr);
                MoveCamera(playerid);
            }
        }
        noclipdata[playerid][udold] = ud; noclipdata[playerid][lrold] = lr;
        return false;
    }

	return true;
}

public GiveWeapWithReloadAnimation(playerid)
{
	// Used OnPlayerRequestClass to give player sawn-off 
	// and set animation on class selection
	ApplyAnimation(playerid, "COLT45", "colt45_reload", 4.1, 0, 1, 1, 1, 1, 0);
	GivePlayerWeapon(playerid, 26, 1);
	return true;
}

public RestoreRoundGuns(world)
{
	// Return guns for all players after skip finalscreen or unfreezed after pause
	for(new i = 0; i < MAX_PLAYER_ID; i++)
	{
	    if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == world)
	    {
	        if (GetPVarInt(i, "Team") < 2 && !GetPVarInt(i, "frz"))
	        {
				RestorePlayerWeapons(i);
	        }
	    }
	}
	return true;
}

public OnPlayerRequestClass(playerid, classid)
{
	if(GetPVarInt(playerid, "Logged") < 1)
	{
		LoginDialog(playerid);
		return false;
	}
	
	SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
	
	if(GetPlayerColor(playerid) != COLOR_GREY) SetPlayerColor(playerid, COLOR_GREY);
	
	// Auto specmode for new connected players if cwmode on
	if(CWmode && speconly)
	{
		SetPlayerTeamEx(playerid, TEAM_SPEC);
		new team = GetPVarInt(playerid, "Team");
		if(pData[playerid][pSkin] != -1) 
		{
			SetSpawnInfo(playerid, 0, pData[playerid][pSkin],
			CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
			0, 0, 0, 0, 0, 0, 0);
		} else {
			new gangs[] = {102,103,104,105,106,107,108,109,110,111,112,113,114,115,116};
			new rand = random(sizeof(gangs));
			SetSpawnInfo(playerid, 0, gangs[rand],
			CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
			0, 0, 0, 0, 0, 0, 0);
		}

		new first_active_playerid = GetActivePlayerid(GetPlayerVirtualWorld(playerid));
		if(first_active_playerid != -1) {
			PlayerTextDrawShow(playerid, TDlagmode[playerid]);
			TextDrawShowForPlayer(playerid, TD[playerid]);
			SetTimerEx("Spectate", 400, false, "ii", playerid, first_active_playerid);
			TogglePlayerControllable(playerid, 1);
			if(pData[playerid][pSkin] != -1) 
			{
				SetSpawnInfo(playerid, 0, pData[playerid][pSkin],
				CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
				0, 0, 0, 0, 0, 0, 0);
			} else {
				new gangs[] = {102,103,104,105,106,107,108,109,110,111,112,113,114,115,116};
				new rand = random(sizeof(gangs));
				SetSpawnInfo(playerid, 0, gangs[rand],
				CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
				0, 0, 0, 0, 0, 0, 0);
			}
			ReSpawnPlayer(playerid);
		} else {
			SetTimerEx("FlyMode", 300, false, "i", playerid);
			ReSpawnPlayer(playerid);
		}
		
		SendClientMessageEx(playerid, COLOR_GREY,
		"Принудительный режим наблюдения включен. В данный момент Вы не можете присоединиться к игре.",
		"Spectate only mode is active. You can't join the game right now.");
		
		SendClientMessageEx(playerid, COLOR_GREY,
		"Вы можете перейти в другой виртуальный мир и играть там (/world)",
		"You can go to another virtual world and play there (/world)");
		
		if (frz) GameTextForPlayer(playerid, "~w~Game~n~ ~r~paused", 3000, 5);
		return true;
	} else {
		SetPlayerPos(playerid, 1410.1056,2211.4719,29.7109);
		SetPlayerFacingAngle(playerid, 315);
		SetPlayerCameraPos(playerid, 1412.5756,2213.9865,29.9109);
		SetPlayerCameraLookAt(playerid, 1410.1056,2211.4719,29.7109);
		SetTimerEx("GiveWeapWithReloadAnimation", 150, false, "i", playerid);
		return true;
	}
}

public OnPlayerRequestSpawn(playerid)
{
	if(GetPVarInt(playerid, "Logged") < 1)
	{
		LoginDialog(playerid);
		return false;
	}
	
	if(GetPVarInt(playerid, "FirstRequestedSpawn") < 1)
	{
        ShowWelcomeMessage(playerid);
        SetPVarInt(playerid, "FirstRequestedSpawn", 1);
    }
	
	// Proxy checker 
	// Sends a repeated VPN verification request after class selection
	if(USE_PROXY_CHECKER) 
	{
        #if defined DISCORD_VERIFICATION
		new szQuery[128], DBResult: verify_query;
		format(szQuery, sizeof(szQuery),
		"SELECT Verified FROM Accounts WHERE (Nickname = '%q')",
		db_escape(PlayerName(playerid)));
		verify_query = db_query(dbaccounts, szQuery);
		if(!db_num_rows(verify_query))
		{
			SetTimerEx("ProxyCheck", 1000, false, "i", playerid);
			db_free_result(verify_query);
		}
        #else
        SetTimerEx("ProxyCheck", 1000, false, "i", playerid);
        #endif
	}
	
	if(TeamsAutoBalance)
	{
		// Auto team select 
		new team0_c, team1_c; //team counters (0 green 1 blue)
		foreach(Player, i)
		{
			if(GetPVarInt(i, "Team") == 0) team0_c += 1;
			if(GetPVarInt(i, "Team") == 1) team1_c += 1;
		}
		if (!LockedTeams)
		{
			if(team0_c == team1_c) SetPlayerTeamEx(playerid, TEAM_GREEN);
			else if(team0_c > team1_c) SetPlayerTeamEx(playerid, TEAM_BLUE);
			else if (team1_c > team0_c)	SetPlayerTeamEx(playerid, TEAM_GREEN);
			else SetPlayerTeamEx(playerid, TEAM_SPEC);
		} else {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы не можете присоединиться к команде во время матча.",
			"Joining teams is locked right now.");
			SetPlayerTeamEx(playerid, TEAM_SPEC);
		}

		// Pre-set player bars and spawn info
		if(pData[playerid][pFpsbar] > 0) PlayerTextDrawShow(playerid, FPSBAR[playerid]);
		if(pData[playerid][pHpbar] > 0)
		{
			PlayerTextDrawShow(playerid, PlayerHp[playerid]);
			PlayerTextDrawShow(playerid, PlayerArmour[playerid]);
		}
		
		new team = GetPVarInt(playerid, "Team");
		SetSpawnInfo(playerid, 0, GetPlayerSkin(playerid),
		CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
		0, 0, 0, 0, 0, 0, 0); // 0.3d R2 bugfix, SpawnPlayer()
		ReSpawnPlayer(playerid);
		return true;
	}
	
	if(AutoTeamSpec)
	{
		SetPlayerColor(playerid, TCC[2]);
		SetPlayerTeam(playerid, 2);
		SetMarkersForPlayer(playerid);
		
		if(speconly)
		{
			new team = GetPVarInt(playerid, "Team");
			SetSpawnInfo(playerid, 0, GetPlayerSkin(playerid),
			CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
			0, 0, 0, 0, 0, 0, 0); // 0.3d R2 bugfix, SpawnPlayer()
			new first_active_playerid = GetActivePlayerid(GetPlayerVirtualWorld(playerid));
			if(first_active_playerid != -1) {
				CheckSpec(playerid);
				Spectate(playerid, first_active_playerid);
				PlayerTextDrawShow(playerid, TDlagmode[playerid]);
				TextDrawShowForPlayer(playerid, TD[playerid]);
				SetTimerEx("Specfunc", 300, false, "ii",
				playerid, first_active_playerid);
			} else {
				//ReSpawnPlayer(playerid);
				//FlyMode(playerid);
				SetTimerEx("FlyMode", 300, false, "i", playerid);
			}
			if (frz) GameTextForPlayer(playerid, "~w~Game~n~ ~r~paused", 3000, 5);
		}
		return true;
	}
	
	// Default Team select menu
	new string[64];
	format(string, sizeof(string), "%s%s\n%s%s\n%sSpectator",
	THC[0], ClanName[0], THC[1], ClanName[1], THC[2]);
	if (pData[playerid][pLang] == 0)
	{
		ShowPlayerDialog(playerid, 4, DIALOG_STYLE_LIST,
		"Выберите команду:", string, "OK", "Cancel");
	}
	else if (pData[playerid][pLang] == 1)
	{
		ShowPlayerDialog(playerid, 4, DIALOG_STYLE_LIST,
		"Choose your team:", string, "OK", "Cancel");
	}
	
	return false;
}

public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{
	if(!AllowPlayersUseVehicles)
	{
		if(GetPlayerVirtualWorld(playerid) == 0 && GetPVarInt(playerid, "Admin") < 3)
		{
			new Float:x,Float:y,Float:z;
			GetPlayerPos(playerid,x,y,z);
			SetPlayerPos(playerid,x,y,z);
			RemovePlayerFromVehicle(playerid);
			SendClientMessageEx(playerid, COLOR_RED,
			"Можно смотреть, но руками не трогать!",
			"You may look but don't touch it with your hands!");
		}
	} 
	if(GetVehicleModel(vehicleid) == 520)
	{
		// Hydra sniper bug fix - When entering a hydra aircraft with sniper rifle,
		// it disturbs the view/camera
		if(GetPlayerWeapon(playerid) == 34) SetPlayerArmedWeapon(playerid, 0);
	}
    return true;
}

public PlayerConnectedLog(playerid)
{
	/* Log connected players. (Ignore fail connections) */ 
	if(!IsPlayerConnected(playerid)) return 1;
	
	new name[MAX_PLAYER_NAME];
	new ip[16], serial[41];
	#if defined _sampcac_included
	new hwid[CAC__MAX_HARDWARE_ID];
	CAC_GetHardwareID(playerid, hwid, sizeof(hwid));
	GetPlayerName(playerid,name,sizeof(name));
	#else 
	new hwid[64] = " ";
	#endif
	gpci(playerid,serial,40);
	GetPlayerIp(playerid, ip, sizeof ip);
	new year,month,day,hour,minute,datetime[20];
	getdate(year, month, day); gettime(hour,minute,_);
	format(datetime, sizeof(datetime), "%d.%d.%d %d:%02d", year, month, day, hour, minute);
	
	new szQuery[256];
	format(szQuery, sizeof(szQuery),
	"INSERT INTO Connectionlog (Datetime, Nickname, IP, Country, City, Serial, Hwid) \
	VALUES('%q','%q','%s', '%q','%q','%q', '%q')",
	datetime, name, ip, 
	PlayerGeoIPInfo[playerid][pCountry], PlayerGeoIPInfo[playerid][pCity],
	serial, hwid);
	db_query(dblogs, szQuery);
	
	return 1;
}

public GeoIPLoadData(playerid)
{
	// Load Player GeoIP data OnPlayerConnect
	// request examples:
	// https://ip-api.com/docs/api:newline_separated#test

	new ip[16], request[128];
	GetPlayerIp(playerid, ip, sizeof ip);
	if(strcmp(ip, "127.0.0.1", false))// ignore localhost connections
	{
		if(GeoIPAsklimit < 40) // Max 45 requests per minute
		{
			format(request, sizeof(request),
			"ip-api.com/line/%s?fields=continent,country,regionName,city,isp,proxy",ip);
			HTTP(playerid, HTTP_GET, request, "", "GeoIPLookingFor");
		} else {
			print("Error: Geo IP request limit exceeded");
		}
	} else {
		if(GeoIPAsklimit < 40) // Max 45 requests per minute
		{// localhost test request
			format(request, sizeof(request),
			"ip-api.com/line/%s?fields=continent,country,regionName,city,isp,proxy","8.8.8.8");
			HTTP(playerid, HTTP_GET, request, "", "GeoIPLookingFor");
		}
	}
	return 1;
}

public GeoIPLookingFor(playerid, response_code, data[])
{
	// Get GeoIP data from https://ip-api.com/
	// The free endpoint is limited to 45 requests / minute
	
	if(response_code == 200)
	{
		#if defined _INC_SSCANF
			PlayerGeoIPInfo[playerid][pSource] = 1;
			sscanf(data, "p<\n>s[32]s[32]s[32]s[32]s[64]s[7]",
			PlayerGeoIPInfo[playerid][pContinent],
			PlayerGeoIPInfo[playerid][pCountry],
			PlayerGeoIPInfo[playerid][pRegion],
			PlayerGeoIPInfo[playerid][pCity],
			PlayerGeoIPInfo[playerid][pIsp],
			PlayerGeoIPInfo[playerid][pProxy]);
			if(Debug) printf("[DEBUG] GeoIP connection data: %s", data);
			data[0] = EOS;
		#endif
		DeletePVar(playerid, "FailedGeoIPAsks");
	} else {
		if(GetPVarInt(playerid, "FailedGeoIPAsks") < 1)
		{
			SetTimerEx("GeoIPLoadData", 15*1000, false, "i", playerid); // repeat request
			SetPVarInt(playerid, "FailedGeoIPAsks", 1);
		} else {
			#if defined _geolocation_included
				new country[32], isp[64], city[32];
				GetPlayerCountry(playerid, country, sizeof(country));
				GetPlayerISP(playerid, isp, sizeof(isp));
				GetPlayerCity(playerid, city, sizeof(city));
				//GetPlayerProxy(playerid); //not work for old base
				PlayerGeoIPInfo[playerid][pSource] = 2;
				PlayerGeoIPInfo[playerid][pCountry] = country;
				PlayerGeoIPInfo[playerid][pCity] = city;
				PlayerGeoIPInfo[playerid][pIsp] = isp;
			#endif
			DeletePVar(playerid, "FailedGeoIPAsks");
		}
	}
	//printf("%s", data);
	return 1;
}

public ProxyCheck(playerid)
{
	// Proxy checker. Get data from https://ip-api.com/
	// Look public GeoIPLookingFor for more info
	new string[128], ip[16];
	GetPlayerIp(playerid, ip, sizeof ip);
	if(strcmp(ip, "127.0.0.1", false))// ignore localhost connections
	{	
		if(strfind(PlayerGeoIPInfo[playerid][pProxy], "true", true) != -1)
		{
			//new string[128];
			format(string, sizeof(string),
			"[AC] %s(%d) is using VPN or Proxy.",
			PlayerName(playerid), playerid);
			if(USE_PROXY_CHECKER == 1) SendSystemMessage(string);
			if(USE_PROXY_CHECKER == 2) KickPlayerEx(playerid, "VPN/Proxy");
		}
	}
}

public OnIncomingConnection(playerid, ip_address[], port)
{
	if ( ! ( 0 <= playerid < _MAX_PLAYERS ) ) {
		new tmpstr[64], blocktime = 60 * 5000;
		format(tmpstr, sizeof(tmpstr), "Refuse invalid player ID incoming conection [%s]", ip_address);
		SendSystemMessage(tmpstr);
		BlockIpAddress( ip_address, blocktime );
	}
	
	#if defined _YSF_included
		new name[MAX_PLAYER_NAME];
		if(!IsValidNickName(name)) {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Некорректное имя! Придумайте другое имя.",
			"Incorrect nickname. Choose another nickname!");
		}
	#endif
	
	#if defined _FCNPC_included
	if(Online >= _MAX_PLAYERS-1)
	{
		for(new npcid = _MAX_PLAYERS; npcid >= 0; --npcid)
		{
			if(FCNPC_IsValid(npcid)) 
			{
				FCNPC_Destroy(npcid);
				printf("Server destroyed the NPC (%d) reason player limit exceed", npcid);
				return 1;
			}
		}
	}
	#endif
	
	if(Debug)
	{
		new tmpstr[64];
		format(tmpstr, sizeof(tmpstr), 
		"Incoming connection for player ID %i [IP/port: %s:%i]",
		playerid, ip_address, port);
		SendSystemMessage(tmpstr);
	}
	return 1;
}

public OnRconLoginAttempt(ip[], password[], success)
{
	// protect RCON admin sub-system
	new pip[16];
	foreach(Player,i) 
    {
		GetPlayerIp(i, pip, sizeof(pip));
        if(!strcmp(ip, pip, true)) 
        {
			KickPlayerEx(i, "RCON hack"); 
			BlockIpAddress(ip, 60000*20);
			printf("[FAIL] RCON login atempts by IP %s reason: RCON DISABLE", ip);
        }
	}
	return 1;
}

public OnPlayerConnect(playerid)
{
	new ip[16], serial[41];
	new name[MAX_PLAYER_NAME];
	GetPlayerName(playerid,name,sizeof(name));
	gpci(playerid,serial,40);
	GetPlayerIp(playerid, ip, sizeof ip);
	pData[playerid][pLang] = 1;// lang pre-set dirty dix
	Kicked[playerid] = false;
	new string[144], stringru[144];
	
	#if defined _YSF_included
	if(!IsValidNickName(name))
	{
		KickPlayerEx(playerid, "Incorrect Nickname. Change nickname in SA:MP client.");
		return true;
	}
	#endif	
	
	if(IsIP(name))
	{
		BanPlayerEx(playerid, "Unfair advertising");
		return true;
	}
	
	#if defined _sampcac_included
		CAC_ReadMemory(playerid, 0xC1704C, 1); // FPS Limit
		CAC_ReadMemory(playerid, 0xA444A0, 1); // HUD		
		CAC_ReadMemory(playerid, 0x96916D, 1); // Bulletproof		
		//CAC_ReadMemory(playerid, 0xB7CEE4, 1); // Infinity run 2
		CAC_ReadMemory(playerid, 0xB7CB64, 4); // Gamespeed
	#endif

	if(BotProtection) FakeClientCheck(playerid);
	// Skip for NPCs
	if(IsPlayerNPC(playerid)) return true;
	
	GeoIPLoadData(playerid);
	
	HardwareBanCheck(playerid);
	
	// Mute bypass checker
	if(fexist("accounts.db"))
	{
		new szQuery[128], DBResult: query;
		new mutedip[16+1];
		format(szQuery, sizeof(szQuery),
		"SELECT Lastip, Muted FROM Accounts WHERE Muted > 0");
		query = db_query(dbaccounts, szQuery);
		new rows = db_num_rows(query);
		for(new i; i < rows; i++)
		{			
			db_get_field(query, 0, mutedip, sizeof(mutedip));
			new len = strlen(mutedip);
			strdel(mutedip, len-1, len);
			
			pData[playerid][pMuted] = db_get_field_int(query, 1);
			
			//printf(mutedip);
			
			if(strfind(ip, mutedip) != -1)
			{
				format(szQuery, sizeof(szQuery),
				"UPDATE Accounts SET Muted = %i WHERE (Nickname = '%q')",
				pData[playerid][pMuted], db_escape(PlayerName(playerid)));
				db_query(dbaccounts, szQuery);
				
				format(string, sizeof(string), "%s(%d) tried bypass mute (ip: %s)",
				PlayerName(playerid), playerid, ip);
				SendSystemMessage(string);
			}
			db_next_row(query);
		}
		db_free_result(query);
	}		
	
	// Blocking the entrance by the administration
	if (ServerLock == 1) // lock login to the new players
	{
		new szQuery[128], DBResult: query;
		format(szQuery, sizeof(szQuery),
		"SELECT Nickname FROM Accounts WHERE (Nickname = '%q')",
		db_escape(PlayerName(playerid)));
		query = db_query(dbaccounts, szQuery);
		if(!db_num_rows(query))
		{
			foreach(Player, p)
			{
				if(GetPVarInt(p, "Admin") >= 1)
				{
					format(string, sizeof(string), "%s(%d) tried to join a locked server",
					PlayerName(playerid), playerid);
					format(stringru, sizeof(stringru), "%s(%d) пытался зайти на закрытый сервер",
					PlayerName(playerid), playerid);
				}
				SendClientMessageEx(p, COLOR_GREY, stringru, string);
			}
			KickPlayerEx(playerid,"Server locked (Account not registered)");
			db_free_result(query);
		}
		return true;
	}
    #if defined DISCORD_VERIFICATION
	else if (ServerLock == 2) // lock unverified login 
	{
		new szQuery[128], DBResult: query;
		format(szQuery, sizeof(szQuery),
		"SELECT Verified FROM Accounts WHERE (Nickname = '%q')",
		db_escape(PlayerName(playerid)));
		query = db_query(dbaccounts, szQuery);
		if(!db_num_rows(query))
		{
			foreach(Player, p)
			{
				if(GetPVarInt(p, "Admin") >= 1)
				{
					format(string, sizeof(string), "%s(%d) tried to join a locked server",
					PlayerName(playerid), playerid);
					format(stringru, sizeof(stringru), "%s(%d) пытался зайти на закрытый сервер",
					PlayerName(playerid), playerid);
				}
				SendClientMessageEx(p, COLOR_GREY, stringru, string);
			}
			KickPlayerEx(playerid,"UNVERIFIED ACCOUNT");
			db_free_result(query);
		}
	}
    #endif
	else if (ServerLock == 3) // lock login for all without team tags 
	{
		if (strfind(name, ClanName[0], true) == -1 && strfind(name, ClanName[1], true) == -1 && strfind(name, CLAN_TAG, true) == -1) // Tag check
		{
			SendClientMessage(playerid, COLOR_RED, "There is a tournament now, check back later.");
			foreach(Player, p)
			{
				if(GetPVarInt(p, "Admin") >= 1)
				{
					format(string, sizeof(string), "%s(%d) tried to join a locked server",
					PlayerName(playerid), playerid);
					format(stringru, sizeof(stringru), "%s(%d) пытался зайти на закрытый сервер",
					PlayerName(playerid), playerid);
				}
				SendClientMessageEx(p, COLOR_GREY, stringru, string);
			}
			KickPlayerEx(playerid,"Server teams locked");
			return true;
		}
	}
	#if defined _sampcac_included
	else if (ServerLock == 4) // lock login for all without sampcac 
	{
		if(CAC_GetStatus(playerid) == 0) {
			SendClientMessage(playerid,COLOR_RED, "SAMPCAC is not installed! Please install the Anti-Cheat SAMPCAC client version.");
			SendClientMessage(playerid, COLOR_RED, "Download it from: www.bitly.com/sampcac10");
			foreach(Player, p)
			{
				if(GetPVarInt(p, "Admin") >= 1)
				{
					format(string, sizeof(string), "%s(%d) tried to join a locked server",
					PlayerName(playerid), playerid);
					format(stringru, sizeof(stringru), "%s(%d) пытался зайти на закрытый сервер",
					PlayerName(playerid), playerid);
				}
				SendClientMessageEx(p, COLOR_GREY, stringru, string);
			}
			KickPlayerEx(playerid, "SAMPCAC is not installed");
			return true;
		}
	}
	#endif
	
	if (strfind("SS", CLAN_TAG, true) == -1)
	{
	   Kick(playerid);
	   return true;
	}
	
	new tick = GetTickCount();
	Online ++;
	
	// Skinchanger
	gHeaderTextDrawId[playerid] = PlayerText:INVALID_TEXT_DRAW;
    gBackgroundTextDrawId[playerid] = PlayerText:INVALID_TEXT_DRAW;
    gCurrentPageTextDrawId[playerid] = PlayerText:INVALID_TEXT_DRAW;
    gNextButtonTextDrawId[playerid] = PlayerText:INVALID_TEXT_DRAW;
    gPrevButtonTextDrawId[playerid] = PlayerText:INVALID_TEXT_DRAW;
    
    for(new x=0; x < SELECTION_ITEMS; x++) {
        gSelectionItems[playerid][x] = PlayerText:INVALID_TEXT_DRAW;
	}
	
	gItemAt[playerid] = 0;
	
	// FlyMode init
	noclipdata[playerid][cameramode] = CAMERA_MODE_NONE;
    noclipdata[playerid][lrold] = 0;
    noclipdata[playerid][udold] = 0;
    noclipdata[playerid][mode] = 0;
    noclipdata[playerid][lastmove] = 0;
    noclipdata[playerid][accelmul] = 0.0;
	OnFly[playerid] = false;
	
	CAM_MOVE_SPEED[playerid] = 50.0;
	CAM_MOVE_DEFAULT[playerid] = 40.0;
	CAM_MOVE_MAXIMUM[playerid] = 65.0;
	CAM_ACCEL_RATE[playerid] = 0.05;
	
	for(new assist; assist < 3; assist++) {
		KillAssist[playerid][assist] = INVALID_PLAYER_ID;
	}
	
	#if !defined _nex_ac_included
	FakeKill[playerid] = INVALID_PLAYER_ID;
	#endif
	
	Stats[playerid][pKills] = 0;
	Stats[playerid][pDeath] = 0;
	Stats[playerid][pKD] = 0.0;
	Stats[playerid][pDamage] = 0.0;
	Stats[playerid][pInjuries] = 0.0;
	Stats[playerid][pEfficiency] = 0.0;
	
	ForceDesynced[playerid] = 0;
	pData[playerid][pAdmin] = 0;
	SetPVarInt(playerid, "Team", 2);
	SetPVarInt(playerid, "world", 0);
	SetPVarInt(playerid, "VoteMap", -1);
	SetPVarFloat(playerid, "LastHP", GameHealth +0.000001);
	SetPVarInt(playerid, "Specing", -1);
	SetPVarInt(playerid, "afk", tick);
    SetPVarInt(playerid, "PreviousMess0", tick);
    SetPVarInt(playerid, "PreviousMess1", tick);
	SetPVarInt(playerid, "specbar",-1);
	SetPVarInt(playerid, "ShowKDtxd",-1);
	SetPVarInt(playerid, "ShowScoretxd",-1);
	SetPVarInt(playerid, "ShowTimetxd",-1);
	SetPVarInt(playerid, "specbarmode",1);
	SetPVarInt(playerid, "enemybar",-1);
	SetPVarInt(playerid, "teamtab",-1);
	SetPVarInt(playerid, "clist", -1);
	SetPVarInt(playerid, "LastPmID", -1);
	SetPVarInt(playerid, "lastdamaged", INVALID_PLAYER_ID); //look takedamage pub
	gPlayerAnimLibsPreloaded[playerid] = 0;
	LastRejectHitReason[playerid] = -1;	
	SetPlayerArmour(playerid, 0.0);
    SetPlayerFightingStyle(playerid, FIGHT_STYLE_NORMAL);
	//SetPVarInt(playerid, "vehCollision", !GetPVarInt(playerid, "vehCollision"));
	//DisableRemoteVehicleCollisions(playerid, GetPVarInt(playerid, "vehCollision"));
	if (GetPlayerColor(playerid) != COLOR_GREY) SetPlayerColor(playerid, COLOR_GREY);
	if (playerid >= MAX_PLAYER_ID) MAX_PLAYER_ID = playerid +1;
	PlayerPlaySound(playerid, 0, 0.0, 0.0, 0.0); //fix looped sound bug
	
	// Russian speakers geo init
	if(strfind(PlayerGeoIPInfo[playerid][pCountry], "Russia", true) != -1 ||
	strfind(PlayerGeoIPInfo[playerid][pCountry], "Ukraine", true) != -1 ||
	strfind(PlayerGeoIPInfo[playerid][pCountry], "Belarus", true) != -1)
	pData[playerid][pLang] = 0; // RU
	else pData[playerid][pLang] = 1; // Default EN
	
    for(new i = 0; i < sizeof(Skill); i++) SetPlayerSkillLevel(playerid, i, Skill[i]);
	
	new i, score_[2][10], soucet_[2][10], round_score_[2][10];
	if (score[0] < 10)
	{
	    format(score_[0], sizeof(score_[]), "~g~0%d", score[0]);
	} else {
	    if (score[0] < Roundkills) format(score_[0], sizeof(score_[]), "~g~%d", score[0]);
		else format(score_[0], sizeof(score_[]), "~r~%d", score[0]);
	}
	if (score[1] < 10)
	{
	    format(score_[1], sizeof(score_[]), "~b~0%d", score[1]);
	} else {
	    if (score[1] < Roundkills) format(score_[1], sizeof(score_[]), "~b~%d", score[1]);
		else format(score_[1], sizeof(score_[]), "~r~%d", score[1]);
	}
	for(i = 0; i < 2; i++)
	{
	    if (soucet[i] < 10) format(soucet_[i], sizeof(soucet_[]), "0%d", soucet[i]);
	    else valstr(soucet_[i], soucet[i]);
	}
	for(i = 0; i < 2; i++)
	{
		if (RoundScore[i] < 10) format(round_score_[i], sizeof(round_score_[]), "0%d", RoundScore[i]);
		else valstr(round_score_[i], RoundScore[i]);
	}
	
	new txdsize[350];
	format(txdsize, sizeof(txdsize),
	"  ~w~Match: %s%s ~w~vs. %s%s ~w~I Score: %s%s~w~:%s%s ~w~I Total: %s%s~w~:%s%s ~w~I Round: %s%s~w~:%s%s ~w~I Damage: ~y~0000~w~ I Injuries: ~y~0000~w~ I Efficiency: ~y~0.00~w~ I Kills: ~y~0~w~ I Deaths: ~y~0~w~ I Ratio: ~y~0.00~w~",
	TDC[0], ClanName[0], TDC[1], ClanName[1], TDC[0], score_[0], TDC[1], score_[1], TDC[0], soucet_[0], TDC[1], soucet_[1], TDC[0], round_score_[0], TDC[1], round_score_[1]);
	
	TextDrawSetString(TD[playerid], txdsize);
	
	// LOGIN screen
	if(!Debug) NoLogin_Timer[playerid] = SetTimerEx("NoLoginKick",
	NOLOGIN_KICK_DELAY*1000, false, "ib", playerid, false);
	
	new CheckQuery[128], DBResult: query;
	format(CheckQuery, sizeof(CheckQuery),
	"SELECT Lang FROM Accounts WHERE Nickname = '%q' LIMIT 1",
	db_escape(name));
	
	query = db_query(dbaccounts, CheckQuery);
	if(db_num_rows(query))
	{
		// Lang pre-set
		pData[playerid][pLang] = db_get_field_int(query, 0);
		db_free_result(query);
		AutoLogin(playerid); 
	} else { 
		RegisterDialog(playerid);
	}
	
	new cQuery[128], DBResult: cquery;
	format(cQuery, sizeof(cQuery),
	"SELECT Lastcountry FROM Accounts WHERE Nickname = '%q'",
	db_escape(name));
	
	cquery = db_query(dbaccounts, cQuery);
	if(db_num_rows(cquery))
	{
		db_get_field(cquery, 0, pData[playerid][pLastCountry], 32);
		db_free_result(cquery);
	}
	#if defined _sampcac_included
	// SAMPCAC after login check
	new hwid[CAC__MAX_HARDWARE_ID];
	new major, minor, patch;
	CAC_GetClientVersion(playerid, major, minor, patch);
	if(CAC_GetStatus(playerid) == 0){
		SendClientMessageEx(playerid,COLOR_RED,
		"SAMPCAC не установлен! Пожалуйста установите античит!",
		"SAMPCAC is not installed! Please install the Anti-Cheat SAMPCAC client version.");
		SendClientMessageEx(playerid, COLOR_RED,
		"Скачать по ссылке: www.bitly.com/sampcac10",
		"Download it from: www.bitly.com/sampcac10");
		foreach(Player, p)
		{
			if(GetPVarInt(p, "Admin") >= 3 && !GetPVarType(playerid, "Youtuber"))
			{
				format(string, sizeof(string),
				"%s(%d) has joined the server without SAMPCAC ( IP: %s %s)",
				PlayerName(playerid), playerid, ip, pData[playerid][pLastCountry]);
				format(stringru, sizeof(stringru), "%s(%d) вошел на сервер без SAMPCAC ( IP: %s %s)",
				PlayerName(playerid), playerid, ip, pData[playerid][pLastCountry]);
			} else {
				format(string, sizeof(string),
				"%s(%d) has joined the server without SAMPCAC",
				PlayerName(playerid), playerid);
				format(stringru, sizeof(stringru), "%s(%d) вошел на сервер без SAMPCAC",
				PlayerName(playerid), playerid);
			}
			SendClientMessageEx(p, COLOR_RED, stringru, string);
		}
		gpci(playerid, serial, sizeof(serial));
		if(Debug) printf("%s hardware ID (serial): %s", PlayerName(playerid), serial);
	} else { 
		if(minor != 10)
		{
			SendClientMessageEx(playerid,COLOR_RED,
			"SAMPCAC установлена устаревшая версия! Пожалуйста установите актуальную версию античита!",
			"SAMPCAC outdated version installed! Please install the current version of the SAMPCAC anti-cheat");
			KickPlayerEx(playerid, "No SAMPCAC");
		} else {
			foreach(Player, p)
			{
				if(GetPVarInt(p, "Admin") >= 3 && !GetPVarType(playerid, "Youtuber"))
				{
					format(string, sizeof(string),
					"%s(%d) has joined the server with SAMPCAC ( IP: %s %s)",
					PlayerName(playerid), playerid, ip, pData[playerid][pLastCountry]);
					format(stringru, sizeof(stringru),
					"%s(%d) вошел на сервер c SAMPCAC ( IP: %s %s)",
					PlayerName(playerid), playerid, ip, pData[playerid][pLastCountry]);
				} else {
					format(string, sizeof(string),
					"%s(%d) has joined the server with SAMPCAC",
					PlayerName(playerid), playerid);
					format(stringru, sizeof(stringru),
					"%s(%d) вошел на сервер c SAMPCAC",
					PlayerName(playerid), playerid);
				}
				SendClientMessageEx(p, 0xa9c4e4, stringru, string);
			}
		}
		CAC_GetHardwareID(playerid, hwid, sizeof(hwid));
		if(Debug) printf("%s hardware ID (hwid): %s", PlayerName(playerid), hwid);
	}
	#else
	foreach(Player, p)
	{
		if(GetPVarInt(p, "Admin") >= 3 && !GetPVarType(playerid, "Youtuber"))
		{
			format(string, sizeof(string), "%s(%d) has joined the server ( IP: %s %s)",
			PlayerName(playerid), playerid, ip, PlayerGeoIPInfo[playerid][pCountry]);
			format(stringru, sizeof(stringru), "%s(%d) вошел на сервер ( IP: %s %s)",
			PlayerName(playerid), playerid, ip, PlayerGeoIPInfo[playerid][pCountry]);
		} else {
			format(string, sizeof(string), "%s(%d) has joined the server",
			PlayerName(playerid), playerid);
			format(stringru, sizeof(stringru), "%s(%d) вошел на сервер",
			PlayerName(playerid), playerid);
		}
		SendClientMessageEx(p, 0xa9c4e4, stringru, string);
	}
	gpci(playerid, serial, sizeof(serial));
	if(Debug) printf("%s hardware ID (serial): %s", PlayerName(playerid), serial);
	#endif

	new ClientVersion[24];
	GetPlayerVersion(playerid, ClientVersion, sizeof(ClientVersion));
	// if the player uses a fake client, he will display a warning to everyone
	if(strfind(ClientVersion, "0.3.7") == -1 && strfind(ClientVersion, "DL") == -1
	&& !IsPlayerNPC(playerid))
	{
		SendClientMessageEx(playerid, COLOR_RED,
		"Вы используете некорректную версию клиента sa-mp, установите версию 0.3.7",
		"You are using an incorrect sa-mp client version, install version 0.3.7");
		format(string, sizeof(string), "%s(%d) has joined the server with incorrect version SA-MP %s\t",
		PlayerName(playerid), playerid, ClientVersion);
		format(stringru, sizeof(stringru), "%s(%d) вошел на сервер c некорректной версией клиента SA-MP %s\t",
		PlayerName(playerid), playerid, ClientVersion);
		SendClientMessageToAllEx(COLOR_RED, stringru, string);
	}
	
	// Proxy checker 
	if(USE_PROXY_CHECKER) 
	{
        #if defined DISCORD_VERIFICATION
		new szQuery[128], DBResult: verify_query;
		format(szQuery, sizeof(szQuery),
		"SELECT Verified FROM Accounts WHERE (Nickname = '%q')",
		db_escape(PlayerName(playerid)));
		verify_query = db_query(dbaccounts, szQuery);
		if(!db_num_rows(verify_query))
		{
			ProxyCheck(playerid);
			db_free_result(verify_query);
		}
        #else
        ProxyCheck(playerid);
        #endif
	}

	// connectionlog
	SetTimerEx("PlayerConnectedLog", 10000, false, "i", playerid);
		
	// FPS and ping textdraw
	FPSBAR[playerid] = CreatePlayerTextDraw(playerid, 499.0, 107.0,"_");
	PlayerTextDrawAlignment(playerid, FPSBAR[playerid],0);
	PlayerTextDrawBackgroundColor(playerid, FPSBAR[playerid], 255);
	PlayerTextDrawFont(playerid, FPSBAR[playerid],1);
	PlayerTextDrawLetterSize(playerid, FPSBAR[playerid],0.23, 1.0);
	PlayerTextDrawColor(playerid, FPSBAR[playerid], 0xFFFFFFFF);
	PlayerTextDrawSetOutline(playerid, FPSBAR[playerid],1);
	PlayerTextDrawSetProportional(playerid, FPSBAR[playerid],1);
	PlayerTextDrawSetShadow(playerid, FPSBAR[playerid],1);
	PlayerTextDrawHide(playerid, FPSBAR[playerid]);
	// HP
	#if defined _INC_WEAPON_CONFIG
	PlayerHp[playerid] = CreatePlayerTextDraw(playerid,570, 56, " ");
	#else
	PlayerHp[playerid] = CreatePlayerTextDraw(playerid,570, 64, " ");
	#endif
	PlayerTextDrawLetterSize(playerid, PlayerHp[playerid], 0.18, 1.3);
	PlayerTextDrawAlignment(playerid, PlayerHp[playerid], 1);
	PlayerTextDrawColor(playerid, PlayerHp[playerid], -1);
	PlayerTextDrawSetShadow(playerid, PlayerHp[playerid], 0);
	PlayerTextDrawSetOutline(playerid, PlayerHp[playerid], 1);
	PlayerTextDrawBackgroundColor(playerid, PlayerHp[playerid], 51);
	PlayerTextDrawFont(playerid, PlayerHp[playerid], 2);
	PlayerTextDrawSetProportional(playerid, PlayerHp[playerid], 1);
	// Armour
	#if defined _INC_WEAPON_CONFIG
