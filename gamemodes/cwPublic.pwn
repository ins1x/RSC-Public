	if(dialogid == 357) // AUTOTUNE_MENU
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			switch(listitem)
			{
				case 0: 
				{
					new WheelsIDs[14] = {1073,1074,1075,1076,
					1077,1078,1079, 1080,1081,1082,1083,1084,1085};
					new RandomWheel = random(sizeof(WheelsIDs));
					AddVehicleComponentNearbyWorld(worldid, playerid, 1010, 50.0);
					AddVehicleComponentNearbyWorld(worldid, playerid, WheelsIDs[RandomWheel], 50.0);
					for(new v = MAX_VEHICLES +1; --v != 0;)
					{
						if(GetVehicleVirtualWorld(v) == worldid)
						{
							new Float:vx, Float:vy, Float:vz;
							GetVehiclePos(v, vx, vy, vz);
							if(!IsPlayerInRangeOfPoint(playerid, 50.0, vx,vy,vz)) continue;
							ChangeVehicleColor(v, random(120), random(120));
						}
					}
					AUTOTUNE_MENU(playerid);
				}
				case 1: WORLD_PAINTJOB(playerid);
				case 2: 
				{
					AddVehicleComponentNearbyWorld(worldid, playerid, 1010, 50.0);
					AUTOTUNE_MENU(playerid);
				}
				case 3:
				{
					AddVehicleComponentNearbyWorld(worldid, playerid, 1087, 50.0);
					AUTOTUNE_MENU(playerid);
				}
				case 4:
				{
					AddVehicleComponentNearbyWorld(worldid, playerid, 1025, 50.0);
