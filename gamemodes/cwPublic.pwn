	switch(slot)
	{
		case 0: pData[playerid][pAttachSlot0] = attachid;
		case 1: pData[playerid][pAttachSlot1] = attachid;
		case 2: pData[playerid][pAttachSlot2] = attachid;
		case 3: pData[playerid][pAttachSlot3] = attachid;
	}
	
	if(savedata)
	{
		new szQuery[256];
		format(szQuery, sizeof(szQuery),
		"UPDATE Accounts SET AttachSlot0 = %i, AttachSlot1 = %i, \
		AttachSlot2 = %i, AttachSlot3 = %i WHERE (Nickname = '%q')",
		pData[playerid][pAttachSlot0], pData[playerid][pAttachSlot1],
		pData[playerid][pAttachSlot2], pData[playerid][pAttachSlot3],
		db_escape(PlayerName(playerid)));
		db_query(dbaccounts, szQuery);
		if(pData[playerid][pSkin] != -1)
		{
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Skin = %i WHERE (Nickname = '%q')",
			pData[playerid][pSkin], db_escape(PlayerName(playerid)));
			db_query(dbaccounts, szQuery);
		}
	}
	
	return attachid;
}

stock PlayerStatistics(playerid, showid)
{
	// Return player statistics dialog
	if(IsPlayerConnected(playerid))
	{
		new statinfo[1024], statheader[80], string[128];
		
		if(!IsPlayerNPC(playerid))
		{
			if(IsPlayerAFK(playerid))
			{	
				if(pData[showid][pLang] == 1) format(statheader,sizeof(statheader),
				"{ffffff}[id:%i] Details of player {ff9900}%s | {ff0000}AFK\n",
				playerid, PlayerName(playerid));
				else if(pData[showid][pLang] == 0) format(statheader,sizeof(statheader),
				"{ffffff}[id:%i] Информация об игроке {ff9900}%s | {ff0000}AFK\n",
				playerid, PlayerName(playerid));
			} else {
				if(pData[showid][pLang] == 1) format(statheader,sizeof(statheader),
				"{ffffff}[id:%i] Details of player {ff9900}%s \n", playerid, PlayerName(playerid));
				else if(pData[showid][pLang] == 0) format(statheader,sizeof(statheader),
				"{ffffff}[id:%i] Информация об игроке {ff9900}%s \n", playerid, PlayerName(playerid));
			}
		} else {
			if(pData[showid][pLang] == 1) format(statheader,sizeof(statheader),
			"{ffffff}[id:%i] Details of NPC {ff9900}%s \n", playerid, PlayerName(playerid));
			else if(pData[showid][pLang] == 0) format(statheader,sizeof(statheader),
			"{ffffff}[id:%i] Информация об NPC {ff9900}%s \n", playerid, PlayerName(playerid));
		}
		
		if (GetPVarInt(playerid, "Admin") > 0 && GetPVarInt(playerid, "tmpAdmin") < 1
		&& strcmp(PlayerName(playerid), "1NS", true)) {
			if(pData[showid][pLang] == 1) {
				format(string,sizeof(string),"{ff0000}Administrator: %i level \n",
				GetPVarInt(playerid, "Admin"));
			} else if (pData[showid][pLang] == 0) {
				format(string,sizeof(string), "{ff0000}Администратор: %i уровень \n",
				GetPVarInt(playerid, "Admin"));
			}
			strcat(statinfo, string);
		}
		
		if (GetPVarInt(playerid, "Fakeadmin") > 0)
		{
			if(pData[showid][pLang] == 1) {
				format(string,sizeof(string),"{ff0000}Administrator: %i level \n",
				GetPVarInt(playerid, "Fakeadmin"));
			} else if (pData[showid][pLang] == 0) {
				format(string,sizeof(string), "{ff0000}Администратор: %i уровень \n",
				GetPVarInt(playerid, "Fakeadmin"));
			}
			strcat(statinfo, string);
		}
		
		if(GetPlayerVirtualWorld(playerid) != 0)
		{
			if(World[GetPlayerVirtualWorld(playerid)][wHosted] == playerid)
			{
				if(pData[showid][pLang]) {
					format(string,sizeof(string),"{FFFFFF}World hoster №%i\n",
					GetPlayerVirtualWorld(playerid));
				} else {
					format(string,sizeof(string), "{FFFFFF}Хостер в мире №%i\n",
					GetPlayerVirtualWorld(playerid));
				}
				strcat(statinfo, string);
			} else {
				if(WorldModerator[playerid])
				{
					if(pData[showid][pLang]) {
						format(string,sizeof(string),"{FFFFFF}Virtual world moderator №%i\n",
						GetPlayerVirtualWorld(playerid));
					} else {
						format(string,sizeof(string), "{FFFFFF}Модератор в мире №%i\n",
						GetPlayerVirtualWorld(playerid));
					}
					strcat(statinfo, string);
				}
			}
		}
		#if defined DISCORD_VERIFICATION	
		if(pData[playerid][pVerified])
		{
			if(pData[showid][pLang] == 1) {
				strcat(statinfo, "{FFFFFF}Account verified\n");
			} else if (pData[showid][pLang] == 0) {
				strcat(statinfo, "{FFFFFF}Аккаунт подтвержден\n");
			}
		}
        #endif
		
		switch(GetPVarInt(playerid, "Team"))
		{
			case 0: 
			{
				if(pData[showid][pLang] == 1) format(string,sizeof(string),
				"{ffffff}Team: %s%s \n", THC[0], ClanName[0]);
				else if(pData[showid][pLang] == 0) format(string,sizeof(string),
				"{ffffff}Команда: %s%s \n", THC[0], ClanName[0]);
			}
			case 1:
			{
				if(pData[showid][pLang] == 1) format(string,sizeof(string),
				"{ffffff}Team: %s%s \n", THC[1], ClanName[1]);
				else if(pData[showid][pLang] == 0) format(string,sizeof(string),
				"{ffffff}Команда: %s%s \n",THC[1], ClanName[1]);
			}
			case 2:
			{
				if(pData[showid][pLang] == 1) format(string,sizeof(string),
				"{ffffff}Team:%s SPECTATOR \n", THC[2]);
				else if(pData[showid][pLang] == 0) format(string,sizeof(string),
				"{ffffff}Команда:%s Наблюдатель \n", THC[2]);
			}
		}
		strcat(statinfo, string);		
		
		#if defined _sampcac_included
		new major, minor, patch;
		CAC_GetClientVersion(playerid, major, minor, patch);
		new client_version[10];
		GetPlayerVersion(playerid, client_version, sizeof(client_version));
		if(CAC_GetStatus(playerid) > 0)
		{
			if(minor != 10)
			{
				if(pData[showid][pLang] == 1) format(string, sizeof(string),
				"{ff0000}SAMPCAC outdated:{ff9900} v%i.%02i.%i {FFFFFF}| \
				SA-MP client version:{ff9900} %s %s\n",
				major, minor, patch, client_version,
				GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
				else if(pData[showid][pLang] == 0) format(string, sizeof(string),
				"{ff0000}SAMPCAC устарел:{ff9900} v%i.%02i.%i {FFFFFF}| \
				Версия клиента SA-MP:{ff9900} %s %s\n",
				major, minor, patch, client_version,
				GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
			} else {
				if(pData[showid][pLang] == 1) format(string, sizeof(string),
				"{EE5555}SAMPCAC {ffffff}installed:{ff9900} v%i.%02i.%i {FFFFFF}| \
				SA-MP client version:{ff9900} %s %s\n",
				major, minor, patch, client_version,
				GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
				else if(pData[showid][pLang] == 0) format(string, sizeof(string),
				"{EE5555}SAMPCAC {ffffff}установлен:{ff9900} v%i.%02i.%i {FFFFFF}| \
				Версия клиента SA-MP:{ff9900} %s %s\n",
				major, minor, patch, client_version,
				GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
			}
			strcat(statinfo, string);
		}
		else
		{
			if(pData[showid][pLang] == 1) format(string, sizeof(string),
			"{ff0000}SAMPCAC Not installed! {FFFFFF}| \
			SA-MP client version:{ff9900} %s %s\n",
			client_version, GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
			else if(pData[showid][pLang] == 0) format(string, sizeof(string),
			"{ff0000}SAMPCAC Не установлен! {FFFFFF}| \
			Версия клиента SA-MP:{ff9900} %s %s\n",
			client_version, GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
			strcat(statinfo, string);
		}
		#else
		new client_version[10];
		GetPlayerVersion(playerid, client_version, sizeof(client_version));
		if(pData[showid][pLang] == 1) format(string, sizeof(string),
		"{ff0000}SAMPCAC Not installed! {FFFFFF}| SA-MP client version:{ff9900} %s %s\n",
		client_version, GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
		else if(pData[showid][pLang] == 0) format(string, sizeof(string),
		"{ff0000}SAMPCAC Не установлен! {FFFFFF}| Версия клиента SA-MP:{ff9900} %s %s\n",
		client_version, GetPVarInt(playerid, "Mobile") ? "| Mobile" : "");
		strcat(statinfo, string);
		#endif
		
		new ip[16];
		GetPlayerIp(playerid, ip, sizeof(ip));
		if(strcmp(ip, "127.0.0.1", false)) 
		{
			if (GetPVarInt(showid, "Admin") >= 2 && !GetPVarType(playerid, "Youtuber"))
			{
				if(pData[showid][pLang] == 1) {
					format(string, sizeof(string),
					"{ffffff}Country: {ff9900}%s{FFFFFF} City: {ff9900}%s{FFFFFF}\n",
					PlayerGeoIPInfo[playerid][pCountry],PlayerGeoIPInfo[playerid][pCity]);
					strcat(statinfo, string);
					if(strlen(PlayerGeoIPInfo[playerid][pRegion]) > 0)
					{
						format(string, sizeof(string),
						"{ffffff}Region: {ff9900}%s{FFFFFF} Provider: {ff9900}%s{FFFFFF}\n",
						PlayerGeoIPInfo[playerid][pRegion],PlayerGeoIPInfo[playerid][pIsp]);
						strcat(statinfo, string);
					}
				}
				else if(pData[showid][pLang] == 0) {
					format(string, sizeof(string),
					"{ffffff}Страна: {ff9900}%s{FFFFFF} Город: {ff9900}%s{FFFFFF}\n",
					PlayerGeoIPInfo[playerid][pCountry],PlayerGeoIPInfo[playerid][pCity]);
					strcat(statinfo, string);
					if(strlen(PlayerGeoIPInfo[playerid][pRegion]) > 0)
					{
						format(string, sizeof(string),
						"{ffffff}Регион: {ff9900}%s{FFFFFF} Провайдер: {ff9900}%s{FFFFFF}\n",
						PlayerGeoIPInfo[playerid][pRegion],PlayerGeoIPInfo[playerid][pIsp]);
						strcat(statinfo, string);
					}
				}				
			} else {
				if(GetPVarType(playerid, "Youtuber"))
				{
					if(pData[showid][pLang]) format(string, sizeof(string),
					"{ffffff}Country: {ff9900}[Hidden]\n");
					else format(string, sizeof(string),
					"{ffffff}Страна: {ff9900}[Скрыто]\n");
					strcat(statinfo, string);
				} else {
					if(pData[showid][pLang] == 1) format(string, sizeof(string),
					"{ffffff}Country: {ff9900}%s\n", PlayerGeoIPInfo[playerid][pCountry]);
					else if(pData[showid][pLang] == 0) format(string, sizeof(string),
					"{ffffff}Страна: {ff9900}%s\n", PlayerGeoIPInfo[playerid][pCountry]);
					strcat(statinfo, string);
				}
			}
		}
		
		if(!IsPlayerNPC(playerid))
		{
			if(pData[showid][pLang] == 1) format(string, sizeof(string),
			"{ffffff}FPS: {ff9900}%.0f {ffffff}Ping: {ff9900}%i {ffffff}Packetloss:{ff9900} %.2f {ffffff}‰.\n", floatabs(GetPVarInt(playerid, "fps")), GetPlayerPing(playerid),NetStats_PacketLossPercent(playerid));
			else if(pData[showid][pLang] == 0) format(string, sizeof(string),
			"{ffffff}FPS: {ff9900}%.0f {ffffff}Пинг: {ff9900}%i {ffffff}Потеря пакетов:{ff9900} %.2f {ffffff}‰.\n", floatabs(GetPVarInt(playerid, "fps")), GetPlayerPing(playerid),NetStats_PacketLossPercent(playerid));
			strcat(statinfo, string);
		}
		
		if(pData[playerid][pAttachSlot0] > 0 && pData[showid][pAdmin] >= 1)
		{
			if(pData[showid][pLang] == 1) format(string,sizeof(string),
			"{ffffff}Skin ID:{ff9900} %i  {ffffff}Costume ID:{ff9900} %i\n",
			GetPlayerSkin(playerid), pData[playerid][pAttachSlot0]);
			else if(pData[showid][pLang] == 0) format(string,sizeof(string),
			"{ffffff}№ Скина:{ff9900} %i  {ffffff}№ Костюма:{ff9900} %i\n",
			GetPlayerSkin(playerid), pData[playerid][pAttachSlot0]);
			strcat(statinfo, string);
		} else {
			if(pData[showid][pLang] == 1) format(string,sizeof(string),
			"{ffffff}Skin ID:{ff9900} %i \n", GetPlayerSkin(playerid));
			else if(pData[showid][pLang] == 0) format(string,sizeof(string),
			"{ffffff}№ Скина:{ff9900} %i \n", GetPlayerSkin(playerid));
			strcat(statinfo, string);
		}
		
		/*if(pData[playerid][pCookies] > 0)
		{
			if(pData[showid][pLang] == 1) format(string, sizeof(string),
			"{ffffff}Cookies:{ff9900} %d \n", pData[playerid][pCookies]);
			else if(pData[showid][pLang] == 0) format(string, sizeof(string),
			"{ffffff}Печенек:{ff9900} %d \n", pData[playerid][pCookies]);
			strcat(statinfo, string);
		}*/
			
		if(pData[showid][pLang] == 1) format(string, sizeof(string),
		"{ffffff}Connected to the server for {ff9900}%d {ffffff}minutes \n",
		NetStats_GetConnectedTime(playerid)/60000);
		else if(pData[showid][pLang] == 0) format(string, sizeof(string),
		"{ffffff}Подключен к серверу {ff9900}%d {ffffff}минут \n",
		NetStats_GetConnectedTime(playerid)/60000);
		strcat(statinfo, string);
		
		#if defined _YSF_included
		if( IsPlayerPaused(playerid) ) {
			if(pData[showid][pLang] == 1) format(string, sizeof(string),
			"{ffffff}AFK {ff9900}%d {ffffff}minutes \n", GetPlayerPausedTime(playerid)/60000);
			else if(pData[showid][pLang] == 0) format(string, sizeof(string),
			"{ffffff}Отошел {ff9900}%d {ffffff}минут \n", GetPlayerPausedTime(playerid)/60000);
			strcat(statinfo, string);
		}
		#endif
		
		if (GetPVarInt(showid, "Admin") >= 1)
		{
			if(pData[playerid][pMuted] > 0)
			{
				if(pData[playerid][pMuted] > 99999999){
					if(pData[showid][pLang] == 1) strcat(statinfo,
					"{FF0000}Player is muted forever{FFFFFF}\n");
					else if(pData[showid][pLang] == 0) strcat(statinfo,
					"{FF0000}Игрок заглушен навсегда{FFFFFF}\n");
				} else {
					if(pData[showid][pLang] == 1) format(string,sizeof(string),
					"{FFFFFF}Player is muted for {ff9900}%d sec (%d min){FFFFFF}\n",
					pData[playerid][pMuted], (pData[playerid][pMuted])/60);
					else if(pData[showid][pLang] == 0) format(string,sizeof(string),
					"{FFFFFF}Игрок заглушен на {ff9900}%d сек (%d мин){FFFFFF}\n",
					pData[playerid][pMuted], (pData[playerid][pMuted])/60);
					strcat(statinfo, string);
				}
			}
		} else {
			if(pData[playerid][pMuted] > 0) {
				if(pData[playerid][pMuted] > 99999999 ||
				GetPVarInt(playerid,"Hwmuted")) {
					if(pData[showid][pLang] == 1) strcat(statinfo,
					"{FF0000}Player is muted forever{FFFFFF}\n");
					else if(pData[showid][pLang] == 0) strcat(statinfo,
					"{FF0000}Игрок заглушен навсегда{FFFFFF}\n");
				} else { 
					if(pData[showid][pLang] == 1) strcat(statinfo, "{FFFFFF}Player is muted\n");
					else if(pData[showid][pLang] == 0) strcat(statinfo, "{FFFFFF}Игрок заглушен\n");
				}
			}
		}
			
		if(GetPlayerState(playerid) == PLAYER_STATE_NONE) {
			if(pData[showid][pLang] == 1) strcat(statinfo,
			"{AFAFAF}Player state Initializing...{FFFFFF}\n");
			else if(pData[showid][pLang] == 0) strcat(statinfo,
			"{AFAFAF}Инициализация...{FFFFFF}\n");
		}
		else if(GetPlayerState(playerid) == PLAYER_STATE_WASTED) {
			if(pData[showid][pLang] == 1) strcat(statinfo,
			"{AFAFAF}Player is dead or in class selection{FFFFFF}\n");
			else if(pData[showid][pLang] == 0) strcat(statinfo,
			"{AFAFAF}Игрок умер или находится в выборе класса{FFFFFF}\n");
		}
			
		if (GetPVarInt(showid, "Admin") >= 1)
		{
			if(GetPVarInt(playerid, "Specing") != -1){
				if(pData[showid][pLang] == 1) format(string,sizeof(string),
				"{ffffff}Player is spectating {ff9900}%s[%d]\n",
				PlayerName(GetPVarInt(playerid, "Specing")),GetPVarInt(playerid, "Specing"));
				else if(pData[showid][pLang] == 0) format(string,sizeof(string),
				"{ffffff}Игрок наблюдает за {ff9900}%s[%d]\n",
				PlayerName(GetPVarInt(playerid, "Specing")),GetPVarInt(playerid, "Specing"));
				strcat(statinfo, string);
			}
		} else {
			if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) {
				if(pData[showid][pLang] == 1) strcat(statinfo,
				"{AFAFAF}Player is spectating{FFFFFF}\n");
				else if(pData[showid][pLang] == 0) strcat(statinfo,
				"{AFAFAF}Игрок в наблюдении{FFFFFF}\n");
			}
		}
		
		if (GetPVarInt(playerid,"HighPlossCount") >= 3 || GetPVarInt(playerid,"HighPingCount") >= 3)
		{
			if(pData[showid][pLang] == 1) strcat(statinfo,
			"{FF0000}Bad server connection{FFFFFF}\n");
			else if(pData[showid][pLang] == 0) strcat(statinfo,
			"{FF0000}Плохое соединение с сервером{FFFFFF}\n");
		}
		
		// Show dialog player (showid)
		if(pData[showid][pLang] == 1) {
			ShowPlayerDialog(showid, 7, DIALOG_STYLE_MSGBOX, statheader, statinfo,"Refresh","Close");
		} else if(pData[showid][pLang] == 0) {
			ShowPlayerDialog(showid, 7, DIALOG_STYLE_MSGBOX, statheader, statinfo,"Обновить","Закрыть");
		}
	}
}
	
stock PlayerRoundStats(showid, playerid)
{
	new statinfo[1000], statheader[80];
	new ratio[MAX_PLAYER_NAME];
	GetPlayerName(playerid, ratio, MAX_PLAYER_NAME);
	new stringen[108];

	strcat(statinfo, "\n{ff0000}Overall:\n{FFFFFF}");
	if (GetPVarInt(playerid, "cwdeath") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", GetPVarInt(playerid, "cwkills") /float(GetPVarInt(playerid, "cwdeath")));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "Kills: %d | Deaths: %d | Ratio: %s", GetPVarInt(playerid, "cwkills"), GetPVarInt(playerid, "cwdeath"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");
	if (GetPVarInt(playerid, "cwdeath") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", (GetPVarInt(playerid, "cwkills") -GetPVarInt(playerid, "cwteamkills")) /float(GetPVarInt(playerid, "cwdeath")));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "TeamKills: %d | Kills without TK: %d | Ratio without TK: %s", GetPVarInt(playerid, "cwteamkills"), GetPVarInt(playerid, "cwkills") -GetPVarInt(playerid, "cwteamkills"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");
	
	if (GetPVarFloat(playerid, "cwinjuries") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", GetPVarFloat(playerid, "cwdamage") /GetPVarFloat(playerid, "cwinjuries"));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "Damage: %.2f | Injuries: %.2f | Ratio: %s", GetPVarFloat(playerid, "cwdamage"), GetPVarFloat(playerid, "cwinjuries"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");
	
	if (GetPVarFloat(playerid, "cwinjuries") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", (GetPVarFloat(playerid, "cwdamage") -GetPVarFloat(playerid, "cwteamdamage")) /GetPVarFloat(playerid, "cwinjuries"));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "Teammates damage: %.2f | Damage without team damage: %.2f | Ratio without team damage: %s", GetPVarFloat(playerid, "cwteamdamage"), GetPVarFloat(playerid, "cwdamage") -GetPVarFloat(playerid, "cwteamdamage"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");
	
	strcat(statinfo, "\n{FF0000}This round:{FFFFFF}\n");
	if (GetPVarInt(playerid, "cwdeath") -GetPVarInt(playerid, "round_death") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", (GetPVarInt(playerid, "cwkills") -GetPVarInt(playerid, "round_kills")) /float(GetPVarInt(playerid, "cwdeath") -GetPVarInt(playerid, "round_death")));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "Kills: %d | Deaths: %d | Ratio: %s", GetPVarInt(playerid, "cwkills") -GetPVarInt(playerid, "round_kills"), GetPVarInt(playerid, "cwdeath") -GetPVarInt(playerid, "round_death"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");
	if (GetPVarInt(playerid, "cwdeath") -GetPVarInt(playerid, "round_death") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", (GetPVarInt(playerid, "cwkills") -GetPVarInt(playerid, "round_kills") -GetPVarInt(playerid, "cwteamkills") +GetPVarInt(playerid, "round_teamkills")) /float(GetPVarInt(playerid, "cwdeath") -GetPVarInt(playerid, "round_death")));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "TeamKills: %d | Kills without TK: %d | Ratio without TK: %s", GetPVarInt(playerid, "cwteamkills") -GetPVarInt(playerid, "round_teamkills"), GetPVarInt(playerid, "cwkills") -GetPVarInt(playerid, "round_kills") -GetPVarInt(playerid, "cwteamkills") +GetPVarInt(playerid, "round_teamkills"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");
	
	if (GetPVarFloat(playerid, "cwinjuries") -GetPVarFloat(playerid, "round_injuries") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", (GetPVarFloat(playerid, "cwdamage") -GetPVarFloat(playerid, "round_damage")) /(GetPVarFloat(playerid, "cwinjuries") -GetPVarFloat(playerid, "round_injuries")));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "Damage: %.2f | Injuries: %.2f | Ratio: %s", GetPVarFloat(playerid, "cwdamage") -GetPVarFloat(playerid, "round_damage"), GetPVarFloat(playerid, "cwinjuries") -GetPVarFloat(playerid, "round_injuries"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");
	
	if (GetPVarFloat(playerid, "cwinjuries") -GetPVarFloat(playerid, "round_injuries") > 0)
	{
		format(ratio, sizeof(ratio), "%.2f", (GetPVarFloat(playerid, "cwdamage") -GetPVarFloat(playerid, "round_damage") -GetPVarFloat(playerid, "cwteamdamage") +GetPVarFloat(playerid, "round_teamdamage")) /(GetPVarFloat(playerid, "cwinjuries") -GetPVarFloat(playerid, "round_injuries")));
	}else{
		ratio = "-";
	}
	format(stringen, sizeof(stringen), "Teammates damage: %.2f | Damage without team damage: %.2f | Ratio without team damage: %s", GetPVarFloat(playerid, "cwteamdamage") -GetPVarFloat(playerid, "round_teamdamage"), GetPVarFloat(playerid, "cwdamage") -GetPVarFloat(playerid, "round_damage") -GetPVarFloat(playerid, "cwteamdamage") +GetPVarFloat(playerid, "round_teamdamage"), ratio);
	strcat(statinfo, stringen);
	strcat(statinfo, "\n");

	// end stats
	ShowPlayerDialog(showid, 51, DIALOG_STYLE_MSGBOX, statheader, statinfo,"Refresh","Close");
}

stock MODSET_MENU(playerid)
{
	new tbtext[640], KICK_LAGERS_State[24], lagcomp_State[32], ServerLock_state[32];
	
	if(KICK_LAGERS == 0) KICK_LAGERS_State = "{AFAFAF}[NO CHECK]";
	else if (KICK_LAGERS == 1) KICK_LAGERS_State = "{FFFF00}[WARNING]";
	else if (KICK_LAGERS == 2) KICK_LAGERS_State = "{00FF00}[KICK]";
	else if (KICK_LAGERS == 3) KICK_LAGERS_State = "{00FF00}[MOVESPEC]";
	
	switch(ServerLock)
	{
		case 0: ServerLock_state = "{AFAFAF}[NO LIMITS]";
		case 1: ServerLock_state = "{00FF00}[REGISTERED]";
		case 2: ServerLock_state = "{00FF00}[VERIFIED]";
		case 3: ServerLock_state = "{00FF00}[TEAMMATES]";
		case 4: ServerLock_state = "{00FF00}[AC ONLY]";
	}
	
	switch(SYNCMODE) 
	{
		case 0: lagcomp_State = "{AFAFAF}Default Skinshot";
		case 1: lagcomp_State = "{AFAFAF}YSI Skinshot";
		case 2: lagcomp_State = "{AFAFAF}Default Lagshot";
		case 3: lagcomp_State = "{AFAFAF}League Skinshot";
		case 4: lagcomp_State = "{AFAFAF}UG Skinshot";
		case 5: lagcomp_State = "{AFAFAF}SKY Skinshot";
	}
	
	if(pData[playerid][pLang] == 1)
	{	
		format(tbtext, sizeof(tbtext),
		"Change hostname\t\n"\
		"Configure Hitbox\t%s\n"\
		"Check Lagers\t%s\n"\
		"Login settings\t%s\n"\
		"Tickrate\t{AFAFAF}%i\n"\
		"Anti-Spam\t%s\n"\
		"{FF0000}Debug{FFFFFF} mode\t%s\n"\
		"Network settings\t\n"\
		"3D text settings\t\n"\
		"NPC and Actors\t\n"\
		"Vehicles\t\n"\
		"{00FF00}Save{FFFFFF} gamemode config file\t\n"\
		"{00FF00}Update{FFFFFF} streamer\t\n"\
		"{00FF00}Reload{FFFFFF} ban list (samp.ban)\t\n"\
		"Exec RCON command\t\n"\
		"Wipe virtual world\t\n"\
		"{FF0000}Restart gamemmode\t\n",
		lagcomp_State,
		KICK_LAGERS_State,
		ServerLock_state,
		GetServerTickRate(),
		(ServerAntiSpam) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(Debug) ? "{00FF00}[ON]" : "{FF0000}[ОFF]");
	} else {
		format(tbtext, sizeof(tbtext),
		"Сменить название сервера\t\n"\
		"Настроить Hitbox\t%s\n"\
		"Обнаружение лагеров\t%s\n"\
		"Вход на сервер\t%s\n"\
		"Тикрейт\t{AFAFAF}%i\n"\
		"Антиспам\t%s\n"\
		"{FF0000}Debug{FFFFFF} режим\t%s\n"\
		"Настройки сети\t\n"\
		"Настройки 3D текста\t\n"\
		"NPC и Актеры\t\n"\
		"Транспорт\t\n"\
		"{00FF00}Обновить{FFFFFF} конфиг мода\t\n"\
		"{00FF00}Обновить{FFFFFF} стример\t\n"\
		"{00FF00}Обновить{FFFFFF} бан лист (samp.ban)\t\n"\
		"Выполнить команду RCON\t\n"\
		"Вайпнуть виртуальный мир\t\n"\
		"{FF0000}>>> Перезагрузить мод\t\n",
		lagcomp_State,
		KICK_LAGERS_State,
		ServerLock_state,
		GetServerTickRate(),
		(ServerAntiSpam) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(Debug) ? "{00FF00}[ON]" : "{FF0000}[ОFF]");
	}
	
	if(GetPVarInt(playerid, "Admin") >= 2) {
		return ShowPlayerDialog(playerid, 62, DIALOG_STYLE_TABLIST,
		".:: Server control panel ::.", tbtext, "Select", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_RED,
		"Для использования этих функций Вы должны быть администратором 2+ уровня!",
		"To use these functions you need to have 2+ level admin rights!");
	}
}

stock NETWORK_MENU(playerid)
{
	new tbtext[320];
	new messageslimit = GetServerVarAsInt("messageslimit");
	new ackslimit = GetServerVarAsInt("ackslimit");
	new messageholelimit = GetServerVarAsInt("messageholelimit");
	new playertimeout = GetServerVarAsInt("playertimeout");
	
	new Bind[16], header[128];
	GetServerVarAsString("bind", Bind, 16);
	format(header, sizeof(header), "Network - Bind IP: %s Port: %i", Bind, GetServerVarAsInt("port"));
	if(strlen(Bind) > 1)
	{
		format(header, sizeof(header), "Network - Bind IP: %s Port: %i",
		Bind, GetServerVarAsInt("port"));
	}
	else format(header, sizeof(header), "Network");
	
	#if defined _YSF_included
		new extendednetstats = YSF_IsExtendedNetStatsEnabled();
	#else
		new extendednetstats = false;
	#endif
	
	if(pData[playerid][pLang])
	{	
		format(tbtext, sizeof(tbtext),
		"Server network statistics\t\n"\
		"Fake ping balancer\t%s\n"\
		"Bot protection\t%s\n"\
		"Extended NetStats\t%s\n"\
		"\t\n"\
		"messageslimit\t%d\n"\
		"ackslimit\t%d\n"\
		"messageholelimit\t%d\n"\
		"playertimeout\t%d\n",
		(FakePingBalancer) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(BotProtection) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(extendednetstats) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		messageslimit,
		ackslimit,
		messageholelimit,
		playertimeout);
	} else {
		format(tbtext, sizeof(tbtext),
		"Сетевая статистика сервера\t\n"\
		"Балансировщик пинга\t%s\n"\
		"Защита от ботов\t%s\n"\
		"Расширенная сетевая статистика\t%s\n"\
		"\t\n"\
		"messageslimit\t%d\n"\
		"ackslimit\t%d\n"\
		"messageholelimit\t%d\n"\
		"playertimeout\t%d\n",
		(FakePingBalancer) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(BotProtection) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(extendednetstats) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		messageslimit,
		ackslimit,
		messageholelimit,
		playertimeout);
	}
	
	if(GetPVarInt(playerid, "Admin") >= 3) {
		return ShowPlayerDialog(playerid, 341, DIALOG_STYLE_TABLIST,
		header, tbtext, "Select", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Для использования этих функций Вы должны быть администратором 3+ уровня!",
		"To use these functions you need to have 3+ level admin rights!");
	}
}

stock VEH_MENU(playerid)
{
	new tbtext[520];

	if(pData[playerid][pLang] == 1)
	{	
		format(tbtext, sizeof(tbtext),
		"Spawn a new vehicle\t\n"\
		"Set HP for all vehicles\t\n"\
		"{FF0000}Hijack{FFFFFF} a player from a vehicle\t\n"\
		"{FF0000}Hijack{FFFFFF} all players\t\n"\
		"Respawn all vehicles\t\n"\
		"Find all vehicles (at virt. world)\t\n"\
		"{FF0000}Destroy{FFFFFF} nearby vehicles (20m)\t\n"\
		"{FF0000}Destroy{FFFFFF} all vehicles)\t\n");
	} else {
		format(tbtext, sizeof(tbtext),
		"Создать транспорт\t\n"\
		"Изменить ХП для всего транспорта\t\n"\
		"{FF0000}Выкинуть{FFFFFF} игрока из транспорта\t\n"\
		"{FF0000}Выкинуть{FFFFFF} всех игроков из транспорта\t\n"\
		"Найти весь транспорт (в вирт. мире)\t\n"\
		"Заспавнить весь транспорт\t\n"\
		"{FF0000}Уничтожить{FFFFFF} транспорт рядом (20m)\t\n"\
		"{FF0000}Уничтожить{FFFFFF} весь транспорт\t\n");
	}
	
	if(GetPVarInt(playerid, "Admin") >= 2) {
		return ShowPlayerDialog(playerid, 129, DIALOG_STYLE_TABLIST,
		"VEHICLES", tbtext, "Ok", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_RED,
		"Для использования этих функций Вы должны быть администратором 2+ уровня!",
		"To use these functions you need to have 2+ level admin rights!");
	}
}

