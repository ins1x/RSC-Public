stock AllowedMods(playerid)
{
	if (pData[playerid][pLang])
	{
		ShowPlayerDialog(playerid, 17, DIALOG_STYLE_MSGBOX, "{FFD700}[Allowed modifications]",
		"{FFFFFF}Allowed: \n"\
		" - replace hud elements, fonts and the samp GUI interface\n"\
		" - replace/remove particles and effects (Particle, EffectsPC, Effects)\n"\
		" - use your timesus, change the distance of the fog drawing \n"\
		" - use plugins that fix game bugs (sensfix, mousefix, flickr, dwm)\n"\
		" - use anti-crashers (crashes.asi, anticrasher.asi)\n"\
		" - replace models of skins and weapons without changing their geometry and characteristics\n"\
		"\n"\
		"{FF0000}Forbidden{FFFFFF}: \n"\
		" - replace samp.exe/samp.dll and gta_sa.exe, as well as standard samp client files \n"\
		" - skins with irregular geometry, collision, non-standard effects.\n"\
		" - modifications of the original map and objects of the game giving an advantage.\n"\
		" - modifications that add an eternal sight or hold it at one point.\n"\
		" - modifications to weapons and changes to the weapons.dat file.\n"\
		" - any plugins/macros for the stele (e.g. example autoscroll, autocbug, fastzoom)\n"\
		" - any plugins/macros for running (e.g. sprinthook, fastwalk)\n"\
		" - any plugins/macros/replacements of original animations, scripts for knocking down animations\n"\
		" - replacement of any vehicle whose dimensions differ from the model being replaced.\n"\
		" - any cheats /cleo/mods/bugs that give an unfair advantage over other players.\n"\
		"\n",
		"OK", "");
	} else {
		ShowPlayerDialog(playerid, 17, DIALOG_STYLE_MSGBOX, "{FFD700}[Разрешенные модификации]",
		"{FFFFFF}Разрешено: \n"\
		" - заменять элементы hud, шрифты и интерфейс samp GUI\n"\
		" - заменять/удалять партиклы и эффекты (Particle, EffectsPC, Effects)\n"\
		" - использовать свой таймсус, изменять дальность прорисовки тумана\n"\
		" - использовать плагины исправляющие баги игры (sensfix, mousefix, flickr, dwm)\n"\
		" - использоать антикрашеры (crashes.asi, anticrasher.asi)\n"\
		" - заменять модели скинов и оружия без изменения их геометрии и характеристик\n"\
		"\n"\
		"{FF0000}Запрещено{FFFFFF}: \n"\
		" - заменять samp.exe/samp.dll и gta_sa.exe, а также стандартные файлы samp клиента\n"\
		" - скины с неправильной геометрией, коллизией, нестандартными эффектами.\n"\
		" - модификации оригинальной карты и объектов игры дающие преимущество.\n"\
		" - модификации добавляющая вечный прицел или его удержание в одной точке.\n"\
		" - модификации на оружие и изменения в файле weapons.dat.\n"\
		" - любые плагины/макросы для стельбы (например autoscroll, autocbug, fastzoom)\n"\
		" - любые плагины/макросы на бег (например sprinthook, fastwalk)\n"\
		" - любые плагины/макросы/замены оригинальных анимаций, скрипты для сбива анимаций\n"\
		" - замена любого транспорта, размеры которого отличаются от заменяемой модели.\n"\
		" - любые читы/клео/моды/баги, дающие нечестное преимущество над другими игроками.\n"\
		"\n",
		"OK", "");
	}
}

stock Rules(playerid)
{
	if (pData[playerid][pLang])
	{
		ShowPlayerDialog(playerid, 17, DIALOG_STYLE_MSGBOX, "{FFD700}[Rules]",
		"{FFFFFF}Russian Sawn-off Community server rules:\n"\
		"\n"\
		"- Do not use hacks/CLEOs/mods/bugs of any kind which give an unfair advantage over other players.\n"\
		"- Do not abuse any glitches or misuse server commands to get an unfair advantage over other players.\n"\
		"- Do not spam, flood or advertise in chat.\n"\
		"- Do not insult, flame or harass other players.\n"\
		"- Do not impersonate other players or use unauthorized clantags.\n"\
		"\n"\
		"By playing on our server you accept the rules above.\n"\
		"Refusing to obey the rules will result in a mute, kick or a ban.\n",
		"OK", "");
	} else {
		ShowPlayerDialog(playerid, 17, DIALOG_STYLE_MSGBOX, "{FFD700}[Правила]",
		"{FFFFFF}На сервере запрещено:\n"\
		"\n"\
		"- Использование любых читов/клео/модов/багов, дающих нечестное преимущество над другими игроками.\n"\
		"- Злоупотребление/использование не по назначению серверных команд для получения преимущества над другими игроками.\n"\
		"- Спам/флуд/реклама в чате.\n"\
		"- Чрезмерные оскорбления, разжигание конфликтов, затрагивание родных в чате.\n"\
		"- Использование фейковых никнеймов других игроков/клан-тегов.\n"\
		"\n"\
		"Играя на нашем сервере, Вы автоматически соглашаетесь с правилами, приведенными выше.\n"\
		"Нарушение правил сервера повлечет за собой мут, кик или бан. \n",
		"OK", "");
	}
}

