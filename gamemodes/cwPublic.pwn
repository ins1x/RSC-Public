	if(dialogid == 258)// permanent skin
	{
		if(response)
		{
			if(isempty(inputtext)) return 0;
			if(!isnumeric(inputtext)) return 0;
			// Clear costumes
			new skinid = strval(inputtext);
			// Skins from 300 to 311 have been added
			// to SA-MP 0.3.7 RC3 and they don't work in older versions!
			if(skinid < 0 || skinid >= 300 || skinid == 74) 
			{
				SendClientMessageEx(playerid,COLOR_GREY,
				"Ошибка: неверный № скина", "ERROR: Invalid skin id!");
				return true;
			}
			switch(skinid)
			{
				case 0,1,2,74,86,92,99,149,265,266,267,268,269,270,271,272:
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Этот скин запрещен!", "This skin is forbidden!");
				}
			}
			if(IsPlayerInAnyVehicle(playerid))
			{
				new Float:x, Float:y, Float:z;
				GetPlayerPos(playerid, x , y, z);
				SetPlayerPos(playerid, x , y, z+1);
			}
			if(GetPlayerAnimationIndex(playerid) == 1274 || GetPlayerAnimationIndex(playerid) == 1159)
			{
				ApplyAnimation(playerid,"PLAYIDLES","stretch",4.0,0,0,0,0,0);
			}
			
			new slot = 0;
			pData[ChosenPlayer[playerid]][pSkin] = skinid;
			PlayerAttachments(ChosenPlayer[playerid], slot, 600);
			SetPlayerSkin(ChosenPlayer[playerid], skinid);
			SetVirtualWorldSpawnInfo(ChosenPlayer[playerid], skinid);
			
			new szQuery[128];
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Skin = %i WHERE (Nickname = '%q')",
			pData[ChosenPlayer[playerid]][pSkin], db_escape(PlayerName(ChosenPlayer[playerid])));
			db_query(dbaccounts, szQuery);
			
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET AttachSlot0 = %i WHERE (Nickname = '%q')",
			pData[ChosenPlayer[playerid]][pAttachSlot0], db_escape(PlayerName(ChosenPlayer[playerid])));
			db_query(dbaccounts, szQuery);
		}
	}
