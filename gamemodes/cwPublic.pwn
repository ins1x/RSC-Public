	if(dialogid == 45)
	{
		if(response)
		{
			if (strval(inputtext) == 0) return SendClientMessageEx(playerid, COLOR_GREY, "Не может быть равно 0", "Don't do bullshits!");
			if (score[0] == Roundkills || score[1] == Roundkills)
		 	{
			    SendClientMessageEx(playerid, COLOR_GREY, "Сейчас Вы не можете использовать данную функцию.", "You can't use this function right now.");
		 	    return true;
		 	}
		 	new string[68], stringen[82], bod = strval(inputtext);
			
			if (!(0 <= bod +score[ChosenTeam[playerid]] <= Roundkills))
			{
				format(string, sizeof(string), "Диапазон очков 0-%d.", Roundkills);
				format(stringen, sizeof(stringen), "Range of points is 0-%d.", Roundkills);
				SendClientMessageEx(playerid, COLOR_GREY, string, stringen);
				return true;
			}
			format(string, sizeof(string), "%s(%d) добавил команде %s %d очков в текущем раунде.", PlayerName(playerid), playerid, ClanName[ChosenTeam[playerid]], bod);
			format(stringen, sizeof(stringen), "%s(%d) has given %d points in round score to %s team.", PlayerName(playerid), playerid, bod, ClanName[ChosenTeam[playerid]]);
			SendClientMessageToVirtualWorld(0, COLOR_GREY, string, stringen);
			score[ChosenTeam[playerid]] += bod;
			soucet[ChosenTeam[playerid]] += bod;
			RefreshScore();
			return true;
		} else ROUNDSET_MENU(playerid);
	}
