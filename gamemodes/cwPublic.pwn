	if(dialogid == 352)
	{
		if(response)
		{
			new worldid = GetPlayerVirtualWorld(playerid);
			if(worldid != 0 && !WorldModerator[playerid])
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не модератор мира!", "You are not moderator!");
				return true;
			}
			
			if(!strlen(inputtext)) return false;
			
			SetPVarInt(playerid, "Audiostreamer", 1);
			
			foreach(Player, i)
			{
				if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(playerid))
				{
					SetPVarInt(i, "Audiolistener", 1);
					StopAudioStreamForPlayer(i);
					PlayAudioStreamForPlayer(i, inputtext);
					SendClientMessageEx(i, COLOR_GREY,
					"Начат аудиострим", "Audiostream started");
				}
			}
			STREAM_MENU(playerid);
		}
		else STREAM_MENU(playerid);
	}
