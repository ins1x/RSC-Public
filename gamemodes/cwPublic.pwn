	if (!strcmp(cmdtext, "/fly", true) || !strcmp(cmdtext, "/flymode", true))
	{
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED
		|| GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}		
		if (GetPVarInt(playerid, "Team") == 2)
		{
			if (GetPVarInt(playerid, "Specing") > -1)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете войти в режим полета. Сначала выйдите из наблюдения!",
				"Spectators can't switch to fly mode right now. Exit spectate mode first!");
				return true;
			}
			if(GetPVarType(playerid, "FlyMode"))
			{
				if (speconly)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"В данный момент наблюдатели обязаны оставаться в режиме наблюдения.",
					"Spectators are required to use spectate mode right now.");
					SendClientMessageEx(playerid, COLOR_GREY,
					"Вы можете перейти в другой виртуальный мир и играть там (/world)",
					"You can go to another virtual world and play there (/world)");
					FlyMode(playerid);
					return true;
				}
			} else {
				//if(GetPVarInt(playerid, "Specing") != -1) SpecOff(playerid);
				FlyMode(playerid);
			}
		} else {
			if(GetPlayerVirtualWorld(playerid) == 0)
			{
				if(GetPVarInt(playerid, "Admin") >= 1)
				{
					OnPlayerCommandText(playerid, "/spec");
					SetTimerEx("FlyMode", 1000, false, "i", playerid);
				}
				else SendClientMessageEx(playerid, COLOR_GREY,
				"Доступно только для наблюдателей!", "Available only to spectators!");
			} else {
				SetTimerEx("FlyMode", 1000, false, "i", playerid);
			}
		}
		return true;
	}
	if (!strcmp(cmdtext, "/sync", true, 5))
	{
		new string[100], stringru[100];
		if(frz && GetPlayerVirtualWorld(playerid) == 0) {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Матч на паузе, попробуйте позже",
			"Match paused, try sync later");
			return true;
		}
		if(freeze_score && GetPlayerVirtualWorld(playerid) == 0) {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Матч заморожен, попробуйте позже",
			"Match freezed, try sync later");
			return true;
		}
		if(GetPVarInt(playerid, "EventPart") > 0)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Недоступно во время ивента",
			"Not available during the event");
			return 1;
		}
		if(GetPVarInt(playerid, "LastSync") > gettime())
		{
			format(string, sizeof(string), "You can use /sync after %d seconds",
			GetPVarInt(playerid, "LastSync")-gettime());
			format(stringru, sizeof(stringru), "Вы сможете использовать /sync через %d секунд",
			GetPVarInt(playerid, "LastSync")-gettime());
			SendClientMessageEx(playerid, COLOR_GREY, stringru, string);
			return true;
		} else {
            SetPVarInt(playerid,"LastSync",gettime() + 60);
		}
		if (GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if (strlen(cmdtext) < 7)
		{
			if (GetPVarInt(playerid, "UnBug"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы уже синхронизированны", "You're currently being synced or anti cheat tested.");
				return true;
			}
			if (GetPlayerState(playerid) != PLAYER_STATE_ONFOOT)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы уже синхронизированны", "You aren't desynced.");
				return true;
			}

			Sync(playerid);
			
			new team = GetPVarInt(playerid, "Team");
			format(string, sizeof(string),
			"%s%s[%d]{afafaf} has been synced (/sync or Num4)",
			THC[team], PlayerName(playerid), playerid);
			format(stringru, sizeof(stringru),
			"%s%s[%d]{afafaf} был синхронизирован (/sync или Num4)",
			THC[team], PlayerName(playerid), playerid);
			SendClientMessageToAllEx(COLOR_GREY, stringru, string);
		} else {
			if (GetPVarInt(playerid, "Admin") >= 1)
			{
				if (strval(cmdtext[6]) > 5)
				{
					strdel(cmdtext[6], 5, strval(cmdtext[6]));
				}
				new PARAM = strval(cmdtext[6]);
				if (!IsPlayerConnected(PARAM))
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Игрок не подключен либо вышел.",
					"The player isn't connected.");
					return true;
				}

				Sync(PARAM);

				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок был синхронизирован.",
				"The player has been synced.");
			}
		}
		return true;
	}
	if (!strcmp("/exit", cmd, true) || !strcmp("/leave", cmd, true))
	{
		new worldid = GetPlayerVirtualWorld(playerid);
		
		if(worldid != 0 && !WorldModerator[playerid])
		{
			if(pData[playerid][pLang])
			{
				ShowPlayerDialog(playerid, 290, DIALOG_STYLE_MSGBOX,
				"Leave virtual world",
				"{FFFFFF}Are you sure you want to get out of the world?",
				"Leave", "Cancel");
			} else {
				ShowPlayerDialog(playerid, 290, DIALOG_STYLE_MSGBOX,
				"Выйти из виртуального мира",
				"{FFFFFF}Вы уверены что хотите выйти из мира?",
				"Выйти", "Отмена");
			}
		}
		else if(worldid != 0 && World[worldid][wHosted] == playerid)
		{
			if(pData[playerid][pLang])
			{
				ShowPlayerDialog(playerid, 290, DIALOG_STYLE_MSGBOX,
				"Leave virtual world",
				"{FFFFFF}All the settings of the world will be reset to default\n\
				Are you sure you want to get out of the world?",
				"Leave", "Cancel");
			} else {
				ShowPlayerDialog(playerid, 290, DIALOG_STYLE_MSGBOX,
				"Выйти из виртуального мира",
				"{FFFFFF}Все настройки мира будут сброшены на стандартные\n\
				Вы уверены что хотите выйти из мира?",
				"Выйти", "Отмена");
			}
		}
		else if(worldid != 0 && WorldModerator[playerid] && World[worldid][wHosted] != playerid)
		{
			if(pData[playerid][pLang])
			{
				ShowPlayerDialog(playerid, 290, DIALOG_STYLE_MSGBOX,
				"Leave virtual world",
				"{FFFFFF}Are you sure you want to get out of the world?\n\
				The moderator rights of the world will be reset",
				"Leave", "Cancel");
			} else {
				ShowPlayerDialog(playerid, 290, DIALOG_STYLE_MSGBOX,
				"Выйти из виртуального мира",
				"{FFFFFF}Вы уверены что хотите выйти из мира?\n\
				Права модератора мира будут обнулены",
				"Выйти", "Отмена");
			}
		}
		
		if(worldid == 0 && GetPVarType(playerid, "Lounge"))
		{
			OnPlayerCommandText(playerid, "/lounge");
			return true;
		}
		return true;
	}
	if (!strcmp("/winfo", cmd, true))
	{	
		tmp = strtok(cmdtext, idx);
		new PARAM = strval(tmp);
		if (!strlen(tmp)) {
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				WORLD_INFO(playerid, GetPlayerVirtualWorld(playerid));
			} else {
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /winfo [№ виртуального мира]", "Use: /winfo [virtual world ID]");
			}
			return true;
		}
		
		if(PARAM != 0)
		{
			WORLD_INFO(playerid, PARAM);
		} else {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /winfo [№ виртуального мира]", "Use: /winfo [virtual world ID]");
			return true;
		}
		
		return true;
	}
	if (!strcmp("/duel", cmd, true) || !strcmp("/dm", cmd, true) 
		|| !strcmp("/tdm", cmd, true) || !strcmp("/derby", cmd, true))
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"На нашем сервере для этого используются виртуальные миры (/worlds)",
		"On our server, virtual worlds are used for this (/worlds)");
		CHANGEWORLD_MENU(playerid);
		return true;
	}
	if (!strcmp("/w", cmd, true) || !strcmp("/vw", cmd, true) 
		|| !strcmp("/world", cmd, true) || !strcmp("/worlds", cmd, true))
	{
		new stringru[100], stringen[100];
		tmp = strtok(cmdtext, idx);
		new PARAM = strval(tmp);
		if (!strlen(tmp) || strval(tmp) > MAX_WORLD_SLOTS) {
			CHANGEWORLD_MENU(playerid);
			return true;
		}
		
		if(GetPlayerVirtualWorld(playerid) != 0 && PARAM != 0)
		{
			if(World[GetPlayerVirtualWorld(playerid)][wHosted] == playerid)
			{
				if(PARAM == GetPlayerVirtualWorld(playerid))
				{
					WORLD_MENU(playerid);
				} else {
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Вы не можете занять другой мир будучи хостером.",
					"You can't occupy another world being a hoster.");
				}
			}
		}
				
		if(PARAM == GetPlayerVirtualWorld(playerid))
		{
			if(World[PARAM][wHosted] == playerid || WorldModerator[playerid]) WORLD_MENU(playerid);
			else if(PARAM != 0) WORLD_INFO(playerid, PARAM);
			return true;
		}
		
		if(World[PARAM][wLocked] == 1)
		{
			tmp = strtok(cmdtext, idx);
			if(!strlen(tmp))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Мир закрыт на пароль. Использование: /world [№ виртуального мира] [пароль]",
				"The world is password protected. Use: /world [virtual world ID] [password]");
				return true;
			}
			
			if(strcmp(World[PARAM][wPass], tmp, true))
			{
				SendClientMessageEx(playerid, COLOR_GREY, 
				"Некорректный пароль", "Incorrect password");
				return true;
			}
		}
		
		/*if(PARAM != 0 && World[PARAM][wHosted] == -1) 
		{
			if(pData[playerid][pVerified] == 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете быть хостером в мире", "You cannot be a hoster in the virtual world");
				SendClientMessageEx(playerid, COLOR_GREY,
				"Ваш аккаунт не верифицирован, пройдите верификацию в настройках (Клавиша N)",
				"Your account is not verified, please verify in settings (Press N)");
				return true;
			}
		}*/
				
		// if speconly and main world return spectate mode
		if(speconly)
		{
			if(PARAM == 0)
			{
				SetPlayerTeamEx(playerid, TEAM_SPEC);
				new team = GetPVarInt(playerid, "Team");
				SetSpawnInfo(playerid, 0, GetPlayerSkin(playerid),
				CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
				0, 0, 0, 0, 0, 0, 0);
				
				new first_active_playerid = GetActivePlayerid(GetPlayerVirtualWorld(playerid));
				if(first_active_playerid != -1) {
					CheckSpec(playerid);
					Spectate(playerid, first_active_playerid);
					PlayerTextDrawShow(playerid, TDlagmode[playerid]);
					TextDrawShowForPlayer(playerid, TD[playerid]);
					SetTimerEx("Specfunc", 300, false, "ii",
					playerid, first_active_playerid);
				} else {
					SetTimerEx("FlyMode", 300, false, "i", playerid);
				}
			} else {
				if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING)
				{
					if(GetPVarType(playerid, "FlyMode")) FlyMode(playerid);
					if(GetPVarInt(playerid, "Specing") > -1) SpecOff(playerid);
				}
			}
		}

		new string[64];
		if (!(0 <= PARAM <= MAX_WORLD_SLOTS))
		{
		    SendClientMessageEx(playerid, COLOR_GREY,
			"Доступные виртуальные миры: 0-"#MAX_WORLD_SLOTS".",
			"Available virtual world IDs: 0-"#MAX_WORLD_SLOTS".");
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /w [№ виртуального мира]", "Use: /w [virtual world ID]");
		    return true;
		}
			
		if(PARAM != 0)
		{
			TextDrawHideForPlayer(playerid, TD[playerid]);
			PlayerTextDrawHide(playerid, TDdatetime[playerid]);
			PlayerTextDrawHide(playerid, TDbigscore[playerid]);
			PlayerTextDrawShow(playerid, TDkdstats[playerid]);
			SetPVarInt(playerid, "ShowKDtxd", 1);
			//SetPVarInt(playerid, "ShowScoretxd", -1);
			SetPVarInt(playerid, "Team", 0);
			SetPVarInt(playerid, "skinid", GetPlayerSkin(playerid));
			SetPlayerColor(playerid, COLOR_WHITE);
			SetPlayerTeam(playerid, NO_TEAM);
			//SetPVarInt(playerid, "Team", 3);
			SetVirtualWorldSpawnInfo(playerid);
			
			if(World[PARAM][wHosted] == -1) 
			{
				// preset world settings
				World[PARAM][wHosted] = playerid;
				WorldModerator[playerid] = true;
				InitWorld(PARAM);
			}

			
			if(World[PARAM][wGamemode] == GAMEMODE_WOT
			|| World[PARAM][wGamemode] == GAMEMODE_DERBY
			|| World[PARAM][wGamemode] == GAMEMODE_DM
			|| World[PARAM][wGamemode] == GAMEMODE_SKILLTEST)
			{
				SetPVarInt(playerid, "ShowScoretxd", 1);
				SetPVarInt(playerid, "ShowTimetxd", 1);
			}
			
			if(World[PARAM][wWeapons])
			{
				if(World[PARAM][wGamemode] == GAMEMODE_TRAINING) {
					WorldWeaponData[PARAM][2] = 24;
					WorldWeaponData[PARAM][6] = 34;
				} else {
					WorldWeaponData[PARAM][2] = 26;
					World[PARAM][wAmmo] = DefaultAmmo;
				}
				
				for(new slot = 12; slot > -1; slot--)
				{
					SetPlayerSkillLevel(playerid, slot, World[PARAM][wSkillLevel]);
				}
			}
			
			if(World[PARAM][wTime] != 12) SetPlayerTime(playerid, World[PARAM][wTime], 0);
			if(World[PARAM][wWeather] != 1) SetPlayerWeather(playerid, World[PARAM][wWeather]);
			
			SetPlayerVirtualWorld(playerid, PARAM);
			SetPVarInt(playerid, "world", PARAM);
			
			pData[playerid][pWorld] = PARAM;
			//format(stringen, sizeof(stringen), "world: %i", PARAM);
			//PlayerTextDrawSetString(playerid, TDlagmode[playerid], stringen);
			PlayerTextDrawSetString(playerid, TDlagmode[playerid], World[PARAM][wName]);
			ReSpawnPlayer(playerid);
			
			if(World[PARAM][wJoinMess] && playerid != World[PARAM][wHosted])
			{
				format(stringru, sizeof(stringru), "%s(%d) вошел в виртуальный мир.",
				PlayerName(playerid), playerid);
				format(stringen, sizeof(stringen), "%s(%d) has entered the virtual world.",
				PlayerName(playerid), playerid);
				SendClientMessageToVirtualWorld(PARAM, COLOR_GREY, stringru, stringen);
			}
	
			WorldsHelp(playerid);
		} else {
			if(World[PARAM][wJoinMess])
			{
				if(WorldModerator[playerid])
				{
					format(stringru, sizeof(stringru), "%s(%d) модератор ушел в основной мир.",
					PlayerName(playerid), playerid);
					format(stringen, sizeof(stringen), "%s(%d) moderator has entered the main world.",
					PlayerName(playerid), playerid);
				} else {
					format(stringru, sizeof(stringru), "%s(%d) ушел в основной мир.",
					PlayerName(playerid), playerid);
					format(stringen, sizeof(stringen), "%s(%d) has entered the main world.",
					PlayerName(playerid), playerid);
				}
				SendClientMessageToVirtualWorld(PARAM, COLOR_GREY, stringru, stringen);
			}
			
			WorldModerator[playerid] = false;
			
			// Restore players attaches
			pData[playerid][pAttachSlot0] = -1;
			for(new s=0; s<MAX_PLAYER_ATTACHED_OBJECTS; s++)
			{
				if(IsPlayerAttachedObjectSlotUsed(playerid, s)) {
					RemovePlayerAttachedObject(playerid, s);
				}
			}
			
			pData[playerid][pAttachSlot0] = -1;
			pData[playerid][pAttachSlot1] = -1;
			pData[playerid][pAttachSlot2] = -1;
			pData[playerid][pAttachSlot3] = -1;

			new szQuery[256], DBResult: query;
			format(szQuery, sizeof(szQuery),
			"SELECT Skin, AttachSlot0, AttachSlot1, AttachSlot2, AttachSlot3 \
			FROM Accounts WHERE (Nickname = '%q')", db_escape(PlayerName(playerid)));
			query = db_query(dbaccounts, szQuery);
			pData[playerid][pSkin] = db_get_field_int(query, 1);
			pData[playerid][pAttachSlot0] = db_get_field_int(query, 1);
			pData[playerid][pAttachSlot1] = db_get_field_int(query, 2);
			pData[playerid][pAttachSlot2] = db_get_field_int(query, 3);
			pData[playerid][pAttachSlot3] = db_get_field_int(query, 4);
			db_free_result(query);
			
			SetPlayerTime(playerid, pData[playerid][pHour], 0);
			SetPlayerWeather(playerid, pData[playerid][pWeather]);
			
			#if defined _INC_WEAPON_CONFIG
				if(lagcomp) PlayerTextDrawSetString(playerid,TDlagmode[playerid],"RSC Skinshot");
				else PlayerTextDrawSetString(playerid,TDlagmode[playerid], "Lagshot");
			#else
				if(lagcomp) PlayerTextDrawSetString(playerid,TDlagmode[playerid],"Skinshot");
				else PlayerTextDrawSetString(playerid,TDlagmode[playerid], "Lagshot");
			#endif 
	
			// Clean actors and pickups
			if(World[GetPVarInt(playerid, "world")][wHosted] == playerid)
			{
				new Float:x, Float:y, Float:z;
				GetPlayerPos(playerid, x, y, z);
				
				new items[128];
				Streamer_GetNearbyItems(x, y, z, STREAMER_TYPE_ACTOR,
				items, sizeof(items), 1000.0, PARAM);
				for(new actor = 0; actor < sizeof(items); actor++)
				{
					if(IsValidDynamicActor(actor)) DestroyDynamicActor(actor);
				}
				
				Streamer_GetNearbyItems(x, y, z, STREAMER_TYPE_PICKUP,
				items, sizeof(items), 1000.0, PARAM);
				for(new pickup = 0; pickup < sizeof(items); pickup++)
				{
					if(IsValidDynamicPickup(pickup)) DestroyDynamicPickup(pickup);
				}
				
				#if defined _FCNPC_included
				for(new npcid = 0; npcid < _MAX_PLAYERS; npcid++)
				{
					if (FCNPC_IsValid(npcid) &&
					FCNPC_GetVirtualWorld(npcid) == GetPVarInt(playerid, "world"))
					{
						FCNPC_Destroy(npcid);
					}
				}
				#endif
			}
			
			SetVirtualWorldSpawnInfo(playerid);
			
			// Find first active moderator to give him hoster rights
			new first_active_moderator = -1;
			foreach(Player, p)
			{
				if(GetPlayerVirtualWorld(p) == GetPVarInt(playerid, "world")
				&& p != playerid)
				{
					if(!IsPlayerAFK(p)) first_active_moderator = p;
				}
			}
			//new first_active_moderator = GetActivePlayerid(GetPVarInt(playerid, "world"));
			if(World[GetPVarInt(playerid, "world")][wHosted] == playerid
			&& first_active_moderator != -1 && first_active_moderator != playerid
			&& WorldModerator[first_active_moderator])
			{
				World[GetPVarInt(playerid, "world")][wHosted] = first_active_moderator;
				SendClientMessageEx(first_active_moderator, COLOR_GREY, 
				"Хостер вышел, Вы получили права хостера. Введите /wcmds, чтобы просмотреть список возможностей, доступных в виртуальном мире",
				"Hoster left, you have received hoster rights. Type /wcmds to see a list of features available in the virtual world");
				format(string, sizeof(string), "Новый хостер в мире %s(%d).",
				PlayerName(first_active_moderator), first_active_moderator);
				format(stringen, sizeof(stringen), "New virtual world hoster is %s(%d).",
				PlayerName(first_active_moderator), first_active_moderator);
				SendClientMessageToVirtualWorld(GetPVarInt(playerid, "world"), COLOR_GREY,
				string, stringen);
			}
			if(World[GetPVarInt(playerid, "world")][wHosted] == playerid
			&& first_active_moderator == -1)
			{
				// Kick all stuck in world players
				for(new p = 0; p < MAX_PLAYER_ID; p++)
				{
					if (IsPlayerConnected(p) && p != playerid)
					{
						if(GetPVarInt(p, "world") == GetPVarInt(playerid, "world"))
						{
							SetPlayerVirtualWorld(p, 0);
							SetPVarInt(p, "world", 0);
							SetPVarInt(p, "ShowKDtxd", -1);
							SetPVarInt(p, "ShowScoretxd", -1);
							SetPVarInt(p, "ShowTimetxd", -1);
							ResetKDStats(p);
							PlayerTextDrawHide(p, TDkdstats[p]);
							TextDrawShowForPlayer(p, TD[p]);
							if(pData[p][pDtbar] > 0) PlayerTextDrawShow(p, TDdatetime[p]);
							GameTextForPlayer(p,
							"~w~Hoster ~r~leave~w~ world~n~Back to ~g~CW/TG", 3000, 4);
							SetPlayerTeamEx(p, 2);
							ResetPlayerWeapons(p);
							ReSpawnPlayer(p);
						}
					}
				}
				// Reset world
				for(new worldid; worldid < MAX_WORLD_SLOTS; worldid++)
				{
					if(World[worldid][wHosted] == playerid)
					{
						ResetWorld(worldid);
						DestroyAllVehicles(worldid);
					}
				}
			}
			
			SetPVarInt(playerid, "ShowKDtxd", -1);
			SetPVarInt(playerid, "ShowScoretxd", -1);
			SetPVarInt(playerid, "ShowTimetxd", -1);
			ResetKDStats(playerid);
			SetPlayerScore(playerid, GetPVarInt(playerid,"cwkills"));
			PlayerTextDrawHide(playerid, TDkdstats[playerid]);
			PlayerTextDrawHide(playerid, TDtime[playerid]);
			TextDrawShowForPlayer(playerid, TD[playerid]);
			if(pData[playerid][pDtbar] > 0) PlayerTextDrawShow(playerid, TDdatetime[playerid]);
			GameTextForPlayer(playerid, "~w~Back to ~g~CW/TG", 3000, 4);
			
			if(CWmode)
			{
				SetPlayerTeamEx(playerid, TEAM_SPEC);
				SetPlayerColor(playerid, COLOR_YELLOW);
				ResetPlayerWeapons(playerid);
			} else {
				SetPlayerTeamEx(playerid, TEAM_GREEN);
				SetPlayerColor(playerid, COLOR_GREEN);
			}
			
			SetPlayerVirtualWorld(playerid, PARAM);
			SetPVarInt(playerid, "world", PARAM);
			pData[playerid][pWorld] = PARAM;
			ResetAllPlayerWeaponsEx(playerid);
			GiveDefaultWeapons(playerid);
			ReSpawnPlayer(playerid);
		}
		
		if(World[PARAM][wHosted] == playerid)
		{
			format(string, sizeof(string),
			"Вы перешли в виртуальный мир № %d. Получены права хостера.", PARAM);
			format(stringen, sizeof(stringen),
			"Moved to virtual world # %d. You have received hoster rights. ", PARAM);
			SendNotify(playerid,
			"Press ~g~<Y>~w~ to open world settings~n~Type ~g~/wcmds~w~ to show available commands", 10);
		} else {
			format(string, sizeof(string), "Вы перешли в виртуальный мир № %d.", PARAM);
			format(stringen, sizeof(stringen), "Moved to virtual world ID %d.", PARAM);
		}
		SendClientMessageEx(playerid, COLOR_GREY, string, stringen);
		return true;
	}
	// --------------------------------
    #if defined DISCORD_VERIFICATION
	if(pData[playerid][pVerified] == 0)
	{
		SendClientMessageEx(playerid, COLOR_GREY,
		"Ваш аккаунт не верифицирован, пройдите верификацию в Discord: dsc.gg/sawncommunity",
		"Your account is not verified, please verify in Discord: dsc.gg/sawncommunity");
		return true;
	}
    #endif
	// vvv only verified section vvvv
	// Verified commands
	if (!strcmp("/votemap", cmd, true))
	{
		tmp = strtok(cmdtext, idx);
		new mapid = strval(tmp);
		StartVoteMap(playerid, mapid);
		return true;
	}
	if (!strcmp("/kickall", cmd, true))
	{	
		new tbtext[256];
		new worldid = GetPlayerVirtualWorld(playerid);
		
		if(worldid != 0 && World[worldid][wHosted] == playerid)
		{
			if(pData[playerid][pLang])
			{
				ShowPlayerDialog(playerid, 216, DIALOG_STYLE_MSGBOX,
				"Kick all players",
				"{FFFFFF}Do you really want to kick all players except moderators?",
				"Kick", "Cancel");
			} else {
				ShowPlayerDialog(playerid, 216, DIALOG_STYLE_MSGBOX,
				"Kick all players",
				"{FFFFFF}Вы действительно хотите кикнуть всех игроков кроме модераторов с мира?",
				"Кикнуть", "Отмена");
			}
			return true;
		}
		
		if(worldid == 0 && GetPVarInt(playerid, "Admin") >= 3)
		{
			if(pData[playerid][pLang])
			{
				format(tbtext, sizeof(tbtext),
				"{FFFFFF}Do you really want to kick all players except %s, %s and %s?",
				ClanName[0], ClanName[1], CLAN_TAG);
				
				ShowPlayerDialog(playerid, 216, DIALOG_STYLE_MSGBOX,
				"Kick all players", tbtext, "Kick", "Cancel");
			} else {
				format(tbtext, sizeof(tbtext),
				"{FFFFFF}Вы действительно хотите кикнуть всех игроков, кроме %s, %s и %s?",
				ClanName[0], ClanName[1], CLAN_TAG);
				
				ShowPlayerDialog(playerid, 216, DIALOG_STYLE_MSGBOX,
				"Kick all players", tbtext, "Кикнуть", "Отмена");
			}
			return true;
		}
	}
	if (!strcmp("/giveweapons", cmd, true))
	{	
		new worldid = GetPlayerVirtualWorld(playerid);
		
		if(worldid != 0 && World[worldid][wHosted] == playerid || WorldModerator[playerid])
		{
			WeaponChoiceMode[playerid] = 0;
			ShowPlayerDialog(playerid, 140, 2, "Weapon pack",
			"Pistols\nShotguns\nSub-machine guns\nRifles\nGrenades\nHand held\nMelee\n{FF0000}Reset weapons{FFFFFF}",
			"Select", "Exit");
			return true;
		}
	}
	if (!strcmp("/makemoder", cmd, true) || !strcmp("/setmoder", cmd, true))
	{
		if(GetPlayerVirtualWorld(playerid) == 0)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы должны быть в виртуальном мире!", "You must be in the virtual world!");
			return 0;
		}
		
		new worldid = GetPlayerVirtualWorld(playerid);
		tmp = strtok(cmdtext, idx);
		new PARAM = strval(tmp);
		
		if(World[worldid][wHosted] != playerid)
		{
			SendClientMessageEx(playerid, COLOR_RED,
			"Вы не хостер", "You are not hoster");
			return true;
		}
		
		if (!strlen(tmp))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /setmoder [ID]", "Use: /setmoder [ID]");
			return true;
		}
		
		if (!IsPlayerConnected(PARAM))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Игрок не подключен либо вышел.", "This player isn't connected.");
			return true;
		}
		
		if (PARAM == playerid)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Не применимо на самого себя", "Not applicable to yourself");
			return true;
		}
		
		if(WorldModerator[PARAM])
		{
			SendClientMessageEx(playerid, COLOR_GREY,
