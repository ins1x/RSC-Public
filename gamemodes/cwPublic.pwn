				name, playerid, name1, PARAM);
				SendClientMessageToAllEx(COLOR_GREY, string, stringen);
				format(string, sizeof(string), "%s - ", name);
			}
			AdminActionsLog(stringen);
			new serial[64], ip[16], query[256];
			gpci(PARAM, serial, sizeof(serial));
			GetPlayerIp(PARAM, ip, sizeof ip);
			new date[10], year, month, day;
			getdate(year, month, day);
			format(date, sizeof(date), "%d.%d.%d", year, month, day);
			
			format(query, sizeof(query),
			"INSERT INTO Banlist (Nickname, Serial, Forceac, IP, Date, Reason) \
			VALUES('%s','%s',%i,'%s','%s','%s')",
			PlayerName(PARAM), serial, 1, ip, date, db_escape(reason));
			db_query(dbcore, query);
			
			printf("%s[%d] banned from playing without AC serial: %s",
			PlayerName(playerid), playerid, serial);
			Kick(PARAM);
			SendClientMessageEx(playerid, COLOR_GREY, 
			"Если вы выдали ошибочно наказание отменить его можно командой /unban",
			"If you issued a ban by mistake, you can cancel it with the command /unban");
		    return true;
    	}
		if (!strcmp("/banip", cmd, true))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Используйте: /ban [ID] <причина>", "Use: /ban [ID] <reason>");
			return true;
		}
		if (!strcmp(cmdtext, "/unbanip", true))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /rcon unbanip (IP игрока)", "Use: /rcon unbanip (their IP)");
			if (GetPVarInt(playerid, "Admin") >= 3)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Очистить таблицу samp.ban с забаненными IP можно с помощью команды: /rcon reloadbans",
				"Reload samp.ban with banned IPs after unbanip: /rcon reloadbans");
			}
			ShowPlayerDialog(playerid, 212, DIALOG_STYLE_INPUT,
			"Unbanip","Enter ip address for unban","Unban","Close");
			return true;
		}
		if (!strcmp("/unban", cmd, true) || !strcmp("/offunban", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			
			if (GetPVarInt(playerid, "Admin") >= 3)
			/*{	SendClientMessageEx(playerid, COLOR_GREY,
				"Очистить таблицу samp.ban с забаненными IP можно с помощью команды: /rcon reloadbans",
				"Reload samp.ban with banned IPs after unbanip: /rcon reloadbans");
			}*/
			if (pData[playerid][pLang] == 0) {
				ShowPlayerDialog(playerid, 250, DIALOG_STYLE_LIST, "{00FF00}Unban",
				"{00FF00}Разбанить{FFFFFF} игрока (ipban)\n\
				{00FF00}Разбанить{FFFFFF} игрока (hwunban)\n\
				{00FF00}Разбанить{FFFFFF} игрока (acunban)\n\
				{00FF00}Разглушить{FFFFFF} игрока (hwmute)\n",
				"Выбрать", "Отмена");
			} else {
				ShowPlayerDialog(playerid, 250, DIALOG_STYLE_LIST, "{00FF00}Unban",
				"{00FF00}Unban{FFFFFF} player (ipban)\n\
				{00FF00}Unban{FFFFFF} player (hwunban)\n\
				{FFFFFF}Unban{FFFFFF} player (acunban)\n\
				{00FF00}Unmute{FFFFFF} player (hwmute)\n",
				"Select", "Cancel");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/setadmin", true))
		{
			SendClientMessageEx(playerid, COLOR_GREY, 
			"Использование: /setadmin [ID] [0 = ничего | 1 = КВ организатор | 2 = администратор | 3 = главный администратор]",
			"Use: /setadmin [ID] [0 = nothing | 1 = CW organizer | 2 = administrator | 3 = head administrator]");
			return true;
		}
		if (!strcmp(cmdtext, "/setadmin ", true, 10))
		{
			if (!cmdtext[10])
			{
				SendClientMessageEx(playerid, COLOR_GREY, 
				"Использование: /setadmin [ID] [0 = ничего | 1 = КВ организатор | 2 = администратор | 3 = главный администратор]",
				"Use: /setadmin [ID] [0 = nothing | 1 = CW organizer | 2 = administrator | 3 = head administrator]");
				return true;
			}
			new len = strlen(cmdtext[10]), string[128]; 
			new stringen[100], stringru[100];
			format(string, 5, "%s", cmdtext[10]);
			new PARAM = strval(string);
			if (!IsPlayerConnected(PARAM))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Игрок не подключен либо вышел.", "This player isn't connected.");
				return true;
			}
			new i;
			for(i = 0; i < len; i++)
			{
				if (cmdtext[10 +i] == ' ')
				{
					break;
				}
			}
			new lvl = strval(cmdtext[10 +i]);
			if (!(-1 < lvl < 4))
			{
				SendClientMessageEx(playerid, COLOR_GREY, 
				"Использование: /setadmin [ID] [0 = ничего | 1 = КВ организатор | 2 = администратор | 3 = главный администратор]",
				"Use: /setadmin [ID] [0 = nothing | 1 = CW organizer | 2 = administrator | 3 = head administrator]");
				return true;
			}
			if (GetPVarInt(PARAM, "Admin") == lvl)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"У игрока уже есть этот уровень прав администратора",
				"The player already has this admin rights.");
				return true;
			}
			if (PARAM == playerid)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете менять права самому себе",
				"You cannot change your own rights.");
				return true;
			}
			if(lvl >= GetPVarInt(playerid, "Admin")) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете выставить уровень админки равный либо выше вашего!",
				"You cannot set the admin level to be equal to or higher than yours!");
			}
			SetPVarInt(PARAM, "Admin", lvl);
			if (lvl == 1 || lvl == 2 || lvl == 3)
			{
				if (pData[playerid][pLang] == 1) {
					format(string, sizeof(string), "You set up admin rights to player %s(%d).",
					PlayerName(PARAM), PARAM);
				} else {
					format(string, sizeof(string), "Вы дали права администратора игроку %s(%d).",
					PlayerName(PARAM), PARAM);
				}
				SendClientMessage(playerid, COLOR_GREY, string);
				if (IsPlayerConnected(PARAM))
				{
					pData[playerid][pAdmin] = lvl;
					new szQuery[256];
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET Admin = %i WHERE (Nickname = '%q')",
					lvl, db_escape(PlayerName(PARAM)));
					db_query(dbaccounts, szQuery);
					
					if (pData[PARAM][pLang]) {
						format(string, sizeof(string), "%s(%d) has given you admin rights.",
						PlayerName(playerid), playerid);
					} else {
						format(string, sizeof(string), "%s(%d) дал Вам права администратора.",
						PlayerName(playerid), playerid);
					}
					SendClientMessage(PARAM, COLOR_RED, string);
					SendClientMessageEx(PARAM, COLOR_RED,
					"Вам запрещено:",
					"You are forbidden:");
					SendClientMessageEx(PARAM, COLOR_RED,
					"Использовать свои возможности во вред игрокам либо серверу",
					"Use your capabilities to the detriment of the players or the server");
					SendClientMessageEx(PARAM, COLOR_RED,
					"Раскрывать данные игроков (IP, геолокацию и.т.д)",
					"Disclose player data (IP, geolocation, etc.)");
					SendClientMessageEx(PARAM, COLOR_RED,
					"Раскрывать информацию предназначенную для администраторов",
					"Disclose information intended for administrators");
					if(lvl == 1) SendClientMessage(PARAM, COLOR_GREY,
					"Type /roundset (or press Y) to open round settings menu. Admin chat @text");
					if(lvl == 2) SendClientMessage(PARAM, COLOR_GREY,"Type /acset (or press ALT+C) to open anti-cheat settings menu");
					if(lvl == 3) SendClientMessage(PARAM, COLOR_GREY,"Type /panel (or press CTRL+Y) to open admin panel");
					SendClientMessage(PARAM, COLOR_GREY,"Type /help, /cwhelp for more information");
					
					format(stringen, sizeof(stringen), "%s(%d) has set %s's(%d) admin level to %d",
					PlayerName(playerid), playerid, PlayerName(PARAM), PARAM, lvl);
					format(stringru, sizeof(stringru), "%s(%d) выдал игроку %s(%d) права администратора %d уровня",
					PlayerName(playerid), playerid, PlayerName(PARAM), PARAM, lvl);
					AdminActionsLog(stringen);
					SendClientMessageToAllEx(COLOR_RED, stringru,stringen);
				}
			}
			else if (lvl == 0)
			{
				if (pData[playerid][pLang] == 1) {
					format(string, sizeof(string), "You deleted %s's(%d) admin rights.",
					PlayerName(PARAM), PARAM);
				} else {
					format(string, sizeof(string), "Вы удалили права администратора у игрока %s(%d).",
					PlayerName(PARAM), PARAM);
				}
				SendClientMessage(playerid, COLOR_GREY, string);
				if (IsPlayerConnected(PARAM))
				{
					pData[playerid][pAdmin] = lvl;
					new szQuery[128];
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET Admin = %i WHERE (Nickname = '%q')",
					pData[playerid][pAdmin], db_escape(PlayerName(PARAM)));
					db_query(dbaccounts, szQuery);
					if (pData[PARAM][pLang] == 1) {
						format(string, sizeof(string), "%s(%d) has deleted your admin rights.",
						PlayerName(playerid), playerid);
					} else {
						format(string, sizeof(string), "%s(%d) удалил Ваши права администратора.",
						PlayerName(playerid), playerid);
					}
					SendClientMessage(PARAM, COLOR_RED, string);
				}
			}
			return true;
		}
	}
	// Admin commands lvl 1
    if (GetPVarInt(playerid, "Admin") >= 1)
    {
		if (!strcmp(cmdtext, "/agm", true))
		{
			if(GetPVarInt(playerid, "Admin") < 3 && GetPVarInt(playerid, "Team") != 2)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Доступно только для наблюдателей!", "Available only to spectators!");
			} else {
				if(GetPVarInt(playerid, "agm") > 0)
				{
					SetPVarInt(playerid, "agm", 0);
					SetPlayerHealth(playerid, 100.0);
					if(GameHealth > 100) SetPlayerArmour(playerid, GameHealth-100);
					new string[100];
					format(string, sizeof(string),
					"%s(%d) enable admin godmode.", PlayerName(playerid), playerid);
					AdminActionsLog(string);
					SendClientMessageEx(playerid, -1,
					"Админский godmode - {FF0000}[OFF]",
					"Admin godmode - {FF0000}[OFF]");
				} else {
					SetPlayerHealth(playerid, 99999);
					if(GameHealth > 100) SetPlayerArmour(playerid, 99999);
					SetPVarInt(playerid, "agm", 1);
					SendClientMessageEx(playerid, -1,
					"Админский godmode - {00FF00}[ON]",
					"Admin godmode - {00FF00}[ON]");
				}
			}
			return true;
		}
		if (!strcmp("/specset", cmd, true))
		{
			SPECTATE_MENU(playerid);
			return true;
		}
		if (!strcmp("/youtube", cmd, true) || !strcmp("/stream", cmd, true))
		{
			YOUTUBER_MENU(playerid);
			return true;
		}
		if (!strcmp("/afkmessage", cmd, true) || !strcmp("/senddialog", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			new pid = strval(tmp);
			
			if(!strlen(tmp))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /senddialog <ID> TEXT", "Use: /senddialog <ID> TEXT");
			}
			if(playerid == pid)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Нельзя использовать на себя", "You can't unblock yourself");
				return true;
			}
			
			if(!IsPlayerAFK(playerid))
			{
				if(GetPVarInt(playerid, "Admin") < 3)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Игрок не в афк", "Non afk player");
					return true;
				}
			}
			
			if(!strlen(cmdtext[14]))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /senddialog <ID> TEXT", "Use: /senddialog <ID> TEXT");
			}
			
			SetPVarInt(pid, "afkmessageid", playerid);
			new header[32], stringen[100];
			
			format(header, sizeof(header),
			"%s(%d) send a message", PlayerName(playerid), playerid);
			
			format(stringen, sizeof(stringen),
			"%s(%d) show dialog %s to %s(%d).",
			PlayerName(playerid), playerid, cmdtext[11], PlayerName(pid), pid);
			
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы успешно отправили диалог игроку",
			"You have successfully sent the dialog to the player");
			
			ShowPlayerDialog(pid, 340, DIALOG_STYLE_MSGBOX,
			header, cmdtext[14], "OK", "Cancel");
			
			AdminActionsLog(stringen);
			return true;
		}
		if (!strcmp(cmdtext, "/cc", true) || !strcmp(cmdtext, "/clancolor", true)) // team color
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			new string[64];
			format(string, sizeof(string), "%s%s\n%s%s",
			THC[0], ClanName[0], THC[1], ClanName[1]);
			if (pData[playerid][pLang] == 0)
			{
				ShowPlayerDialog(playerid, 155, DIALOG_STYLE_LIST,
				"Выберите команду:", string, "OK", "Cancel");
			}
			else if (pData[playerid][pLang] == 1)
			{
				ShowPlayerDialog(playerid, 155, DIALOG_STYLE_LIST,
				"Choose team:", string, "OK", "Cancel");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/gamehealth", true))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /gamehealth [1-200]", "Use: /gamehealth [1-200]");
			return true;
		}
		if (!strcmp(cmdtext, "/gamehealth ", true, 12))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
		    if (!cmdtext[12])
		    {
		        SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /gamehealth [1-200]", "Use: /gamehealth [1-200]");
		        return true;
		    }
		    if (strlen(cmdtext[12]) > 5)
		    {
		        strdel(cmdtext[12], 17, strlen(cmdtext[12]));
			}
		    new PARAM = strval(cmdtext[12]);
		    if (GameHealth == PARAM)
		    {
		        SendClientMessageEx(playerid, COLOR_GREY,
				"Такое значение уже выставлено.", "This health is already set up.");
		        return true;
		    }
		    if (PARAM > 0 && PARAM <= 200)
		    {
				GameHealth = PARAM;
				new Float: health, Float: armour;
				for(new i = 0; i < MAX_PLAYER_ID; i++)
				{
				    if (IsPlayerConnected(i))
				    {
				        if (GetPlayerState(i) == PLAYER_STATE_ONFOOT && GetPVarInt(i, "Team") != 2)
	                	{
					        GetPlayerHealth(i, health);
							GetPlayerArmour(i, armour);
							if (health +armour > GameHealth)
							{
								if (GameHealth > 100)
								{
								    SetPlayerHealth(i, 100.0);
								    SetPlayerArmour(i, GameHealth -100);
								}else{
								    SetPlayerHealth(i, GameHealth);
								    SetPlayerArmour(i, 0.0);
								}
								SetPVarFloat(i, "LastHP", GameHealth +0.000001);
							}
							ReSpawnPlayer(i);
						}
				    }
				}
				new stringru[73], stringen[74];
		        if (GameHealth > 100)
		        {
		        	format(stringru, sizeof(stringru), "%s(%d) выставил 100 хп и %d брони.", name, playerid, GameHealth -100);
		        	format(stringen, sizeof(stringen), "%s(%d) has set up game with 100 HP and %d armour.", name, playerid, GameHealth -100);
				}else{
				    format(stringru, sizeof(stringru), "%s(%d) выставил %d хп.", name, playerid, GameHealth);
				    format(stringen, sizeof(stringen), "%s(%d) has set up game with %d HP.", name, playerid, GameHealth);
				}
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
		    }else{
		        SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /gamehealth [1-999999]", "Use: /gamehealth [1-999999]");
		    }
			return true;
		}
		if (!strcmp(cmdtext, "/asay", true))
		{
			if (GetPVarInt(playerid, "Admin") >= 2) 
			{
				if (pData[playerid][pLang] == 1)
				{
					ShowPlayerDialog(playerid, 128, DIALOG_STYLE_INPUT,
					"Admin say","{FFFFFF}Enter text to say as administrator",
					"Ok", "Cancel");
				} else {
					ShowPlayerDialog(playerid, 128, DIALOG_STYLE_INPUT,
					"Admin say","{FFFFFF}Введите текст который будет сообщен от имени администрации",
					"Ok", "Выход");
				}
			} else { 
				SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 2+ уровня!",
				"To use these functions you need to have 2+ level admin rights!");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/clear", true))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Что Вы имели ввиду? /clearchat - очистить общий чат или /clearkillchat - очистить килл-чат",
			"What did you mean? /clearchat - clear chat for all players or /clearkillchat - clear kill list.");
			return true;
		}
		if (!strcmp(cmdtext, "/clearchat", true))
		{
			for(new i = 0; i < 250; i++) SendClientMessageToAll(COLOR_GREY," ");
			SendClientMessageToAllEx(COLOR_GREY,"Чат был очищен администратором.","The chat has been cleared.");
			return true;
		}
		if (!strcmp(cmdtext, "/clearkillist", true) || !strcmp(cmdtext, "/clearkillchat", true))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			for(new i = 0; i < 5; i++) SendDeathMessage(255, 50, 255);
			return true;
		}
		if (!strcmp(cmdtext, "/roundset", true) || !strcmp(cmdtext, "/menu", true) 
			|| !strcmp(cmdtext, "/mn", true)) {
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			ROUNDSET_MENU(playerid);
			return true;
		}
		if (!strcmp(cmdtext, "/sethp", true) || !strcmp(cmdtext, "/sethp ", true, 8))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			if (pData[playerid][pLang] == 0) { 
				ShowPlayerDialog(playerid,56,DIALOG_STYLE_INPUT,
				"Выберите игрока","Введите id игрока:","Принять","Отмена");
			} else {
				ShowPlayerDialog(playerid,56,DIALOG_STYLE_INPUT,
				"Select Player","Enter player ID","Next","Close");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/setarm", true) || !strcmp(cmdtext, "/setarm ", true, 9))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			if (pData[playerid][pLang] == 0) { 
				ShowPlayerDialog(playerid,58,DIALOG_STYLE_INPUT,
				"Выберите игрока","Введите id игрока:","Принять","Отмена");
			} else {
				ShowPlayerDialog(playerid,58,DIALOG_STYLE_INPUT,
				"Select Player","Enter player ID","Next","Close");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/save", true))
		{
		    SendClientMessageEx(playerid, COLOR_GREY, "Использование: /save [ID]", "Use: /save [ID]");
	    	return true;
		}
		if (!strcmp(cmdtext, "/save ", true, 6))
		{
		    if (!cmdtext[6])
		    {
		        SendClientMessageEx(playerid, COLOR_GREY, "Использование: /save [ID]", "Use: /save [ID]");
		        return true;
		    }
		    new string[128];
	        format(string, 5, "%s", cmdtext[6]);
	        new PARAM = strval(string);
	        if (!IsPlayerConnected(PARAM))
	        {
	            SendClientMessageEx(playerid, COLOR_GREY, "Игрок не подключен либо вышел.", "This player isn't connected.");
	            return true;
	        }
	        if (GetPlayerState(PARAM) != PLAYER_STATE_ONFOOT)
	        {
	            SendClientMessageEx(playerid, COLOR_GREY, "Игрок не заспавнился.", "The player must be spawned.");
	            return true;
	        }
	        GetPlayerPos(PARAM, pData[PARAM][pSyncX],
			pData[PARAM][pSyncY], pData[PARAM][pSyncZ]);
	        GetPlayerFacingAngle(PARAM, pData[PARAM][pSyncA]);
	        new Float: health, Float: armour;
	        GetPlayerHealth(PARAM, health);
	        GetPlayerArmour(PARAM, armour);
