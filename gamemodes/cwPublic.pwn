						format(szQuery, sizeof(szQuery),
						"SELECT Nickname, Muted, Lastip FROM Accounts WHERE Muted > 0 LIMIT 20");
						query = db_query(dbaccounts, szQuery);
						new rows = db_num_rows(query);
						strcat(tbtext, "Nickname\tMuted\tIP\n");
						for(new i; i < rows; i++)
						{
							db_get_field(query, 0, row0, sizeof(row0));
							format(row0, sizeof(row0), "%s\t", row0);
							
							db_get_field(query, 1, row1, sizeof(row1));
							if(strval(row1) > 60)
							{
								format(row1, sizeof(row1), "%i min\t", strval(row1)/60);
							} else {
								format(row1, sizeof(row1), "%i sec\t", strval(row1));
							}
							
							db_get_field(query, 2, row2, sizeof(row2));
							format(row2, sizeof(row2), "%s\n", row2);
							
							strcat(tbtext, row0);
							strcat(tbtext, row1);
							strcat(tbtext, row2);
							db_next_row(query);
						}
						db_free_result(query);
						
						if(strlen(tbtext) < 2)
						{
