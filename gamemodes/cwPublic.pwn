				format(stringen, sizeof(stringen),
				"The test account %s has successfully registered. The password corresponds to the nickname", PlayerNickName);
				SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
				
				format(stringen, sizeof(stringen), "%s(%d) created test account %s",
				PlayerName(playerid), playerid, PlayerNickName);
				SendSystemMessage(stringen);
				AdminActionsLog(stringen);
			} else {
				printf("%s", szQuery);
				SendSystemMessage("Player registration FAIL!. Check logs");
			}
			
			db_free_result(query);
        }
	}
