						format(szQuery, sizeof(szQuery),
						"SELECT Nickname, Admin FROM Accounts WHERE Admin > 0 \
						ORDER BY Admin DESC LIMIT 100");
						query = db_query(dbaccounts, szQuery);
						new rows = db_num_rows(query);
						if(rows)
						{
							for(new i; i < rows; i++)
							{
								db_get_field(query, 0, nickname, sizeof(nickname));
								format(nickname, sizeof(nickname), "%s\t", nickname);
								adminlvl = db_get_field_int(query, 1);
								
								if(adminlvl == 4)
								{
									format(tmpstr, 128, "_ _ _  [ %d lvl ] - %s",
									adminlvl, nickname);
								}
								if(adminlvl == 3)
								{
									format(tmpstr, 128, "| | | _   [ %d lvl ] - %s",
									adminlvl, nickname);
								}
								if(adminlvl == 2)
								{
									format(tmpstr, 128, "| | _ _  [ %d lvl ] - %s",
									adminlvl, nickname);
								}
