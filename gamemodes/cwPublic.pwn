			#if defined _nex_ac_included
				new specid = strval(inputtext);
				if(!IsPlayerConnected(specid)) {
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Игрок не подключен либо вышел.", "This player isn't connected.");
				}
				new tmpstr[64], header[64], tbtext[500];
				format(header, sizeof header, "NEXAC trigger counters - %s(%d)",
				PlayerName(specid), specid);

				for(new code = 0; code != 53; code++) //52
				{
					//if(NEXAC_DETECT_COUNTERS[specid][code] != 0)
					format(tmpstr, sizeof tmpstr, "#%d. %d\t",
					code, NEXAC_DETECT_COUNTERS[specid][code]);
					strcat(tbtext, tmpstr);
					if((code % 5) == 0) strcat(tbtext, "\n");
				}
				ShowPlayerDialog(playerid, 164, DIALOG_STYLE_MSGBOX,
				header, tbtext, "Ok", "");
			#endif
		}
		else NEXAC_OPTIONS(playerid);
