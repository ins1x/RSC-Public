public OnGameModeExit()
{
    SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	SendDeathMessage(INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
	GameTextForAll(" ", 1, 3);

	foreach(Player, i)
	{
		SetPlayerSpecialAction(i, SPECIAL_ACTION_NONE);
		// EndRound Soundf bugix
		PlayerPlaySound(i, 1069, 0.0, 0.0, 0.0);
		// Fly mode camera
		if(noclipdata[i][cameramode] == CAMERA_MODE_FLY) SpecOff(i);
	}
	
	for (new p = 0; p < _MAX_PLAYERS; p++) 
	{
		// drop players data table
		pData[p] = NULL_pData;
		// player stats
		Stats[p] = NULL_Stats;
		// drop players data table
		PlayerGeoIPInfo[p] = NULL_PlayerGeoIPInfo;

		//fix attachments. (Server Doesn't remove objects when the mode ends)
		#if !defined _INC_SAMP_Community_fixes
		for (new i = 0; i != MAX_PLAYER_ATTACHED_OBJECTS; ++i)
		{
			if (IsPlayerAttachedObjectSlotUsed(p, i))
			{
				RemovePlayerAttachedObject(p, i);
			}
		}
		#endif
	}
	
	for (new slot = 0; slot < MAX_WORLD_SLOTS; slot++) 
	{
		// drop minigame data
		World[slot] = NULL_WorldData;
	}
		
	// Close database
	db_close(dbcore);
	db_close(dbaccounts);
	db_close(dblogs);
	
	// Destroy Girl Actors
	for(new actor = 1; actor < 9; actor++) DestroyActor(GirlActor[actor]);
	
	return true;
}

// Replace OnPlayerGiveDamage and OnPlayerTakeDamage
// https://github.com/oscar-broman/samp-weapon-config
#if defined _INC_WEAPON_CONFIG
public OnPlayerDamage(&playerid, &Float:amount, &issuerid, &weapon, &bodypart)
{
	if (onspawnprotect[playerid]) return 0;
	#if !defined _nex_ac_included
	if(issuerid != INVALID_PLAYER_ID)
	{
		FakeKill[playerid] = issuerid;
	}
	#endif
	return 1;
}

public OnPlayerDamageDone(playerid, Float:amount, issuerid, weapon, bodypart)
{
	// Specbar part
	new Float: fHitPosX, Float: fHitPosY, Float: fHitPosZ;
	new Float:fOriginX, Float:fOriginY, Float:fOriginZ;
	//new Float:rangedistance;
	
	if(issuerid != INVALID_PLAYER_ID)
	{
		GetPlayerLastShotVectors(issuerid, fOriginX, fOriginY, fOriginZ, fHitPosX, fHitPosY, fHitPosZ);
		//rangedistance = VectorSize(fOriginX-fHitPosX, fOriginY-fHitPosY, fOriginZ-fHitPosZ);
		new Float: distance = GetDistanceBetweenPlayers( playerid, issuerid );
		Stats[issuerid][pDistance] = distance;
		Stats[issuerid][pHits]++;
		Stats[issuerid][pAmount] = amount;
		Stats[issuerid][pBodypart] = bodypart;
		Stats[issuerid][pDamagedid] = playerid;
	}
	
	// Check hit distance
	if(AC_DistanceBug)
	{
		if(issuerid != playerid)
		{
			if(GetDistanceBetweenPlayers(playerid, issuerid) > MAX_HIT_DISTANCE)
			{
				if(weapon == 26 || weapon == 28 || weapon == 32) return 0; // lamo pack
			}
		}
	}
	
	// damage bell (if not on spawn protect)
	if(issuerid != INVALID_PLAYER_ID) 
	{
		if (pData[issuerid][pBell] > 0) {
			PlayerPlaySound(issuerid, pData[issuerid][pBell] ,0,0,0);
		}
	}
	return 1;
}

