			}
			
			if(strval(inputtext) < 0 || strval(inputtext) > 299 || strval(inputtext) == 74)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное значение", "Incorrect value");
				return WORLD_ACTORS(playerid);
			}
			
			if(worldid == 0 && GetPVarInt(playerid, "Admin") < 3)
			{
