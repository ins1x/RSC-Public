	}
	if(dialogid == 59) //setarm
	{
		if(response)
		{
			if(strlen(inputtext) > 3) return SendClientMessageEx(playerid, COLOR_GREY, "Максимум 3 символа","Maximum 3 symbols");
			if(strval(inputtext) == 0) return SendClientMessageEx(playerid, COLOR_GREY, "Не должно быть равно 0","Must not be equal to 0");
			new PARAM = ChosenPlayer[playerid];
