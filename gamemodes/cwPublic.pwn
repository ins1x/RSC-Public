	clanname, clantag, country, clanleader, year, webpage);
	
	if(GetPVarInt(playerid, "Admin") >= 3) {
		ShowPlayerDialog(playerid, 382, DIALOG_STYLE_TABLIST,
		".:: Clan manage ::.", tbtext, "Select", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Для использования этих функций Вы должны быть администратором 3+ уровня!",
		"To use these functions you need to have 3+ level admin rights!");
	}
	return 1;
}

#if defined _FCNPC_included
public FCNPC_OnInit()
{
	// Gets called when an FCNPC plugin are fully initialized 
	return 1;
}

public FCNPC_OnSpawn(npcid)
{
	// Gets called when an NPC gets spawned for the first time.
	new worldid = FCNPC_GetVirtualWorld(npcid);
	new weaponid = World[worldid][wBotWeaponid];
	
	FCNPC_ResetAnimation(npcid);
	FCNPC_SetWeapon(npcid, weaponid);
	FCNPC_UseInfiniteAmmo(npcid, true);
	//FCNPC_SetAmmo(npcid, DefaultAmmo);
	FCNPC_UseReloading(npcid, true);
	FCNPC_SetMinHeightPosCall(npcid, 5.0);
	//FCNPC_SetFightingStyle(npcid, random(4) + 3);
	//FCNPC_Respawn(npcid);
	if(Debug)
	{
		new string[128];
		format(string, sizeof(string), "Bot %d spawned", npcid);
		SendClientMessageToVirtualWorld(FCNPC_GetVirtualWorld(npcid),
		COLOR_GREY, string, string);
	}
	return 1;	
}

public FCNPC_OnRespawn(npcid)
{
	// Gets called when an NPC gets respawned.
	new worldid = FCNPC_GetVirtualWorld(npcid);
	new weaponid = World[worldid][wBotWeaponid];
	
	// Fix spawn
	if(worldid != 0)
	{
		if(World[worldid][wSpawnPoint])
		{
			FCNPC_SetPosition(npcid, World[worldid][wSpawnX]+random(5),
			World[worldid][wSpawnY]+random(5), World[worldid][wSpawnZ]);
		} else {
			new map = World[worldid][wMap];
			FCNPC_SetPosition(npcid, CwMaps[map][TEAM_GREEN][0]+random(5),
			CwMaps[map][TEAM_GREEN][1]+random(5), CwMaps[map][TEAM_GREEN][2]);
		}
	} else {
		FCNPC_SetPosition(npcid, CwMaps[Map][TEAM_GREEN][0]+random(5),
		CwMaps[Map][TEAM_GREEN][1]+random(5), CwMaps[Map][TEAM_GREEN][2]);
	}
	FCNPC_ResetAnimation(npcid);
	
	FCNPC_SetWeaponAccuracy(npcid, weaponid, World[worldid][wBotAccuracy]);
	FCNPC_SetWeaponReloadTime(npcid, weaponid, World[worldid][wBotReloadtime]);
	FCNPC_SetWeaponShootTime(npcid, weaponid, World[worldid][wBotShootrate]);
	//FCNPC_UseMoveMode(FCNPC_MOVE_TYPE_SPRINT, true);
	
	FCNPC_SetWeapon(npcid, weaponid);
	switch(weaponid)
	{
		case 22, 23: FCNPC_GiveAmmoInClip(npcid, 17);
		case 24: FCNPC_GiveAmmoInClip(npcid, 7);
		case 26: FCNPC_GiveAmmoInClip(npcid, 2);
		case 28, 32: FCNPC_GiveAmmoInClip(npcid, 100);
		case 29, 30: FCNPC_GiveAmmoInClip(npcid, 30);
		case 31: FCNPC_GiveAmmoInClip(npcid, 50);
		default: FCNPC_GiveAmmoInClip(npcid, 1);
	}
	
	if(World[worldid][wBotHealth] > 100)
	{
		FCNPC_SetHealth(npcid, 100.0);
		FCNPC_SetArmour(npcid, World[worldid][wBotHealth] - 100);
	} else {
		FCNPC_SetHealth(npcid, World[worldid][wBotHealth]);
		FCNPC_SetArmour(npcid, 0.0);
	}
	
	if(Debug)
	{
		new string[128];
		format(string, sizeof(string), "Bot %d respawned", npcid);
		SendClientMessageToVirtualWorld(FCNPC_GetVirtualWorld(npcid),
		COLOR_GREY, string, string);
	}
	return 1;
}

public FCNPC_OnDeath(npcid, killerid, reason)
{
	//FCNPC_ResetAnimation(npcid);
	//FCNPC_SetAnimation(npcid, 1205, 4.1, 0, 1, 1, 0, 3000); //"KO_shot_face" 
	FCNPC_StopAttack(npcid);
	FCNPC_StopAim(npcid);
	FCNPC_Respawn(npcid);
	if(Debug)
	{
		new string[128];
		format(string, sizeof(string), "Bot %d death", npcid);
		SendClientMessageToVirtualWorld(FCNPC_GetVirtualWorld(npcid),
		COLOR_GREY, string, string);
	}
	return 1;
}

public FCNPC_OnDestroy(npcid)
{
	if(Debug)
	{
		new string[128];
		new worldid = FCNPC_GetVirtualWorld(npcid);
		format(string, sizeof(string), "Bot %d destroyed", npcid);
		SendClientMessageToVirtualWorld(worldid,
		COLOR_GREY, string, string);
	}
	return 1;
}

public FCNPC_OnStreamOut(npcid, forplayerid)
{
	FCNPC_StopAim(npcid);
	return 1;
}

public FCNPC_OnTakeDamage(npcid, issuerid, Float:amount, weaponid, bodypart)
{
	// Gets called when an NPC takes damage from a player or other NPC.
	new Float:angle, Float:x, Float:y, Float:z;
	GetPlayerPos(issuerid, x, y, z);
	GetPlayerFacingAngle(issuerid, angle);
	new worldid = FCNPC_GetVirtualWorld(npcid);
	 
	switch(bodypart)
	{
		//case 3:	//Torso
		case 4:	FCNPC_SetAnimation(npcid, 1085, 4.1, 0, 1, 1, 0, 0); //Left arm (DAM_stomach_frmLT)
		case 5:	FCNPC_SetAnimation(npcid, 1073, 4.1, 0, 1, 1, 0, 0); //Left arm (DAM_armL_frmLT)
		case 6: FCNPC_SetAnimation(npcid, 1075, 4.1, 0, 1, 1, 0, 0); //Right arm (DAM_armR_frmFT)
		case 7:	FCNPC_SetAnimation(npcid, 1079, 4.1, 0, 1, 1, 0, 0); //Left leg (DAM_LegL_frmLT)
		case 8:	FCNPC_SetAnimation(npcid, 1081, 4.1, 0, 1, 1, 0, 0); //Right leg (DAM_LegR_frmFT)
		//case 9:	//Head
	}
	 
	if(World[worldid][wBotType])
	{
		if(World[worldid][wBotAction] == 1)
		{
			if(issuerid != INVALID_PLAYER_ID)
			{
				FCNPC_GoToPlayer(npcid, issuerid, 
				.type = World[worldid][wBotMovetype]);
				FCNPC_AimAtPlayer(npcid, issuerid, .shoot = true,
				.shoot_delay = World[worldid][wBotShootdelay]);
			}
		}
		if(World[worldid][wBotAction] == 2)
		{
			FCNPC_AimAtPlayer(npcid, issuerid, .shoot = true,
			.shoot_delay = World[worldid][wBotShootdelay]);
			//FCNPC_TriggerWeaponShot(npcid, FCNPC_GetWeapon(npcid),
			//BULLET_HIT_TYPE_PLAYER, issuerid, x, y, z);
		}
		if(World[worldid][wBotAction] == 3)
		{
			FCNPC_GoToPlayer(npcid, issuerid,
			.type = World[worldid][wBotMovetype]);
		}
		if(World[worldid][wBotAction] == 4)
		{
			FCNPC_ResetAnimation(npcid);
			FCNPC_StopAttack(npcid);
			FCNPC_StopAim(npcid);
			FCNPC_SetAnimation(npcid, 1209, 4.1, 0, 1, 1, 0, 0); // "KO_skid_front"
		}
		if(World[worldid][wBotAction] == 5)
		{
			FCNPC_SetPosition(npcid, x-random(20), y-random(20), z);
			FCNPC_SetAngleToPlayer(npcid, issuerid);
		}
	}

	/* if(FCNPC_GetHealth(npcid) <= 15.0)
	{
		FCNPC_ResetAnimation(npcid);
		FCNPC_SetAnimation(npcid, 1205, 4.1, 0, 1, 1, 0, 0); //"KO_shot_face"
		FCNPC_StopAttack(npcid);
		FCNPC_StopAim(npcid);
		//SetTimerEx("FCNPC_OnSpawn", 3000, false, "d", npcid);
	} */

	//FCNPC_TriggerWeaponShot(npcid, weaponid, BULLET_HIT_TYPE_PLAYER, issuerid, x, y, z);
	return 1;
}

public FCNPC_OnGiveDamage(npcid, damagedid, Float:amount, weaponid, bodypart)
{
	// Gets called when an NPC gives damage to a player or other NPC.
	new worldid = FCNPC_GetVirtualWorld(npcid);
	FCNPC_SetAngleToPlayer(npcid, damagedid);
	
	if(World[worldid][wBotAction] == 1 
	|| World[worldid][wBotAction] == 3
	|| World[worldid][wBotAction] == 5)
	{
		if(!FCNPC_IsMovingAtPlayer(npcid, damagedid))
		{
			FCNPC_GoToPlayer(npcid, damagedid, 
			.type = World[worldid][wBotMovetype]);
		}
	}
	
	if(World[worldid][wBotAction] == 2)
	{
		FCNPC_StopAim(npcid);
	}
	return 1;
}

public FCNPC_OnWeaponShot(npcid, weaponid, hittype, hitid, Float:fX, Float:fY, Float:fZ)
{
	// Gets called when an NPC fires a shot from a weapon, or when FCNPC_TriggerWeaponShot is called.
	//printf("%d", FCNPC_GetWeaponState(npcid));
	//https://sampwiki.blast.hk/wiki/Weapon_States
	if(hittype == BULLET_HIT_TYPE_PLAYER && weaponid == 26)
	{
		FCNPC_SetWeaponState(npcid, WEAPONSTATE_RELOADING);
	}
	return 1;
}

public FCNPC_OnUpdate(npcid)
{
	//GetDistanceBetweenPlayers(Player1, Player2)
	return 1;
}

