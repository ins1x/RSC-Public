		new worldid = GetPlayerVirtualWorld(inviteplayerid);
		if(worldid != 0)
		{
			new param[24];
			format(param, 24, "/w %d", worldid);
			OnPlayerCommandText(playerid, param);
		} else {
			ResetPlayerWeapons(playerid);
			SetPlayerInterior(playerid, interiorid);
