		}
			
		if (!strlen(tmp))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /giveallgun [Weapon ID] [Ammo]", "Use: /giveallgun [Weapon ID] [Ammo]");
			return true;
		}
		new weaponid = strval(tmp);

		if(weaponid < 1 || weaponid > 46 
		|| weaponid == 19 || weaponid == 20 || weaponid == 21) 
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Недопустимый ID оружия", "Invalid weapon ID");
			return true;
		}
		
		// Heavy weapons
		if(weaponid >= 35 && weaponid <= 40) 
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Данный вид оружия запрещен", "This weapon is prohibited");
			return true;
		}
		
		// Grenades
		if(weaponid >= 16 && weaponid <= 18
		&& GetPlayerVirtualWorld(playerid == 0)) 
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Данный вид оружия запрещен в оснонво мире",
			"These weapons are prohibitedin in the main world");
			return true;
		}
		
		tmp = strtok(cmdtext, idx);
		new ammo = strval(tmp);
		if(ammo < 0 || ammo > 9999)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Недопустимое количество боеприпасов [1-9999]", "Invalid ammo amount [1-9999]");
			return true;
		}
		
		new slot = GetWeaponSlot(weaponid);
		GetWeaponsForAll(GetPlayerVirtualWorld(playerid), weaponid, slot, ammo);
		return true;
	}
