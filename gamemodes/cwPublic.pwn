stock AC_MENU(playerid)
{
	//	Administrators dialog. This menu is used to control the settings of the anti-cheat
	new tbtext[220], FS_SAMPCAC_STATE[30], NEXAC_STATE[24];

	FS_SAMPCAC_STATE = "{FF0000}[Not loaded]";
	#if defined _nex_ac_included
	NEXAC_STATE = "{00FF00}[Loaded]";
	#else
	NEXAC_STATE = "{FF0000}[Not loaded]";
	#endif
	
	#if defined _YSF_included
	new scriptname[32];
	for(new i; i != 16; i++)
	{
		//printf("%s:%s", cmp, scriptname);
		GetFilterScriptName(i, scriptname);
		if(isnull(scriptname)) continue; // If no FS
		if(!strcmp(scriptname, "sampcac_base", true)) FS_SAMPCAC_STATE = "{00FF00}[Loaded]";
	}
	#else 
		#if defined _sampcac_included
		FS_SAMPCAC_STATE = "{00FF00}[Loaded]";
		#else 
		FS_SAMPCAC_STATE = "{FF0000}[Not loaded]";
		#endif
	#endif
						
	format(tbtext, sizeof(tbtext),
	"{ff6347}[>] SAMPCAC \t%s\n"\
	"{ff69b4}[>] NEX-AC \t%s\n",
	FS_SAMPCAC_STATE, NEXAC_STATE);

	if(GetPVarInt(playerid, "Admin") >= 3)
	{ 	
		ShowPlayerDialog(playerid, 72, DIALOG_STYLE_TABLIST, "[AC] MENU", tbtext, "Select", "Cancel");
	} else if(GetPVarInt(playerid, "Admin") == 1) { 
		return SendClientMessageEx(playerid, COLOR_GREY, "Для использования этих функций Вы должны быть администратором 2+ уровня!", "To use these functions you need to have 2+ level admin rights!");
	}
	return 0;
}

stock GAMEACSET(playerid)
{
	//	This menu is used to control the gamesettings of the anti-cheat
	new tbtext[520], NEXAC_DETECT_ACTION_State[24];

	#if defined _nex_ac_included
	if(!NEXAC_DETECT_ACTION) NEXAC_DETECT_ACTION_State = "{FF0000}[Disabled]";
	else NEXAC_DETECT_ACTION_State = "{00FF00}[Enabled]";
	#else
	NEXAC_DETECT_ACTION_State = "{FF0000}[Disabled]";
	#endif
	format(tbtext, sizeof(tbtext),
	"Sprinthook detection\t%s\n"\
	"Spawn protection\t%s\n"\
	"FPS unlocker\t%s\n"\
	"Slide\t%s\n"\
	"Cbug\t%s\n"\
	"Autoscroll\t%s\n"\
	"Rapidfire\t%s\n"\
	"Aimbots\t%s\n"\
	"Minigun\t%s\n"\
	"DamageHacks\t%s\n"\
	"{ff0000}Server-side AC\t%s\n",
	(AC_SPRINTHOOK_PROTECT) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	(SPAWN_PROTECT) ? "{00FF00}[Active]" : "{FF0000}[Disabled]",
	(fpsunlock) ? "{00FF00}[Allowed]" : "{FF0000}[Blocked]",	
	(AC_ANTISLIDE_PROTECT) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	(AC_CBUG_PROTECT) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	(AC_AUTOSCROLL) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	(AC_Rapidfire) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	(AC_AimWarnings) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	(AC_Minigun) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	(AC_DAMAGEHACKS) ? "{00FF00}[Check]" : "{FF0000}[Disabled]",
	NEXAC_DETECT_ACTION_State);

	if(GetPVarInt(playerid, "Admin") >= 3)
	{ 	
		strcat(tbtext, "{ff0000}Extended AC settings\t\n");
	}
	
	if(GetPVarInt(playerid, "Admin") >= 1)
	{ 	
		ShowPlayerDialog(playerid, 77, DIALOG_STYLE_TABLIST,
		"Game AC settings",	tbtext, "Select", "Back");
	} 
	return 0;
}

stock NEXAC_OPTIONS(playerid) // nexac menu
{
	// NEXAC Anticheat settings easy GUI access
	#if defined _nex_ac_included
	new tbtext[500], header[48];
	new NEXAC_DETECT_ACTION_State[24];
	
	switch(NEXAC_DETECT_ACTION)
	{
		case 0: NEXAC_DETECT_ACTION_State = "{CDCDCD}[NO ACTION]";
		case 1: NEXAC_DETECT_ACTION_State = "{FFFF00}[WARNING]";
		case 2: NEXAC_DETECT_ACTION_State = "{FF0000}[KICK]";
		case 3: NEXAC_DETECT_ACTION_State = "{FF0000}[BAN]";
	}

	format(header, sizeof(header), "NEXAC v%s: Anti-cheat settings", NEX_AC_VERSION);
	if(pData[playerid][pLang] == 1)
	{		
		format(tbtext, sizeof(tbtext),
		"Disable AC option by №\t\n"\
		"Enable AC option by №\t\n"\
		"Show current {FF0000}AC{FFFFFF} settings\t\n"\
		"Show current {FF0000}NOP{FFFFFF} settings\t\n"\
		"NEXAC statistics\t\n"\
		"Number of warnings before {FF0000}KICK{FFFFFF}\t%d\n"\ 
		"Action after detection\t%s\n"\ 
		"Ignore lagers\t%s\n"\ 
		"Show AC counters for player\t\n"\ 
		"{FF0000}Drop AC counters for player\t\n"\ 
		"{FF0000}Drop AC counters for all players\t\n"\
		"{FF0000}Drop all AC temp data (ACInfo)\t\n", 
		NEXAC_KICK_AFTER, NEXAC_DETECT_ACTION_State,
		(NEXAC_IGNORE_LAGERS) ? ("{00FF00}[ON]") : ("{FF0000}[ОFF]"));
	} else {
		format(tbtext, sizeof(tbtext),
		"Отключить опцию античита по номеру\t\n"\
		"Включить опцию античита по номеру\t\n"\
		"Показать текущие настройки {FF0000}NEXAC{FFFFFF}\t\n"\
		"Показать текущие настройки {FF0000}NOP{FFFFFF}\t\n"\
		"Показать статистику\t\n"\
		"Кол-во предупреждений перед киком\t%d\n"\ 
		"Действие при обнаружении читера\t%s\n"\ 
		"Игнорировать лагеров\t%s\n"\ 
		"Показать счетчики сработок на игрока\t\n"\ 
		"{FF0000}Сбросить счетчики для игрока\t\n"\
		"{FF0000}Сбросить счетчики для всех игроков\t\n"\
		"{FF0000}Сбросить все временные данные (ACInfo)\t\n", 
		NEXAC_KICK_AFTER, NEXAC_DETECT_ACTION_State, 
		(NEXAC_IGNORE_LAGERS) ? ("{00FF00}[ON]") : ("{FF0000}[ОFF]"));
	}
	
	if(GetPVarInt(playerid, "Admin") >= 3) {
		return ShowPlayerDialog(playerid, 85, DIALOG_STYLE_TABLIST, header, tbtext, "Ok", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_GREY, "Для использования этих функций Вы должны быть администратором 3+ уровня!", "To use these functions you need to have 3+ level admin rights!");
	}
	#else
	return SendClientMessageEx(playerid, COLOR_GREY, "NEXAC не подключен", "NEXAC not connected");	
	#endif
}

stock WEAPONCONFIG_OPTIONS(playerid)
{
	// GUI for weapon-config.inc
	#if defined _INC_WEAPON_CONFIG
	new tbtext[500];
	
	format(tbtext, sizeof(tbtext),
	"Current weapon\t{FFFF00}[%d] %s\n"\
	"Set weapon max range\t{FFFF00}%.1f\n"\
	"Set weapon shoot rate\t{FFFF00}%.1f\n"\
	"Set weapon damage\t\n"\
	"Respawn time\t{FFFF00}%d\n",
	WC_SelectedWeapon, WeaponNamesEN[WC_SelectedWeapon],
	GetWeaponMaxRange(WC_SelectedWeapon), GetWeaponShootRate(WC_SelectedWeapon),
	GetRespawnTime());
	
	if(GetPVarInt(playerid, "Admin") >= 2) {
		return ShowPlayerDialog(playerid, 11, DIALOG_STYLE_TABLIST,
		"Weapon config", tbtext, "Ok", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Для использования этих функций Вы должны быть администратором 2+ уровня!",
		"To use these functions you need to have 2+ level admin rights!");
	}
	#else
	SendClientMessageEx(playerid, COLOR_GREY,
	"Недоступно Weapon-config не подключен", "Error. Weapon-config not connected");
	#endif
}

