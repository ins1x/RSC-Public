			new worldid = GetPlayerVirtualWorld(playerid);
			new param[24];
			
			switch(listitem)
			{
				case 0: PlayerStatistics(ChosenPlayer[playerid], playerid);
				case 1: 
				{
					format(param, sizeof(param), "/spawn %i", ChosenPlayer[playerid]);
					OnPlayerCommandText(playerid, param);
				}
				case 2:
				{
					format(param, sizeof(param), "/sync %i", ChosenPlayer[playerid]);
					OnPlayerCommandText(playerid, param);
				}
				case 3:	
				{
					format(param, sizeof(param), "/heal %i", ChosenPlayer[playerid]);
					OnPlayerCommandText(playerid, param);
				}
				case 4: 
				{
					format(param, sizeof(param), "/disarm %i", ChosenPlayer[playerid]);
					OnPlayerCommandText(playerid, param);
				}
				case 5: Spectate(playerid, ChosenPlayer[playerid]);
				case 6: 
				{
					format(param, sizeof(param), "/goto %i", ChosenPlayer[playerid]);
					OnPlayerCommandText(playerid, param);					
				}
				case 7:
				{
					if(World[worldid][wHosted] != playerid)
					{
						SendClientMessageEx(playerid, COLOR_RED,
						"Вы не хостер", "You are not hoster");
						return true;
					}
					if(!WorldModerator[ChosenPlayer[playerid]])
					{
						format(param, sizeof(param), "/makemoder %i", ChosenPlayer[playerid]);
						OnPlayerCommandText(playerid, param);
					} else {
						format(param, sizeof(param), "/delmoder %i", ChosenPlayer[playerid]);
						OnPlayerCommandText(playerid, param);
					}
				}
				case 8: 
				{
					format(param, sizeof(param), "/wkick %i", ChosenPlayer[playerid]);
					OnPlayerCommandText(playerid, param);
				}
			}
		}
	}
	if(dialogid == 381)
	{
		if(response)
		{
			switch(listitem)
			{
				case 0: CLANLIST_MENU(playerid); // /clans
				case 1: CLANADD_MENU(playerid);
				case 2:
				{
					new tbtext[1240];
					new clanname[32], clantag[12], tmpstr[50];
					new szQuery[128], DBResult: query;
					format(szQuery, sizeof(szQuery),
					"SELECT Clanname, Tag FROM Clanlist LIMIT 25");
					query = db_query(dbcore, szQuery);
					new rows = db_num_rows(query);
					for(new p; p < rows; p++)
					{	
						db_get_field(query, 0, clanname, 32);
						format(clanname, 32, "%s", clanname);
						
						db_get_field(query, 1, clantag, 12);
						format(clantag, 12, "%s", clantag);
						
						format(tmpstr, sizeof(tmpstr), "%s\t {AFAFAF}%s\n", clanname, clantag); 
						strcat(tbtext, tmpstr);
						db_next_row(query);
					}
					db_free_result(query);
					
					ShowPlayerDialog(playerid, 389, DIALOG_STYLE_TABLIST,
					".:: Remove Clan ::.", tbtext, "Remove", "Cancel");
				}
			}
		}
		else ADMIN_MENU(playerid);
	}
