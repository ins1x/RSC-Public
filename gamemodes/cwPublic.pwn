	return DeletePlayer3DTextLabel(targetid, label);
}
#if defined _streamer_included
forward HideActorDamageInformer(targetid, STREAMER_TAG_3D_TEXT_LABEL:label);
public HideActorDamageInformer(targetid, STREAMER_TAG_3D_TEXT_LABEL:label) 
{
	if(IsValidDynamic3DTextLabel(label)) return DestroyDynamic3DTextLabel(label);
	else return false;
}
