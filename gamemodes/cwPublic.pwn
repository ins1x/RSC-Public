					new test4 = GetTickCount();
					new year, month, day, hour, minute, datetime[20];
					getdate(year, month, day); gettime(hour, minute, _);
					format(datetime, sizeof(datetime), "%d.%d.%d %d:%02d",
					year, month, day, hour, minute);
					format(string, 128, "%s run database test", PlayerName(playerid));
					format(szQuery, sizeof(szQuery),
					"INSERT INTO Adminactions (Datetime, Action) VALUES ('%s', '%q')",
					datetime, string);
					db_query(dblogs, szQuery);
					db_free_result(query);
					format(szQuery, sizeof(szQuery),
					"SELECT * FROM Adminactions WHERE Datetime LIKE '%%%s%%'",
					datetime);
					db_query(dblogs, szQuery);
					if(db_num_rows(query))
					{
						if(GetTickCount() - test4 > 0)
						{
							format(string, sizeof(string),
							"dblogs log rw request completed for %d ms",
							GetTickCount() - test4);
							SendClientMessage(playerid, COLOR_GREY, string);
						}
						else SendClientMessage(playerid, COLOR_GREY,
						"dblogs log rw request completed less than for 1 ms");
					} else {
						SendClientMessage(playerid, COLOR_RED, "failed dblogs request");
					}
					db_free_result(query);
					
				}
				case 9: ShowDbTotalStistics(playerid);
			}
		}
	}
	if(dialogid == 30)// changename
	{
		if(response)
		{
