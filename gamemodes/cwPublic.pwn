		if (!strcmp("/find", cmd, true))
		{
			tmp = strtok(cmdtext, idx);
			
			if (GetPVarInt(playerid, "Admin") < 3) 
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Для использования этих функций Вы должны быть администратором 3 уровня!",
				"To use these functions you need to have 3 level admin rights!");
			}
			if(strlen(tmp) < 2 || isnull(tmp) || strlen(tmp) > 24)
			{
				//SendClientMessage(playerid, COLOR_GREY, "Error: Incorrect value");
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /find [nickname]", "Use: /find [nickname]");
				DBFIND_MENU(playerid);
				return true;
			}
			
			if(GetPVarInt(playerid, "Admin") < 3)
			{
				if(strfind(tmp, "Can") != -1 || strfind(tmp, "1NS") != -1)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Нет результатов для отображения", "No results to display");
					return true;
				}
			}
			
			new nick[24 +8], verified, tbtext[1024], tmpstr[128];
			new szQuery[256], DBResult: query;
			format(szQuery, sizeof(szQuery),
			"SELECT Nickname, Verified FROM Accounts WHERE Nickname LIKE '%%%s%%' LIMIT 100",
			db_escape(tmp));
			query = db_query(dbaccounts, szQuery);
			new rows = db_num_rows(query);
			if(rows > 10)
			{
				for(new i; i < rows; i++)
				{
					db_get_field(query, 0, nick, sizeof(nick));
					format(nick, sizeof(nick), "%s", nick);
					
					verified = db_get_field_int(query, 1);
					
					if(verified) format(tmpstr, 128, "{00FF00}%s", nick);
					else format(tmpstr, 128, "%s", nick);
					SendClientMessage(playerid, -1, tmpstr);
					db_next_row(query);
				}
				
				if(rows < 1)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Нет результатов для отображения", "No results to display");
				} else {
					format(tmpstr, 128, "Found results: %i", rows);
					SendClientMessage(playerid, -1, tmpstr);
				}
				
				db_free_result(query);
			} else {
				for(new i; i < rows; i++)
				{
					db_get_field(query, 0, nick, sizeof(nick));
					
					verified = db_get_field_int(query, 1);
					
					if(verified) format(nick, sizeof(nick), "{00FF00}%s\n", nick);
					else format(nick, sizeof(nick), "%s\n", nick);
					
					strcat(tbtext, nick);
					db_next_row(query);
				}
				db_free_result(query);

				if(strlen(tbtext) < 1)
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Нет результатов для отображения", "No results to display");
				}
				else ShowPlayerDialog(playerid, 248, DIALOG_STYLE_LIST,
				"Find accs by name", tbtext, "Select", "Cancel");
			}	
			return true;
		}
