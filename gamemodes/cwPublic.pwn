		for(new i = 0; i < sizeof(weatherlist); i++)
		{
			format(tmpstr, sizeof(tmpstr), "%s\n", weatherlist[i]);
			strcat(tbtext, tmpstr);
		}
		ShowPlayerDialog(playerid, 21, DIALOG_STYLE_LIST, "Set weather",
		tbtext, "Select", "Cancel");
	    return true;
	}
	if (!strcmp(cmdtext, "/fpsweather", true))
	{
		SetPlayerWeather(playerid,42);
		pData[playerid][pWeather] = 42;
		new szQuery[128];
		format(szQuery, sizeof(szQuery),
		"UPDATE Accounts SET Weather = %i WHERE (Nickname = '%q')",
		pData[playerid][pWeather], db_escape(PlayerName(playerid)));
		db_query(dbaccounts, szQuery);
		return 1;
	}
	if (!strcmp(cmdtext, "/weather ", true, 9))
	{
	    new len = strlen(cmdtext[9]);
	    if (len < 1)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /weather [№ погоды]", "Use: /weather [weather ID]");
			return true;
		}
		if (len > 10)
		{
		    strdel(cmdtext[9], 10, len);
		}
		if(strval(cmdtext[9]) >= 0)
		{
			SetPlayerWeather(playerid, strval(cmdtext[9]));
			pData[playerid][pWeather] = strval(cmdtext[9]);
			new szQuery[128];
			format(szQuery, sizeof(szQuery),
			"UPDATE Accounts SET Weather = %i WHERE (Nickname = '%q')",
			pData[playerid][pWeather], db_escape(PlayerName(playerid)));
			db_query(dbaccounts, szQuery);
		} else {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /weather [№ погоды]", "Use: /weather [weather ID]");
		}
	    return true;
	}
	if (!strcmp(cmdtext, "/newmap", true))
	{
		if (GetPVarInt(playerid, "Admin") < 3) 
