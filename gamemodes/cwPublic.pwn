				/*case 5:	
				{
					if(pData[playerid][pLang] == 1)
					{
						ShowPlayerDialog(playerid, 95, DIALOG_STYLE_LIST, "misc",
						"{cdcdcd}Show / Hide player\n"\
						"Remove all player attaches\n",
						"Select","Cancel");
					} else {
						ShowPlayerDialog(playerid, 95, DIALOG_STYLE_LIST, "misc",
						"{cdcdcd}Показать / Скрыть игрока\n"\
						"Удалить все аттачи игрока\n",
						"Select","Cancel");
					}
				}*/
				case 6:
				{
					new 
						tbtext[1024], tmpstr[200], 
						Clan0Players[300], Clan1Players[300], SpectPlayers[300]
					;
						
					foreach(Player, i)
					{
						switch(GetPVarInt(i, "Team"))
						{
							case 0:
							{
								format(tmpstr, sizeof(tmpstr), " %s[%d] ", PlayerName(i),i);
								strcat(Clan0Players, tmpstr);
							}
							case 1:
							{
								format(tmpstr, sizeof(tmpstr), " %s[%d] ", PlayerName(i),i);
								strcat(Clan1Players, tmpstr);
							}
							case 2:
							{
								format(tmpstr, sizeof(tmpstr), " %s[%d] ", PlayerName(i),i);
								strcat(SpectPlayers, tmpstr);
							}
						}
					}
					format(tbtext, sizeof(tbtext),
					"%s%s: %s\n%s%s: %s\n%sSpectators: %s\n\n", 
					THC[0], ClanName[0], Clan0Players, THC[1], ClanName[1], Clan1Players, THC[2], SpectPlayers);
					
					if (pData[playerid][pLang] == 1)
					{
						strcat(tbtext, "{FFFFFF}Enter the player id");
						ShowPlayerDialog(playerid, 42, DIALOG_STYLE_INPUT, "Move team",tbtext, "Ok", "Cancel");
					} else {
						strcat(tbtext, "{FFFFFF}Введите ID игрока");
						ShowPlayerDialog(playerid, 42, DIALOG_STYLE_INPUT, "Переместить игрока в",tbtext, "Ok", "Выход");
					}
				}
				case 7: 
				{
					if(GetPVarType(playerid, "Lounge")) DeletePVar(playerid, "Lounge");
					RemovePlayerAttachedObject(ChosenPlayer[playerid], 0);
					ReSpawnPlayer(ChosenPlayer[playerid]); // /respawn
					format(stringen, sizeof(stringen), "%s(%d) has respawned player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) заспавнил игрока %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
				}
				case 8:
				{
					if(GetPVarType(playerid, "Lounge")) DeletePVar(playerid, "Lounge");
					format(stringen, sizeof(stringen), "%s(%d) has sync player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) синхронизировал игрока %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					Sync(ChosenPlayer[playerid]); // /sync
				}
				case 9:	
				{
					if(GetPVarInt(playerid, "Admin") < 2)
					{
						if(CWmode && GetPlayerVirtualWorld(playerid) == 0) 
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Недоступно во время проведения матча", "Not available during CW match");
							return true;
						}
					}
					if(GameHealth > 100){
						SetPlayerHealth(ChosenPlayer[playerid], 100.0);
						SetPlayerArmour(ChosenPlayer[playerid], 100.0);
					} else {
						SetPlayerHealth(ChosenPlayer[playerid], 100.0);
					}
					format(stringen, sizeof(stringen), "%s(%d) has refilled HP of player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) пополнил ХП игроку %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
				}
				case 10: 
				{
					if(GetPVarInt(playerid, "Admin") < 2)
					{
						if(CWmode && GetPlayerVirtualWorld(playerid) == 0) 
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Недоступно во время проведения матча", "Not available during CW match");
							return true;
						}
					}
					new id = ChosenPlayer[playerid];
					SetPlayerSpecialAction(id,SPECIAL_ACTION_CUFFED);
					ResetPlayerWeapons(id);
					SetSpawnInfo(id, 0, GetPlayerSkin(id),
					CwMaps[Map][2][0], CwMaps[Map][2][1], CwMaps[Map][2][2], 0, 0, 0, 0, 0, 0, 0);
					format(stringru, sizeof(stringru), "%s(%d) забрал оружие у %s(%d)",
					PlayerName(playerid), playerid, PlayerName(id), id);
					format(stringen, sizeof(stringen), "%s(%d) has disarmed %s(%d)",
					PlayerName(playerid), playerid,PlayerName(id), id);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
				}
				case 11: Spectate(playerid, ChosenPlayer[playerid]);
				case 12: 
				{
					if(GetPVarInt(playerid, "Admin") < 2)
					{
						if(CWmode && GetPlayerVirtualWorld(playerid) == 0) 
						{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Недоступно во время проведения матча", "Not available during CW match");
							return true;
						}
					}
						
					new Float:x, Float:y, Float:z;
					GetPlayerPos(ChosenPlayer[playerid], x, y, z);
					SetPlayerPos(playerid, x+2, y+2, z);
					format(stringen, sizeof(stringen), "%s(%d) has teleported to player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) телепортировался к игроку %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
				}
				// SETTINGS_MENU(ChosenPlayer[playerid], playerid);
			}
		}
	}
	if (dialogid == 91) //dop info
	{
		if(!response) DOP_MENU(playerid);
	}
	if (dialogid == 92) // empty
	{
		if(response)
		{
			#if defined _YSF_included
			SendClientMessagef(playerid, -1, "Check IsBanned IP(%s) status = %d", inputtext, IsBanned(inputtext));
			#else
			SendClientMessageEx(playerid, COLOR_RED, "Нужен плагин YSF", "Install YSF plugin for use it");
			#endif
		}
		else BANLOGS_MENU(playerid);
	}
	if (dialogid == 93) // helper
	{
		if(response)
		{
			if (GetPVarInt(playerid, "Admin") < GetPVarInt(ChosenPlayer[playerid], "Admin"))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"У данного игрока выше уровень админки", "This player has a higher admin level");
				return true;
			}
			new stringen[128], stringru[128];
			switch(listitem)
			{
				case 0:
				{
					new Float: x, Float: y, Float: z;
					GetPlayerPos(ChosenPlayer[playerid], x, y, z);
					SetPlayerPos(ChosenPlayer[playerid], x+1, y+1, z+1.5);
					format(stringen, sizeof(stringen), "%s(%d) has slapped %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) слапнул игрока %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
					PlayerPlaySound(ChosenPlayer[playerid], 1130, x, y, z); // PUNCH_PED
				}
				case 1:
				{
					ShowPlayerDialog(playerid, 106, DIALOG_STYLE_INPUT,
					"Change skin to player",
					"{FFFFFF}This action removed ban on changing the skin\nEnter new skin id:",
					"Change","Cancel");
				}
				case 2:
				{
					new header[48];
					if (pData[playerid][pLang] == 0)
					{
						format(header, sizeof(header), "Сменить никнейм %s(%d)",
						PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
						return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
						"{FFFFFF}Использовать ники администраторов, других игроков и теги чужих кланов{FF0000}\
						запрещено!{FFFFFF}\nВведите новый ник (максимум 20 символов):", "Сменить", "Выйти");
					} else {
						format(header, sizeof(header), "Change nickname %s(%d)",
						PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
						return ShowPlayerDialog(playerid, 224, DIALOG_STYLE_INPUT, header,
						"{FFFFFF}Impersonating administrators, other players and clantags {FF0000}\
						is forbidden!{FFFFFF}\nEnter a new nickname (max 20 symbols):", "Save", "Cancel");
					}
				}
				case 3:
				{
					if(pData[ChosenPlayer[playerid]][pHud] == 1) {
						HudToggle(ChosenPlayer[playerid], false);
					} 
					else HudToggle(ChosenPlayer[playerid], true);
					format(stringen, sizeof(stringen), "%s(%d) toggle HUD to player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) переключил HUD игроку %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					AdminActionsLog(stringen);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
				}
				case 4: 
				{
					format(stringen, sizeof(stringen), "%s(%d) show rules to player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) показал правила игроку %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
					Rules(ChosenPlayer[playerid]);
				}
				case 5:
				{
					format(stringen, sizeof(stringen), "%s(%d) show help dialog to player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) показал диалог помощи игроку %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
					Help(ChosenPlayer[playerid]);
				}
				case 6:
				{
					format(stringen, sizeof(stringen), "%s(%d) show settings dialog to player %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) показал диалог настройки игроку %s(%d).",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
					SETTINGS_MENU(ChosenPlayer[playerid]);
				}
				case 7:
				{
					if (GetPlayerState(ChosenPlayer[playerid]) == PLAYER_STATE_SPECTATING)
					{
						SpecOff(ChosenPlayer[playerid]);
					}
					format(stringru, sizeof(stringru), "%s(%d) вывел %s(%d) из наблюдения",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringen, sizeof(stringen), "%s(%d) has force specoff %s(%d)",
					PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
				}
				case 8:
				{
					pData[ChosenPlayer[playerid]][pAttachSlot0] = -1;
					pData[ChosenPlayer[playerid]][pAttachSlot1] = -1;
					pData[ChosenPlayer[playerid]][pAttachSlot2] = -1;
					pData[ChosenPlayer[playerid]][pAttachSlot3] = -1;
					for(new s=0; s<MAX_PLAYER_ATTACHED_OBJECTS; s++)
					{
						if(IsPlayerAttachedObjectSlotUsed(ChosenPlayer[playerid], s)) {
							RemovePlayerAttachedObject(ChosenPlayer[playerid], s);
						}
					}
					
					new szQuery[256];
					format(szQuery, sizeof(szQuery),
					"UPDATE Accounts SET AttachSlot0 = %i, AttachSlot1 = %i, \
					AttachSlot2 = %i, AttachSlot3 = %i WHERE (Nickname = '%q')",
					pData[ChosenPlayer[playerid]][pAttachSlot0],
					pData[ChosenPlayer[playerid]][pAttachSlot1],
					pData[ChosenPlayer[playerid]][pAttachSlot2],
					pData[ChosenPlayer[playerid]][pAttachSlot3],
					db_escape(PlayerName(ChosenPlayer[playerid])));
					db_query(dbaccounts, szQuery);
					
					format(stringen, sizeof(stringen), "%s(%d) has removed all attaches %s(%d).",
					PlayerName(playerid), playerid,
					PlayerName(ChosenPlayer[playerid]),	ChosenPlayer[playerid]);
					format(stringru, sizeof(stringru), "%s(%d) удалил все аттачи с игрока %s(%d).",
					PlayerName(playerid), playerid,
					PlayerName(ChosenPlayer[playerid]),	ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
					AdminActionsLog(stringen);
				}
			}
		}
		else DOP_MENU(playerid);
	}
	if (dialogid == 94) //dop tests
	{
		if(response)
		{
			if (GetPVarInt(ChosenPlayer[playerid], "Admin") > GetPVarInt(playerid, "Admin")) 
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете использовать на администратора выше уровня",
				"You cannot use it for admin above level");
				return true;
			}
			switch(listitem)
			{
				case 0:
				{
					new Float: x, Float: y, Float: z;
					GetPlayerPos(ChosenPlayer[playerid], x, y, z);
					CreateExplosion(x, y, z, 12, 7);
					SendClientMessageEx(playerid, -1,
					"Помните некоторые читы обходят ГМ тест и при взрыве игроку сносит ХП.",
					"Remember some of the cheats bypass the GM test and the explosion blows the player HP.");
				}
				case 1:
				{
					if (!IsPlayerConnected(ChosenPlayer[playerid]))
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Игрок не подключен либо вышел.", "This player isn't connected.");
						return true;
					}
					if (GetPVarInt(ChosenPlayer[playerid], "UnBug"))
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Игрок уже проходит проверку", "The player already being tested."); 
						return true;
					}
					if (GetPlayerState(ChosenPlayer[playerid]) != PLAYER_STATE_ONFOOT)
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Игрок уже проходит проверку", "The player isn't ready for the test.");
						return true;
					}
					SetPVarInt(ChosenPlayer[playerid], "UnBug", true);
					new Float: x, Float: y, Float: z;
					GetPlayerPos(ChosenPlayer[playerid], x, y, z);
					SetPlayerPos(ChosenPlayer[playerid], x, y, z +3.9);
					GetPlayerHealth(ChosenPlayer[playerid], x);
					GetPlayerArmour(ChosenPlayer[playerid], y);
					if (x +y > GameHealth)
					{
						KickPlayerEx(ChosenPlayer[playerid], "health/armour refill");
						return true;
					}
					SetTimerEx("falltest", 900, false, "iif", playerid, ChosenPlayer[playerid], x);
				}
				case 2:
				{
					if (!IsPlayerConnected(ChosenPlayer[playerid]))
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Игрок не подключен либо вышел.", "This player isn't connected.");
						return true;
					}
					if (GetPVarInt(ChosenPlayer[playerid], "UnBug"))
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Тест уже запущен", "The player already being tested."); 
						return true;
					}
					if (GetPlayerState(ChosenPlayer[playerid]) != PLAYER_STATE_ONFOOT)
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Игрок не заспавлен или не готов к тесту", "The player isn't ready for the test.");
						return true;
					}
					new Float: x1, Float: y1, Float: z1;
					GetPlayerVelocity(ChosenPlayer[playerid], x1, y1, z1);
					if (z1 < -0.1)
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Игрок падает. После испытаний он будет по-прежнему гореть. Подождите, пока он упадет.", "The player is falling. After test he will still burn. Wait untill he fall down.");
						return true;
					}
					new anim = GetPlayerAnimationIndex(playerid);
					if (1538 <= anim <= 1544 || anim == 1062) // swim animations
					{
						SendClientMessageEx(playerid, COLOR_GREY, "Игрок не должен быть в воде.", "The player mustn't be in a water.");
						return true;
					}
					SetPVarInt(ChosenPlayer[playerid], "UnBug", true);
					new Float: x, Float: y, Float: z;
					GetPlayerPos(ChosenPlayer[playerid], x, y, z);
					new Float: health, Float: armour;
					GetPlayerHealth(ChosenPlayer[playerid], health);
					GetPlayerArmour(ChosenPlayer[playerid], armour);
					if (health +armour > GameHealth)
					{
						KickPlayerEx(ChosenPlayer[playerid], "health/armour");
						return true;
					}
					SetPlayerHealth(ChosenPlayer[playerid], 85.0);
					SetPlayerArmour(ChosenPlayer[playerid], 0.0);

					new Float: a;
					GetPlayerFacingAngle(ChosenPlayer[playerid], a);
					new obj = CreatePlayerObject(ChosenPlayer[playerid], 2669, x -floatsin(-a, degrees), y -floatcos(-a, degrees), z +50.0, 0.0, 0.0, a);
					SetPlayerPos(ChosenPlayer[playerid], x, y, z +50.0);
					CreateExplosion(x, y, z +50.0, 1, 1.0);
					
					SetTimerEx("firetest", 1000, false, "iiiiffffff", ChosenPlayer[playerid], playerid, floatround(health +armour, floatround_floor), obj, x, y, z, x1, y1, z1);
					return true;
				}
				case 3: // kill
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Если игрок не умер, то у игрока NOP на обновление HP, либо игрок рассинхронизирован",
					"If the player is not dead, then the player has a NOP to update HP, or the player is out of sync");
					SetPlayerHealth(ChosenPlayer[playerid], 0.0);
					SetPlayerArmour(ChosenPlayer[playerid], 0.0);
					#if defined _INC_SKY
						SendDeath(playerid);
					#endif
				}
				case 4: // Fake health
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"Игроку принудительно обновлены показатели хп, если показатели не изменились игрок рассинхронизирован",
					"The player has forcibly updated the hp indicators, if the indicators have not changed the player is desync");
					new	Float: health, Float: armour;
					new tmpstr[64];
    				GetPlayerHealth(ChosenPlayer[playerid], health); 
    				GetPlayerArmour(ChosenPlayer[playerid], armour); 
					format(tmpstr, sizeof(tmpstr),
					"SERVER DATA - health: %.1f armour %.1f", health, armour);
					SendClientMessage(playerid, COLOR_GREY, tmpstr);

					#if defined _nex_ac_included
						AntiCheatGetHealth(ChosenPlayer[playerid], health);
						AntiCheatGetArmour(ChosenPlayer[playerid], armour);
						format(tmpstr, sizeof(tmpstr),
						"NEX-AC - health: %.1f armour %.1f", health, armour);
						SendClientMessage(playerid, COLOR_GREY, tmpstr);
					#endif
					
					#if defined _INC_WEAPON_CONFIG
						format(tmpstr, sizeof(tmpstr), "WC DATA - health: %.1f armour %.1f",
						WC_GetPlayerHealth(ChosenPlayer[playerid]), WC_GetPlayerArmour(ChosenPlayer[playerid]));
						SendClientMessage(playerid, COLOR_GREY, tmpstr);
					#endif

					SetPlayerHealth(ChosenPlayer[playerid], health);
					SetPlayerArmour(ChosenPlayer[playerid], armour);
					
					#if defined _INC_SKY
						SetFakeHealth(ChosenPlayer[playerid], floatround(health));
						SetFakeArmour(ChosenPlayer[playerid], floatround(armour));
					#endif
				}
				case 5:
				{
					NoStunTestMenu(playerid);
					SendClientMessageEx(playerid, COLOR_GREY,
					"Чтобы вывести игрока из этого состояние используйте /sync id", 
					"To get the player out of this state use /sync id");
					SendClientMessageEx(playerid, COLOR_GREY,
					"Некоторые анимации могут не отображаться корректно из-за рассинхронизации.", 
					"Some animations may not be displayed correctly due to out-of-sync.");
					SendClientMessageEx(playerid, COLOR_GREY,
					"Однако если игрок при этом будет стоять на месте без движений - это чит.", 
					"However, if the player at the same time stands still without movement, is a cheat.");
				}
				case 6: // fpstest
				{
					SetPVarInt(ChosenPlayer[playerid], "fpstest", 9);
					SetPVarInt(ChosenPlayer[playerid],
					"fpstest_startval", GetPlayerFPS(ChosenPlayer[playerid]));
					SetPVarInt(ChosenPlayer[playerid],
					"fpstest_endval", GetPlayerFPS(ChosenPlayer[playerid]));
					
					fpstest(ChosenPlayer[playerid],playerid);
					
					SendClientMessageEx(ChosenPlayer[playerid], COLOR_GREY,
					"Идет проверка FPS. Ждите 10 секунд", "Checking FPS in progress.");
					
					new Float: x, Float: y, Float: z;
					GetPlayerPos(ChosenPlayer[playerid], x, y, z);
					#if defined _streamer_included
					for(new i = 0; i < 5; i++)
					{
						fpstest_object[i] = CreateDynamicObject(19295, x+random(2),y,z, 0.0, 0.0, 0.0, 
