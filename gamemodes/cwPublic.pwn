stock VINFO(playerid, vehicleid)
{
	new tbtext[420], tmpstr[64];
	
	if(IsValidVehicle(vehicleid))
	{
		new modelid, Float:health;
		new Float:CurrX, Float:CurrY, Float:CurrZ;
		new Float:rw, Float:rx, Float:ry, Float:rz;
		new engine, lights, alarm, doors, bonnet, boot, objective;
		GetVehicleParamsEx(vehicleid, engine, lights, alarm, doors, bonnet, boot, objective);
		modelid = GetVehicleModel(vehicleid);
		#if defined _YSF_included
			new Float:X, Float:Y, Float:Z, Float:A,
			scolor1, scolor2, color1, color2, respawn;
			GetVehicleSpawnInfo(vehicleid, X, Y, Z, A, scolor1, scolor2);
			GetVehicleColor(vehicleid, color1, color2);
		#endif
		GetVehiclePos(vehicleid, CurrX, CurrY, CurrZ);
		GetVehicleRotationQuat(vehicleid, rw, rx, ry, rz);
		GetVehicleHealth(vehicleid, health);
		
		format(tmpstr, sizeof(tmpstr), "vehicleid: %d modelid: %d\n", vehicleid, modelid);
		strcat(tbtext, tmpstr);
		
		format(tmpstr, sizeof(tmpstr), "health: %.1f engine: %d\n", health, engine);
		strcat(tbtext, tmpstr);
		
		#if defined _YSF_included
		format(tmpstr, sizeof(tmpstr), "color1: %d color2: %d paintjobj: %d\n",
		color1, color2, GetVehiclePaintjob(vehicleid));
		strcat(tbtext, tmpstr);
		
		format(tmpstr, sizeof(tmpstr), "interior: %d; respawn delay: %d\n",
		GetVehicleInterior(vehicleid), GetVehicleRespawnDelay(vehicleid));
		strcat(tbtext, tmpstr);
		
		format(tmpstr, sizeof(tmpstr), "spawn pos: %.3f, %.3f, %.3f, %.3f\n", X, Y, Z, A);
		strcat(tbtext, tmpstr);
		#endif
		
		format(tmpstr, sizeof(tmpstr), "current pos: %.3f, %.3f, %.3f\n", CurrX, CurrY, CurrZ);
		strcat(tbtext, tmpstr);

		format(tmpstr, sizeof(tmpstr), "rot quat w:%.1f x:%.1f y:%.1f z:%.1f\n", rw, rx, ry, rz);
		strcat(tbtext, tmpstr);
		
		#if defined _YSF_included
		respawn = GetTickCount() - GetVehicleRespawnTick(vehicleid);
		format(tmpstr, sizeof(tmpstr), "occupiedtick: %d, respawntick: %d, lastdriver: %d\n", GetVehicleOccupiedTick(vehicleid), respawn, GetVehicleLastDriver(vehicleid));
		strcat(tbtext, tmpstr);
		
		format(tmpstr, sizeof(tmpstr), "hasbeenoccupied: %d, occupied: %d, dead: %d, trailer: %d, cab: %d\n", HasVehicleBeenOccupied(vehicleid), IsVehicleOccupied(vehicleid), IsVehicleDead(vehicleid), GetVehicleTrailer(vehicleid), GetVehicleCab(vehicleid));
		strcat(tbtext, tmpstr);
		
		format(tmpstr, sizeof(tmpstr), "models: %d, used models: %d\n",
		GetVehicleModelCount(modelid), GetVehicleModelsUsed());
		strcat(tbtext, tmpstr);
		#endif
		
		ShowPlayerDialog(playerid, 120, DIALOG_STYLE_MSGBOX,
		"vinfo", tbtext,
		"Refresh", "Cancel");
		return true;
	} else {
		return SendClientMessageEx(playerid, COLOR_GREY,
		"Некорректный ID(vehicleid) транспорта. Найти vehicleid можно командой /DL",
		"Invalid vehicle ID(vehicleid). You can find the vehicleid with the command /DL");
	}
}

