				{
					return ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT, "Сменить ник",
					"{FFFFFF}Использовать ники администраторов, других игроков и теги чужих кланов{FF0000} запрещено!{FFFFFF}\nВведите новый ник (максимум 20 символов):", "Сменить", "Выйти");
				} else {
					return ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT,
					"Change nickname","{FFFFFF}Impersonating administrators, other players and clantags {FF0000} is forbidden!{FFFFFF}\nEnter a new nickname (max 20 symbols):", "Save", "Cancel");
				}
			}
			#endif
			
			if(strlen(inputtext) > MAX_PLAYER_NAME || strlen(inputtext) < 3 || isnull(inputtext))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Некорректное имя! Придумайте другое имя.",
				"Incorrect nickname. Choose another nickname!");
				if (pData[playerid][pLang] == 0)
				{
					return ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT, "Сменить ник",
					"{FFFFFF}Использовать ники администраторов, других игроков и теги чужих кланов{FF0000} запрещено!{FFFFFF}\nВведите новый ник (максимум 20 символов):", "Сменить", "Выйти");
				} else {
					return ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT,
					"Change nickname","{FFFFFF}Impersonating administrators, other players and clantags {FF0000} is forbidden!{FFFFFF}\nEnter a new nickname (max 20 symbols):", "Save", "Cancel");
				}
			}
			
			new szQuery[256];
			new DBResult: query;
			format(szQuery, sizeof(szQuery),
			"SELECT Nickname FROM Accounts WHERE (Nickname = '%q')",
			db_escape(inputtext));
			query = db_query(dbaccounts, szQuery);
			if(db_num_rows(query))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Это имя уже занято. Придумайте другое имя.",
				"This nickname already exists. Choose another nickname!");
				db_free_result(query);
				if (pData[playerid][pLang] == 0)
				{
					return ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT, "Сменить ник",
					"{FFFFFF}Использовать ники администраторов, других игроков и теги чужих кланов{FF0000} запрещено!{FFFFFF}\nВведите новый ник (максимум 20 символа):", "Сменить", "Выйти");
				} else {
					return ShowPlayerDialog(playerid, 30, DIALOG_STYLE_INPUT,
					"Change nickname","{FFFFFF}Impersonating administrators, other players and clantags {FF0000} is forbidden!{FFFFFF}\nEnter a new nickname (max 20 symbols):", "Save", "Cancel");
				}
			} else {
				format(szQuery, sizeof(szQuery),
				"UPDATE Accounts SET Nickname = '%q' WHERE (Nickname = '%q')",
				db_escape(inputtext), db_escape(NickName));
				db_query(dbaccounts, szQuery);
				db_free_result(query);
				
				new name[MAX_PLAYER_NAME], stringen[128], stringru[128];
				format(name, MAX_PLAYER_NAME, "%s", inputtext);
				format(stringen, sizeof(stringen), "%s(%d) has changed nickname to %s.",
				NickName, playerid, name);
				format(stringru, sizeof(stringru), "%s(%d) сменил никнейм на %s.",
				NickName, playerid, name);
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
				SetPlayerName(playerid, name);
				
				new year, month, day, hour, minute, datetime[20];
				getdate(year, month, day); gettime(hour, minute, _);
				format(datetime, sizeof(datetime), "%d.%d.%d %d:%02d", year, month, day, hour, minute);

				format(szQuery, sizeof(szQuery),
				"INSERT INTO Nicknameslog (Datetime, Nickname, NewNickname) VALUES ('%s', '%q', '%q')",
				datetime, NickName, name);
				db_query(dblogs, szQuery);
			
				SendClientMessageEx(playerid, COLOR_GREY,
				"{FF0000}ВАЖНО:{FFFFFF} Не забудьте сменить никнейм в SA:MP клиенте!",
				"{FF0000}IMPORTANT:{FFFFFF} Do not forget to change your nickname in the SA:MP client!");
				if(!strcmp(name, NickName, true))
				{
					SendClientMessageEx(playerid, COLOR_GREY,
					"{FF0000}ВАЖНО:{FFFFFF} Вам необходимо перезайти чтобы ваш новый никнейм вступил в силу!",
					"{FF0000}IMPORTANT:{FFFFFF} You need to re-login for your new nickname to take effect.");
					KickPlayerEx(playerid, "Relog");
				}
			}
		} else {
			if(LAST_DIALOG[playerid] == 19) SETTINGS_MENU(playerid);
		}
	}
