	}
	if (!strcmp(cmdtext, "/netstats ", true, 10))
	{
		if (!cmdtext[10])
		{
		    SendClientMessageEx(playerid, COLOR_GREY,
			"Использование: /netstats [ID or \"server\"]", "Use: /netstats [ID or \"server\"]");
		    return true;
		}
		//SendClientMessage(playerid, -1, "NetStats PacketLossPercent the return value isn't correct most of the time, it is usually too big.");
		new string[401];
		if (!strcmp(cmdtext[10], "server", true))
		{
		    SetPVarInt(playerid, "netstats", -1);
            GetNetworkStats(string, sizeof(string));
            if (pData[playerid][pLang] == 0)
			{
				ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX, "Server's network stats", string, "Обновить", "Скрыть");
			}
			else if (pData[playerid][pLang] == 1)
			{
			    ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX, "Server's network stats.", string, "Refresh", "Hide");
			}
            return true;
		}
		format(string, 5, "%s", cmdtext[10]);
		new PARAM = strval(string);
		if (!IsPlayerConnected(PARAM))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Игрок не подключен либо вышел.", "This player isn't connected.");
			return true;
		}
		SetPVarInt(playerid, "netstats", PARAM);
		GetPlayerNetworkStats(PARAM, string, sizeof(string));
		GetPlayerName(PARAM, name, sizeof(name));
		new string1[47];
		if (pData[playerid][pLang] == 0)
		{
		    format(string1, sizeof(string1), "Cтатистика для %s(%d).", name, PARAM);
			ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX, string1, string, "Обновить", "Скрыть");
		}
		else if (pData[playerid][pLang] == 1)
		{
			format(string1, sizeof(string1), "Network stats of %s(%d).", name, PARAM);
		    ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX, string1, string, "Refresh", "Hide");
		}
	    return true;
	}
	if (!strcmp(cmdtext, "/fpsbar", true))
	{
	    if(pData[playerid][pFpsbar] == 1)
		{
			PlayerTextDrawHide(playerid, FPSBAR[playerid]);
			pData[playerid][pFpsbar] = 0;
		}
		else
		{
			PlayerTextDrawShow(playerid, FPSBAR[playerid]);
			pData[playerid][pFpsbar] = 1;
		}
	    return true;
