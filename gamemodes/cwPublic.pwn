			if(listitem == 9) // default
			{
				OnPlayerCommandText(playerid, "/leave");
			} else {
				if(GetPlayerVirtualWorld(playerid) != 0)
				{
					if(World[GetPlayerVirtualWorld(playerid)][wHosted] == playerid)
					{
						if(listitem+1 == GetPlayerVirtualWorld(playerid))
						{
							WORLD_MENU(playerid);
						} else {
							return SendClientMessageEx(playerid, COLOR_GREY,
							"Вы не можете занять другой мир будучи хостером.",
							"You can't occupy another world being a hoster.");
						}
					}
				}
				new worldid = listitem+1;
				if(World[worldid][wHosted] != -1)
				{			
					if(World[worldid][wLocked])
					{
						SetPVarInt(playerid, "WorldSelect", worldid);
						
						if(pData[playerid][pLang])
						{
							ShowPlayerDialog(playerid, 291, DIALOG_STYLE_INPUT,
							"World locked",
							"{FFFFFF}Enter the password to get into the virtual world:",
							"Select", "Cancel");
						} else {
							ShowPlayerDialog(playerid, 291, DIALOG_STYLE_INPUT,
							"Мир заблокирован", "{FFFFFF}Введите пароль для входа в мир:",
							"Выбрать", "Отмена");
						}
					} else {
						format(tmpstr, sizeof(tmpstr), "/w %d", worldid);
						OnPlayerCommandText(playerid, tmpstr);
					}
				} else {
					if(World[worldid][wHosted] == playerid)
					{
						return CHANGEWORLD_MENU(playerid); // already hosted
					}
					if(GetPlayerVirtualWorld(playerid) == worldid)
					{
						return WORLD_INFO(playerid, worldid);
					}
					format(tmpstr, sizeof(tmpstr), "/w %d", worldid);
					OnPlayerCommandText(playerid, tmpstr);
				}
			}
		}
	}
