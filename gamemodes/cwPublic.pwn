#if !defined _INC_WEAPON_CONFIG
stock IsBulletWeapon(weaponid)
{
	return (WEAPON_COLT45 <= weaponid <= WEAPON_SNIPER) || weaponid == WEAPON_MINIGUN;
}

public OnPlayerWeaponShot(playerid, weaponid, hittype, hitid, Float:fX, Float:fY, Float:fZ)
{
	/* This callback is only called when lag compensation is enabled.
	This callback is called when a player fires a shot from a weapon. 
	Only bullet weapons are supported. Only passenger drive-by is supported
	(not driver drive-by, and not sea sparrow / hunter shots).
	*/
	
	// Shot distance vectors
	new string[128];
	new Float: fHitPosX, Float: fHitPosY, Float: fHitPosZ;
	new Float:rangedistance, Float:fOriginX, Float:fOriginY, Float:fOriginZ;
	GetPlayerLastShotVectors(playerid, fOriginX, fOriginY, fOriginZ, fHitPosX, fHitPosY, fHitPosZ);
	rangedistance = VectorSize(fOriginX-fHitPosX, fOriginY-fHitPosY, fOriginZ-fHitPosZ);
	LastShotTime[playerid] = GetTickCountDifference(GetTickCount(), LastShotTick[playerid]);
	
	if(Kicked[playerid] || GetPVarInt(playerid, "Logged") < 1) return false;
	
	if(IsBulletWeapon(weaponid))
	{
		Stats[playerid][pShots]++;//shots counter
		LastShotVal[playerid]++; //rapidfire
		if(floatabs(rangedistance) < 500) Stats[playerid][pShotDistance] = floatabs(rangedistance);
		Stats[playerid][pHitid] = hitid; // save last player hit id
	}
	
	// Spawn protect 
	if (playerid != INVALID_PLAYER_ID && onspawnprotect[playerid])
    {
        KillTimer(SpawnKill_Timer[playerid]);
        CallLocalFunction("RestoreHealth", "i", playerid);
    }

	// Rapidfire
	if(AC_Rapidfire)
	{
		// Rapidfire variables
		new interval = GetTickCountDifference(GetTickCount(), LastShotTick[playerid]);
		//new interval = LastShotTick[playerid] - GetTickCount();
		new weaponshotinterval = WeaponShotIntervals[weaponid - 22] - 20;
		
		if(Skill[playerid] == 999) {
			switch(weaponid) {
				case 22: weaponshotinterval = 185;
				case 26: weaponshotinterval = 120;
				case 28: weaponshotinterval = 35;
				case 32: weaponshotinterval = 35;
			}
		}

		// c-bug issue
		if(weaponid == 24) {
			if(GetTickCountDifference(LastCrouchTick[playerid], GetTickCount()) < 600) {
				weaponshotinterval = 100;
			}
		}

		if(interval <= weaponshotinterval) {
		//if(weaponshotinterval - interval > 5) {
			SetPVarInt(playerid, "rapidinfractions", GetPVarInt(playerid, "rapidinfractions") + 1);
			LastRejectHitReason[playerid] = 14;
			if(GetPVarInt(playerid, "rapidinfractions") >= 5) {
				format(string, sizeof(string),
				"Warning %s(%d) possible Rapidfire [code 1]. lastinterval:%d",
				PlayerName(playerid), playerid, interval);
				SendSystemMessage(string);
				SetPVarInt(playerid, "rapidinfractions", 0);
				ClearAnimations(playerid);
				ApplyAnimation(playerid, "PED", "IDLE_stance", 4.1, 0, 1, 1, 1, 1000, 1);
				//KickPlayerEx(playerid, "Rapidfire");
			}
			return 0;
		}
	}
	  
	if(AC_DAMAGEHACKS)
	{
		// Ignore invalid damage and desync players damage
		
		//Fake data send interrupt
		if(!(0 <= hittype <= 4) || !IsPlayerConnected(playerid))
		{
			LastRejectHitReason[playerid] = 8;
			return 0;
		}
		
		// check weapons
		if (weaponid < 22 || weaponid > 38)
		{
			LastRejectHitReason[playerid] = 1;
			return 0;
		}
		
		// Bullet crasher
		new	Float:x, Float:y, Float:z;
		GetPlayerPos(playerid, x, y, z);
		if (! (-20000.0 <= z <= 20000.0))
		{
			LastRejectHitReason[playerid] = 11;
			return 0;
		}
		
		// Fix crash of fake bullet weapon data is sent by a malicious user
		if(!IsBulletWeapon(weaponid)) return 0;
		
		// Simple. But effective. Anti-Shooting Hacks.
		new	keys, ud, lr;
		GetPlayerKeys( playerid, keys, ud, lr );
		if ( ! ( keys & KEY_FIRE )  ) {
			LastRejectHitReason[playerid] = 0;
			return 0;
		}
	
		// Invalid hit (very far offset from player)
		if ( hittype == BULLET_HIT_TYPE_PLAYER && ( ( fX >= 20.0 || fX <= -20.0 )
		|| ( fY >= 20.0 || fY <= -20.0 ) || ( fZ >= 20.0 || fZ <= -20.0 ) ) ) {
			LastRejectHitReason[playerid] = 12;
			return 0;
		}
		
		if(hittype != BULLET_HIT_TYPE_NONE) // bounds arena aiming
		{
			if(!(BULLET_HIT_TYPE_NONE <= hittype <= BULLET_HIT_TYPE_PLAYER_OBJECT)) 
			{
				LastRejectHitReason[playerid] = 8;
				return 0;
			}
			if(!(-1000.0 <= fX <= 1000.0) || !(-1000.0 <= fY <= 1000.0) ||
			 !(-1000.0 <= fZ <= 1000.0)) {
				LastRejectHitReason[playerid] = 12;
				return 0;
			}
		}

		if(hittype == BULLET_HIT_TYPE_PLAYER && hitid != playerid)
		{
			if(GetPlayerState(hitid) == PLAYER_STATE_WASTED)
			{
				LastRejectHitReason[playerid] = 5;
				return 0;
			}
		}
	}
	
	if(AC_AimWarnings)
	{
		// Silent aimbot (Johnny Project Fix)
		if (hittype == BULLET_HIT_TYPE_PLAYER)
		{
			GetPlayerLastShotVectors(playerid, fOriginX, fOriginY, fOriginZ, fHitPosX, fHitPosY, fHitPosZ);
			new Float:BulletDistanceForHit = GetPlayerDistanceFromPoint(hitid, fHitPosX, fHitPosY, fHitPosZ);
			if (BulletDistanceForHit == 0 && (weaponid > 21 && weaponid != 35 && weaponid != 42 && weaponid < 47))
			{
				format(string, sizeof(string),
				"Warning %s(%d) use aimbot or lag (Silent Aimbot)",
				PlayerName(playerid), playerid);
				SendSystemMessage(string);
				BulletDistanceForHit = 1.0; // RSC Drop lastshot data
				return 0; //It prevents the bullet from reaching the target player.
			}
		}
		
		// Raknet Silent Aimbot checker
		#if defined PAWNRAKNET_INC_
		// https://github.com/katursis/Pawn.RakNet/releases
		IPacket:206(playerid, BitStream:bs) 
		{
			new bulletData[PR_BulletSync];
			
			BS_IgnoreBits(bs, 8);
			BS_ReadBulletSync(bs, bulletData);
			
			if(bulletData[PR_hitType] == BULLET_HIT_TYPE_PLAYER)
			{
				new 
					Float: getPlayerX, Float: getPlayerY,
					Float: getPlayerZ, Float: getLastPlayerZ;
					
				GetPlayerPos(playerid, getgetPlayerX, getgetPlayerY, getPlayerZ);
				GetPlayerPos(bulletData[PR_hitId], getLastPlayerZ, getLastPlayerZ, getLastPlayerZ);
				
				new Float:betweenDistance = floatabs(bulletData[PR_origin][0] - getPlayerX) + floatabs(bulletData[PR_origin][1] - getPlayerY);
				
				if(bulletData[PR_offsets][0] == 0.0 && bulletData[PR_offsets][1] == 0.0 && bulletData[PR_offsets][2] == 0.0 || betweenDistance < 0.15 || floatabs(bulletData[PR_origin][2] - getPlayerZ) < 0.01 || floatabs(getLastPlayerZ - bulletData[PR_hitPos][2]) < 0.01) { 
					format(string, sizeof(string),
					"Warning %s(%d) use aimbot or lag (Silent Aimbot [2])",
					PlayerName(playerid), playerid);
					SendSystemMessage(string);
					return 0;
				}
			}
		}
		#endif
		
		// Perfect AIM checker
		if(hitid != INVALID_PLAYER_ID)
		{
			if(hittype == 1)
			{
				if(IsPlayerInAnyVehicle(playerid)) return false;
				if(fX == 0.0 || fY == 0.0 || fZ == 0.0)
				{
					if(hitid != 65535)
					{
						PerfectAimWarns[playerid]++;
						if(PerfectAimWarns[playerid] >= 2)
						{
							format(string, sizeof(string),
							"Warning %s(%d) use aimbot or lag (Perfect Aimbot)",
							PlayerName(playerid), playerid);
							SendSystemMessage(string);
							PerfectAimWarns[playerid] = 0;
							return 0;
						}
					}
				}
			}
		}
		// End aim check
	}

	// Check hit distance (only lamo pack)
	if(AC_DistanceBug)
	{
		if(hittype == BULLET_HIT_TYPE_PLAYER && hitid != playerid)
		{
			if(GetDistanceBetweenPlayers(playerid, hitid) > MAX_HIT_DISTANCE)
			{
				if(weaponid == 26 || weaponid == 28 || weaponid == 32){
					if(playerid != INVALID_PLAYER_ID) LastRejectHitReason[playerid] = 12;
					return 0;
				}
			}
		}
	}
	
	// Enable vehicle damage
	if(hittype == BULLET_HIT_TYPE_VEHICLE && GetPlayerVirtualWorld(playerid) != 0)
	{
		if( !IsVehicleOccupied( hitid ) )
		{
			if( weaponid >= 22 && weaponid < 39 )
			{
				new Float: vehicle_health;
				GetVehicleHealth( hitid, vehicle_health );
				SetVehicleHealth( hitid, vehicle_health - s_ValidVehicleDamage[weaponid - 21]);
			}
		}
	}
	
	LastShotTick[playerid] = GetTickCount();
    return 1;
}

public HideDamageInformer(targetid, PlayerText3D:label) 
