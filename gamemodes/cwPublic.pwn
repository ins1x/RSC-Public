				SendClientMessageEx(playerid, COLOR_GREY, "Вы не наблюдаете за кем-либо", "You aren't spectating anyone.");
				return true;
			}
			SpecOff(playerid);
			if(pData[playerid][pFpsbar] > 0 ) PlayerTextDrawShow(playerid, FPSBAR[playerid]);
			if(pData[playerid][pHpbar] > 0 ) 
			{
				PlayerTextDrawShow(playerid, PlayerHp[playerid]);
				PlayerTextDrawShow(playerid, PlayerArmour[playerid]);
			}
			return true;
		}
		if (GetPVarInt(playerid, "Team") != 2)
		{
			if (frz && GetPVarInt(playerid, "frz"))
			{
				//ClearAnimations(playerid);
				TogglePlayerControllable(playerid, true);
				SetPVarInt(playerid, "frz", false);
			}
			if (!Marker)
			{
				for(new i = 0; i < MAX_PLAYER_ID; i++)
				{
					if (IsPlayerConnected(i))
					{
						if (GetPVarInt(i, "Team") < 2)
						{
							if (GetPVarInt(i, "Team") != GetPVarInt(playerid, "Team"))
							{
