	TDC[0], ClanName[0], TDC[1], ClanName[1], TDC[0], score_[0], TDC[1], score_[1], TDC[0], soucet_[0], TDC[1], soucet_[1], TDC[0], round_score_[0], TDC[1], round_score_[1], stats_[3], stats_[4], efficiency, cwkills, cwdeath, ratio_[0]);
	
	TextDrawSetString(TD[p], string);
}

public Win(team)
{
	// Finalscreen 
	//if (score[0] != Roundkills && score[1] != Roundkills) - if (won)
	Finalscreen = true;

	for (new actorid = 1; actorid < 10; actorid++)
	{
		SetActorVirtualWorld(GirlActor[actorid], 0);
	}

	if (CWmode)
	{
		freeze_score = true;
		for(new i = 0; i < MAX_PLAYER_ID; i++)
		{
		    if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == 0)
		    {
				new playerstate = GetPlayerState(i);
				if (playerstate == PLAYER_STATE_ONFOOT)
				{
					PlayerPlaySound(i, 1185, 0.0, 0.0, 0.0);
					SetPlayerCameraPos(i, 1379.0, 2180.6, 12.0);
					SetPlayerCameraLookAt(i, 1383.6, 2185.2, 10.0);
					SetPlayerInterior(i, 0);
				}else{
					if (playerstate == PLAYER_STATE_WASTED && GetPlayerColor(i) != COLOR_GREY)
					{
						SetPlayerPos(i, 1407.6, 2208.9, 19.8);
						if (GameHealth > 100)
						{
							SetPlayerHealth(i, 100.0);
							SetPlayerArmour(i, GameHealth -100);
						}else{
							SetPlayerHealth(i, GameHealth);
							SetPlayerArmour(i, 0.0);
						}
						SetPVarFloat(i, "LastHP", GameHealth +0.000001);
						SetPVarInt(i, "Specing", -1);
						PlayerPlaySound(i, 1185, 0.0, 0.0, 0.0);
					}
				}
		    }
		}

		RoundScore[team]++;
		ReportLog();
		//SetTimerEx("Check", 500, false, "i", team);
		WinEx(team);
	} else {
	    WinEx(team);
	}
	return true;
}

public falltest(adminid, playerid, Float: health)
{
	if (IsPlayerConnected(playerid))
	{
	    new name[MAX_PLAYER_NAME];
	    GetPlayerName(playerid, name, sizeof(name));
	    new Float: newhealth;
	    GetPlayerHealth(playerid, newhealth);
	    new stringen[81];
	    if (newhealth +5.0 <= health)
	    {
	        format(stringen, sizeof(stringen), "%s's(%d) fall damage is +- normal.", name, playerid);
	    }
	    else if (newhealth < health)
	    {
	        format(stringen, sizeof(stringen),
			"%s's(%d) fall damage is only %.0f HP. Normal damage is 5 HP.",
			name, playerid, health -newhealth);
		    } else {
	        format(stringen, sizeof(stringen), "%s's(%d) fall didn't take damage!", name, playerid);
	    }
	    SendClientMessage(adminid, COLOR_RED, stringen);
	    SetPlayerHealth(playerid, health);
	    SetPVarFloat(playerid, "LastHP", health +0.000001);
	    SetPVarInt(playerid, "UnBug", false);
    }
	return true;
}

public firetest(playerid, adminid, health, objectid,
Float: x, Float: y, Float: z, Float: x1, Float: y1, Float: z1)
{
	if (IsPlayerConnected(playerid))
	{
	    if (!GetPVarInt(playerid, "UnBug"))
	 	{
            SendClientMessageEx(adminid, COLOR_RED,
			"Игрок прыгнул в ходе испытания. Огонь может снять меньше хп",
			"The player has jumped during the test. Fire could take fewer healths.");
   		}
	    new name[MAX_PLAYER_NAME];
	    GetPlayerName(playerid, name, sizeof(name));
		new Float: hp;
		GetPlayerHealth(playerid, hp);
		new stringru[124], stringen[93];
		if (hp >= 85.0)
		{
		    format(stringru, sizeof(stringru),
			"%s(%d) не получает урон в течение одной секунды!", name, playerid);
		    format(stringen, sizeof(stringen),
			"%s's(%d) flame didn't take damage for one second!", name, playerid);
		}
		else if (hp > 77.0)
		{
		    format(stringru, sizeof(stringru),
			"%s(%d) пламя снимает только %.0f в секунду! Нормальный урон 8 хп в секунду.",
			name, playerid, 85.0 -hp);
		    format(stringen, sizeof(stringen),
			"%s's(%d) flame takes only %.0f HP per one second! Normal damage is 8 HP.",
			name, playerid, 85.0 -hp);
		}else{
		    format(stringru, sizeof(stringru), "%s(%d) урон +- нормальный.", name, playerid);
		    format(stringen, sizeof(stringen), "%s(%d) flame damage is +- normal.", name, playerid);
		}
		SendClientMessageEx(adminid, COLOR_RED, stringru, stringen);
		SetPlayerPos(playerid, 5000.0, 500.0, 0.0);
		DestroyPlayerObject(playerid, objectid);
		ReSpawnPlayer(playerid);
	}
	return true;
}

public SobeitCheck(playerid, adminid)
{
	if(GetPVarInt(playerid, "sobcheck") > 1) {
		SetPVarInt(playerid, "sobcheck", GetPVarInt(playerid, "sobcheck")-1);
		return SetTimerEx("SobeitCheck", 1000, false, "ii",playerid, adminid);
	}
	new Float:x, Float:y, Float:z;
	GetPlayerCameraFrontVector(playerid, x, y, z);
	SetPVarFloat(playerid, "sobcheck_x", x);
	SetPVarFloat(playerid, "sobcheck_y", y);
	SetPVarFloat(playerid, "sobcheck_z", z);
	if(GetPVarInt(playerid, "sobcheck") == 1 && GetPVarFloat(playerid, "sobcheck_z") < -0.4)
	{
		SendClientMessageEx(adminid, COLOR_GREY,
		"Игрок провалил проверку на s0beit. Событие было отмечено в adminlog", 
		"Player fail s0beit check. This action added to adminlog");
		SendClientMessageEx(adminid, COLOR_GREY,
		"Проверьте файл d3d9.dll в корневом катологе GTA:SA у игрока", 
		"Check file d3d9.dll in players GTA:SA folder");
		new tmpstr[128];
		format(tmpstr, 128, "%s detect s0beit %s by test", PlayerName(adminid), PlayerName(playerid));
		AdminActionsLog(tmpstr);
		//return KickPlayerEx(playerid, "s0beit");
		return 0;
	} else {
		DeletePVar(playerid, "sobcheck_x");
		DeletePVar(playerid, "sobcheck_y");
		DeletePVar(playerid, "sobcheck_z");
		DeletePVar(playerid, "sobcheck");
		TogglePlayerControllable(playerid, true);
		SendClientMessageEx(adminid, COLOR_GREY,
		"Тест {00FF00}пройден успешно.", "Test {00FF00}successfully completed");
		SendClientMessageEx(playerid, COLOR_GREY,
		"Тест {00FF00}пройден успешно.", "Test {00FF00}successfully completed");
		return 1;
	}
}

public fpstest(playerid, adminid)
{
	if(GetPVarInt(playerid, "fpstest") > 1) {
		new fps = GetPlayerFPS(playerid);
		SetPVarInt(playerid, "fpstest", GetPVarInt(playerid, "fpstest")-1);
		
		if(GetPVarInt(playerid, "fpstest_endval") > fps) {
			SetPVarInt(playerid, "fpstest_endval", fps);
		}
		new tmpstr[32];
		format(tmpstr, 32, "~w~sec~g~%d ~w~FPS: ~g~%d",
		GetPVarInt(playerid, "fpstest"),fps);
		GameTextForPlayer(playerid, tmpstr, 500, 3);
		PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
		PlayerPlaySound(adminid, 1056, 0.0, 0.0, 0.0);
		Streamer_Update(playerid, -1);
		return SetTimerEx("fpstest", 1000, false, "ii",playerid, adminid);
	}
	if(GetPVarInt(playerid, "fpstest") == 1)
	{
		TogglePlayerControllable(playerid, true);
		
		new message[64];
		//new dropval;
		//if(GetPVarInt(playerid, "fpstest_startval") > 150) dropval = 50; else dropval = 25;
		format(message, 64, "Results - start_fps:%d max_fpsdrop:%d",
		GetPVarInt(playerid, "fpstest_startval"), GetPVarInt(playerid, "fpstest_endval"));
		SendClientMessage(playerid, -1, message);
		SendClientMessage(adminid, -1, message);
		
		/*if(GetPVarInt(playerid, "fpstest_startval")-GetPVarInt(playerid, "fpstest_endval") >= dropval)
		{
			format(message, 64, "Test successfully completed. startfps:%d endfps:%d",
			GetPVarInt(playerid, "fpstest_startval"), GetPVarInt(playerid, "fpstest_endval"));
			SendSystemMessage(message);
			SendClientMessageEx(playerid, COLOR_GREY,
			"Тест {00FF00}пройден успешно.", "Test {00FF00}successfully completed");	
		} else {
			format(message, 64, "Test failed. startfps:%d endfps:%d",
			GetPVarInt(playerid, "fpstest_startval"), GetPVarInt(playerid, "fpstest_endval"));
			SendSystemMessage(message);
			SendClientMessageEx(playerid, COLOR_GREY,
			"Тест {FF0000}не пройден!", "Test {FF0000}failed!");
		}*/	
		ReSpawnPlayer(playerid);
		
		DeletePVar(playerid, "fpstest");
		DeletePVar(playerid, "fpstest_startval");
		DeletePVar(playerid, "fpstest_endval");
		
		#if defined _streamer_included
		for(new i = 0; i < 30; i++) DestroyDynamicObject(fpstest_object[i]);
		#else
		for(new i = 0; i < 30; i++) DestroyObject(fpstest_object[i]);	
		#endif
		
	}
	return 1;
}

public fpsdrop(count)
{
	new string[128];
	for(new i = 0; i < count; i++)
	{
	    if (IsPlayerConnected(fpslagers[i]))
	    {
	        if (0 < GetPVarInt(fpslagers[i], "fps") < MIN_FPS)
	        {
	            new name[MAX_PLAYER_NAME];
    			GetPlayerName(fpslagers[i], name, sizeof(name));
    			format(string, sizeof(string), "%s%s (%d FPS), ",
				string, name, GetPVarInt(fpslagers[i], "fps"));
	        }
	    }
	    fpslagers[i] = -1;
	}
	if (string[0])
	{
	    SendClientMessageToAllEx(COLOR_GREY,
		"Эти игроки имеют низкий FPS:", "These players have low FPS:");
		strdel(string, strlen(string) -2, strlen(string));
		format(string, sizeof(string), "%s.", string);
		SendClientMessageToAll(COLOR_GREY, string);
    }
	return true;
}

stock BalanceTeams()
{
	// Autobalance teams via League script
	new TotalGreen, TotalBlue;

	foreach(new i : Player)
	{
		if(IsPlayerSpawned(i) && GetPlayerVirtualWorld(i) == 0)
		{
			if(GetPVarInt(i, "Team") == TEAM_GREEN || GetPVarInt(i, "Team") == TEAM_BLUE)
			{
				new tid = random(2);
				if (tid == 0)
				{
					SetPlayerTeamEx(i, TEAM_BLUE);
					TotalBlue++;
				}
				else if (tid == 1)
				{
					SetPlayerTeamEx(i, TEAM_GREEN);
					TotalGreen++;
				}
			}
		}
	}

    new Divisor = floatround((TotalBlue + TotalGreen) / 2);

	foreach(new i : Player)
	{
		if(!GetPlayerVirtualWorld(i))
		{
			if(GetPVarInt(i, "Team") == TEAM_GREEN || GetPVarInt(i, "Team") == TEAM_BLUE)
			{
				new randomnum = random(2);
				switch(randomnum)
				{
					case 0:
					{
						if(TotalBlue <= Divisor) {
							if(GetPVarInt(i, "Team") == TEAM_GREEN) TotalGreen--;
							SetPlayerTeamEx(i, TEAM_BLUE);
							TotalBlue++;
						} else if(TotalGreen <= Divisor) {
							if(GetPVarInt(i, "Team") == TEAM_BLUE) TotalBlue--;
							SetPlayerTeamEx(i, TEAM_GREEN);
							TotalGreen++;
						}
					}
					case 1:
					{
						if(TotalGreen <= Divisor) {
							if(GetPVarInt(i, "Team") == TEAM_BLUE) TotalBlue--;
							SetPlayerTeamEx(i, TEAM_GREEN);
							TotalGreen++;
						} else if(TotalBlue <= Divisor) {
							if(GetPVarInt(i, "Team") == TEAM_GREEN) TotalGreen--;
							SetPlayerTeamEx(i, TEAM_BLUE);
							TotalBlue++;
						}
					}
				}
				if(TotalBlue == TotalGreen)
					break;
			}
		}
	}
	return 1;
}

public WinEx(team)
{
    new i, Pocet;
	if (!CWmode)
	{
		RoundScore[team]++;
		for(i = 0; i < MAX_PLAYER_ID; i++)
		{
		    if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == 0)
		    {
				if (GetPVarInt(i, "FlyMode") != 1)
				{
					if (GetPlayerState(i) == PLAYER_STATE_WASTED && GetPlayerColor(i) != COLOR_GREY)
					{
						
						SetPlayerPos(i, 1407.6, 2208.9, 19.8);// baseball area spectator pos
						if (GameHealth > 100)
						{
							SetPlayerHealth(i, 100.0);
							SetPlayerArmour(i, GameHealth -100);
						} else {
							SetPlayerHealth(i, GameHealth);
							SetPlayerArmour(i, 0.0);
						}
						SetPVarFloat(i, "LastHP", GameHealth +0.000001);
						SetPVarInt(i, "Specing", -1);
					}
				}
			}
		}
	}

	for(i = 0; i < MAX_PLAYER_ID; i++)
	{
	    if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == 0)
	    {
			PlayerTextDrawHide(i, FPSBAR[i]);
			PlayerTextDrawHide(i, PlayerHp[i]);
			PlayerTextDrawHide(i, PlayerArmour[i]);
			PlayerTextDrawHide(i, Commands[i]);
			PlayerTextDrawHide(i, TDlagmode[i]);
			PlayerTextDrawHide(i, TDdatetime[i]);
			#if defined _INC_WEAPON_CONFIG
			EnableHealthBarForPlayer(i, false);
			#endif
			
	        if (GetPVarInt(i, "Team") == team)
			{
			    if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
			    {
			    	Pocet++;
				}
			}
	        if (GetPVarInt(i, "Team") < 2)
	        {
	            if (pocet_TD[GetPVarInt(i, "Team")] < sizeof(TDStats[]))
				{
		            new sstring[222], stats_[6][13];
		            for(new e = 0; e < 3; e++)
		            {
		                format(sstring, 13, "round_stats%d", e);
						if (GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring) < 10)
						{
						    format(stats_[e], sizeof(stats_[]), "0%d", GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring));
						} else {
						    valstr(stats_[e], GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring));
						    //format(stats_[e], sizeof(stats_[]), "%d", GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring));
						}
					}
					new cwdamage = floatround(GetPVarFloat(i, "cwdamage")-GetPVarFloat(i, "round_damage"), floatround_round);
					new cwinjuries = floatround(GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries"), floatround_round);
					new cwteamdamage = floatround(GetPVarFloat(i, "cwteamdamage") -GetPVarFloat(i, "round_teamdamage"), floatround_round);

					if (cwdamage < 10) {
					    format(stats_[3], sizeof(stats_[]), "000%d", cwdamage);
					}
					else if (cwdamage < 100) {
					    format(stats_[3], sizeof(stats_[]), "00%d", cwdamage);
					}
					else if (cwdamage < 1000) {
					    format(stats_[3], sizeof(stats_[]), "0%d", cwdamage);
					} else {
					    valstr(stats_[3], cwdamage);
					}

					if (cwinjuries < 10) {
					    format(stats_[4], sizeof(stats_[]), "000%d", cwinjuries);
					}
					else if (cwinjuries < 100) {
					    format(stats_[4], sizeof(stats_[]), "00%d", cwinjuries);
					}
					else if (cwinjuries < 1000) {
					    format(stats_[4], sizeof(stats_[]), "0%d", cwinjuries);
					} else {
					    valstr(stats_[4], cwinjuries);
					}

					if (cwteamdamage < 10) {
					    format(stats_[5], sizeof(stats_[]), "0%d", cwteamdamage);
					} else {
					    valstr(stats_[5], cwteamdamage);
					}
					
					new ratio[2][13];
					if (GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death") > 0)
					{
						format(ratio[0], sizeof(ratio[]), "%.2f", (GetPVarInt(i, "cwkills") -GetPVarInt(i, "round_kills")) /float(GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death")));
					}else{
						ratio[0] = "-";
					}
					if (GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage") > 0)
					{
						format(ratio[1], sizeof(ratio[]), "%.2f", (GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage")) /(GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries")));
					}else{
						ratio[1] = "-";
					}
		
					// RSC revision added data efficiency, kills, death
					new round_kills = GetPVarInt(i, "cwkills") - GetPVarInt(i, "round_kills");
					new round_deaths = GetPVarInt(i, "cwdeath") - GetPVarInt(i, "round_death");
					new Float:round_efficiency, td_round_efficiency[5];
					if(cwinjuries > 0) {
						round_efficiency = (GetPVarFloat(i, "cwdamage")-GetPVarFloat(i,"round_damage")) / (GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries"));
						if(round_efficiency < 1.0) {
							format(td_round_efficiency, sizeof(td_round_efficiency), "%.2f0", round_efficiency);
						} else if(round_efficiency< 10.0) {
							format(td_round_efficiency, sizeof(td_round_efficiency), "%.2f", round_efficiency);
						} else {
							format(td_round_efficiency, sizeof(td_round_efficiency), "0.0");
						}
					} else {
						format(td_round_efficiency, sizeof(td_round_efficiency), "0.0");
					}
					
					// k/d ratio
					new Float:kd_ratio, td_kd_ratio[5];
					//new Float:kd_ratio = GetPVarInt(i, "cwkills")/float(GetPVarInt(i, "cwdeath");
					
					if(round_deaths > 0) kd_ratio = float(round_kills/round_deaths);
					else kd_ratio = 1.0;
					
					if(kd_ratio > 0.0)
					{
						if(kd_ratio < 1.0) {
							format(td_kd_ratio, sizeof(td_kd_ratio), "%.2f0", kd_ratio);
						} else if(kd_ratio < 10.0) {
							format(td_kd_ratio, sizeof(td_kd_ratio), "%.2f", kd_ratio);
						}
					} else {
						//format(td_kd_ratio, sizeof(td_kd_ratio), "0.0");
						format(td_kd_ratio, sizeof(td_kd_ratio), "%.2f", kd_ratio);
					}
					
					GetPlayerName(i, sstring, MAX_PLAYER_NAME);
					new playerteam = GetPVarInt(i, "Team");
					
					if (playerteam == 0)
					{
		            	format(sstring, sizeof(sstring),
						"%s%s~w~ - Damage: ~y~%s~w~ I Injuries: ~y~%s~w~ I Efficiency: ~y~%s~w~ I Kills: ~y~%d~w~ I Deaths: ~y~%d~w~ I Ratio: ~y~%s~w~",
						TDC[0], sstring, stats_[3], stats_[4], td_round_efficiency, round_kills, round_deaths, td_kd_ratio);
					} else {
						format(sstring, sizeof(sstring),
						"%s%s~w~ - Damage: ~y~%s~w~ I Injuries: ~y~%s~w~ I Efficiency: ~y~%s~w~ I Kills: ~y~%d~w~ I Deaths: ~y~%d~w~ I Ratio: ~y~%s~w~",
						TDC[1], sstring, stats_[3], stats_[4], td_round_efficiency, round_kills, round_deaths, td_kd_ratio);
					}
					TextDrawSetString(TDStats[playerteam][pocet_TD[playerteam]], sstring);
					pocet_TD[playerteam]++;
				}
	        }
		}
	}

	new health, armour;
	if (GameHealth > 100)
	{
		health = 100;
		armour = GameHealth -100;
	}else{
		health = GameHealth;
	}
	
	new Pocet2, action = SPECIAL_ACTION_DANCE1;
	for(i = 0; i < MAX_PLAYER_ID; i++)
	{
		if (IsPlayerConnected(i) && GetPlayerVirtualWorld(i) == 0)
		{
			for(new e = 0; e < pocet_TD[0]; e++)
			{
				TextDrawShowForPlayer(i, TDStats[0][e]);
			}
			for(new e = 0; e < pocet_TD[1]; e++)
			{
				TextDrawShowForPlayer(i, TDStats[1][e]);
			}
			if (GetPlayerState(i) != PLAYER_STATE_WASTED && GetPVarInt(i, "Team") != 2)
			{
				if (GetPVarInt(i, "FlyMode") != 1)
				{
					SetPlayerHealth(i, health);
					SetPlayerArmour(i, armour);
					SetPVarFloat(i, "LastHP", GameHealth +0.000001);
					TogglePlayerControllable(i, false);
					
					if(GetPVarInt(i, "Team") != team && GetPVarInt(i, "Team") != 2)
					{
						SetPlayerPos(i, 1371.1683,2172.9846,11.0234);
					}
					
					if (GetPVarInt(i, "Team") == team)
					{
						SetPlayerPos(i, 1382.6 +((2.3 /Pocet) *Pocet2),
						2184.2 -((2.3 /Pocet) *Pocet2), 11.0);
						SetPlayerFacingAngle(i, 135.0);
						if (Pocet2 >= 0)
						{
							Pocet2++;
						}
						Pocet2 *= -1;
						SetPlayerSpecialAction(i, action);
					}
					SetPlayerCameraPos(i, 1379.0, 2180.6, 12.0);
					SetPlayerCameraLookAt(i, 1383.6, 2185.2, 10.0);
					SetPlayerInterior(i, 0);
				}
			} else {
				if (GetPVarInt(i, "Team") == 2)
				{
					if (GetPVarInt(i, "FlyMode") == 1) SetPVarInt(i, "RestoreFlymode", 1);
					SpecOff(i);
					if (GetPVarInt(i, "Specing") > -1)
					{
						GameTextForPlayer(i, " ", 1, 3);
						TogglePlayerSpectating(i, false);
						SetPVarInt(GetPVarInt(i, "Specing"), "Spected", false);
						SetPVarInt(i, "Specing", -1);
						continue;
					}
				}
				SetPlayerPos(i, 1373.6, 2175.2, 11.1);
				SetPlayerSpecialAction(i, SPECIAL_ACTION_DANCE1);
			}
		}
	}

	new string[144];
	// Show GameText for all palyers with win team name
	new winteam[16];
	if(score[0] > score[1]){
		format( string, sizeof(string), "%s%s ~w~team ~n~has won this round!",TDC[0], ClanName[0]);
		format( winteam, sizeof(winteam), "%s%s team{FFFFFF}", THC[0], ClanName[0]);
	}
	else if (score[0] < score[1]){
		format( string, sizeof(string), "%s%s ~w~team ~n~has won this round!", TDC[1], ClanName[1]);
		format( winteam, sizeof(winteam), "%s%s team{FFFFFF}",THC[1], ClanName[1]);
	}
	else if (score[0] == score[1]){ 
		format( string, sizeof(string), "~p~Equal ~w~score ~n~of both teams!");
	}
	else {
		format( string, sizeof(string), "~r~No winners ~n~~w~in this round!");
	}
	
	foreach(Player, p) {
		if(GetPlayerVirtualWorld(p) == 0) GameTextForPlayer(p, string, 8000, 3);
	}
	
	// Top Score data init
	new Float:topdamage = GetPVarFloat(0, "cwdamage");
	new topkills = GetPVarInt(0, "cwkills");
	new Float:efficiency, Float:topefficiency;
	if (GetPVarFloat(0, "cwinjuries") > 0.0) {
		topefficiency = GetPVarFloat(0, "cwdamage")/GetPVarFloat(0, "cwinjuries");
	} else {
		topefficiency = 0.0;
	}
	new Float:ratio, Float:topratio;
	if (GetPVarInt(0, "cwdeath") > 0) {
		topratio = GetPVarInt(0, "cwkills")/float(GetPVarInt(0, "cwdeath"));
	} else {
		topratio = 0.0;
	}
	
	for(i = 0; i < MAX_PLAYER_ID; i++)
	{
		if (IsPlayerConnected(i))
		{
			if(GetPVarFloat(i, "cwdamage") > topdamage) topdamage = GetPVarFloat(i, "cwdamage"); 
			if(GetPVarInt(i, "cwkills") > topkills) topkills = GetPVarInt(i, "cwkills");
			if (GetPVarInt(i, "cwdeath") > 0) {
				ratio = GetPVarInt(i, "cwkills")/float(GetPVarInt(i, "cwdeath"));
				if(ratio > topratio) topratio = ratio;
			}
			if(GetPVarFloat(i, "cwinjuries") > 0.0) {
				efficiency = GetPVarFloat(i, "cwdamage")/GetPVarFloat(i, "cwinjuries");
				if(efficiency > topefficiency) topefficiency = efficiency;
			}
		}
	}
	
	new topdamageName[MAX_PLAYER_NAME];
	new topkillsName[MAX_PLAYER_NAME];
	new topratioName[MAX_PLAYER_NAME];
	new topefficiencyName[MAX_PLAYER_NAME];
	for(i = 0; i < MAX_PLAYER_ID; i++)
	{
		if (IsPlayerConnected(i))
		{
			if(GetPVarFloat(i, "cwdamage") == topdamage)
			{
				GetPlayerName(i, topdamageName, MAX_PLAYER_NAME);
				if(CWmode) GivePlayerCookies(i, 1, true);
			}
			if(GetPVarInt(i, "cwkills") == topkills)
			{
				GetPlayerName(i, topkillsName, MAX_PLAYER_NAME); 
				if(CWmode) GivePlayerCookies(i, 1, true);
			}
			if (GetPVarInt(i, "cwdeath") > 0)
			{
				ratio = GetPVarInt(i, "cwkills")/float(GetPVarInt(i, "cwdeath"));
				if(ratio == topratio) {
					GetPlayerName(i, topratioName, MAX_PLAYER_NAME);
					if(CWmode) GivePlayerCookies(i, 1, true);
				}
			}
			if(GetPVarFloat(i, "cwinjuries") > 0.0)
			{
				efficiency = GetPVarFloat(i, "cwdamage")/GetPVarFloat(i, "cwinjuries");
				if(efficiency == topefficiency) {
					GetPlayerName(i, topefficiencyName, MAX_PLAYER_NAME);
					if(CWmode) GivePlayerCookies(i, 1, true);
				}
				
			}
		}
	}
	
	// Send to global chat top player statistics per round
	SendClientMessageToVirtualWorld(0, -1,	
	"- - - - - - - - - - - - - - - - - - - -", "- - - - - - - - - - - - - - - - - - - -");
	if (score[0] == score[1]){ 
		format( string, sizeof(string), "Equal score of both teams! %s%i:%s%i (%s%i:%s%i)", 
		THC[0],score[0],THC[1],score[1],THC[0],soucet[0],THC[1],soucet[1]);
		SendClientMessageToVirtualWorld(0, -1, string, string);
	}
	else if (score[0] > score[1]){
		format( string, sizeof(string), "Team %s%s{FFFFFF} has won this round! %s%i:%s%i (%s%i:%s%i)", 
		THC[0],ClanName[0],THC[0],score[0],THC[1],score[1],THC[0],soucet[0],THC[1],soucet[1]);
		SendClientMessageToVirtualWorld(0, -1, string, string);
	}
	else if (score[0] < score[1]){
		format( string, sizeof(string), "Team %s%s{FFFFFF} has won this round! %s%i:%s%i (%s%i:%s%i)", 
		THC[1],ClanName[1],THC[0],score[0],THC[1],score[1],THC[0],soucet[0],THC[1],soucet[1]);
		SendClientMessageToVirtualWorld(0, -1, string, string);
	} else {
		format( string, sizeof(string), "No winners in this round! %s%i:%s%i (%s%i:%s%i)", 
		THC[0],score[0],THC[1],score[1],THC[0],soucet[0],THC[1],soucet[1]);
		SendClientMessageToVirtualWorld(0, -1, string, string);
	}
	format( string, sizeof(string), "Overall statistics:");
	SendClientMessageToVirtualWorld(0, -1, string, string);
	format( string, sizeof(string), "Top damage: %s (%.2f)", topdamageName, topdamage);
	SendClientMessageToVirtualWorld(0, -1, string, string);
	format( string, sizeof(string), "Top kills: %s (%i)", topkillsName, topkills);
	SendClientMessageToVirtualWorld(0, -1, string, string);
	format( string, sizeof(string), "Top kill/death ratio: %s (%.2f)", topratioName, topratio);
	SendClientMessageToVirtualWorld(0, -1, string, string);
	format( string, sizeof(string), "Top efficiency: %s (%.2f)", topefficiencyName, topefficiency);
	SendClientMessageToVirtualWorld(0, -1, string, string);
	SendClientMessageToVirtualWorld(0, -1,
	"- - - - - - - - - - - - - - - - - - - -", "- - - - - - - - - - - - - - - - - - - -");

	RestartRound_Timer = SetTimer("RestartRound", 30000, false);
	return true;
}

public RestartRound()
{
	/* Restore players after finalscreen.*/
	Finalscreen = false;
	FirstBlood = true;
	Round++; //increase current round counter
	//  Hide actors
	for (new actorid = 1; actorid < 10; actorid++)
	{
		SetActorVirtualWorld(GirlActor[actorid], 66666);
	}
	
	// clean score
	score[0] = 0; score[1] = 0;
	
	foreach(Player, i)	
	{
		if(GetPlayerVirtualWorld(i) == 0)
		{
			// clean killchat
			SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
			SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
			SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
			SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
			SendDeathMessageToPlayer(i, INVALID_PLAYER_ID, INVALID_PLAYER_ID, 0);
			// show bars
			if(pData[i][pFpsbar] > 0) PlayerTextDrawShow(i, FPSBAR[i]);
			if(pData[i][pHpbar] > 0) PlayerTextDrawShow(i, PlayerHp[i]);
			if(pData[i][pHpbar] > 0) PlayerTextDrawShow(i, PlayerArmour[i]);
			if(pData[i][pHud] > 0) PlayerTextDrawShow(i, Commands[i]);
			if(pData[i][pHud] > 0) PlayerTextDrawShow(i, TDlagmode[i]);
			if(pData[i][pDtbar] > 0) PlayerTextDrawShow(i, TDdatetime[i]);
			#if defined _INC_WEAPON_CONFIG
			EnableHealthBarForPlayer(i, true);
			#endif
			
			if (!GetPVarInt(i, "UnBug"))
			{
				/*new playerstate = GetPlayerState(i);
				if (playerstate == PLAYER_STATE_ONFOOT || playerstate == PLAYER_STATE_SPECTATING)*/
				if (GetPlayerState(i) == PLAYER_STATE_ONFOOT)
				{
					if (GetPVarInt(i, "FlyMode") != 1) ReSpawnPlayer(i);
					SetPlayerSpecialAction(i, SPECIAL_ACTION_NONE);
				}
			}
			PlayerPlaySound(i, 1069, 0.0, 0.0, 0.0);
			SetPVarInt(i, "round_kills", GetPVarInt(i, "cwkills"));
			SetPVarInt(i, "round_death", GetPVarInt(i, "cwdeath"));
			SetPVarInt(i, "round_teamkills", GetPVarInt(i, "cwteamkills"));
			SetPVarFloat(i, "round_damage", GetPVarFloat(i, "cwdamage"));
			SetPVarFloat(i, "round_injuries", GetPVarFloat(i, "cwinjuries"));
			SetPVarFloat(i, "round_teamdamage", GetPVarFloat(i, "cwteamdamage"));
			
			if(MaxRounds != 0 && Round <= MaxRounds) {
				new tmpstr[24];
				format(tmpstr, sizeof(tmpstr), "~w~ROUND ~g~%d", Round);
				GameTextForPlayer(i, tmpstr, 3000, 5);
			}
			
			if(GetPVarInt(i, "Specing") > -1 && GetPVarInt(i, "world") == 0) 
			{
				ReSpawnPlayer(i);
			}
		}
	}
	
	for(new e = 0; e < pocet_TD[0]; e++)
	{
		TextDrawHideForAll(TDStats[0][e]);
	}
	for(new e = 0; e < pocet_TD[1]; e++)
	{
		TextDrawHideForAll(TDStats[1][e]);
	}
	pocet_TD[0] = 0;
	pocet_TD[1] = 0;
	
	RefreshScore();

	if (!CWmode) freeze_score = false;
	
	// maxrounds. off cwmode
	if(MaxRounds != 0 && Round > MaxRounds) CwModeToggle();
	
	KillTimer(RestartRound_Timer);
	return true;
}

forward HideRoundStatsTD();
public HideRoundStatsTD()
{
	for(new e = 0; e < pocet_TD[0]; e++)
	{
		TextDrawHideForAll(TDStats[0][e]);
	}
	for(new e = 0; e < pocet_TD[1]; e++)
	{
		TextDrawHideForAll(TDStats[1][e]);
	}
	pocet_TD[0] = 0;
	pocet_TD[1] = 0;
	
	RefreshScore();	
	return true;
}

public OnPlayerKeyStateChange(playerid, newkeys, oldkeys)
{
	SetPVarInt(playerid, "newkey", newkeys);
	SetPVarInt(playerid, "oldkey", oldkeys);

	if(newkeys == 65536 && Votemap != -1)
	{
		if(GetPVarInt(playerid, "VoteMap") == -1)
		{
			SetPVarInt(playerid, "VoteMap", Votemap);
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы проголосовали за смену карты", "You voted to change the map");
			SendNotify(playerid, "~g~ + VOTE", 5);
		}
	}
	// Dialog keybinds
	if(newkeys == 65536)// Open ROUNDSET menu on press Y
	{
		if(GetPlayerVirtualWorld(playerid) == 0)
		{
			if(GetPVarInt(playerid, "Admin") > 0) ROUNDSET_MENU(playerid);
		} else {
			new worldid = GetPlayerVirtualWorld(playerid);
			if(World[worldid][wHosted] == playerid || WorldModerator[playerid]) WORLD_MENU(playerid);
		}
	}
	if (( newkeys & KEY_SPRINT ) && ( newkeys & 65536 ))// Open ADMIN menu on press SPRINT + Y
	{
		if(GetPVarInt(playerid, "Admin") >= 3) ADMIN_MENU(playerid);
	}
	if(newkeys & KEY_WALK)
	{ // ALT
		if(GetPVarType(playerid, "YoutuberMenuHotkey")) YOUTUBER_MENU(playerid);
	}
	if((newkeys & KEY_WALK) && (newkeys & KEY_CROUCH))
	{ // ALT + C
		if(GetPlayerVirtualWorld(playerid) == 0) GAMEACSET(playerid);
	}
	if(newkeys & KEY_CROUCH && GetPlayerState(playerid) == PLAYER_STATE_SPECTATING)
	{
		if(GetPVarType(playerid, "FlyMode")) CAM_MENU(playerid);
	}
	// Store the time when the player hits crouch (Rapidfire func)
	if(newkeys & KEY_CROUCH)
	{
		if(GetPlayerState(playerid) != PLAYER_STATE_SPECTATING)
		{
			LastCrouchTick[playerid] = GetTickCount();
		}
	}
	if(newkeys & KEY_ACTION)
	{
		if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT)
		{
			SetPlayerChatBubble(playerid, "..opens tab menu..", COLOR_GREY, 50.0, 5000);
		}
	}
	// spec players toggle
	if (GetPVarInt(playerid, "Specing") > -1)
	{
		if (newkeys == KEY_FIRE) SpecNext(playerid);
		if (newkeys == KEY_HANDBRAKE) SpecPrev(playerid);
		if (newkeys == KEY_SPRINT) SpecNext(playerid);
		if (newkeys == KEY_JUMP) SpecNext(playerid);
	}
	if (GetPVarInt(playerid, "Skating"))
	{
		if (!IsPlayerInAnyVehicle(playerid))
		{
			if (newkeys & KEY_SPRINT)
			{
				ApplyAnimation(playerid, "SKATE", "skate_sprint",4.1, 1, 1, 1, 1, 1, 1); // sprint
			}
			else ApplyAnimation(playerid, "SKATE", "skate_idle",4.1, 1, 1, 1, 1, 1, 1); // stand still/idle
		}
	}
	
	/*if(newkeys & KEY_JUMP)
	{
		if(GetPlayerVirtualWorld(playerid) != 0 && World[GetPlayerVirtualWorld(playerid)][wVehicleJump])
		{
			if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
			{
				new Float:x, Float:y, Float:z;
				GetVehicleVelocity(GetPlayerVehicleID(playerid),x,y,z);
				SetVehicleVelocity(GetPlayerVehicleID(playerid),x,y,z+0.3);
			}
		}
	}*/

	//CJ Run
	if(GetPlayerVirtualWorld(playerid) != 0 
	&& !World[GetPlayerVirtualWorld(playerid)][wCJrun])
	{
		if (HOLDING( KEY_SPRINT ))
		{
			if (!IsPlayerInAnyVehicle(playerid))
			{	
				//ApplyAnimation(playerid,"PED","run_gang1",4.1,1,1,1,1,1);
				ApplyAnimation(playerid,"PED","run_gang1",4.1,1,1,1,1,1);
				IsAnimLoop[playerid] = true; 
			}
		}
		if (RELEASED( KEY_SPRINT))
		{
			ApplyAnimation(playerid,"PED","Run_stop",4.1,0,1,1,0,1);
			IsAnimLoop[playerid] = false;
		}
	}
	// Open settings menu on press N
	if(newkeys == 131072) SETTINGS_MENU(playerid);
	/*if(newkeys == KEY_WALK) // specbar dynbox modes toggle
	{
		if (GetPVarInt(playerid, "specbar") != -1)
		{
			if (GetPVarInt(playerid, "specbarmode") < 2)
			{
				SetPVarInt(playerid, "specbarmode", GetPVarInt(playerid, "specbarmode")+1);
			} else {
				SetPVarInt(playerid, "specbarmode", 1);
			}
		}
	}*/
	// Sprinthook binds
	if (PRESSED( KEY_JUMP))
	{
		//necessary to avoid false positives AC_SPRINTHOOK
		SetPVarInt(playerid,"AC_SPRINTHOOKTIME",gettime() + 3); 
	}
	if (newkeys & KEY_FIRE) 
 	{
		// drop spawn protect
		if (onspawnprotect[playerid])
		{
			KillTimer(SpawnKill_Timer[playerid]);
			CallLocalFunction("RestoreHealth", "i", playerid);
		}
		if(GetPVarInt(playerid, "Team") == 2 && GetPVarInt(playerid, "Admin") < 2)
		{
			//GameTextForPlayer(playerid, "~r~No damage allowed here", 3000, 3);
			ClearAnimations(playerid);
		}
	}
	// piss
	if(newkeys == 262144 && GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) //H
	{
		//if(pData[playerid][pVerified])
		if(GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_CUFFED)
		{
			ApplyAnimation(playerid, !"PAULNMAC", !"Piss_loop" ,4.1,1,0,0,0,0,0);
			SetPlayerSpecialAction(playerid, 68);
			IsAnimLoop[playerid] = 1;
		}
		
	}
	// Bike 180 trick
/* 	if(GetPlayerVirtualWorld(playerid) != 0 && newkeys == KEY_CROUCH
	&& GetPlayerState(playerid) == PLAYER_STATE_DRIVER) //H
	{
		new modelid = GetVehicleModel(GetPlayerVehicleID(playerid));
		new Float:angle;
		switch(modelid)
		{
			case 481, 509, 510, 468, 471:
			{
				GetVehicleZAngle(GetPlayerVehicleID(playerid), angle);
				SetVehicleZAngle(GetPlayerVehicleID(playerid), angle - 180);
			}
		}
	} */
	// Clear animation
	if(PRESSED( KEY_JUMP) || PRESSED( KEY_SECONDARY_ATTACK) || PRESSED( KEY_FIRE))
    {
		if(GetPlayerState(playerid) != PLAYER_STATE_WASTED && 
		GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_CUFFED)
		{
			if(IsAnimLoop[playerid] == 1)
			{			
				ClearAnimations(playerid);
				SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
				IsAnimLoop[playerid] = 0; //clear loop piss anim
			}
		}
    }
	// Map select binds
	if (newkeys == KEY_JUMP)
	{
		if (GetPVarInt(playerid, "MapSelect") > 0)
		{
			new string[128];
			new worldid = GetPlayerVirtualWorld(playerid);
			if(worldid == 0)
			{
				if(GetPVarInt(playerid, "Admin") >= 1)
				{
					if(pData[playerid][pLang] == 1)
					{
						format(string, sizeof(string),
						"{AFAFAF}№ %i.%s{FFFFFF}\n\
						Are you sure you want to change this map?",
						LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
						ShowPlayerDialog(playerid, 38, DIALOG_STYLE_MSGBOX,
						"Select map", string, "Confirm", "Cancel");
					} else {
						format(string, sizeof(string),
						"{AFAFAF}№ %i.%s{FFFFFF}\n\
						Вы уверены что хотите выбрать эту карту?",
						LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
						ShowPlayerDialog(playerid, 38, DIALOG_STYLE_MSGBOX,
						"Select map", string, "Выбрать", "Отмена");
					}
				} else {
					if(pData[playerid][pLang] == 1)
					{
						format(string, sizeof(string),
						"{AFAFAF}№ %i.%s{FFFFFF}\n\
						Are you sure you want to start voting for this map?",
						LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
						ShowPlayerDialog(playerid, 38, DIALOG_STYLE_MSGBOX,
						"Change map voting", string, "Confirm", "Cancel");
					} else {
						format(string, sizeof(string),
						"{AFAFAF}№ %i.%s{FFFFFF}\n\
						Вы уверены что хотите запустить голосование для этой карты?",
						LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
						ShowPlayerDialog(playerid, 38, DIALOG_STYLE_MSGBOX,
						"Change map voting", string, "Запустить", "Отмена");
					}
				}
			} else {
				if(World[worldid][wHosted] == playerid || WorldModerator[playerid])
				{
					if(pData[playerid][pLang] == 1)
					{
						format(string, sizeof(string),
						"{AFAFAF}№ %i.%s{FFFFFF}\n\
						Are you sure you want to change this map?",
						LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
						ShowPlayerDialog(playerid, 38, DIALOG_STYLE_MSGBOX,
						"Select map", string, "Confirm", "Cancel");
					} else {
						format(string, sizeof(string),
						"{AFAFAF}№ %i.%s{FFFFFF}\n\
						Вы уверены что хотите выбрать эту карту?",
						LAST_MAP_INDEX[playerid], MapNames[LAST_MAP_INDEX[playerid]]);
						ShowPlayerDialog(playerid, 38, DIALOG_STYLE_MSGBOX,
						"Select map", string, "Выбрать", "Отмена");
					}
				}
			}
		}
	}
	if (newkeys == KEY_CROUCH)
	{
		if (GetPVarInt(playerid, "MapSelect") > 0)
		{
			new CategoriesIDs[] = {0, 9, 24, 37, 56, 65, 73, 80};
			if(GetPVarInt(playerid, "MapCategory") > -1)
			{
				if(GetPVarInt(playerid, "MapCategory") < sizeof(CategoriesIDs)-1) 
				{
					SetPVarInt(playerid, "MapCategory", GetPVarInt(playerid, "MapCategory") + 1);
				} else {
					SetPVarInt(playerid, "MapCategory", 0);
				}
				LAST_MAP_INDEX[playerid] = CategoriesIDs[GetPVarInt(playerid, "MapCategory")];
				MoveMapCam(playerid, LAST_MAP_INDEX[playerid]);
			}
		}
	}
	if (newkeys == KEY_FIRE) // maptoggle ++
 	{
 	    if (GetPVarInt(playerid, "MapSelect") > 0)
		{   
			if(GetPVarInt(playerid, "MapSelect") == 1)
			{
				if(LAST_MAP_INDEX[playerid] != MAX_MAPID-1)
				{
					if(LAST_MAP_INDEX[playerid] > -1) {
						LAST_MAP_INDEX[playerid]++;
						MoveMapCam(playerid, LAST_MAP_INDEX[playerid]); 
					}
				}
			}			
		}
	}
	if (newkeys == KEY_HANDBRAKE)
	{
		if (GetPVarInt(playerid, "MapSelect") > 0)
		{
			if(LAST_MAP_INDEX[playerid]){
				if(LAST_MAP_INDEX[playerid] != 0) {
					LAST_MAP_INDEX[playerid]--;
					MoveMapCam(playerid, LAST_MAP_INDEX[playerid]); //prev 
				}
			} 
		}
	}
	// fly mode key binds
	if(newkeys == 262144) //H
	{
		// Sets the camera at one point
		if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY)
		{
			StopPlayerObject(playerid, noclipdata[playerid][flyobject]);
            noclipdata[playerid][mode]      = 0;
            noclipdata[playerid][accelmul]  = 0.0;
		}
	}
	if(newkeys == KEY_SECONDARY_ATTACK) // ENTER
	{
		if(OnFly[playerid]) SurflyMode(playerid);// disable surfly
		if (speconly)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"В данный момент наблюдатели обязаны оставаться в режиме наблюдения.",
			"Spectators are required to use spectate mode right now.");
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы можете перейти в другой виртуальный мир и играть там (/world)",
			"You can go to another virtual world and play there (/world)");
			return true;
		} else {
			//if(RestartRound_Timer) return 0; // check finalscreen mode
			if(Finalscreen) return 0;
			if (GetPVarInt(playerid, "Team") == 2){
				if(GetPVarType(playerid, "FlyMode")) SpecOff(playerid); // stop fly mode on F key
			}
			if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) SpecOff(playerid);
		}
	}
	if (oldkeys == KEY_SECONDARY_ATTACK) // finalscreen
	{
		if (score[0] == Roundkills || score[1] == Roundkills)
		{
			SetPlayerSpecialAction(playerid, SPECIAL_ACTION_DANCE1);
		}
	}
	if (PRESSED( KEY_SPRINT))
	{
		if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY)
		{
			CAM_MOVE_SPEED[playerid] = CAM_MOVE_MAXIMUM[playerid];
		}
	}
	else if (RELEASED( KEY_SPRINT ))
	{
		if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY)
		{
			CAM_MOVE_SPEED[playerid] = CAM_MOVE_DEFAULT[playerid];
		}
	}
	
	if (PRESSED( KEY_JUMP))
	{
		if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY)
		{
			if(CAM_MOVE_SPEED[playerid] >= CAM_MOVE_DEFAULT[playerid]) CAM_MOVE_SPEED[playerid] = 5.0;
			else CAM_MOVE_SPEED[playerid] = CAM_MOVE_SPEED[playerid] + 10.0;
		}
	}
	else if (RELEASED( KEY_JUMP ))	{
		if(noclipdata[playerid][cameramode] == CAMERA_MODE_FLY)
		{
			CAM_MOVE_SPEED[playerid] = CAM_MOVE_DEFAULT[playerid];
		}
	}
	// Old mode sprinthook compatibility
	else if (newkeys & KEY_JUMP)
	{
		if (GetPVarInt(playerid, "UnBug"))
		{
		    SetPVarInt(playerid, "UnBug", false);
		}
	}
	// Switches the player in the specbar (Num 4 - Num 6)
	if(newkeys & KEY_ANALOG_LEFT) 
	{
		if (GetPVarInt(playerid, "specbar") > 0) {
			if(IsPlayerConnected(GetPVarInt(playerid, "specbar") - 1))
			{
				SetPVarInt(playerid, "specbar", GetPVarInt(playerid, "specbar") - 1);
			} else {
				for(new i = GetPVarInt(playerid, "specbar")-1; i > 0; i--)
				{
					if(IsPlayerConnected(i)){
						SetPVarInt(playerid, "specbar", i);
						break;
					}
				}
			}
		}
	}
	if(newkeys & KEY_ANALOG_RIGHT) 
	{
		if (GetPVarInt(playerid, "specbar") >= 0) {
			if(GetPVarInt(playerid, "specbar") < MAX_PLAYER_ID) {
				if(IsPlayerConnected(GetPVarInt(playerid, "specbar") + 1))
				{
					SetPVarInt(playerid, "specbar", GetPVarInt(playerid, "specbar") + 1);
				} else {
					for(new i = GetPVarInt(playerid, "specbar")+1; i < MAX_PLAYER_ID; i++)
					{
						if(IsPlayerConnected(i)){
							SetPVarInt(playerid, "specbar", i);
							break;
						}
					}
				}
			}
		}
	}
	//Anti-cbug
	if(GetPlayerVirtualWorld(playerid) == 0 && AC_CBUG_PROTECT
	|| GetPlayerVirtualWorld(playerid) != 0 && !World[GetPlayerVirtualWorld(playerid)][wCbug]) 
	{
		if(newkeys & KEY_FIRE && oldkeys & KEY_CROUCH && GetPlayerState(playerid) == 1)
		{
			if(GetPlayerWeapon(playerid) == 24 || GetPlayerWeapon(playerid) == 25)
			{
				if(GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_DUCK) 
				{
					SetPVarInt(playerid, "ac_cbug", GetPVarInt(playerid, "ac_cbug") + 1);
					if(GetPVarInt(playerid, "ac_cbug") > 2)
					{
						SetPVarInt(playerid, "ac_cbug",0);
						ApplyAnimation(playerid,"FAT","IDLE_tired",4.1,0,0,0,0,0,1); 
					}
				}
			}
		}
	}
	
	// Anti-slide protect by OKstyle
	if(GetPlayerVirtualWorld(playerid) == 0 && AC_ANTISLIDE_PROTECT
	|| GetPlayerVirtualWorld(playerid) != 0 && !World[GetPlayerVirtualWorld(playerid)][wCbug]) 
	{
		if(GetPVarInt(playerid, "Slide") == 1 && GetPlayerWeapon(playerid) == 24 &&
		newkeys & KEY_SPRINT && newkeys & KEY_HANDBRAKE){
			ApplyAnimation(playerid, "PED", "getup_front", 4.0, 0, 0, 1, 0, 0); 
		}
	}

	if(newkeys == KEY_ANALOG_LEFT) // Num 4
	{
		new string[100], stringru[100];
		if (GetPlayerState(playerid) == PLAYER_STATE_SPECTATING)
		{
			return true;
		}
		if(GetPVarInt(playerid, "specbar") != -1)
		{
			return true;
		}
		if(frz && GetPlayerVirtualWorld(playerid) == 0) {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Матч на паузе, попробуйте позже",
			"Match paused, try sync later");
			return true;
		}
		if(freeze_score && GetPlayerVirtualWorld(playerid) == 0) {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Матч заморожен, попробуйте позже",
			"Match freezed, try sync later");
			return true;
		}
		if(GetPVarInt(playerid, "LastSync") > gettime())
		{
			format(string, sizeof(string), "You can use /sync after %d seconds",
			GetPVarInt(playerid, "LastSync")-gettime());
			format(stringru, sizeof(stringru), "Вы сможете использовать /sync через %d секунд",
			GetPVarInt(playerid, "LastSync")-gettime());
			SendClientMessageEx(playerid, COLOR_GREY, stringru, string);
			return true;
		} else {
            SetPVarInt(playerid,"LastSync",gettime() + 60);
		}
		if (GetPVarType(playerid, "Lounge"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		if (GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_CUFFED)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Сейчас Вы не можете заспавниться.", "You can't respawn yourself right now.");
			return true;
		}
		
		if (GetPVarInt(playerid, "UnBug"))
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы уже синхронизированны", "You're currently being synced or anti cheat tested.");
			return true;
		}
		if (GetPlayerState(playerid) != PLAYER_STATE_ONFOOT)
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы уже синхронизированны", "You aren't desynced.");
			return true;
		}

		Sync(playerid);
		
		new team = GetPVarInt(playerid, "Team");
		format(string, sizeof(string),
		"%s%s[%d]{afafaf} has been synced (/sync or Num4)",
		THC[team],PlayerName(playerid), playerid);
		format(stringru, sizeof(stringru),
		"%s%s[%d]{afafaf} был синхронизирован (/sync или Num4)",
		THC[team],PlayerName(playerid), playerid);
		SendClientMessageToAllEx(COLOR_GREY, stringru, string);//33AA33 TCC[0]
	}
	
	if(newkeys == 512)
	{
		new WheelsIDs[14] = {1073,1074,1075,1076,1077,1078,1079,1080,1081,1082,1083,1084,1085};
		// http://wiki.sa-mp.com/wiki/Car_Component_ID
		new RandomWheel = random(sizeof(WheelsIDs));
		new vehicleid = GetPlayerVehicleID(playerid);
		new worldid = GetPlayerVirtualWorld(playerid);
		if (IsPlayerInAnyVehicle(playerid))
		{
			if(World[worldid][wVehicleFix])
			{
				ChangeVehicleColor(vehicleid, random(120), random(120));
				switch(GetVehicleModel(GetPlayerVehicleID(playerid)))
				{
					case 446,432,448,452,424,453,454,461,462,463,468,471,430,472,449,473,481,484,
					493,509,510,521,538,522,523,532,537,570,581,586,590,569,595,604,611: return 0;
				}
				AddVehicleComponent(vehicleid, WheelsIDs[RandomWheel]);
			}
		}
	}
	// Auto NOs refill
	if(newkeys == 1 || newkeys == 9 || newkeys == 33 
	&& oldkeys != 1 || oldkeys != 9 || oldkeys != 33)
	{
		switch(GetVehicleModel(GetPlayerVehicleID(playerid)))
		{
			case 446,448,452,424,453,454,461,462,463,468,471,430,472,449,473,481,484,
			493,509,510,521,538,522,523,532,537,570,581,586,590,569,595,604,611: return 0;
		}
		AddVehicleComponent(GetPlayerVehicleID(playerid), 1010);
	}
	// flip on press H key 
	if(newkeys == 2 && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{
		new Float:a;
		new worldid = GetPlayerVirtualWorld(playerid);
		if(worldid != 0 && !WorldModerator[playerid])
		{
			if(World[worldid][wVehicleFix])
			{
				GetVehicleZAngle(GetPlayerVehicleID(playerid), a);
				SetVehicleZAngle(GetPlayerVehicleID(playerid), a);
			}
		}
		if(worldid != 0 && World[worldid][wGamemode] != GAMEMODE_DERBY)
		{
			GetVehicleZAngle(GetPlayerVehicleID(playerid), a);
			SetVehicleZAngle(GetPlayerVehicleID(playerid), a);
		}
	}
	
	if(PRESSED(KEY_FIRE)) SetPVarInt(playerid, "PR_LMB", 1); 
	else if(RELEASED(KEY_FIRE)) SetPVarInt(playerid, "PR_LMB", 0);

	if(PRESSED(KEY_AIM)) SetPVarInt(playerid, "PR_RMB", 1);
	else if(RELEASED(KEY_AIM)) SetPVarInt(playerid, "PR_RMB", 0);
	
	if(PRESSED(KEY_JUMP)) SetPVarInt(playerid, "PR_JUMP", 1); 
	else if(RELEASED(KEY_JUMP)) SetPVarInt(playerid, "PR_JUMP", 0);
	
	if(PRESSED(KEY_SPRINT)) SetPVarInt(playerid, "PR_SPRINT", 1); 
	else if(RELEASED(KEY_SPRINT)) SetPVarInt(playerid, "PR_SPRINT", 0);
	
	return true;
}

#if defined _streamer_included
public OnPlayerEditDynamicObject(playerid, objectid, response,
Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz)
{
	if(response == EDIT_RESPONSE_FINAL || response == EDIT_RESPONSE_CANCEL)
	{
		CancelEdit(playerid);
		SetPVarInt(playerid, "Editmode", 0);
	}
	return 1;
}

public OnPlayerSelectDynamicObject(playerid, objectid, modelid, Float:x, Float:y, Float:z)
{ 
	EDIT_OBJECTMODELID[playerid] = modelid;
	EDIT_OBJECTID[playerid] = objectid;
	new Float:rx, Float:ry, Float:rz;
	GetDynamicObjectRot(objectid, rx, ry, rz);
	
	new tmpstr[256];
	format(tmpstr, sizeof(tmpstr),
	"~w~Model: ~g~%i~n~\
	~w~x: ~g~%.3f ~w~y: ~g~%.3f ~w~z: ~g~%.3f~n~\
	~w~rx: ~g~%.3f ~w~ry: ~g~%.3f ~w~rz: ~g~%.3f",
	modelid, x, y, z, rx, ry, rz); 

	SendNotify(playerid, tmpstr, 5);
	printf("modelid: %i, x:%.3f, y:%.3f, z:%.3f, rx:%.3f, ry:%.3f, rz:%.3f",
	modelid, x, y, z, rx, ry, rz); 
	
	switch(GetPVarInt(playerid, "Editmode"))
	{
		case 2: EditDynamicObject(playerid, objectid);
		case 3:
		{
			DestroyDynamicObject(objectid);
			EDIT_OBJECTID[playerid] = -1;
			CancelEdit(playerid);
		}
		case 4:
		{
			printf("CreateDynamicObject(%i, %.4f, %.4f, %.4f, %.4f, %.4f, %.4f, %i, %i);",
			modelid, x, y, z, rx, ry, rz, GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid)); 
			CancelEdit(playerid);
		}
	}
	return 1;
}

public OnPlayerEnterDynamicCP(playerid, checkpointid)
{
	new worldid = GetPlayerVirtualWorld(playerid);
	new stringen[128], stringru[128];
	
	if(IsValidDynamicCP(WorldCheckpoint[worldid]) && checkpointid == WorldCheckpoint[worldid])
	{
		/* if(WorldModerator[playerid])
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы на чекпоинте, чекпоинт не удален т.к. вы модератор",
			"You are on checkpoint, checkpoint has not been deleted because you are a moderator");		return false;
		} */
		SetPlayerScore(playerid, GetPlayerScore(playerid) + 1);
		DestroyDynamicCP(WorldCheckpoint[worldid]);
		WorldCheckpoint[worldid] = 0;
		PlayerPlaySound(playerid, 1183, 0, 0, 0);
		format(stringen, sizeof(stringen), "%s(%d) first arrived at checkpoint",
		PlayerName(playerid), playerid);
		format(stringru, sizeof(stringru), "%s(%d) первый прибыл к чекпоинту",
		PlayerName(playerid), playerid);
		SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
	}
	if(IsValidDynamicCP(WorldVehCheckpoint[worldid]) && checkpointid == WorldVehCheckpoint[worldid])
	{
		/* if(WorldModerator[playerid])
		{
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы на чекпоинте, чекпоинт не удален т.к. вы модератор",
			"You are on checkpoint, checkpoint has not been deleted because you are a moderator");		return false;
		} */
		if(IsPlayerInAnyVehicle(playerid))
		{
			SetPlayerScore(playerid, GetPlayerScore(playerid) + 1);
			DestroyDynamicCP(WorldVehCheckpoint[worldid]);
			WorldVehCheckpoint[worldid] = 0;
			PlayerPlaySound(playerid, 1183, 0, 0, 0);
			format(stringen, sizeof(stringen), "%s(%d) first arrived at checkpoint",
			PlayerName(playerid), playerid);
			format(stringru, sizeof(stringru), "%s(%d) первый прибыл к чекпоинту",
			PlayerName(playerid), playerid);
			SendClientMessageToVirtualWorld(worldid, COLOR_GREY, stringru, stringen);
		}
	}
	return 1;
}

public OnPlayerEnterDynamicArea(playerid, areaid) 
{ 
	new worldid = GetPlayerVirtualWorld(playerid);
	if(GetPlayerVirtualWorld(playerid) != 0)
	{
		if(!World[worldid][wGreenZone]) return 0; 
		if(areaid == World[worldid][wGreenZone])
