				"Функция недоступна в текущем режиме игры.",
				"The function is not available in the current game mode");
			}
			if(!WorldModerator[playerid] && World[worldid][wGamemode] == GAMEMODE_WOT)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Функция недоступна в текущем режиме игры.",
				"The function is not available in the current game mode");
			}
		}
		
		//SendClientMessageEx(playerid, COLOR_GREY,
		//"Использование: /v [Vehicle ID or Vehicle Name]", "Use: /v [Vehicle ID or Vehicle Name]");
		if(pData[playerid][pLang])
		{
			ShowPlayerDialog(playerid, 186, DIALOG_STYLE_INPUT,
