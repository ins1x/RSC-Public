				}
			}
		}
		else WORLD_VEHICLES(playerid);
	}
	if(dialogid == 358) // attach share
	{
		if(response)
		{
			if(!strlen(inputtext)) return false;
			if(!isnumeric(inputtext)) return false;
			new stringru[100], stringen[100];
			
			new pid = strval(inputtext);
			if(pid != INVALID_PLAYER_ID && IsPlayerConnected(pid))
			{
				if(pData[pid][pAttachSlot0] == 600)
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Недоступно для этого игрока", "Unavailable for this player");
				}
				if(pid == playerid)
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Нельзя передать самому себе", "You can't pass it on to yourself");
				}
				ChosenPlayer[playerid] = pid;
				SetPVarInt(playerid, "ShareActionDelay", gettime() + 65);
				SetPVarInt(pid, "ShareActionDelay", gettime() + 65);
				SetPVarInt(pid, "SharePlayerID", playerid);
				
				format(stringru, sizeof(stringru),
				"Вы отправили свой набор аттачей игроку %s(%d)",
				PlayerName(pid), pid);
				format(stringen, sizeof(stringen),
				"You have sent your set of attachments to the player %s(%d)",
				PlayerName(pid), pid);
				SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
				
				format(stringru, sizeof(stringru),
				"%s(%d) поделился с вами аттачами, чтобы принять введите /accept",
				PlayerName(playerid), playerid);
				format(stringen, sizeof(stringen),
				"%s(%d) shared attachments with you to accept enter /accept",
				PlayerName(playerid), playerid);
				SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
			}
		}
	}
