stock WORLD_INFO(playerid, worldid)
{
	new tbtext[512], mapname[32];
	new players = GetPlayersInWorld(worldid);
	new vehicles = 0;
	//new actors = 0;
	
	for(new i = GetVehiclePoolSize() +1; --i != 0;)
	{
		if(GetVehicleVirtualWorld(i) == worldid) vehicles++;
	}
	
	/*#if defined _streamer_included
	for(new actorid = 0; actorid < MAX_ACTORS; actorid++)
	{				
		if(IsValidDynamicActor(actorid))
		{
			if(GetDynamicActorVirtualWorld(actorid) == worldid) actors++;
		}
	}
	#else
	for(new actorid = 0; actorid < MAX_ACTORS; actorid++)
	{				
		if(IsValidActor(actorid)) 
		{
			if(GetActorVirtualWorld(actorid) == worldid) actors++;
		}
	}
	#endif */
	
	if(World[worldid][wSpawnPoint]) 
	{
		format(mapname, sizeof(mapname), "Custom spawn");
	} else {
		format(mapname, sizeof(mapname), "%s", MapNames[World[worldid][wMap]]);
	}
	
	new worldmode[24];
	format(worldmode, sizeof(worldmode), "%s", WorldModes[World[worldid][wGamemode]]);
	
	new moderators[256], tmpstr[32];
	foreach(Player, i)
	{
		if(WorldModerator[i])
		{
			format(tmpstr, sizeof(tmpstr), " %s ", PlayerName(i));
			strcat(moderators, tmpstr);
		}
	}
		
	if(pData[playerid][pLang])
	{
		format(tbtext, sizeof(tbtext),
		"{FFFFFF}World %d:\t %s\n\
		{FFFFFF}World hoster:\t %s\n\
		{FFFFFF}World moderators:\t%s\n\
		{FFFFFF}World gamemode:\t %s\n\
		{FFFFFF}Map:\t %s\n\
		{FFFFFF}Vehicles:\t %s\n\
		{FFFFFF}Vehicles fix:\t %s\n\
		{FFFFFF}Weapons:\t %s\n\
		{FFFFFF}Teleports:\t %s\n\
		{FFFFFF}Players in world:\t %d\n\
		{FFFFFF}Vehicles in world:\t %d\n\
		{FFFFFF}Anticheat:\t %s",
		worldid, (World[worldid][wLocked]) ? ("{FF0000}Locked") : ("{00FF00}Open"),
		PlayerName(World[worldid][wHosted]), 
		moderators,
		worldmode, mapname,
		(World[worldid][wVehicles]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[worldid][wVehicleFix]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[worldid][wWeapons]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[worldid][wTeleports]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		players, vehicles,
		(World[worldid][wAnticheat]) ? ("{00FF00}[Enabled]") : ("{FF0000}[Disabled]"));
	} else {
		format(tbtext, sizeof(tbtext),
		"{FFFFFF}Мир %d:\t %s\n\
		{FFFFFF}Хостер:\t %s\n\
		{FFFFFF}Модераторы:\t%s\n\
		{FFFFFF}Режим:\t %s\n\
		{FFFFFF}Карта:\t %s\n\
		{FFFFFF}Транспорт:\t %s\n\
		{FFFFFF}Починка транспорта:\t %s\n\
		{FFFFFF}Оружие:\t %s\n\
		{FFFFFF}Телепорты:\t %s\n\
		{FFFFFF}Игроков в мире:\t %d\n\
		{FFFFFF}Транспорта в мире:\t %d\n\
		{FFFFFF}Античит:\t %s",
		worldid, (World[worldid][wLocked]) ? ("{FF0000}[Закрыт]") : ("{00FF00}[Открыт]"),
		PlayerName(World[worldid][wHosted]), 
		moderators,
		worldmode, mapname,
		(World[worldid][wVehicles]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		(World[worldid][wVehicleFix]) ? ("{00FF00}[Разрешена]") : ("{FF0000}[Запрещена]"),
		(World[worldid][wWeapons]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		(World[worldid][wTeleports]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		players, vehicles,
		(World[worldid][wAnticheat]) ? ("{00FF00}[Включен]") : ("{FF0000}[Отключен]"));
	}
	ShowPlayerDialog(playerid, 306, DIALOG_STYLE_TABLIST,
	"About world", tbtext, "Close", "");
	return 1;
}

