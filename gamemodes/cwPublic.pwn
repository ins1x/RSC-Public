				}
			}
			
			if(!CWmode)
			{
				if(TotalGreen < 1 || TotalBlue < 1)
				{
					return SendClientMessageEx(playerid, COLOR_GREY,
					"Для запуска матча нужен как минимум один игрок в каждой команде!",
					"To start a match, you need at least one player in each team!");
				}
			}
			
			CwModeToggle(playerid);
			
			if(!CWmode) GameTextForPlayer(playerid, "~w~Type ~r~/Default", 3000, 4);
			else ROUNDSET_MENU(playerid);
			
		    return true;
		}
		if (!strcmp(cmdtext, "/showagain", true))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return true;
			}
			
			if(!CWmode)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Сперва включите Clan War режим!", "Turn ON Clan War mode first!");
				return true;
			}	
			
			SendClientMessageEx(playerid, COLOR_GREY,
			"Таблицы скроется автоматически через 10 секунд",
			"The tables will be hidden automatically after 10 seconds");
				
			new i;
			for(i = 0; i < MAX_PLAYER_ID; i++)
			{
				if (GetPVarInt(i, "Team") < 2)
				{
					if (pocet_TD[GetPVarInt(i, "Team")] < sizeof(TDStats[]))
					{
						new sstring[222], stats_[6][13];
						for(new e = 0; e < 3; e++)
						{
							format(sstring, 13, "round_stats%d", e);
							if (GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring) < 10)
							{
								format(stats_[e], sizeof(stats_[]), "0%d", GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring));
							}else{
								valstr(stats_[e], GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring));
								//format(stats_[e], sizeof(stats_[]), "%d", GetPVarInt(i, sstring[6]) -GetPVarInt(i, sstring));
							}
						}
						new cwdamage = floatround(GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage"), floatround_round);
						new cwinjuries = floatround(GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries"), floatround_round);
						new cwteamdamage = floatround(GetPVarFloat(i, "cwteamdamage") -GetPVarFloat(i, "round_teamdamage"), floatround_round);

						if (cwdamage < 10) {
							format(stats_[3], sizeof(stats_[]), "000%d", cwdamage);
						}
						else if (cwdamage < 100) {
							format(stats_[3], sizeof(stats_[]), "00%d", cwdamage);
						}
						else if (cwdamage < 1000) {
							format(stats_[3], sizeof(stats_[]), "0%d", cwdamage);
						} else {
							valstr(stats_[3], cwdamage);
						}

						if (cwinjuries < 10) {
							format(stats_[4], sizeof(stats_[]), "000%d", cwinjuries);
						}
						else if (cwinjuries < 100) {
							format(stats_[4], sizeof(stats_[]), "00%d", cwinjuries);
						}
						else if (cwinjuries < 1000) {
							format(stats_[4], sizeof(stats_[]), "0%d", cwinjuries);
						} else {
							valstr(stats_[4], cwinjuries);
						}

						if (cwteamdamage < 10) {
							format(stats_[5], sizeof(stats_[]), "0%d", cwteamdamage);
						} else {
							valstr(stats_[5], cwteamdamage);
						}
						
						new ratio[2][13];
						if (GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death") > 0)
						{
							format(ratio[0], sizeof(ratio[]), "%.2f", (GetPVarInt(i, "cwkills") -GetPVarInt(i, "round_kills")) /float(GetPVarInt(i, "cwdeath") -GetPVarInt(i, "round_death")));
						}else{
							ratio[0] = "-";
						}
						if (GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage") > 0)
						{
							format(ratio[1], sizeof(ratio[]), "%.2f", (GetPVarFloat(i, "cwdamage") -GetPVarFloat(i, "round_damage")) /(GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries")));
						}else{
							ratio[1] = "-";
						}
			
						// RSC revision added data efficiency, kills, death
						new round_kills = GetPVarInt(i, "cwkills") - GetPVarInt(i, "round_kills");
						new round_deaths = GetPVarInt(i, "cwdeath") - GetPVarInt(i, "round_death");
						new Float:round_efficiency, td_round_efficiency[5];
						if(cwinjuries > 0) {
							round_efficiency = (GetPVarFloat(i, "cwdamage")-GetPVarFloat(i,"round_damage")) / (GetPVarFloat(i, "cwinjuries") -GetPVarFloat(i, "round_injuries"));
							if(round_efficiency < 1.0) {
								format(td_round_efficiency, sizeof(td_round_efficiency), "%.2f0", round_efficiency);
							} else if(round_efficiency< 10.0) {
								format(td_round_efficiency, sizeof(td_round_efficiency), "%.2f", round_efficiency);
							} else {
								format(td_round_efficiency, sizeof(td_round_efficiency), "0.0");
							}
						} else {
							format(td_round_efficiency, sizeof(td_round_efficiency), "0.0");
						}
						
						// k/d ratio
						new Float:kd_ratio, td_kd_ratio[5];
						//new Float:kd_ratio = GetPVarInt(i, "cwkills")/float(GetPVarInt(i, "cwdeath");
						
						if(round_deaths > 0) kd_ratio = float(round_kills/round_deaths);
						else kd_ratio = 1.0;
						
						if(kd_ratio > 0.0)
						{
							if(kd_ratio < 1.0) {
								format(td_kd_ratio, sizeof(td_kd_ratio), "%.2f0", kd_ratio);
							} else if(kd_ratio < 10.0) {
								format(td_kd_ratio, sizeof(td_kd_ratio), "%.2f", kd_ratio);
							}
						} else {
							//format(td_kd_ratio, sizeof(td_kd_ratio), "0.0");
							format(td_kd_ratio, sizeof(td_kd_ratio), "%.2f", kd_ratio);
						}
						
						GetPlayerName(i, sstring, MAX_PLAYER_NAME);
						new playerteam = GetPVarInt(i, "Team");
						
						if (playerteam == 0)
						{
							format(sstring, sizeof(sstring),
							"%s%s~w~ - Damage: ~y~%s~w~ I Injuries: ~y~%s~w~ I Efficiency: ~y~%s~w~ I Kills: ~y~%d~w~ I Deaths: ~y~%d~w~ I Ratio: ~y~%s~w~",
							TDC[0], sstring, stats_[3], stats_[4], td_round_efficiency, round_kills, round_deaths, td_kd_ratio);
						} else {
							format(sstring, sizeof(sstring),
							"%s%s~w~ - Damage: ~y~%s~w~ I Injuries: ~y~%s~w~ I Efficiency: ~y~%s~w~ I Kills: ~y~%d~w~ I Deaths: ~y~%d~w~ I Ratio: ~y~%s~w~",
							TDC[1], sstring, stats_[3], stats_[4], td_round_efficiency, round_kills, round_deaths, td_kd_ratio);
						}
						TextDrawSetString(TDStats[playerteam][pocet_TD[playerteam]], sstring);
						pocet_TD[playerteam]++;
					}
				}
				for(new e = 0; e < pocet_TD[0]; e++)
				{
					TextDrawShowForPlayer(i, TDStats[0][e]);
				}
				for(new e = 0; e < pocet_TD[1]; e++)
				{
					TextDrawShowForPlayer(i, TDStats[1][e]);
				}
				SetTimerEx("HideRoundStatsTD", 7000, false, "");
			}
			return true;
		}
		if (!strcmp(cmdtext, "/speconly", true))
		{
			if(GetPlayerVirtualWorld(playerid) != 0)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в виртуальном мире!", "Not available in the virtual world!");
				return 1;
			}
			Speconly_mode(playerid);
		    return true;
		}
	}
	if (!strcmp(cmdtext, "/hitbox", true) || !strcmp(cmdtext, "/hb", true))
	{
		HITBOX_SETTINGS(playerid);
		return true;
	}
	if (!strcmp(cmdtext, "/cwhelp", true))
	{
		CwHelp(playerid);
		return true;
	}
	// Command not found 
	new string[128], stringen[128];
	format(string, sizeof(string),
	"Команда \"%s\" не существует. Используйте: /cmds чтобы показать список доступных команд", cmdtext);
	format(stringen, sizeof(stringen),
	"Command \"%s\" doesn't exist. Use: /cmds to show a list of available commands", cmdtext);
	SendClientMessageEx(playerid, COLOR_GREY, string, stringen);
	PlayerPlaySound(playerid, 1135, 0, 0, 0);
	SendNotify(playerid, "~r~Unknown command ~w~Use: /cmds", 5);
	return true;
}

public OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
	// Dialog crasher protection
	if(strlen(inputtext) && (strfind(inputtext,"`") != -1 || strfind(inputtext,"'") != -1 
	|| strfind(inputtext,"=") != -1 || strfind(inputtext,"{") != -1 || strfind(inputtext,"}") != -1))
	{
 		SendClientMessageEx(playerid, COLOR_GREY,
		"Ошибка. Найдены запрещенные символы.", "Error. Founded prohibited characters.");
		return false;
	}
	
	if(response) PlayerPlaySound(playerid, 30800, 0.0, 0.0, 0.0); // NULL_1A
	else PlayerPlaySound(playerid, 30802, 0.0, 0.0, 0.0); // NULL_2A
	// Save last opened dialog
	if(response) LAST_DIALOG[playerid] = dialogid; 
	//if(response) PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0); //VC IN
	//else PlayerPlaySound(playerid, 1053, 0.0, 0.0, 0.0); //VC OUT
	
	if (dialogid == 0) // Stub
	{
		// A stub for dialogs of type DIALOG_STYLE_MSGBOX 
		// use it if you do not need to use response actions. 
		// Example: (For displaying information only)
	}
	if(dialogid == 1)// register lang select
	{
		if(response)
		{
			switch(listitem)
			{
				case 0:
				{
					pData[playerid][pLang] = 1;
					SendClientMessage(playerid, COLOR_GREY,
					"Your language has been set to English");
					LoginDialog(playerid);
				}
				case 1:
				{
					pData[playerid][pLang] = 0;
					SendClientMessage(playerid, COLOR_GREY,
					"Выбран русский язык.");
					LoginDialog(playerid);
				}
				default: pData[playerid][pLang] = 1;
			}
		}
		else 
		{
			ShowPlayerDialog(playerid, 1, DIALOG_STYLE_LIST,
			"Language", "English\nRussian", "OK", "Cancel");
		}
	}
	if (dialogid == 2) // register dialog ( /register )
    {
        if(!strlen(inputtext)) return RegisterDialog(playerid);
        if(response) 
        {
			new 
				serial[41], ip[16],
				hwid[64], passhash[64 + 1],
				PlayerNickName[MAX_PLAYER_NAME],
				year,month,day,hour,minute,second,date[20]
			;
            
            GetPlayerName(playerid,PlayerNickName,sizeof(PlayerNickName));
			getdate(year, month, day); gettime(hour,minute,second);
			format(date, sizeof(date), "%d.%d.%d %d:%d", day,month,year,hour,minute);
			
			new stringru[100], stringen[100];
			if(strlen(inputtext) < 4 || strlen(inputtext) > 20)
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Пароль должен состоять из 4-20 символов",
				"Password must consist of at least 4 characters, but no more than 20 characters!");
				RegisterDialog(playerid);
			}
			
			SHA256_PassHash(inputtext, KEY, passhash, sizeof(passhash));

			GetPlayerIp(playerid, ip, sizeof ip);
			gpci(playerid,serial,40);
			
			#if defined _sampcac_included
			CAC_GetHardwareID(playerid, hwid, sizeof(hwid));
			#else
			format(hwid, sizeof(hwid), "None");
			#endif

			pData[playerid][pAdmin] = 0;
			pData[playerid][pLang] = 0;
			pData[playerid][pSkin] = -1;
			pData[playerid][pWeather] = 1;
			pData[playerid][pHour] = 12;
			pData[playerid][pHud] = 1;
			pData[playerid][pFpsbar] = 1;
			pData[playerid][pDtbar] = 0;
			pData[playerid][pBottombar] = 0;
			pData[playerid][pHpbar] = 1;
			pData[playerid][pBell] = 17802;
			pData[playerid][pKillchat] = -1;
			pData[playerid][pDmgInformer] = 0;
			pData[playerid][pTogpm] = 0;
			pData[playerid][pAttachSlot0] = -1;
			pData[playerid][pAttachSlot1] = -1;
			pData[playerid][pAttachSlot2] = -1;
			pData[playerid][pAttachSlot3] = -1;
			pData[playerid][pBanned] = 0;
			pData[playerid][pMuted] = 0;
			pData[playerid][pVerified] = 0;
			pData[playerid][pCookies] = 0;
			pData[playerid][pSfx] = 1;
			
			new szQuery[650], DBResult: query;
			format(szQuery, sizeof(szQuery),
			"INSERT INTO Accounts (Nickname, Admin, Password, Serial, Lang, Skin, \
			Weather, Hour, Hud, Fpsbar, Dtbar, Bottombar, Hpbar, Bell, Killchat, \
			Dmginformer, Togpm,	AttachSlot0, AttachSlot1, AttachSlot2, AttachSlot3, \
			Lastip, Lastlogin, Lastcountry, Lastcity, Banned, Muted, Verified, Cookies, Sfx) \
			VALUES ('%q', %i, '%s', '%q', %i, %i,\
			%i, %i, %i, %i, %i, %i, %i, %i, %i, \
			%i, %i, %i, %i, %i, %i, \
			'%q', '%q', '%q', '%q', %i, %i, %i, %i, %i)",
			db_escape(PlayerNickName), pData[playerid][pAdmin], passhash, serial,
			pData[playerid][pLang],	pData[playerid][pSkin], pData[playerid][pWeather],
			pData[playerid][pHour], pData[playerid][pHud], pData[playerid][pFpsbar],
			pData[playerid][pDtbar], pData[playerid][pBottombar], pData[playerid][pHpbar],
			pData[playerid][pBell],	pData[playerid][pKillchat], pData[playerid][pDmgInformer],
			pData[playerid][pTogpm], pData[playerid][pAttachSlot0],	pData[playerid][pAttachSlot1],
			pData[playerid][pAttachSlot2], pData[playerid][pAttachSlot3], ip, date,
			PlayerGeoIPInfo[playerid][pCountry], PlayerGeoIPInfo[playerid][pCity],
			pData[playerid][pBanned], pData[playerid][pMuted],
			pData[playerid][pVerified], pData[playerid][pCookies], pData[playerid][pSfx]);
			query = db_query(dbaccounts, szQuery);
			if(query && Debug) print ("[DEBUG] Registration completed");
			
			if(query)
			{
				format(stringru, sizeof(stringru),
				"%s(%d) успешно зарегистрировался. Добро пожаловать!",
				PlayerName(playerid), playerid);
				format(stringen, sizeof(stringen),
				"%s(%d) has successfully registered. Welcome!",
				PlayerName(playerid), playerid);
				SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
			} else {
				printf("%s", szQuery);
				SendSystemMessage("Player registration FAIL!. Check logs");
			}
			
			db_free_result(query);
			
			ShowPlayerDialog(playerid, 1, DIALOG_STYLE_LIST,
			"Language", "English\nRussian", "OK", "Cancel");
        }
        else RegisterDialog(playerid);
	}
	if (dialogid == 3) // login dialog ( /login )
	{
		// DIALOG_LOGIN
		if(!strlen(inputtext)) return LoginDialog(playerid);
		if(response)
		{
			// new LastLogMess[50];
			new 
				PlayerNickName[MAX_PLAYER_NAME], 
				ip[16], serial[41], passhash[64 + 1]
			;
			// new serial[41], tmpstr[128]; look drop privileges code bellow
			new stringen[128],stringru[128];
			GetPlayerIp(playerid, ip, sizeof ip);
			gpci(playerid,serial,40);
            GetPlayerName(playerid, PlayerNickName, sizeof(PlayerNickName));
			new year,month,day,hour,minute,second, lastlogin[24];
			getdate(year, month, day); gettime(hour,minute,second);
			format(lastlogin, sizeof(lastlogin), "%d.%d.%d %d:%d", day,month,year,hour,minute);
			
			SHA256_PassHash(inputtext, KEY, passhash, sizeof(passhash));
			
			if(fexist("accounts.db"))
			{
				new szQuery[512], accpass[64+1], DBResult: query;
				format(szQuery, sizeof(szQuery),
				"SELECT Password FROM Accounts WHERE Nickname = '%q'",
				db_escape(PlayerNickName));
				query = db_query(dbaccounts, szQuery);
				if(db_num_rows(query))
				{
					db_get_field(query, 0, accpass, sizeof(accpass));
					db_free_result(query);
					if(!strcmp(passhash, accpass, true))
					{
						format(szQuery, sizeof(szQuery),
						"SELECT Admin, Lang, Skin, \
						Weather, Hour, Hud, Fpsbar, Dtbar, Bottombar, Hpbar, Bell, Killchat, \
						Dmginformer, Togpm,	AttachSlot0, AttachSlot1, AttachSlot2, AttachSlot3, \
						Muted, Banned, Verified, Cookies, Sfx FROM Accounts WHERE Nickname = '%q'",
						db_escape(PlayerNickName));
						query = db_query(dbaccounts, szQuery);
						
						pData[playerid][pAdmin] = db_get_field_int(query, 0);
						pData[playerid][pLang] = db_get_field_int(query, 1);
						pData[playerid][pSkin] = db_get_field_int(query, 2);
						pData[playerid][pWeather] = db_get_field_int(query, 3);
						pData[playerid][pHour] = db_get_field_int(query, 4);
						pData[playerid][pHud] = db_get_field_int(query, 5);
						pData[playerid][pFpsbar] = db_get_field_int(query, 6);
						pData[playerid][pDtbar] = db_get_field_int(query, 7);
						pData[playerid][pBottombar] = db_get_field_int(query, 8);
						pData[playerid][pHpbar] = db_get_field_int(query, 9);
						pData[playerid][pBell] = db_get_field_int(query, 10);
						pData[playerid][pKillchat] = db_get_field_int(query, 11);
						pData[playerid][pDmgInformer] = db_get_field_int(query, 12);
						pData[playerid][pTogpm] = db_get_field_int(query, 13);
						pData[playerid][pAttachSlot0] = db_get_field_int(query, 14);
						pData[playerid][pAttachSlot1] = db_get_field_int(query, 15);
						pData[playerid][pAttachSlot2] = db_get_field_int(query, 16);
						pData[playerid][pAttachSlot3] = db_get_field_int(query, 17);
						pData[playerid][pMuted] = db_get_field_int(query, 18);
						pData[playerid][pBanned] = db_get_field_int(query, 19);
						pData[playerid][pVerified] = db_get_field_int(query, 20);
						pData[playerid][pCookies] = db_get_field_int(query, 21);
						pData[playerid][pSfx] = db_get_field_int(query, 22);
						
						db_free_result(query);
						
						if(strlen(PlayerGeoIPInfo[playerid][pCountry]) > 1)
						{
							format(szQuery, sizeof(szQuery),
							"UPDATE Accounts SET Lastip = '%s', Lastlogin = '%s', \
							Lastcountry = '%s', Lastcity = '%s' WHERE (Nickname = '%q')",
							ip, lastlogin,
							PlayerGeoIPInfo[playerid][pCountry],
							PlayerGeoIPInfo[playerid][pCity],
							db_escape(PlayerNickName));
						} else {
							format(szQuery, sizeof(szQuery),
							"UPDATE Accounts SET Lastip = '%s', Lastlogin = '%s' \
							WHERE (Nickname = '%q')", ip, lastlogin, db_escape(PlayerNickName));
						}
						query = db_query(dbaccounts, szQuery);
						db_free_result(query);
						
						if(pData[playerid][pBanned] > 0)
						{
							if(fexist("core.db"))
							{
								new banquery[128];
								format(banquery, sizeof(banquery),
								"SELECT Date, Reason FROM Banlist WHERE Nickname = '%q' LIMIT 1",
								db_escape(PlayerNickName));
								query = db_query(dbcore, banquery);
								if(db_num_rows(query))
								{
									new date[22], reason[48], tmpstr[128];
									db_get_field(query, 0, date, sizeof(date));
									db_get_field(query, 1, reason, sizeof(reason));
									db_free_result(query);
									
									if(strlen(reason))
									{
										format(tmpstr, sizeof(tmpstr),
										"Account was banned %s (reason: %s)", date, reason);
										KickPlayerEx(playerid, tmpstr);	
									}
									else KickPlayerEx(playerid, "Account banned");
								} else {
									KickPlayerEx(playerid, "Account banned");
								}
							}
						}
						
						SetPVarInt(playerid, "Logged", 1);
						SetPVarInt(playerid, "Admin", pData[playerid][pAdmin]);
						SetPlayerWeather(playerid, pData[playerid][pWeather]); 
						SetPlayerTime(playerid,pData[playerid][pHour],0);
						
						#if defined _INC_WEAPON_CONFIG
						if(pData[playerid][pDmgInformer] > 0) {
							SetDamageFeedForPlayer(playerid, 1);
						} 
						else SetDamageFeedForPlayer(playerid, -1);
						#endif
						
						KillTimer(NoLogin_Timer[playerid]);

						#if defined _nex_ac_included
						if(GetPVarInt(playerid, "Admin") >= 3)
						{
							// Disable dialog spoofing check
							EnableAntiCheatForPlayer(playerid, 39, false);
						}
						#endif

						if(GetPVarInt(playerid, "Admin") > 0 && strcmp(PlayerNickName, "1NS", true))
						{
							format(stringen, sizeof(stringen), "%s(%d) has logged in as Admin! (Level:%i)", PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
							format(stringru, sizeof(stringru), "%s(%d) вошел на сервер как Администратор! (Уровень:%i)", PlayerName(playerid), playerid, GetPVarInt(playerid, "Admin"));
							SendClientMessageToAllEx(COLOR_GREY, stringru, stringen);
						}
						//ShowWelcomeMessage(playerid);
						//SetTimerEx("SetSkin", 1000, false, "i", playerid);
					} else {
						PlayerPlaySound(playerid, 1135, 0, 0, 0);
						SetPVarInt(playerid, "LoginAttempts", GetPVarInt(playerid, "LoginAttempts") + 1);
						
						format(stringen, sizeof(stringen),
						"Wrong password! Check CAPSLOCK and keyboard layout (attempts left: %i)",
						MAX_LOGIN_ATTEMPTS-GetPVarInt(playerid, "LoginAttempts"));
						format(stringru, sizeof(stringru),
						"Неверный пароль! Проверьте CAPSLOCK и раскладку. (осталось попыток: %i)",
						MAX_LOGIN_ATTEMPTS-GetPVarInt(playerid, "LoginAttempts"));
						SendClientMessageEx(playerid, COLOR_GREY, stringru, stringen);
						
						
						if(GetPVarInt(playerid, "LoginAttempts") == MAX_LOGIN_ATTEMPTS)	{
							SendClientMessageEx(playerid, COLOR_GREY,
							"Вы можете обратиться в Дискорд к старшей администрации если возникли проблемы с авторизацией",
							"You can contact Discord to the senior administration if you have problems with authorization");
							SetTimerEx("KickWithDelay", 250, 0, "d", playerid);
						}
						LoginDialog(playerid);
					}
				} else {
					RegisterDialog(playerid);
				}
			}
		}
        else LoginDialog(playerid);
	}
	if (dialogid == 4) // team select
	{
		if (response)
		{
			if(GetPVarInt(playerid, "Logged") < 1)
			{
				LoginDialog(playerid);
				return false;
			}
		    if (!LockedTeams)
		    {
          		SetPVarInt(playerid, "Team", listitem);
				switch(listitem)
				{
					case 0:	SetPlayerTeamEx(playerid, TEAM_GREEN);
					case 1:	SetPlayerTeamEx(playerid, TEAM_BLUE);
					case 2: 
					{
						SetPlayerTeamEx(playerid, TEAM_SPEC);
						SetMarkersForPlayer(playerid);
						
						if(speconly)
						{
							new team = GetPVarInt(playerid, "Team");
							SetSpawnInfo(playerid, 0, GetPlayerSkin(playerid),
							CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
							0, 0, 0, 0, 0, 0, 0); // 0.3d R2 bugfix, SpawnPlayer()
							new first_active_playerid = GetActivePlayerid(GetPlayerVirtualWorld(playerid));
							if(first_active_playerid != -1) {
								CheckSpec(playerid);
								Spectate(playerid, first_active_playerid);
								PlayerTextDrawShow(playerid, TDlagmode[playerid]);
								TextDrawShowForPlayer(playerid, TD[playerid]);
								SetTimerEx("Specfunc", 300, false, "ii",
								playerid, first_active_playerid);
							} else {
								//SpawnPlayer(playerid);
								//FlyMode(playerid);
								SetTimerEx("FlyMode", 300, false, "i", playerid);
							}
							if (frz) GameTextForPlayer(playerid, "~w~Game~n~ ~r~paused", 3000, 5);
						}
					}
				}
			}else{
			    if (listitem < 2)
			    {
			    	SendClientMessageEx(playerid, COLOR_GREY,
					"Вы не можете присоединиться к команде во время матча.",
					 "Joining teams is locked right now.");
				}
                SetPlayerTeamEx(playerid, TEAM_SPEC);
				SetMarkersForPlayer(playerid);
			}
		}
		if(pData[playerid][pFpsbar] > 0) PlayerTextDrawShow(playerid, FPSBAR[playerid]);
		if(pData[playerid][pHpbar] > 0)
		{
			PlayerTextDrawShow(playerid, PlayerHp[playerid]);
			PlayerTextDrawShow(playerid, PlayerArmour[playerid]);
		}
		
		SendNotify(playerid,
		"Press ~g~<N>~w~ to open account settings~n~Type ~g~/cmds~w~ to show available commands", 10);
		
		new team = GetPVarInt(playerid, "Team");
		SetSpawnInfo(playerid, 0, GetPlayerSkin(playerid), CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2],
		0, 0, 0, 0, 0, 0, 0); // 0.3d R2 bugfix, SpawnPlayer()
		ReSpawnPlayer(playerid);
		return true;
	}
	if (dialogid == 5) //netstats
	{
	    if (response)
		{
			new string[401];
		    if (GetPVarInt(playerid, "netstats") == -1)
	  		{
	            GetNetworkStats(string, sizeof(string));
	            if (pData[playerid][pLang] == 0)
				{
					ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX,
					"Server's network stats.", string, "Обновить", "Скрыть");
				}
				else if (pData[playerid][pLang] == 1)
				{
				    ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX,
					"Server's network stats.", string, "Refresh", "Hide");
				}
				return true;
	  		}
	  		if (IsPlayerConnected(GetPVarInt(playerid, "netstats")))
	  		{
	  		    GetPlayerNetworkStats(GetPVarInt(playerid, "netstats"), string, sizeof(string));
	  		    new name[MAX_PLAYER_NAME];
				GetPlayerName(GetPVarInt(playerid, "netstats"), name, sizeof(name));
				new string1[47];
				if (pData[playerid][pLang] == 0)
				{
				    format(string1, sizeof(string1), "Network stats of %s(%d).", name, GetPVarInt(playerid, "netstats"));
					ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX, string1, string, "Обновить", "Скрыть");
				}
				else if (pData[playerid][pLang] == 1)
				{
					format(string1, sizeof(string1), "Network stats of %s(%d).", name, GetPVarInt(playerid, "netstats"));
				    ShowPlayerDialog(playerid, 5, DIALOG_STYLE_MSGBOX, string1, string, "Refresh", "Hide");
				}
	  		    return true;
	  		}
		}
		return true;
	}
	if (dialogid == 6) // lang change
	{
		if(response)
		{
			switch(listitem)
			{
				case 0:
				{
					pData[playerid][pLang] = 1;
					SendClientMessage(playerid, COLOR_GREY, "Your language has been set to English");
				}
				case 1:
				{
					pData[playerid][pLang] = 0;
					SendClientMessage(playerid, COLOR_GREY, "Выбран русский язык.");
				}
				default: pData[playerid][pLang] = 1;
			}
		}
	}
	if (dialogid == 7)// playerstat
	{
		if(response) PlayerStatistics(ChosenPlayer[playerid], playerid);
	}
	//if (dialogid == 8) //empty
	if(dialogid == 9)// /skin
    {
        if(response)
        {
            new skinid = strval(inputtext);
			new worldid = GetPlayerVirtualWorld(playerid);
            if(skinid < 0 || skinid >= 300 || skinid == 74)
            {
                return SendClientMessageEx(playerid, COLOR_GREY, "Ошибка: Выберите скин в диапазоне 0-299", "Error: Choose a skin ID between 0 and 299.");
            }
			if(pData[playerid][pAttachSlot0] == 600)
			{
				return SendClientMessageEx(playerid, COLOR_GREY,
				"Это действие вам запрещено администрацией",
				"The action was forbidden to you by the administration");
			}
			if(GetPlayerAnimationIndex(playerid) == 1274 || GetPlayerAnimationIndex(playerid) == 1159)
			{
				ApplyAnimation(playerid,"PLAYIDLES","stretch",4.0,0,0,0,0,0);
			}
            else
            {
				if (IsPlayerInAnyVehicle(playerid))
				{
					return SendClientMessage(playerid, COLOR_GREY, "Exit from vehicle!");
				}
				if(!World[worldid][wBagoskins] || worldid == 0)
				{
					switch(skinid)
					{
						case 0,1,2,74,86,92,99,149,265,266,267,268,269,270,271,272:
						{
							return SendClientMessageEx(playerid, COLOR_GREY,
							"Этот скин запрещен!", "This skin is forbidden!");
						}
					}
				}
				new oldskinid = GetPlayerSkin(playerid);
				new string[128];
				if (pData[playerid][pLang] == 1) {
					format(string, sizeof(string), "{afafaf}New skin id: {008000}%i{afafaf}, old skin id: {008000}%i{ffffff}", skinid, oldskinid);
				} else {
					format(string, sizeof(string), "{afafaf}№ нового скина: {008000}%i{afafaf}, № предыдущего скина: {008000}%i{ffffff}", skinid, oldskinid);
				}
				SendClientMessage(playerid, COLOR_GREY, string);
                SetPlayerSkin(playerid, skinid);
				new team = GetPVarInt(playerid, "Team");
				SetSpawnInfo(playerid, 0, GetPlayerSkin(playerid),
				CwMaps[Map][team][0], CwMaps[Map][team][1], CwMaps[Map][team][2], 0, 0, 0, 0, 0, 0, 0);
            }
        } else {
			if(LAST_DIALOG[playerid] == 19) SETTINGS_MENU(playerid);
		}
    }
