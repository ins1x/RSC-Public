					pData[ChosenPlayer[playerid]][pAttachSlot3],
					db_escape(PlayerName(ChosenPlayer[playerid])));
					db_query(dbaccounts, szQuery);
					
					
					format(stringen, sizeof(stringen), "%s(%d) has removed all attaches %s(%d).",
