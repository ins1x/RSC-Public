		"Аттаковать ближайшего игрока\t\n"\
		"Создать группу ботов\t\n"\
		"Актеры\t\n"\
		"\t\n"\
		"{00FF00}Добавить бота\n"\
		"{FFFFFF}Список ботов\n"\
		"{FF0000}Удалить ботов\n"\
		"Информация\n",
		botskin, 
		World[worldid][wBotHealth],
		WeaponNamesEN[World[worldid][wBotWeaponid]],
		action, damageset, movetype,
		(World[worldid][wBotType]) ? ("[Динамический]") : ("[Статический]"));
		
		ShowPlayerDialog(playerid, 333, DIALOG_STYLE_TABLIST,
		header, tbtext, "Ok", "Cancel");
	}
	#else
		ShowPlayerDialog(playerid, 333, DIALOG_STYLE_TABLIST,
		"Error", "NPC plugin deactivated", "Ok", "Cancel");
	#endif
	return 1;
}

