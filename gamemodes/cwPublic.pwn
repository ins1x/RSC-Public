			}*/
			/*
			if (GetPVarInt(ChosenPlayer[playerid], "Admin") > GetPVarInt(playerid, "Admin")) 
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Вы не можете сменить команду администратору выше уровня",
				"You cannot change team to admin above level");
				return true;
			}*/
			if (GetPlayerSpecialAction(ChosenPlayer[playerid]) == SPECIAL_ACTION_USEJETPACK)
			{
				new Float: x, Float: y, Float: z;
				GetPlayerPos(ChosenPlayer[playerid], x, y, z);
				SetPlayerPos(ChosenPlayer[playerid], x, y, z);
			}
			if (GetPVarInt(ChosenPlayer[playerid], "Team") == 2)
			{
				if (GetPVarInt(ChosenPlayer[playerid], "Specing") > -1)
				{
					SpecOff(ChosenPlayer[playerid]);
				}
				else if (!frz)
				{
					RestorePlayerWeapons(ChosenPlayer[playerid]);
				}
				ResetPlayerWeapons(ChosenPlayer[playerid]);
			}
			if (frz)
			{
				TogglePlayerControllable(ChosenPlayer[playerid], false);
				SetPVarInt(ChosenPlayer[playerid], "frz", true);
				GiveDefaultWeapons(ChosenPlayer[playerid]);
			}
			switch(listitem)
			{
				case 0:
				{
		 		    SetPVarInt(ChosenPlayer[playerid], "Team", 0);
					SetPlayerTeamEx(ChosenPlayer[playerid], TEAM_GREEN);
					format(string, sizeof(string), "%s(%d) переместил игрока %s(%d) в команду %s.", PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid], ClanName[0]);
					format(stringen, sizeof(stringen), "%s(%d) has moved player %s(%d) to %s team.", PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid], ClanName[0]);
					SendClientMessageToAllEx(COLOR_GREY, string, stringen);
				}
				case 1:
				{
					SetPVarInt(ChosenPlayer[playerid], "Team", 1);
					SetPlayerTeamEx(ChosenPlayer[playerid], TEAM_BLUE);
					format(string, sizeof(string), "%s(%d) переместил игрока %s(%d) в команду %s.", PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid], ClanName[1]);
					format(stringen, sizeof(stringen), "%s(%d) has moved player %s(%d) to %s team.", PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid], ClanName[1]);
					SendClientMessageToAllEx(COLOR_GREY, string, stringen);
				}
				case 2:
				{
					SetPVarInt(ChosenPlayer[playerid], "Team", 2);
					SetPlayerTeamEx(ChosenPlayer[playerid], TEAM_SPEC);
					format(string, sizeof(string), "%s(%d) переместил игрока %s(%d) в команду наблюдателей", PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					format(stringen, sizeof(stringen), "%s(%d) has moved player %s(%d) to Spectator team.", PlayerName(playerid), playerid, PlayerName(ChosenPlayer[playerid]), ChosenPlayer[playerid]);
					SendClientMessageToAllEx(COLOR_GREY, string, stringen);
				}
			}
			ReSpawnPlayer(ChosenPlayer[playerid]);
			TEAMS_MENU(playerid);
			return true;
		}
		else ROUNDSET_MENU(playerid);
	}
