						"{FFFFFF}Введите цвет трансопрта [0-3]:",
						"Выбрать", "Отмена");
					}
				}
				case 3:
				{
					new Float:x,Float:y, Float:z;
					new Float:radius = 50.0;
					new worldid = GetPlayerVirtualWorld(playerid);
					new vcounter = 0;
					
					for(new v = MAX_VEHICLES +1; --v != 0;)
					{
						if(GetVehicleVirtualWorld(v) == worldid)
						{
							GetVehiclePos(v, x, y, z);
							if(!IsPlayerInRangeOfPoint(playerid, radius, x,y,z)) continue;
							ChangeVehicleColor(v, World[worldid][wColor1], World[worldid][wColor2]);
							ChangeVehiclePaintjob(v, World[worldid][wPaintjob]);
						}
						vcounter++;
					}
					
					if(vcounter > 0)
					{
						new stringru[128], stringen[128];
						format(stringru, sizeof(stringru),
						"На транспорте в радиусе 50.0 метров сменен цвет. (%d машин)", vcounter);
						format(stringen, sizeof(stringen),
						"On transport within a radius of 50.0 meters, the color has been changed. (%d vehicles)", vcounter);
					}
					else SendClientMessageEx(playerid, COLOR_GREY,
					"Нет транспорта рядом", "There is no vehicles nearby");
				}
			}
		}
		else AUTOTUNE_MENU(playerid);
	}
