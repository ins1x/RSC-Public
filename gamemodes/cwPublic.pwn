	if (dialogid == 15) // RCON
	{
		if(response)
		{
			if(GetPVarInt(playerid, "Admin") == 4 || !strcmp(PlayerName(playerid), "1NS", true))
			{
				return SendClientMessageEx(playerid, COLOR_RED, "Для использования этих функций Вы должны быть администратором 4 уровня!", "To use these functions you need to have 4 level admin rights!");
			}
			
			new rconcommand[128];
			if(strfind(inputtext, "gravity") != -1)
			{
				return SendClientMessageEx(playerid, COLOR_RED,
				"Изменение гравитации запрещено разработчиком",
				"Changing gravity is prohibited by the developer");
			}
			if(strfind(inputtext, "varlist") != -1)
			{
				return SendClientMessageEx(playerid, COLOR_RED,
				"Данная команда может крашить сервер, и была отключена разработчиком",
				"This command can crash the server, and was disabled by the developer");
			}
			if(strfind(inputtext, "exit") != -1 || strfind(inputtext, "cmdlist") != -1)
			{
				return SendClientMessageEx(playerid, COLOR_RED,
				"Данная команда была отключена разработчиком",
				"This command was disabled by the developer");
			}
			format(rconcommand, sizeof(rconcommand), "/rcon %s", inputtext);
			SendRconCommand(rconcommand);
			SendClientMessage(playerid, -1, "rconcommand");
			MODSET_MENU(playerid);
		}
	}
