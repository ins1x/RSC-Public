			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Недоступно в режиме стримера", "Not available in streamer mode");
				return true;
			}
			if (strlen(tmp) == 0 || strval(tmp) == INVALID_PLAYER_ID){
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /hwid [ID]", "Use: /hwid [ID]");
				return true;
			}
			if(!IsPlayerConnected(strval(tmp)))
			{
				SendClientMessageEx(playerid, COLOR_GREY,
				"Использование: /hwid [ID]", "Use: /hwid [ID]");
