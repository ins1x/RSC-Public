				"Set country", "{FFFFFF}Enter the country of the clan:\n","Set", "Cancel");
				case 3: ShowPlayerDialog(playerid, 386, DIALOG_STYLE_INPUT,
				"Set leader", "{FFFFFF}Enter the clan leader nickname\n","Set", "Cancel");
				case 4: ShowPlayerDialog(playerid, 387, DIALOG_STYLE_INPUT,
				"Set year", "{FFFFFF}Enter the date the clan was founded\n","Set", "Cancel");
				case 5: ShowPlayerDialog(playerid, 388, DIALOG_STYLE_INPUT,
				"Set webpage", "{FFFFFF}Enter the clans website or discord\n","Set", "Cancel");
				case 6: CLANADD_MENU(playerid);
				case 7:
				{
					new clanname[32], country[32], year[12], clantag[12], clanleader[32], webpage[32];
	
					GetPVarString(playerid, "editclanname", clanname, sizeof(clanname));
					GetPVarString(playerid, "editclancountry", country, sizeof(country));
					GetPVarString(playerid, "editclanyear", year, sizeof(year));
					GetPVarString(playerid, "editclantag", clantag, sizeof(clantag));
					GetPVarString(playerid, "editclanleader", clanleader, sizeof(clanleader));
					GetPVarString(playerid, "editclanwebpage", webpage, sizeof(webpage));
	
					new szQuery[256];
					format(szQuery, sizeof(szQuery),
					"INSERT INTO ClanList (Clanname, Country, Tag, Leader, Webpage, Year)\
					VALUES ('%q', '%q', '%q', '%q', '%q', '%q')", 
					clanname, country, clantag, clanleader, webpage, year);
					db_query(dbcore, szQuery);
					
					new string[128];
					format(string, sizeof(string), "%s(%d) add clan %s %s to clanlist",
					PlayerName(playerid), playerid, clanname, clantag);
					SendSystemMessage(string);
					AdminActionsLog(string);
			
					SendClientMessageEx(playerid, COLOR_GREY,
					"Клан был добавлен в список", "The clan has been added to the list");
				}
				case 8:
				{
					DeletePVar(playerid, "editclanname");
					DeletePVar(playerid, "editclancountry");
					DeletePVar(playerid, "editclanyear");
					DeletePVar(playerid, "editclantag");
					DeletePVar(playerid, "editclanleader");
					DeletePVar(playerid, "editclanwebpage");
				}
			}
		}
