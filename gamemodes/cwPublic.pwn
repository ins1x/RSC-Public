stock WORLD_MODE(playerid)
{
	new tbtext[512], tmpstr[128];
	
	for(new worldmode=0; worldmode < sizeof(WorldModes); worldmode++)
	{
		if((worldmode % 2) == 0) format(tmpstr, sizeof(tmpstr), "{A9A9A9}%s\n", WorldModes[worldmode]);
		else format(tmpstr, sizeof(tmpstr), "%s\n", WorldModes[worldmode]);
		strcat(tbtext, tmpstr);
	}
	
	ShowPlayerDialog(playerid, 308, DIALOG_STYLE_LIST,
	".:: World gamemode ::.", tbtext, "Select", "Cancel");
	
	SetPlayerChatBubble(playerid, "..opens world settings..", COLOR_GREY, 50.0, 5000);
	return 1;
}

stock WORLD_MANAGE(playerid)
{
	new tbtext[1024];
	new slot = GetPlayerVirtualWorld(playerid);
	
	new worldmode[24];
	format(worldmode, sizeof(worldmode), "%s", WorldModes[World[slot][wGamemode]]);
	
	new worldname[24];
	if(strlen(World[slot][wName])) {
		format(worldname, sizeof(worldname), "{00FF00}[%s]",World[slot][wName]);
	}
	else format(worldname, sizeof(worldname), "[%s]",
	(pData[playerid][pLang]) ? ("Not changed") : ("Стандартное"));
	
	if(pData[playerid][pLang])
	{
		format(tbtext, sizeof(tbtext),
		"Gamemode\t {AFAFAF}%s\n\
		Entrance to the world\t %s\n\
		Use vehicles\t %s\n\
		Use weapons\t %s\n\
		Use teleports\t %s\n\
		Use greenzone\t %s\n\
		Markers on radar\t %s\n\
		Map on radar\t %s\n\
		Heal after kill\t %s\n\
		Fix vehicles\t %s\n\
		Spawn point\t {AFAFAF}%s\n\
		Cbug and slide \t %s\n\
		CJ run \t %s\n\
		Default skin set\t %s\n\
		Health\t {AFAFAF}%d\n\
		Map\t {AFAFAF}%s\n\
		Time\t {AFAFAF}%d\n\
		Weather\t {AFAFAF}%d\n\
		World name\t {AFAFAF}%s\n\
		Anticheat\t %s\n\
		{FF0000}Grant moderator rights\t\n",
		worldmode, 
		(World[slot][wLocked]) ? ("{FF0000}[Locked]") : ("{00FF00}[Open]"),
		(World[slot][wVehicles]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[slot][wWeapons]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[slot][wTeleports]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[slot][wGreenZone]) ? ("{00FF00}[Enabled]") : ("{FF0000}[Disabled]"),
		(!World[slot][wMarkers]) ? ("{00FF00}[Shown]") : ("{FF0000}[Hidden]"),
		(World[slot][wMapRadar]) ? ("{00FF00}[Shown]") : ("{FF0000}[Hidden]"),
		(World[slot][wKillheal]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[slot][wVehicleFix]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[slot][wSpawnPoint]) ? ("{00FF00}[Custom]") : ("{00FF00}[Default]"),
		(World[slot][wCbug]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[slot][wCJrun]) ? ("{00FF00}[Allowed]") : ("{FF0000}[Forbidden]"),
		(World[slot][wSkin]) ? ("{00FF00}[Active]") : ("{FF0000}[Disabled]"),
		World[slot][wGamehealth],
		MapNames[World[slot][wMap]],
		World[slot][wTime], World[slot][wWeather],
		worldname,
		(World[slot][wAnticheat]) ? ("{00FF00}[Enabled]") : ("{FF0000}[Disabled]")
		);
	
		ShowPlayerDialog(playerid, 301, DIALOG_STYLE_TABLIST,
		".:: Manage world ::.", tbtext, "Select", "Cancel");
	} else {
		format(tbtext, sizeof(tbtext),
		"Режим\t {AFAFAF}%s\n\
		Вход в мир\t %s\n\
		Использовать транспорт\t %s\n\
		Использовать оружие\t %s\n\
		Использовать телепорт\t %s\n\
		Зеленая зона\t %s\n\
		Маркеры на радаре\t %s\n\
		Отображение карты на радаре\t %s\n\
		Лечение после убийства\t %s\n\
		Починка транспорта\t %s\n\
		Точка появления\t {AFAFAF}%s\n\
		Cbug и слайды\t %s\n\
		Бег сиджея\t %s\n\
		Скин по-умолчанию \t %s\n\
		Здоровье\t {AFAFAF}%d\n\
		Карта\t {AFAFAF}%s\n\
		Время\t {AFAFAF}%d\n\
		Погода\t {AFAFAF}%d\n\
		Название мира\t {AFAFAF}%s\n\
		Античит\t %s\n\
		{FF0000}Выдать права модератора\t\n",
		worldmode,
		(World[slot][wLocked]) ? ("{FF0000}[Закрыт]") : ("{00FF00}[Открыт]"),
		(World[slot][wVehicles]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		(World[slot][wWeapons]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		(World[slot][wTeleports]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		(World[slot][wGreenZone]) ? ("{00FF00}[Включена]") : ("{FF0000}[Отключена]"),
		(!World[slot][wMarkers]) ? ("{00FF00}[Показаны]") : ("{FF0000}[Скрыты]"),
		(World[slot][wMapRadar]) ? ("{00FF00}[Показана]") : ("{FF0000}[Скрыта]"),
		(World[slot][wKillheal]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		(World[slot][wVehicleFix]) ? ("{00FF00}[Разрешено]") : ("{FF0000}[Запрещено]"),
		(World[slot][wSpawnPoint]) ? ("{00FF00}[Своя]") : ("{00FF00}[Стандартная]"),
		(World[slot][wCbug])  ? ("{00FF00}[Разрешен]") : ("{FF0000}[Запрещен]"),
		(World[slot][wCJrun]) ? ("{00FF00}[Разрешен]") : ("{FF0000}[Запрещен]"),
		(World[slot][wSkin]) ? ("{00FF00}[Используется]") : ("{FF0000}[Отключено]"),
		World[slot][wGamehealth],
		MapNames[World[slot][wMap]],
		World[slot][wTime], World[slot][wWeather],
		worldname,
		(World[slot][wAnticheat]) ? ("{00FF00}[Включен]") : ("{FF0000}[Отключен]")
		);
		
		ShowPlayerDialog(playerid, 301, DIALOG_STYLE_TABLIST,
		".:: Управление миром ::.", tbtext, "Выбрать", "Отменить");
	}
	SetPlayerChatBubble(playerid, "..opens world settings..", COLOR_GREY, 50.0, 5000);
	return 1;
}

