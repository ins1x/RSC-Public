main() { print("RSC CW/TG mode by Russian Sawn-off Community"); }

public OnGameModeInit()
{
	#if defined PROFILER_PROFILER_INC
	Profiler_Start();
	#endif
	
    new AntiDeAMX[][] = {"OnGameModeInit (0)", "CW/TG mode"};
	#pragma unused AntiDeAMX
	new AntiDeAMX2[258] =
	{
        0x02, 0x01, 0x00, 0x00, 0xE0, 0xF1, 0x08, 0x08, 0x04, 0x00, 0x08, 0x00, 0xA8, 0x00, 0x00, 0x00,
