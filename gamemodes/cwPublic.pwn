	}
	
	if(World[worldid][wGamemode] == GAMEMODE_WOT)
	{
		new Float:WoTRandomSpawn[][5] = { //Warcity
			{1545.2513,1325.0438,10.9974,90.0585},
			{1443.5988,1322.6613,10.9973,92.3780},
			{1409.6022,1276.5363,11.0107,267.4533},
			{1486.5839,1262.9264,11.0368,356.6988},
			{1516.0486,1275.2606,11.0799,87.9241},
			{1417.3835,1353.1895,10.9974,1.5039},
			{1389.8726,1375.5979,11.0899,269.7520},
			{1536.6676,1382.9215,10.9976,105.0108},
			{1522.6357,1455.4204,10.9972,269.0577},
			{1531.2682,1511.8236,10.9982,86.4603},
			{1509.7935,1487.2468,10.9972,179.7321},
			{1526.1416,1471.0447,11.0048,89.9646},
			{1524.4581,1543.6775,10.9970,172.8328},
			{1482.9568,1526.7620,11.1080,182.2657},
			{1448.0594,1530.3257,10.9971,117.8452},
			{1400.2136,1498.5531,11.0302,184.8834},
			{1373.8690,1470.1572,11.0369,271.0292},
			{1451.6145,1343.1096,10.9973,0.6615}
		};
		
		new rand = random(sizeof(WoTRandomSpawn));
		
		if(GetPVarInt(playerid, "Vehicle") != 0) {
			DestroyVehicle(GetPVarInt(playerid, "Vehicle"));
		}
		
		new vehicle = CreateVehicle(432, WoTRandomSpawn[rand][0],
		WoTRandomSpawn[rand][1], WoTRandomSpawn[rand][2], WoTRandomSpawn[rand][3],
		World[worldid][wColor1], World[worldid][wColor2], -1);
		
		SetPVarInt(playerid, "Vehicle", vehicle);
		SetVehicleVirtualWorld(vehicle, GetPlayerVirtualWorld(playerid));
		LinkVehicleToInterior(vehicle, World[worldid][wInterior]);	
		PutPlayerInVehicle(playerid, vehicle, 0);
		//ResetAllPlayerWeaponsEx(playerid);
	}
	
	if(World[worldid][wGamemode] == GAMEMODE_DERBY)
	{
		new Float:RandomSpawn[][5] = { 
			{-2061.2175,-109.1674,35.6955,182.6414},
			{-2072.3269,-108.4042,35.6950,179.5406},
			{-2082.1106,-108.5483,35.6916,181.6209},
			{-2091.1492,-108.3672,35.6916,179.9503},
			{-2053.1885,-108.9269,35.6625,177.2123},
			{-2041.7460,-107.6400,35.5712,178.9534},
			{-2014.9181,-114.7994,35.5625,180.1930},
			{-2015.8956,-273.5818,35.6913,0.0},
			{-2020.8956,-273.5818,35.6913,0.0},
			{-2025.8956,-273.5818,35.6913,0.0},
			{-2035.8956,-273.5818,35.6913,0.0},
			{-2045.8956,-273.5818,35.6913,0.0},
			{-2055.8956,-273.5818,35.6913,0.0},
			{-2065.8956,-273.5818,35.6913,0.0},
			{-2075.8956,-273.5818,35.6913,0.0},
			{-2085.8956,-273.5818,35.6913,0.0},
			{-2090.8411,-273.5818,35.6913,0.0}
		};
		
		new DerbyVehiclesList[] = {
			536, //Blade
			575, //Broadway
			534, //Remington
			567, //Savanna
			535, //Slamvan
			576, //Tornado  
			412, //Voodoo   
			542, //Clover
			603, //Phoenix  
			475, //Sabre
			492, //Greenwood
			466, //Glendale
			604, //Glendale shit
			467, //Oceanic
			566, //Tahoma
			474, //Hermes
			545, //Hustler
			517, //Majestic
			600, //Picador
			439, //Stallion
			491 //Virgo
		};
		
		new rand = random(sizeof(RandomSpawn));
		new randveh = random(sizeof(DerbyVehiclesList));
		
		if(GetPVarInt(playerid, "Vehicle") != 0) {
			DestroyVehicle(GetPVarInt(playerid, "Vehicle"));
		}
		
		//new color1, color2 = -1;
		new vehicle = CreateVehicle(DerbyVehiclesList[randveh],
		RandomSpawn[rand][0], RandomSpawn[rand][1], RandomSpawn[rand][2],
		RandomSpawn[rand][3], -1, -1, -1);
		
		SetPVarInt(playerid, "Vehicle", vehicle);
		AddVehicleComponent(vehicle, 1025); // offroad wheels
		SetVehicleHealth(vehicle, 2000); 
		SetVehicleVirtualWorld(vehicle, GetPlayerVirtualWorld(playerid));
		LinkVehicleToInterior(vehicle, World[worldid][wInterior]);	
		PutPlayerInVehicle(playerid, vehicle, 0);
		//ResetAllPlayerWeaponsEx(playerid);
	}
	
	/*if(World[worldid][wGamemode] == GAMEMODE_FLAGGAME)
	{
		// Give grenade at Flaggame mode
		GivePlayerWeapon(playerid, 16, 1);
	} */
	
	if(World[worldid][wGamemode] == GAMEMODE_PVP)
	{
		Countdown(3, GetPlayerVirtualWorld(playerid));
	}
		
	if(worldid != 0 && World[worldid][wVehicleDefaultModel])
	{
		if(GetPVarInt(playerid, "Vehicle") != 0) {
			DestroyVehicle(GetPVarInt(playerid, "Vehicle"));
		}
		
		new vehicle = CreateVehicle(World[worldid][wVehicleDefaultModel],
		World[worldid][wSpawnX], World[worldid][wSpawnY], World[worldid][wSpawnZ],
		World[worldid][wSpawnA], -1, -1, -1);
		
		SetPVarInt(playerid, "Vehicle", vehicle);
		SetVehicleVirtualWorld(vehicle, worldid);
		LinkVehicleToInterior(vehicle, World[worldid][wInterior]);	
		PutPlayerInVehicle(playerid, vehicle, 0);
	}
	
	if(worldid != 0 && World[worldid][wFreezeOnSpawn])
	{
		TogglePlayerControllable(playerid, false);
		SetPVarInt(playerid, "frz", true);
		SendClientMessageEx(playerid, COLOR_GREY,
		"Вы получите оружие через 3 секунды после старта.",
		"You will receive weapons 3 seconds after start.");
		//GameTextForPlayer(playerid, "~w~Game~n~ ~r~paused", 3000, 5);
	}
	
	if(worldid != 0 && World[worldid][wOffCollision])
	{
		// 1 to disable collisions, 0 to enable collisions.
		SetPVarInt(playerid, "vehCollision", 0);
		DisableRemoteVehicleCollisions(playerid, GetPVarInt(playerid, "vehCollision"));
	}
	
	if(worldid != 0 && World[worldid][wTime] != 12) {
		SetPlayerTime(playerid, World[worldid][wTime], 0);
	}
	if(worldid != 0 && World[worldid][wWeather] != 1) {
		SetPlayerWeather(playerid, World[worldid][wWeather]);
	}
	
	// Sets which weapon (that a player already has) the player is holding. 
	// Default set sawn-off or weapon which was selected through /weaponmenu
	if(worldid != 0 && World[worldid][wWeapons])
	{
		if(SelectedWeapon > 0 && SelectedWeapon <= 46) {
			SetPlayerArmedWeapon(playerid, SelectedWeapon); 
		}
	} else if(worldid == 0 && SelectedWeapon > 0 && SelectedWeapon <= 46) {	
		SetPlayerArmedWeapon(playerid, SelectedWeapon);
	}
	
	if(SPAWN_PROTECT) Spawnkill(playerid);
	
	if(GetPVarInt(playerid, "agm") > 0)//agm
	{
		SetPlayerHealth(playerid, 99999);
		if(GameHealth > 100) SetPlayerArmour(playerid, 99999);
	}
	
	if(GetPlayerVirtualWorld(playerid) == 0)
	{
		if (GetPVarInt(playerid, "frz"))
		{
			TogglePlayerControllable(playerid, false);
			GameTextForPlayer(playerid, "~w~Game~n~ ~r~paused", 3000, 5);
		}
		else if (frz)
		{
			if (team < 2)
			{
				TogglePlayerControllable(playerid, false);
				SetPVarInt(playerid, "frz", true);
				GameTextForPlayer(playerid, "~w~Game~n~ ~r~paused", 3000, 5);
			}
		}
	}
	// Fast Respawn anti-cheat
	if(AC_FAST_RESPAWN)
	{	
		// AC Author: Twixxx a.k.a Twixyck
		// RSC improved version
		player_call_spawn_count[playerid]++;
		already_spawned_time[playerid] = GetTickCount() - player_spawn_time[playerid];
		
		if(GetPlayerVirtualWorld(playerid) == 0 && already_spawned_time[playerid] < 2000)
		{
			if(player_call_spawn_count[playerid] == 2)
			{
				if (GetPVarInt(playerid, "AC_FASTRESPAWN") > 1) 
                {
                    new string[64];
                    format(string, sizeof(string), "%s(%d) fast respawn bug",
                    PlayerName(playerid), playerid);
                    SendSystemMessage(string);
                }
				player_spawn_time[playerid] = 0;
				already_spawned_time[playerid] = 0;
				player_call_spawn_count[playerid] = 0;
				SetPVarInt(playerid, "AC_FASTRESPAWN", GetPVarInt(playerid, "AC_FASTRESPAWN") + 1);
				if(GetPVarInt(playerid, "AC_FASTRESPAWN") == 3) KickPlayerEx(playerid, "fast respawn");
			}
			else return 1;
		}
		else
		{
			player_spawn_time[playerid] = 0;
			already_spawned_time[playerid] = 0;
			player_call_spawn_count[playerid] = 0;
		}
		return 1;
	}
	
	#if defined _YSF_included
	// invis mode (for player, not for markers)
	if(GetPVarInt(playerid, "Invis") > 0)
	{
		TogglePlayerGhostMode(playerid, true);
		// hide marker
		//SetPlayerColor(playerid, COLOR_GREY);
		foreach(Player, i) {
			//ResetPlayerMarkerForPlayer(playerid, i);
			SetPlayerMarkerForPlayer(i, playerid, 0xFFFFFF00);
			HidePlayerForPlayer(i, playerid);
		}
	}
	#endif
	
	#if defined _sampcac_included
	//ped.ifp checker
	if(GetPVarInt(playerid,"CacModPED") > 0)
	{
		KickPlayerEx(playerid, "SAMPCAC: PED.ifp modded");
	}
	#endif
		
	return true;
}

public OnPlayerDeath(playerid, killerid, reason)
{
	new string[144];
	new Float:x, Float:y, Float:z, Float: health, Float: armour;
	GetPlayerHealth(killerid, health);
	GetPlayerArmour(killerid, armour);
	GetPlayerPos(playerid, x, y, z);
	SetPVarInt(playerid, "PlayerDeathReason", reason);
	SetPVarInt(killerid, "enemybar", -1);
	player_spawn_time[playerid] = GetTickCount(); // Anti Fast Respawn var
	OnFly[playerid] = false;
	
	#if defined _FCNPC_included
	if(IsPlayerNPC(killerid))
	{
		FCNPC_StopAim(killerid);
		FCNPC_StopAttack(killerid);
	}
	#endif
	
	#if !defined _nex_ac_included
	if(killerid != INVALID_PLAYER_ID && FakeKill[playerid] != killerid)
	{
		if(AC_DAMAGEHACKS) return KickPlayerEx(playerid, "Fake Kill");
	}
	#endif
	//firstpersonfix
	if(IsValidObject(firstperson[playerid])) {
		DestroyObject(firstperson[playerid]);
	} 
				
	// Drop assits data
	for(new assist; assist < 3; assist++) {
		KillAssist[playerid][assist] = INVALID_PLAYER_ID;
	}
	
	new worldid = GetPlayerVirtualWorld(playerid);
	if(worldid != 0)
	{
		/* if(World[worldid][wGamemode] == GAMEMODE_FLAGGAME)
		{
			#if defined _streamer_included
			if(GetPVarInt(playerid, "Team") == WORLD_TEAM_RED)
			{
				WorldFlagsRedTeam[worldid] = CreateDynamicPickup(19306, 1,
				x, y, z, World[worldid][wInterior], worldid);
			}
			
			if(GetPVarInt(playerid, "Team") == WORLD_TEAM_BLUE)
			{
				WorldFlagsBlueTeam[worldid] = CreateDynamicPickup(19307, 1, 
				x, y, z, World[worldid][wInterior], worldid);
			}
			#endif
		} */
		if(World[worldid][wGamemode] == GAMEMODE_PVP)
		{
			ResetPlayerWeapons(playerid);
			ResetPlayerWeapons(killerid);
		}
	}
	
    if (killerid != INVALID_PLAYER_ID)
	{
		if(AC_Minigun)
		{
			if(!IsPlayerNPC(killerid) && reason == WEAPON_MINIGUN) 
			{
				BanPlayerEx(killerid, "Minigun abuse"); 
				return 1;
			}
		}
		
		foreach (Player, i)
		{
			if(pData[i][pKillchat] > 0)
			{
				if(reason != 0 && GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(killerid)) 
				{
					// https://ru.powerthesaurus.org/killed/synonyms
					new deathmessage[32];
					switch(reason)
					{
						case WEAPON_KNIFE, WEAPON_SHOVEL, WEAPON_KATANA, WEAPON_CHAINSAW:
						{
							new DeathMessages[][] = {"slashed","sliced","separated","diced",
							"sacrificed", "shredded", "divided","surprised"};
							new rand = random(sizeof(DeathMessages));
							format(deathmessage, sizeof deathmessage, DeathMessages[rand]);
						}
						case WEAPON_GRENADE, WEAPON_TEARGAS, WEAPON_COLLISION, WEAPON_ROCKETLAUNCHER, WEAPON_HEATSEEKER, WEAPON_BOMB, WEAPON_FIREEXTINGUISHER, WEAPON_MOLTOV, WEAPON_FLAMETHROWER:
						{
							new DeathMessages[][] = {"barbecued","atomized","sprayed",
							"pulverized","detonated","grilled","roasted", "slammed"};
							new rand = random(sizeof(DeathMessages));
							format(deathmessage, sizeof deathmessage, DeathMessages[rand]);
						}	
						default:
						{
							new DeathMessages[][] = {"killed","pawned","busted","smashed",
							"obliterated","butchered","massacred","beat down","hammered",
							"smashed","farmed","drilled","terminated","pumped","annihilated",
							"terminated","drilled","shelled","perforated","destroyed",
							"liquidated","demolished","executed","slaughtered"};
							new rand = random(sizeof(DeathMessages));
							format(deathmessage, sizeof deathmessage, DeathMessages[rand]);
						}
					}
					format(string, sizeof(string),
					"%s[%d] %s %s[%d] with %s | hp:%.1f armour:%.1f (distance %.1f m)",
					PlayerName(killerid), killerid, deathmessage, PlayerName(playerid), playerid,
					WeaponNamesEN[reason], health, armour,
					GetDistanceBetweenPlayers(killerid, playerid));
					
					// send message
					if(strlen(string) > 0) {
						if(GetPVarInt(killerid, "Team") == 0) SendClientMessage(i,TCC[0], string);
						else if(GetPVarInt(killerid, "Team") == 1) SendClientMessage(i,TCC[1], string);
					}
					
					// untested killassist
					/*
					for(new assist; assist < 3; assist++)
					{
						if(KillAssist[playerid][assist] == killerid)
						{
							KillAssist[playerid][assist] = INVALID_PLAYER_ID;
						}

						if((KillAssist[playerid][assist]!= INVALID_PLAYER_ID) 
						&& (KillAssist[playerid][assist] != killerid))
						{
							new tmpstr[64]
							format(tmpstr, sizeof(tmpstr), 
							"[kill-assist] You assisted to kill %s(%d)",
							PlayerName(killerid), PlayerName(playerid));
							SendClientMessage(playerid, -1, newStr);

							KillAssist[playerid][assist] = INVALID_PLAYER_ID; // keep this last
						}
					}
					*/
				}
			}
		}
		if (!IsPlayerNPC(killerid) && GetPVarInt(killerid, "Team") == 2)
	    {
	        KickPlayerEx(killerid, "Spectator kill abuse");
	        return true;
	    }
		if (GetPVarInt(playerid, "Team") == 2)
		{
			return true;
		}
		
		GetPlayerName(playerid, string, MAX_PLAYER_NAME);
		format(string, 28, "~w~%s", string);
		PlayerTextDrawSetString(killerid, TDnames[killerid], string);
		PlayerTextDrawShow(killerid, TDnames[killerid]);
		
		if(playerid != INVALID_PLAYER_ID && !IsPlayerNPC(playerid))
		{
			if(GetPVarInt(playerid, "Killstrike") >= 3)
			{
				if(pData[playerid][pSfx]) PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/holyshit_3.mp3");
			}
			else if(GetPVarInt(playerid, "Killstrike") < 3 && GetPVarInt(playerid, "Killstrike") > 0) 
			{
				if(pData[playerid][pSfx]) PlayAudioStreamForPlayer(playerid,
				"https://www.myinstants.com/media/sounds/gta-v-death-sound-effect-102.mp3");
			}
			SetPVarInt(playerid, "Killstrike", 0);
		}
		SetPVarInt(killerid, "Killstrike", GetPVarInt(killerid, "Killstrike") + 1);
		
		if(CWmode && FirstBlood)
		{
			GameTextForPlayer(killerid, "~r~FIRST BLOOD", 1500, 4);
			if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
			"https://www.myinstants.com/media/sounds/firstblood.mp3");
			FirstBlood = false;
		}
		if(reason != 34 && !IsPlayerNPC(playerid))
		{
			if(health == 100.0) 
			{
				GameTextForPlayer(killerid, "FLAWLESS VICTORY", 1500, 4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"http://soundfxcenter.com/video-games/mortal-kombat-3-trilogy/8d82b5_Mortal_Kombat_3_Flawless_Victory_Sound_Effect.mp3");
			}
			else if(health >= 90.0) 
			{
				GameTextForPlayer(killerid, "~w~GOD~r~LIKE", 1500, 4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"https://www.myinstants.com/media/sounds/godlike.mp3");
			}
			else if(health >= 80.0)
			{
				GameTextForPlayer(killerid, "~w~TOTAL ~r~DOMINATION", 1500, 4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"https://www.myinstants.com/media/sounds/dominating_1.mp3");
			}
		}
		
		if(reason == 9 && !IsPlayerNPC(playerid))
		{
			if(health >= 90.0) 
			{
				GameTextForPlayer(killerid, "~r~FRESH MEAT", 1500, 4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"https://www.myinstants.com/media/sounds/butcher_0NJLHCd.mp3");
			}
		}
		
		if(!IsPlayerNPC(playerid))
		{
			if(GetPVarInt(killerid, "Killstrike") == 2)
			{
				GameTextForPlayer(killerid,"~w~DOUBLE ~r~KILL",1500,4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"https://www.myinstants.com/media/sounds/announcer_kill_double_01.mp3");
			}
			if(GetPVarInt(killerid, "Killstrike") == 3) 
			{
				GameTextForPlayer(killerid,"~w~TRIPLE ~r~KILL",1500,4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"https://www.myinstants.com/media/sounds/announcer_kill_triple_01.mp3");
			}
			if(GetPVarInt(killerid, "Killstrike") == 4)
			{
				GameTextForPlayer(killerid,"~y~ULTRA ~r~KILL",1500,4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"https://www.myinstants.com/media/sounds/announcer_kill_ultra_01.mp3");
			}
			if(GetPVarInt(killerid, "Killstrike") == 5) 
			{
				GameTextForPlayer(killerid, "~r~RAM~r~~h~PA~r~~h~~h~GE", 1500, 4);
				if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
				"https://www.myinstants.com/media/sounds/announcer_kill_rampage_01.mp3");
			}
		}
		
		if(GetPlayerVirtualWorld(killerid) != 0)
		{
			if(World[GetPlayerVirtualWorld(killerid)][wKillheal])
			{
				if(World[GetPlayerVirtualWorld(killerid)][wGamehealth] > 100)
				{
					SetPlayerHealth(killerid, 100.0);
					SetPlayerArmour(killerid, World[GetPlayerVirtualWorld(killerid)][wGamehealth] -100);
				} else {
					SetPlayerHealth(killerid, World[GetPlayerVirtualWorld(killerid)][wGamehealth]);
					SetPlayerArmour(killerid, 0.0);
				}
				SetPVarFloat(killerid, "LastHP", 
				World[GetPlayerVirtualWorld(killerid)][wGamehealth] +0.000001);
			}
		} else {
			if (HPDead)
			{
				if(GameHealth > 100)
				{
					SetPlayerHealth(killerid, 100.0);
					SetPlayerArmour(killerid, GameHealth -100);
				} else {
					SetPlayerHealth(killerid, GameHealth);
					SetPlayerArmour(killerid, 0.0);
				}
				SetPVarFloat(killerid, "LastHP", GameHealth +0.000001);
			}
		}
		
		if(GetPlayerVirtualWorld(killerid) != 0)
		{
			Stats[killerid][pKills]++;
			Stats[playerid][pDeath]++;
		}
		
		if (!freeze_score)
		{
			foreach(Player, i) 
			{
				if(GetPlayerVirtualWorld(i) == GetPlayerVirtualWorld(killerid))
				{
					SendDeathMessageToPlayer(i, killerid, playerid, reason);
					//SendDeathMessage(killerid, playerid, reason);
				}
			}
			
			if(GetPlayerVirtualWorld(killerid) == 0)
			{
				SetPVarInt(playerid, "cwdeath", GetPVarInt(playerid, "cwdeath") +1);
				SetPVarInt(killerid, "cwkills", GetPVarInt(killerid, "cwkills") +1);
				if (GetPVarInt(killerid, "Team") == GetPVarInt(playerid, "Team"))
				{	
					SetPVarInt(killerid, "cwteamkills", GetPVarInt(killerid, "cwteamkills") +1);
					new name[MAX_PLAYER_NAME];
					GetPlayerName(killerid, name, sizeof(name));
					new stringen[98];
					if (GetPVarInt(killerid, "Team") == 0)
					{
						format(string, sizeof(string),
						"%s(%d) из команды %s совершил тимкилл! +1 очко команде %s.",
						name, killerid, ClanName[0], ClanName[1]);
						format(stringen, sizeof(stringen),
						"%s(%d) from %s team commited team kill! +1 Point for %s team.",
						name, killerid, ClanName[0], ClanName[1]);
						score[1]++;
						soucet[1]++;
					}else{
						format(string, sizeof(string),
						"%s(%d) из команды %s совершил тимкилл! +1 очко команде %s.",
						name, killerid, ClanName[1], ClanName[0]);
						format(stringen, sizeof(stringen),
						"%s(%d) from %s team commited team kill! +1 Point for %s team.",
						name, killerid, ClanName[1], ClanName[0]);
						score[0]++;
						soucet[0]++;
					}
					if(CWmode) 
					{
						SendClientMessageToAllEx(COLOR_GREY, string, stringen);
						if(pData[killerid][pSfx]) PlayAudioStreamForPlayer(killerid,
						"https://www.myinstants.com/media/sounds/disappointed-crowd-41486.mp3");
					}
				}else{
					score[GetPVarInt(killerid, "Team")]++;
					soucet[GetPVarInt(killerid, "Team")]++;
				}
				RefreshScore();
			}
			SetPlayerScore(killerid, GetPlayerScore(killerid) +1);
		}
	}	
	// Bugged if killer on vehicle 
	/*} else {
		if (GetPVarInt(killerid, "world") == 0 && !freeze_score
		&& GetPVarInt(playerid, "Team") < 2) {
			SendDeathMessage(INVALID_PLAYER_ID, playerid, reason);
		}
		
	} */
	return true;
}

public OnVehicleDeath(vehicleid, killerid)
{
	/*
	vehicleid	The ID of the vehicle that was destroyed.
	killerid	The ID of the player that reported (synced) the vehicle's destruction (name is misleading). Generally the driver or a passenger (if any) or the closest player.
	IMPORTANT: Re-Defined killerid to driverid for better code readability
	*/
	new worldid = GetPlayerVirtualWorld(killerid);
	if(worldid != 0)
    { 
		if(World[worldid][wGamemode] == GAMEMODE_DERBY
		|| World[worldid][wGamemode] == GAMEMODE_WOT)
		{
			new driverid = killerid;
			new playerid = GetClosestPlayer(driverid);
			new playername[MAX_PLAYER_NAME];
			new drivername[MAX_PLAYER_NAME];
			GetPlayerName(playerid, playername, sizeof(playername));
			GetPlayerName(driverid, drivername, sizeof(drivername));
			
			new deathmessage[32];
			new DeathMessages[][] = {"barbecued","atomized","sprayed",
			"pulverized","detonated","grilled","roasted", "slammed"};
			new rand = random(sizeof(DeathMessages));
			format(deathmessage, sizeof deathmessage, DeathMessages[rand]);
			new string[64];
			
			if(playerid != INVALID_PLAYER_ID && playerid != killerid
			&& GetPlayerVirtualWorld(playerid) == GetPlayerVirtualWorld(driverid))
			{
				format(string, sizeof(string),
				"%s[%d] %s %s[%d] (distance %.1f m)",
				playername, playerid, deathmessage, drivername, driverid,
				GetDistanceBetweenPlayers(driverid, playerid));
				SendClientMessageToVirtualWorld(GetPlayerVirtualWorld(driverid), -1, string, string);
			
				SetPlayerScore(playerid, GetPlayerScore(playerid) + 1);
				GameTextForPlayer(playerid, "+1 score", 3000, 3);
				
				foreach(Player, p) 
				{
					if(GetPlayerVirtualWorld(p) == GetPlayerVirtualWorld(driverid))
					{
						SendDeathMessageToPlayer(p, playerid, driverid, 51);
					}
				}
			} else {
                new closestcar = GetClosestCar(driverid);
                if(IsValidVehicle(closestcar))
                {
					foreach(Player, i) 
					{	
						if(GetPlayerState(i) == PLAYER_STATE_DRIVER
						&& GetPlayerVehicleID(i) == closestcar)
						{
							format(string, sizeof(string),
							"%s[%d] %s %s[%d] (distance %.1f m)",
							playername, i, deathmessage, drivername, driverid,
							GetDistanceBetweenPlayers(driverid, i));
							SendClientMessageToVirtualWorld(GetPlayerVirtualWorld(driverid), -1, string, string);
						
							SetPlayerScore(i, GetPlayerScore(i) + 1);
							GameTextForPlayer(i, "+1 score", 3000, 3);
							
							foreach(Player, p) 
							{
								if(GetPlayerVirtualWorld(p) == GetPlayerVirtualWorld(driverid))
								{
									SendDeathMessageToPlayer(p, i, driverid, 51);
								}
							}
							return true;
						}
					}
				}
			}
		}
	}
	return true;
}

stock RefreshScore()
{
	new score_[2][13], i, soucet_[2][13], round_score_[2][13], stats_[6][13], ratio_[2][13], string[512], bool: won;

	if (score[0] < 10)
	{
	    if (score[0] < Roundkills)
	    {
	    	format(score_[0], sizeof(score_[]), "0%d", score[0]);
		}else{
		    format(score_[0], sizeof(score_[]), "0%d", score[0]);
		    Win(0);
		    won = true;
		}
	}else{
	    if (score[0] < Roundkills)
	    {
	    	format(score_[0], sizeof(score_[]), "%d", score[0]);
		}else{
		    format(score_[0], sizeof(score_[]), "%d", score[0]);
		    Win(0);
		    won = true;
		}
	}
	if (score[1] < 10)
	{
	    if (score[1] < Roundkills)
	    {
	    	format(score_[1], sizeof(score_[]), "0%d", score[1]);
		}else{
		    format(score_[1], sizeof(score_[]), "0%d", score[1]);
		    if (!won)
		    {
				Win(1);
			}
		}
	}else{
	    if (score[1] < Roundkills)
	    {
	    	format(score_[1], sizeof(score_[]), "%d", score[1]);
		}else{
		    format(score_[1], sizeof(score_[]), "%d", score[1]);
		    if (!won)
		    {
				Win(1);
			}
		}
	}
	for(i = 0; i < 2; i++)
	{
	    if (soucet[i] < 10)
	    {
	        format(soucet_[i], sizeof(soucet_[]), "0%d", soucet[i]);
	    }else{
	        valstr(soucet_[i], soucet[i]);
	        //format(soucet_[i], sizeof(soucet_[]), "%d", soucet[i]);
		}
	}
	for(i = 0; i < 2; i++)
	{
		if (RoundScore[i] < 10)
		{
		    format(round_score_[i], sizeof(round_score_[]), "0%d", RoundScore[i]);
		}else{
		    valstr(round_score_[i], RoundScore[i]);
		    //format(round_score_[i], sizeof(round_score_[]), "%d", RoundScore[i]);
		}
	}
	format(string, sizeof(string), "mapname (%d) %s:%s (%d)",
	RoundScore[0], soucet_[0], soucet_[1], RoundScore[1]);
	SendRconCommand(string);

	for(new p = 0; p < MAX_PLAYER_ID; p++)
	{
	    if (IsPlayerConnected(p))
	    {
			for(i = 0; i < 3; i++)
			{
			    format(string, 13, "stats%d", i);
				if (GetPVarInt(p, string) < 10)
				{
				    format(stats_[i], sizeof(stats_[]), "0%d", GetPVarInt(p, string));
				}else{
				    valstr(stats_[i], GetPVarInt(p, string));
				    //format(stats_[i], sizeof(stats_[]), "%d", GetPVarInt(p, string));
				}
			}
			if (GetPVarInt(p, "cwdeath") > 0)
			{
			    format(ratio_[0], sizeof(ratio_[]), "%.2f", GetPVarInt(p, "cwkills") /float(GetPVarInt(p, "cwdeath")));
			}else{
			    ratio_[0] = "0.00";
			}
			
			new cwkills = GetPVarInt(p, "cwkills"); // kills
			new cwdeath = GetPVarInt(p, "cwdeath"); //death
			new cwdamage = floatround(GetPVarFloat(p, "cwdamage"), floatround_round); // damage
			new cwinjuries = floatround(GetPVarFloat(p, "cwinjuries"), floatround_round); // injuries
			new cwteamdamage = floatround(GetPVarFloat(p, "cwteamdamage"), floatround_round);
			SetPVarFloat(p, "efficiency", GetPVarFloat(p, "cwdamage")/GetPVarFloat(p, "cwinjuries"));
			new Float:efficiency;
			if (GetPVarFloat(p, "efficiency") > 0.0 && GetPVarFloat(p, "cwinjuries") > 0.0) {
				efficiency = GetPVarFloat(p, "efficiency");
			} else {
				efficiency = 0.0;
			}
				
			if (cwdamage < 10)
			{
			    format(stats_[3], sizeof(stats_[]), "000%d", cwdamage);
			}
			else if (cwdamage < 100)
			{
			    format(stats_[3], sizeof(stats_[]), "00%d", cwdamage);
			}
			else if (cwdamage < 1000)
			{
			    format(stats_[3], sizeof(stats_[]), "0%d", cwdamage);
			}else{
			    valstr(stats_[3], cwdamage);
			}

			if (cwinjuries < 10)
			{
			    format(stats_[4], sizeof(stats_[]), "000%d", cwinjuries);
			}
			else if (cwinjuries < 100)
			{
			    format(stats_[4], sizeof(stats_[]), "00%d", cwinjuries);
			}
			else if (cwinjuries < 1000)
			{
			    format(stats_[4], sizeof(stats_[]), "0%d", cwinjuries);
			}else{
			    valstr(stats_[4], cwinjuries);
			}
			
			if (cwteamdamage < 10)
			{
			    format(stats_[5], sizeof(stats_[]), "0%d", cwteamdamage);
			}else{
			    valstr(stats_[5], cwteamdamage);
			}

			if (cwinjuries > 0)
			{
			    format(ratio_[1], sizeof(ratio_[]), "%.2f", GetPVarFloat(p, "cwdamage") /GetPVarFloat(p, "cwinjuries"));
			}else{
			    ratio_[1] = "-";
			}
			
			// Damage  - stats_[3]
			// Injuries- stats_[4]
			
			format(string, sizeof(string),
			"  ~w~Match: %s%s ~w~vs. %s%s ~w~I Score: %s%s~w~:%s%s ~w~I Total: %s%s~w~:%s%s ~w~I Round: %s%s~w~:%s%s ~w~I Damage: ~y~%s~w~ I Injuries: ~y~%s~w~ I Efficiency: ~y~%.2f~w~ I Kills: ~y~%d~w~ I Deaths: ~y~%d~w~ I Ratio: ~y~%s~w~",
			TDC[0], ClanName[0], TDC[1], ClanName[1], TDC[0], score_[0], TDC[1], score_[1], TDC[0], soucet_[0], TDC[1], soucet_[1], TDC[0], round_score_[0], TDC[1], round_score_[1], stats_[3], stats_[4], efficiency, cwkills, cwdeath, ratio_[0]);
			TextDrawSetString(TD[p], string);	
			
		}
	}
}

