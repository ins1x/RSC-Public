stock LOGINCONFIG_MENU(playerid)
{
	new tbtext[420], ServerLock_state[32], Proxy_state[24];
	
	switch(ServerLock)
	{
		case 0: ServerLock_state = "{808080}[NO LIMITS]";
		case 1: ServerLock_state = "{00FF00}[REGISTERED]";
		case 2: ServerLock_state = "{00FF00}[VERIFIED]";
		case 3: ServerLock_state = "{00FF00}[TEAMMATES]";
		case 4: ServerLock_state = "{00FF00}[AC ONLY]";
	}
	
	switch(USE_PROXY_CHECKER)
	{
		case 0: Proxy_state = "{00FF00}[Disabled]";
		case 1: Proxy_state = "{FFFF00}[ONLY_WARN]";
		case 2: Proxy_state = "{00FF00}[KICK]";
	}
	
	if(pData[playerid][pLang] == 1)
	{
		format(tbtext, sizeof(tbtext),
		"Login mode\t%s\n"\
		"Login attempts\t%d\n"\
		"No login kick after\t%d(sec)\n"\
		"Auto team balance\t%s\n"\
		"Auto spectator set\t%s\n"\
		"Proxy and VPN checker\t%s\n",
		ServerLock_state, MAX_LOGIN_ATTEMPTS, NOLOGIN_KICK_DELAY,
		(TeamsAutoBalance) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(AutoTeamSpec) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		Proxy_state);
	} else {
		format(tbtext, sizeof(tbtext),
		"Режим входа\t%s\n"\
		"Попыток ввода пароля\t%d\n"\
		"Кикнуть если игрок не вошел через\t%d(сек)\n"\
		"Авто-баланс команд\t%s\n"\
		"Авто-спавн за наблюдателей\t%s\n"\
		"Прокси и VPN чекер\t%s\n",
		ServerLock_state, MAX_LOGIN_ATTEMPTS, NOLOGIN_KICK_DELAY,
		(TeamsAutoBalance) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		(AutoTeamSpec) ? "{00FF00}[ON]" : "{FF0000}[ОFF]",
		Proxy_state);
	}
	
	if(GetPVarInt(playerid, "Admin") >= 3) {
		return ShowPlayerDialog(playerid, 27, DIALOG_STYLE_TABLIST,
		"Login config", tbtext, "Ok", "Cancel");
	} else { 
		return SendClientMessageEx(playerid, COLOR_RED,
		"Для использования этих функций Вы должны быть администратором 3+ уровня!",
		 "To use these functions you need to have 3+ level admin rights!");
	}
}

CLANLIST_MENU(playerid)
{
	new tbtext[1240];
	new clanname[32], clantag[12], tmpstr[50];
	new szQuery[128], DBResult: query;
	format(szQuery, sizeof(szQuery),
	"SELECT Clanname, Tag FROM Clanlist LIMIT 25");
	query = db_query(dbcore, szQuery);
	new rows = db_num_rows(query);
	for(new p; p < rows; p++)
	{	
		db_get_field(query, 0, clanname, 32);
		format(clanname, 32, "%s", clanname);
		
		db_get_field(query, 1, clantag, 12);
		format(clantag, 12, "%s", clantag);
		
		format(tmpstr, sizeof(tmpstr), "%s\t {AFAFAF}%s\n", clanname, clantag); 
		strcat(tbtext, tmpstr);
		db_next_row(query);
	}
	db_free_result(query);
	
	ShowPlayerDialog(playerid, 115, DIALOG_STYLE_TABLIST,
	".:: Clanlist ::.", tbtext, "Select", "Cancel");
}

stock OFFLINE_ACC(playerid, nickname[24] = "")
{
	new header[64];// nickname[MAX_PLAYER_NAME];
	if(strlen(nickname) < 2) GetPVarString(playerid, "OfflineAccountName", nickname, sizeof nickname);
	else SetPVarString(playerid, "OfflineAccountName", db_escape(nickname));
	format(header, sizeof(header), "Offline account actions DB - %s", nickname);
	
	if (GetPVarInt(playerid, "Admin") >= 3) 
	{
		if (pData[playerid][pLang] == 1)
		{
			ShowPlayerDialog(playerid, 240, DIALOG_STYLE_LIST, header,
			"View account statistics\n\
			View geolocation information\n\
			View hwban information\n\
			View hardware information\n\
			Find all player accounts\n\
			Change nickname on account\n\
			Set admin level\n\
			{00FF00}Verification\n\
			{FF0000}[>] Reset in settings\n\
			{00FF00}[>] Remove account restrictions\n\
			{FF0000}[>] Issue punishment\n\
			{FF0000}>> Delete account\n",
			"Ok", "Cancel");
		} else {
			ShowPlayerDialog(playerid, 240, DIALOG_STYLE_LIST, header,
			"Посмотреть статистику аккаунта\n\
			Получить информацию о геолокации\n\
			Получить информацию о наказаниях\n\
			Получить информацию о железе\n\
			Найти все аккаунты игрока\n\
			Сменить никнейм на аккаунте\n\
			Изменить админ права\n\
			{00FF00}Верификация\n\
			{FF0000}[>] Сбросить в настройках\n\
			{00FF00}[>] Снять ограничения с аккаунта\n\
			{FF0000}[>] Выдать наказание\n\
			{FF0000}>> Удалить аккаунт\n",
			"Ok", "Выход");
		}
	} else { 
		SendClientMessageEx(playerid, COLOR_RED,
		"Для использования этих функций Вы должны быть администратором 3+ уровня!",
		"To use these functions you need to have 3+ level admin rights!");
	}
}

stock HITSOUND(playerid)
{
	new tbtext[150];
	
	switch(pData[playerid][pBell])
	{
		case 1137: format(tbtext, sizeof(tbtext),
		"{00FF00}[CHECKPOINT]{FFFFFF}\n[LIFT_PING]\n[RACE_GO]\n\
		[DOOR_BELL]\n[DEFAULT]\n{FF0000}[DISABLE]\n");
		case 6401: format(tbtext, sizeof(tbtext),
		"{FFFFFF}[CHECKPOINT]\n{00FF00}[LIFT_PING]{FFFFFF}\n[RACE_GO]\n\
		[DOOR_BELL]\n[DEFAULT]\n{FF0000}[DISABLE]\n");
		case 1057: format(tbtext, sizeof(tbtext),
		"{FFFFFF}[CHECKPOINT]\n[LIFT_PING]\n{00FF00}[RACE_GO]{FFFFFF}\n\
		[DOOR_BELL]\n[DEFAULT]\n{FF0000}[DISABLE]\n");
		case 31000: format(tbtext, sizeof(tbtext),
		"{FFFFFF}[CHECKPOINT]\n[LIFT_PING]\n[RACE_GO]\n\
		{00FF00}[DOOR_BELL]{FFFFFF}\n[DEFAULT]\n{FF0000}[DISABLE]\n");
		case 17802: format(tbtext, sizeof(tbtext),
		"{FFFFFF}[CHECKPOINT]\n[LIFT_PING]\n[RACE_GO]\n\
		[DOOR_BELL]\n{00FF00}[DEFAULT]{FFFFFF}\n{FF0000}[DISABLE]\n");
		case 0: format(tbtext, sizeof(tbtext),
		"{FFFFFF}[CHECKPOINT]\n[LIFT_PING]\n[RACE_GO]\n\
		[DOOR_BELL]\n[DEFAULT]\n{00FF00}[DISABLE]\n");
	}
	
	SetPlayerChatBubble(playerid, "..chooses hitsound..", COLOR_GREY, 50.0, 5000);
	ShowPlayerDialog(playerid, 20, DIALOG_STYLE_LIST, "HITSOUND", tbtext, "Confirm", "Cancel");
}

stock SETTINGS_MENU(playerid, showid = -1)
{
	// Player settings dialog
	// showid: -1 == playerid, else another playerid (admin id)
	new tbtext[550];
	
	if(pData[playerid][pLang])
	{		
		format(tbtext, sizeof(tbtext),
		"{ffffff}Skin\t%d\n"\
		"Hitsound\t%s\n"\
		"Sound Effects\t%s\n"\
		"Weather\t{ffffff}%d\n"\
		"Time\t{ffffff}%d\n"\
		"Kill feed in chat\t%s\n"\
		"Damage informer\t%s\n"\
		"Block private messages\t%s\n"\
		"Language\t{ffffff}%s\n"\
		"[>] Attachments\t \n"\
		"[>] Panel settings\t \n"\
		"{FF0000}Change password\t \n"\
		"{FF0000}Change nickname\t \n",
		GetPlayerSkin(playerid),
		(pData[playerid][pBell] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pSfx] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		pData[playerid][pWeather], pData[playerid][pHour],
		(pData[playerid][pKillchat] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pDmgInformer] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pTogpm] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pLang] == 1) ? "[English]" : "[Russian]");
		
        #if defined DISCORD_VERIFICATION
		if(!pData[playerid][pVerified])
		{
			strcat(tbtext,"{00FF00}Verify account\t\n");
		}
		#endif
	} else {
		format(tbtext, sizeof(tbtext),
		"{ffffff}Скин\t%d\n"\
		"Звук попаданий\t%s\n"\
		"Звуковые эффекты\t%s\n"\
		"Погода\t{ffffff}%d\n"\
		"Время\t{ffffff}%d\n"\
		"Килл лог в чате\t%s\n"\
		"Дамаг информер\t%s\n"\
		"Отключение ЛС\t%s\n"\
		"Язык\t{ffffff}%s\n"\
		"[>] Объекты на игрока\t \n"\
		"[>] Настройки панелей\t \n"\
		"{FF0000}Сменить пароль\t \n"\
		"{FF0000}Сменить никнейм\t \n",
		GetPlayerSkin(playerid),
		(pData[playerid][pBell] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pSfx] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		pData[playerid][pWeather],pData[playerid][pHour],
		(pData[playerid][pKillchat] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pDmgInformer] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pTogpm] > 0) ? "{00FF00}[ON]" : "{FF0000}[OFF]",
		(pData[playerid][pLang] == 1) ? "[English]" : "[Russian]");
		
        #if defined DISCORD_VERIFICATION
		if(!pData[playerid][pVerified])
		{
			strcat(tbtext,"{00FF00}Верифицировать аккаунт\t\n");
		}
        #endif
	}
	if(showid == -1)
	{
		showid = playerid;
		if(pData[showid][pLang])
		{
			ShowPlayerDialog(showid, 19, DIALOG_STYLE_TABLIST,
			".:: Settings ::.", tbtext, "Ok", "Cancel");
		} else {
			ShowPlayerDialog(showid, 19, DIALOG_STYLE_TABLIST,
			".:: Настройки ::.", tbtext, "Ok", "Выход");
		}	
	} else {
		if(pData[showid][pLang])
		{
			ShowPlayerDialog(showid, 19, DIALOG_STYLE_MSGBOX,
			".:: Settings ::.", tbtext, "Cancel", "");
		} else {
			ShowPlayerDialog(showid, 19, DIALOG_STYLE_MSGBOX,
			".:: Настройки ::.", tbtext, "Выход", "");
		}	
	}
	
	SetPlayerChatBubble(playerid, "..opens settings..", COLOR_GREY, 50.0, 5000);
	return 1;
}

