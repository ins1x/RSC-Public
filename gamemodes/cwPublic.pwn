	if (!strcmp(cmdtext, "/recon", true))
	{
		if (GetPVarInt(playerid, "Specing") > -1)
		{
	        new i = GetPVarInt(playerid, "Specing") +1;
	        while(i < MAX_PLAYER_ID)
	        {
	            if (Specfunc(playerid, i)) {
	                return true;
	            }
	            i++;
	        }
	        i = 0;
	        while(i < GetPVarInt(playerid, "Specing"))
	        {
	            if (Specfunc(playerid, i)) {
	                return true;
	            }
	            i++;
	        }
	        return true;
		} else {
			SendClientMessageEx(playerid, COLOR_GREY,
			"Вы не находитесь в наблюдении за игроком",
