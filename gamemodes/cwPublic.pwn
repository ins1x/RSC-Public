						{
							if (0 < GetPVarInt(i, "fps") < MIN_FPS) // check fps lagers
							{
								fpslagers[pole] = i;
								pole++;
							}
							else if (IsPlayerAFK(i))
							{
								new name1[MAX_PLAYER_NAME];
								GetPlayerName(i, name1, sizeof(name1));
								format(string, sizeof(string), "%s%s, ", string, name1);
							}
							TogglePlayerControllable(i, false);
							SetPVarInt(i, "frz", true);
						}
					}
					
					if (string[0])
					{
						SendClientMessageToVirtualWorld(0, COLOR_RED, 
						"Эти игроки находятся в АФК:", "These players are AFK:");
						strdel(string, strlen(string) -2, strlen(string));
						format(string, sizeof(string), "%s.", string);
						SendClientMessageToVirtualWorld(0, -1, string, string);
					}
					if (pole > 0)
					{
						SetTimerEx("fpsdrop", 5000, false, "i", pole);
					}
					Countdown(3, GetPlayerVirtualWorld(playerid)); // 123
					
					if(Round <= 1 && score[0] == 0 && score[1] == 0) ShowGameSettings();
					
					SetPlayerChatBubble(playerid, "..has started countdown..", COLOR_GREY, 50.0, 5000);
					
					format(string, sizeof(string), "%s(%d) запустил отсчет...",
					PlayerName(playerid), playerid);

					format(stringen, sizeof(stringen), "%s(%d) has started countdown...",
					PlayerName(playerid), playerid);
					SendClientMessageToVirtualWorld(0, COLOR_GREY, string, stringen);
				}
			}
